        return "gsa-session-http-transport", "GSA still needs inherited session/transport plumbing for retained GMP workflows."
    if name == "alert.ts":
        return "alert-delivery-and-credentials", "Alert delivery payload mutation, credentials, and broad alert-definition editing remain inherited; native control covers retained creation, metadata, cloning, deletion, testing, and manual report delivery."
    if name == "scanner.ts":
        return "scanner-control-or-credential", "Scanner and credential surfaces remain inherited until control/secret handling is designed."
    if name == "hosts.js":
        return "asset-action-or-rich-context", "Host actions and richer inherited context remain outside the current native read contract."
    if name == "port-lists.ts":
        return "asset-action-or-rich-context", "Port-list imports, exports, and UI actions remain inherited."
    if name == "report.ts":
        return "report-export-delete-or-rich-context", "Report export/delete/upload and rich inherited report context remain inherited."
    if name == "report-format.ts":
        return "report-format-file-import-export-verify-param-writes-and-deletes", "Report-format file import/export, verification, parameter mutations, deletes, and dialog side effects remain inherited."
    if name == "scan-configs.js":
        return None
    if name == "schedules.js":
        return "schedule-calendar-edit-and-task-recalculation", "Existing-schedule calendar edit and linked-task next-time recalculation remain inherited."
    if name == "filter.ts":
        return "saved-filter-gsa-filter-actions-or-alert-linkage", "GSA saved-filter dialog actions, export/settings behavior, and alert linkage remain inherited outside the bounded direct write-control contract."
    if name == "tag.ts":
        return "tag-write-or-resource-actions", "Tag writes and unsupported resource actions remain inherited."
    if name == "user.ts":
