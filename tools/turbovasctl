    candidate = rust_migration_candidate_state(repo_root)
    scanner_workspace = repo_root / "components" / "openvas-scanner" / "rust" / "Cargo.toml"
    artifact_dir = rust_migration_artifact_dir(repo_root)
    findings: list[dict[str, Any]] = []
    missing_tools = [item["name"] for item in tools if item["status"] == "fail"]
    warning_tools = [item["name"] for item in tools if item["status"] == "warn"]
    findings.append(finding("fail" if missing_tools else "pass", "rust-migration.tools", "All Rust migration tools are available." if not missing_tools else "Some Rust migration tools are missing.", details={"missing": missing_tools, "warnings": warning_tools, "tools": tools}))
    failed_toolchain = [name for name, item in toolchain.items() if item["status"] == "fail"]
    findings.append(finding("fail" if failed_toolchain else "pass", "rust-migration.toolchain", "Rust, Cargo, Clang, and LLVM config are available." if not failed_toolchain else "Rust/LLVM toolchain prerequisite is missing.", details={"missing": failed_toolchain, "toolchain": toolchain}))
    findings.append(finding("pass" if scanner_workspace.is_file() else "warn", "rust-migration.scanner-workspace", "Inherited scanner Rust workspace exists." if scanner_workspace.is_file() else "Inherited scanner Rust workspace was not found.", str(scanner_workspace)))
    candidate_ready = bool(candidate.get("c_file_exists") and candidate.get("header_exists") and candidate.get("test_file_exists"))
    findings.append(finding("pass" if candidate_ready else "fail", "rust-migration.first-candidate", "First dry-run C-to-Rust candidate exists and has tests." if candidate_ready else "First dry-run C-to-Rust candidate is incomplete.", details=candidate))
    try:
        artifact_dir.mkdir(parents=True, exist_ok=True)
