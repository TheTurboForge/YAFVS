def c_source_function_body(source: str, name: str) -> str:
    match = re.search(rf"\b{re.escape(name)}\s*\([^)]*\)\s*{{", source)
    if match is None:
        return ""
    start = source.find("{", match.start())
    depth = 0
    for index in range(start, len(source)):
        char = source[index]
        if char == "{":
            depth += 1
        elif char == "}":
            depth -= 1
            if depth == 0:
                return source[start + 1 : index]
    return ""


def c_string_constants(function_body: str) -> dict[str, str]:
    return {
        match.group(1): match.group(2)
        for match in re.finditer(r'const\s+gchar\s+\*\s*(\w+)\s*=\s*"([^"]*)"\s*;', function_body)
    }


def c_string_array_values(function_body: str, name: str) -> list[str]:
    match = re.search(rf"const\s+gchar\s+\*\s*{re.escape(name)}\s*\[\]\s*=\s*{{(?P<body>.*?)}};", function_body, re.DOTALL)
    if match is None:
        return []
    return re.findall(r'"([^"]+)"', match.group("body"))


def native_api_gsad_proxy_allowlist_templates(repo_root: Path | None) -> tuple[list[str], list[str]]:
    if repo_root is None:
        return [], []
    relative_path = "components/gsad/src/gsad_native_api.c"
    try:
        source = (repo_root / relative_path).read_text(encoding="utf-8")
    except OSError:
        return [], [f"missing_source:{relative_path}"]

    function_body = c_source_function_body(source, "native_api_path_is_allowed")
    if not function_body:
        return [], ["missing_function:native_api_path_is_allowed"]

    constants = c_string_constants(function_body)
    templates: set[str] = set()
    errors: list[str] = []

    for match in re.finditer(
        r"if\s*\(\s*g_strcmp0\s*\(\s*path\s*,\s*(\w+)\s*\)\s*==\s*0\s*\)\s*return\s+TRUE\s*;",
        function_body,
        re.DOTALL,
    ):
        variable = match.group(1)
        value = constants.get(variable)
        if value and value.startswith("/api/v1"):
            templates.add(value)
        else:
            errors.append(f"unresolved_exact_path:{variable}")

    if "results_path" in constants and "g_str_has_prefix (path, results_path)" in function_body:
        templates.add(f"{constants['results_path']}/{{}}")

    single_segment_prefixes = (
        "cpe_prefix",
        "cve_prefix",
        "cert_bund_advisory_prefix",
        "dfn_cert_advisory_prefix",
        "nvt_prefix",
        "operating_system_prefix",
        "host_prefix",
        "tls_certificate_prefix",
        "scanner_prefix",
        "filter_prefix",
        "alert_prefix",
        "tag_resource_names_prefix",
        "override_prefix",
        "port_list_prefix",
        "schedule_prefix",
        "report_config_prefix",
        "report_format_prefix",
        "scope_report_prefix",
        "target_prefix",
        "task_prefix",
    )
    for variable in single_segment_prefixes:
        value = constants.get(variable)
        if value and f"g_str_has_prefix (path, {variable})" in function_body:
            templates.add(f"{value.rstrip('/')}/{{}}")

    for prefix_variable, suffix_variable in (
        ("scan_config_prefix", "scan_config_families_suffix"),
        ("tag_prefix", "tag_resources_suffix"),
    ):
        prefix = constants.get(prefix_variable)
        suffix = constants.get(suffix_variable)
        if prefix and suffix and f"g_str_has_prefix (path, {prefix_variable})" in function_body:
            templates.add(f"{prefix.rstrip('/')}/{{}}")
            templates.add(f"{prefix.rstrip('/')}/{{}}{suffix}")

    raw_report_prefix = constants.get("raw_report_prefix")
    if raw_report_prefix and "g_str_has_prefix (path, raw_report_prefix)" in function_body:
        templates.add(f"{raw_report_prefix.rstrip('/')}/{{}}")
        for suffix_variable in (
            "metrics_suffix",
            "results_suffix",
            "hosts_suffix",
            "ports_suffix",
            "applications_suffix",
            "operating_systems_suffix",
            "cves_suffix",
            "tls_certificates_suffix",
            "errors_suffix",
        ):
            suffix = constants.get(suffix_variable)
            if suffix and f"g_str_has_suffix (path, {suffix_variable})" in function_body:
                templates.add(f"{raw_report_prefix.rstrip('/')}/{{}}{suffix}")

    scope_prefix = constants.get("scope_prefix")
    if scope_prefix and "g_str_has_prefix (path, scope_prefix)" in function_body:
        templates.add(f"{scope_prefix.rstrip('/')}/{{}}")
        for suffix in c_string_array_values(function_body, "scope_collection_suffixes"):
            if suffix.startswith("/"):
                templates.add(f"{scope_prefix.rstrip('/')}/{{}}/reports/{{}}{suffix}")

    return sorted(templates), errors


def native_api_browser_proxy_contract_summary(repo_root: Path | None, endpoints: list[dict[str, Any]]) -> dict[str, Any]:
    browser_proxied = sorted(
        item["endpoint"]
        for item in endpoints
        if isinstance(item.get("endpoint"), str)
        and native_api_browser_access_from_status(str(item.get("status", "unknown"))) == "browser_proxied"
