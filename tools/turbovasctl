def feed_path_summary(path: Path, markers: tuple[str, ...]) -> dict[str, Any]:
    file_count = 0
    byte_count = 0
    latest_mtime: float | None = None
    errors: list[str] = []
    if path.is_dir():
        for entry in path.rglob("*"):
            try:
                if entry.is_file():
                    stat = entry.stat()
                    file_count += 1
                    byte_count += stat.st_size
                    latest_mtime = stat.st_mtime if latest_mtime is None else max(latest_mtime, stat.st_mtime)
            except OSError as error:
                errors.append(f"{entry}: {error}")
    marker_rows = [{"path": marker, "exists": (path / marker).exists()} for marker in markers]
    latest = datetime.fromtimestamp(latest_mtime, timezone.utc).replace(microsecond=0).isoformat() if latest_mtime is not None else None
    return {
        "exists": path.is_dir(),
        "file_count": file_count,
        "byte_count": byte_count,
        "latest_mtime": latest,
        "markers": marker_rows,
        "errors": errors[:20],
    }


def feed_location_findings(repo_root: Path, location: str, root: Path, rel_attr: str) -> list[dict[str, Any]]:
    findings: list[dict[str, Any]] = []
    findings.append(finding("pass" if root.is_dir() else "warn", f"feed.{location}.root", f"{location} feed root {'exists' if root.is_dir() else 'is missing'}.", str(root)))
    for feed_class in FEED_CLASSES:
        rel = getattr(feed_class, rel_attr)
        path = root / rel
        summary = feed_path_summary(path, feed_class.markers)
        marker_missing = [row["path"] for row in summary["markers"] if not row["exists"]]
        status = "pass" if summary["exists"] and summary["file_count"] > 0 and not marker_missing and not summary["errors"] else "warn"
        if not summary["exists"]:
            message = f"{feed_class.label} directory is missing."
        elif summary["file_count"] == 0:
            message = f"{feed_class.label} directory exists but contains no files."
        elif marker_missing:
            message = f"{feed_class.label} has files but expected markers are missing."
        elif summary["errors"]:
            message = f"{feed_class.label} state has filesystem inspection errors."
        else:
            message = f"{feed_class.label} is present."
        findings.append(finding(status, f"feed.{location}.{feed_class.key}", message, str(path), {"summary": summary, "missing_markers": marker_missing}))
    return findings


def cert_public_dir(repo_root: Path) -> Path:
    return runtime_path(repo_root, "certs", "CA")


def cert_private_dir(repo_root: Path) -> Path:
    return runtime_path(repo_root, "certs", "private", "CA")


def cert_files(repo_root: Path) -> dict[str, Path]:
    public = cert_public_dir(repo_root)
    private = cert_private_dir(repo_root)
    return {
        "ca_key": private / "cakey.pem",
        "ca_cert": public / "cacert.pem",
        "server_key": private / "serverkey.pem",
        "server_cert": public / "servercert.pem",
        "client_key": private / "clientkey.pem",
        "client_cert": public / "clientcert.pem",
    }


def cert_file_findings(repo_root: Path) -> list[dict[str, Any]]:
    findings: list[dict[str, Any]] = []
    for name, path in cert_files(repo_root).items():
        findings.append(finding("pass" if path.is_file() and path.stat().st_size > 0 else "warn", "runtime.cert", f"{name} {'exists' if path.is_file() else 'is missing'}.", str(path)))
    return findings


def certs_complete(repo_root: Path) -> bool:
    return all(path.is_file() and path.stat().st_size > 0 for path in cert_files(repo_root).values())


def certs_partial(repo_root: Path) -> bool:
    existing = [path for path in cert_files(repo_root).values() if path.exists()]
    return bool(existing) and not certs_complete(repo_root)


def gvm_cert_env(repo_root: Path) -> dict[str, str]:
    env = build_env(repo_root)
    env.update(
        {
            "GVM_KEY_LOCATION": str(cert_private_dir(repo_root)),
            "GVM_CERT_LOCATION": str(cert_public_dir(repo_root)),
            "GVM_CERTIFICATE_HOSTNAME": "localhost",
            "GVM_CERTIFICATE_SAN_DNS": "localhost",
            "GVM_CERTIFICATE_SAN_IP_ADDRESS": "127.0.0.1",
        }
    )
    return env


def runtime_secret_path(repo_root: Path, name: str) -> Path:
    return runtime_path(repo_root, "secrets", name)


def read_or_create_runtime_secret(repo_root: Path, name: str) -> tuple[str, bool]:
    path = runtime_secret_path(repo_root, name)
    path.parent.mkdir(parents=True, exist_ok=True)
    if path.is_file():
        return path.read_text(encoding="utf-8").strip(), False
    secret = secrets.token_urlsafe(24)
    path.write_text(secret + "\n", encoding="utf-8")
    path.chmod(0o600)
    return secret, True


