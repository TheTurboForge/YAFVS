def runtime_secret_path(repo_root: Path, name: str) -> Path:
    return runtime_path(repo_root, "secrets", name)


def runtime_secret_file_metadata(path: Path) -> dict[str, Any]:
    if not path.is_file():
        return {
            "exists": False,
            "mode": None,
            "permission_ok": False,
            "group_or_world_accessible": False,
        }
    mode = path.stat().st_mode & 0o777
    group_or_world_accessible = bool(mode & 0o077)
    return {
        "exists": True,
        "mode": f"{mode:04o}",
        "permission_ok": not group_or_world_accessible,
        "group_or_world_accessible": group_or_world_accessible,
    }


def read_or_create_runtime_secret(repo_root: Path, name: str, default: str | None = None) -> tuple[str, bool]:
    path = runtime_secret_path(repo_root, name)
    path.parent.mkdir(parents=True, exist_ok=True)
    if path.is_file():
        return path.read_text(encoding="utf-8").strip(), False
    secret = default if default is not None else secrets.token_urlsafe(24)
    write_private_text(path, secret + "\n")
    return secret, True


def write_private_text(path: Path, text: str) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    fd = os.open(path, os.O_WRONLY | os.O_CREAT | os.O_TRUNC | getattr(os, "O_CLOEXEC", 0), 0o600)
    try:
        with os.fdopen(fd, "w", encoding="utf-8") as stream:
            fd = -1
            # Runtime/dev service secrets are stored only in ignored,
            # owner-readable local runtime files for container consumption.
            # codeql[py/clear-text-storage-sensitive-data]
            stream.write(text)
    finally:
        if fd >= 0:
            os.close(fd)
    path.chmod(0o600)


def write_runtime_secret(repo_root: Path, name: str, secret: str) -> Path:
    path = runtime_secret_path(repo_root, name)
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp = path.with_name(f".{path.name}.tmp")
    write_private_text(tmp, secret + "\n")
    tmp.replace(path)
    path.chmod(0o600)
    return path


def rotate_runtime_secret(repo_root: Path, name: str) -> Path:
    return write_runtime_secret(repo_root, name, secrets.token_urlsafe(32))


