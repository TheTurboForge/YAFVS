def redact_text(text: str, secrets_to_redact: Iterable[str]) -> str:
    redacted = text
    for secret in secrets_to_redact:
        redacted = redact_secret_value(redacted, secret)
    return redacted


def redact_secret_value(text: str, secret: str) -> str:
    if not secret:
        return text
    if len(secret) >= LONG_SECRET_MIN_LENGTH:
        return text.replace(secret, "[redacted]")
    escaped = re.escape(secret)
    token_pattern = re.compile(
        rf"(?<![{SHORT_SECRET_BOUNDARY_CHARS}]){escaped}(?![{SHORT_SECRET_BOUNDARY_CHARS}])(?![\"']\s*:)",
    )
    return token_pattern.sub("[redacted]", text)


