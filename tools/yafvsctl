        YAFVS_API_DIRECT_BIND_ENV,
    )
    if not any(name in os.environ for name in direct_setting_names):
        bindings = current_native_api_direct_published_bindings(repo_root)
        if len(bindings) == 1:
            binding = bindings[0]
            ensure_native_api_direct_runtime_env_defaults(repo_root, env)
            env[YAFVS_API_DIRECT_HOST_ENV] = (
                native_api_direct_env_host_from_published_binding(
                    binding["host"]
                )
            )
            env[YAFVS_API_DIRECT_PORT_ENV] = binding["host_port"]
    return env


def runtime_native_api_rebuild_env(repo_root: Path) -> dict[str, str]:
    env = deployed_app_env(repo_root)
    if native_api_direct_requested(env):
        ensure_native_api_direct_runtime_env_defaults(repo_root, env)
    return env


def compose_file(repo_root: Path) -> Path:
    return repo_root / "compose" / "dev.yaml"


def compose_command(
    repo_root: Path,
    *args: str,
    env: dict[str, str] | None = None,
    extra_files: Sequence[Path] = (),
) -> list[str]:
    command = ["docker", "compose", "-f", str(compose_file(repo_root))]
    env = runtime_env(repo_root) if env is None else env
    gsad_override = ensure_gsad_ports_override(repo_root, env)
    if gsad_override is not None:
        command.extend(["-f", str(gsad_override)])
    direct_api_override = ensure_native_api_direct_ports_override(repo_root, env)
    if direct_api_override is not None:
        command.extend(["-f", str(direct_api_override)])
    for extra_file in extra_files:
        command.extend(["-f", str(extra_file)])
    command.extend(args)
    return command


def app_image_override_path(repo_root: Path) -> Path:
    return runtime_path(repo_root, "state", "feed-generation", "app-images.json")


def write_app_image_override(repo_root: Path, image_ids: dict[str, str]) -> Path:
    normalized = validate_app_service_image_ids(image_ids)
    ensure_feed_activation_state_directory(repo_root)
    path = app_image_override_path(repo_root)
    write_private_text(
        path,
        json.dumps(
            {"services": {service: {"image": normalized[service]} for service in APP_SERVICES}},
            indent=2,
            sort_keys=True,
        )
        + "\n",
    )
    return path


def compose_command_with_app_images(
    repo_root: Path,
    image_ids: dict[str, str],
    *args: str,
    env: dict[str, str] | None = None,
) -> list[str]:
    override = write_app_image_override(repo_root, image_ids)
    return compose_command(repo_root, *args, env=env, extra_files=(override,))


def configured_app_service_image_refs(
    repo_root: Path, app_env: dict[str, str] | None = None
) -> tuple[dict[str, str], str | None]:
    app_env = deployed_app_env(repo_root) if app_env is None else app_env
    result = run_command(
        compose_command(repo_root, "--profile", "app", "config", "--format", "json", env=app_env),
        repo_root,
        env=app_env,
        timeout=120,
    )
    if result.returncode != 0:
        return {}, f"Compose config failed: {'; '.join(output_tail(result.stdout, 20))}"
    try:
        config = json.loads(result.stdout)
    except json.JSONDecodeError as error:
        return {}, f"Compose config was not valid JSON: {error}"
    services = config.get("services") if isinstance(config, dict) else None
    if not isinstance(services, dict):
        return {}, "Compose config does not contain services"
    refs: dict[str, str] = {}
    for service in APP_SERVICES:
        service_config = services.get(service)
        image = service_config.get("image") if isinstance(service_config, dict) else None
        if not isinstance(image, str) or not image:
            return {}, f"Compose service {service} has no explicit image name"
        refs[service] = image
    return refs, None


def docker_image_id(repo_root: Path, image: str) -> str | None:
    result = run_command(
        ["docker", "image", "inspect", "--format", "{{.Id}}", image],
        repo_root,
        env=runtime_env(repo_root),
        timeout=120,
    )
    value = result.stdout.strip().splitlines()[-1] if result.returncode == 0 and result.stdout.strip() else ""
    return value if re.fullmatch(r"sha256:[0-9a-f]{64}", value) else None


def app_service_image_availability_error(
    repo_root: Path, image_ids: dict[str, str]
) -> str | None:
    normalized = validate_app_service_image_ids(image_ids)
    unavailable = [
        service
        for service in APP_SERVICES
        if docker_image_id(repo_root, normalized[service]) != normalized[service]
    ]
    if unavailable:
        return (
            "Pinned application image objects are unavailable for "
            f"{', '.join(unavailable)}; restore those exact image objects by digest "
            "from a trusted registry or docker load before continuing"
        )
    return None


def _hash_app_runtime_artifact(
    repo_root: Path,
    path: Path,
    digest: Any,
) -> tuple[int, int]:
    relative = path.relative_to(repo_root).as_posix()
    before = path.lstat()
    mode = stat.S_IMODE(before.st_mode)
    entry_digest = hashlib.sha256()
    if stat.S_ISLNK(before.st_mode):
        target = os.readlink(path)
        target_path = Path(target)
        if target_path.is_absolute():
            normalized_target = Path(os.path.abspath(target_path))
            image_owned = normalized_target.parts[:2] in {
                ("/", "bin"),
                ("/", "lib"),
                ("/", "lib64"),
                ("/", "usr"),
            }
            if not image_owned:
                raise OSError(
                    f"runtime artifact symlink escapes the attested deployment roots: {relative}"
                )
        else:
            resolved = Path(os.path.abspath(path.parent / target_path))
            attested_roots = [
                Path(os.path.abspath(repo_root / root))
                for root in APP_RUNTIME_ARTIFACT_ROOTS
            ]
            attested_files = {
                Path(os.path.abspath(repo_root / artifact))
                for artifact in APP_RUNTIME_ARTIFACT_FILES
            }
            within_root = any(
                resolved == root or path_is_within(resolved, root)
                for root in attested_roots
            )
            if not within_root and resolved not in attested_files:
                raise OSError(
                    f"runtime artifact symlink escapes the attested deployment roots: {relative}"
                )
        if target.startswith("/workspace/"):
            raise OSError(
                f"runtime artifact symlink escapes the attested deployment roots: {relative}"
            )
        content = target.encode("utf-8", errors="surrogateescape")
        entry_digest.update(content)
        kind = "symlink"
        byte_count = len(content)
    elif stat.S_ISREG(before.st_mode):
        byte_count = 0
        with path.open("rb") as handle:
            while chunk := handle.read(1024 * 1024):
                entry_digest.update(chunk)
                byte_count += len(chunk)
        after = path.lstat()
        before_identity = (
            before.st_dev,
            before.st_ino,
            before.st_size,
            before.st_mtime_ns,
            before.st_mode,
        )
        after_identity = (
            after.st_dev,
            after.st_ino,
            after.st_size,
            after.st_mtime_ns,
            after.st_mode,
        )
        if before_identity != after_identity:
            raise OSError(f"runtime artifact changed while hashing: {relative}")
        kind = "file"
    else:
        raise OSError(f"unsupported runtime artifact type: {relative}")
    record = json.dumps(
        [relative, kind, mode, byte_count, entry_digest.hexdigest()],
        ensure_ascii=True,
        separators=(",", ":"),
    ).encode("ascii")
    digest.update(record)
    digest.update(b"\n")
    return 1, byte_count


def app_runtime_artifact_manifest(repo_root: Path) -> dict[str, Any]:
    digest = hashlib.sha256()
    entry_count = 0
    byte_count = 0

    def visit(path: Path) -> None:
        nonlocal entry_count, byte_count
        relative = path.relative_to(repo_root).as_posix()
        if relative in APP_RUNTIME_ARTIFACT_IGNORED_PATHS:
            return
        metadata = path.lstat()
        if stat.S_ISDIR(metadata.st_mode):
            for child in sorted(path.iterdir(), key=lambda item: item.name):
                if child.name in APP_RUNTIME_ARTIFACT_IGNORED_DIRS:
                    continue
                if child.suffix in APP_RUNTIME_ARTIFACT_IGNORED_SUFFIXES:
                    continue
                visit(child)
            return
        entries, size = _hash_app_runtime_artifact(repo_root, path, digest)
        entry_count += entries
        byte_count += size

    for relative in APP_RUNTIME_ARTIFACT_ROOTS:
        root = repo_root / relative
        if not root.is_dir() or root.is_symlink():
            raise OSError(f"required runtime artifact directory is unavailable: {relative}")
        visit(root)
    for relative in APP_RUNTIME_ARTIFACT_FILES:
        path = repo_root / relative
        if not path.is_file() or path.is_symlink():
            raise OSError(f"required runtime artifact file is unavailable: {relative}")
        visit(path)

    return validate_app_runtime_artifact_manifest(
        {
            "schema_version": 1,
            "algorithm": "sha256",
            "digest": digest.hexdigest(),
            "entry_count": entry_count,
            "byte_count": byte_count,
            "roots": [
                str(path)
                for path in (*APP_RUNTIME_ARTIFACT_ROOTS, *APP_RUNTIME_ARTIFACT_FILES)
            ],
        }
    )


def app_compose_contract_manifest(
    repo_root: Path,
    image_ids: dict[str, str],
    *,
    app_env: dict[str, str],
) -> dict[str, Any]:
    command = compose_command_with_app_images(
        repo_root,
        image_ids,
        "--profile",
        "app",
        "config",
        "--format",
        "json",
        env=app_env,
    )
    rendered = run_command(command, repo_root, env=app_env, timeout=120)
    if rendered.returncode != 0:
        raise OSError(
            "rendered application Compose contract is unavailable: "
            + "; ".join(output_tail(rendered.stdout, 20))
        )
    try:
        config = json.loads(rendered.stdout)
    except json.JSONDecodeError as error:
        raise ValueError(
            f"rendered application Compose contract is not valid JSON: {error}"
        ) from error
    services = config.get("services") if isinstance(config, dict) else None
    if not isinstance(services, dict) or any(
        not isinstance(services.get(service), dict) for service in APP_SERVICES
    ):
        raise ValueError("rendered application Compose services are incomplete")
    normalized_services: dict[str, dict[str, Any]] = {}
    for service in APP_SERVICES:
        normalized_service = dict(services[service])
        ports = normalized_service.get("ports")
        if isinstance(ports, list):
            # Compose port declaration order does not change the execution contract.
            normalized_service["ports"] = sorted(
                ports,
                key=lambda item: json.dumps(
                    item, ensure_ascii=True, separators=(",", ":"), sort_keys=True
                ),
            )
        normalized_services[service] = normalized_service
    contract = {
        "services": normalized_services,
        "networks": config.get("networks", {}),
        "volumes": config.get("volumes", {}),
        "secrets": config.get("secrets", {}),
        "configs": config.get("configs", {}),
    }
    canonical = json.dumps(
        contract, ensure_ascii=True, separators=(",", ":"), sort_keys=True
    ).encode("ascii")
    return validate_app_compose_contract(
        {
            "schema_version": 1,
            "algorithm": "sha256",
            "digest": hashlib.sha256(canonical).hexdigest(),
            "services": list(APP_SERVICES),
        }
    )


def app_compose_contract_finding(
    repo_root: Path,
    image_ids: dict[str, str],
    expected: dict[str, Any],
    *,
    app_env: dict[str, str],
    check: str,
) -> dict[str, Any]:
    normalized = validate_app_compose_contract(expected)
    try:
        observed = app_compose_contract_manifest(
            repo_root, image_ids, app_env=app_env
        )
    except (OSError, ValueError) as error:
        return finding(
            "fail",
            check,
            f"Application Compose execution contract could not be verified: {error}",
            details={"expected_digest": normalized["digest"]},
        )
    matches = hmac.compare_digest(observed["digest"], normalized["digest"])
    return finding(
        "pass" if matches else "fail",
        check,
        "Rendered application Compose execution contract matches the prepared deployment."
        if matches
        else "Rendered application Compose execution contract changed after deployment preparation.",
        details={"expected": normalized, "observed": observed},
    )


def app_runtime_artifact_finding(
    repo_root: Path,
    expected: dict[str, Any],
    *,
    check: str,
) -> dict[str, Any]:
    normalized = validate_app_runtime_artifact_manifest(expected)
    try:
        observed = app_runtime_artifact_manifest(repo_root)
    except (OSError, ValueError) as error:
        return finding(
            "fail",
            check,
            f"Runtime deployment artifact identity could not be verified: {error}",
            details={"expected_digest": normalized["digest"]},
        )
    matches = hmac.compare_digest(observed["digest"], normalized["digest"])
    return finding(
        "pass" if matches else "fail",
        check,
        "Bind-mounted runtime artifacts match the captured deployment identity."
        if matches
        else "Bind-mounted runtime artifacts changed during the feed transition.",
        details={"expected": normalized, "observed": observed},
    )


def app_deployment_receipt_path(repo_root: Path) -> Path:
    return runtime_dir(repo_root) / APP_DEPLOYMENT_RECEIPT


def validate_app_deployment_receipt(value: Any) -> dict[str, Any]:
    if not isinstance(value, dict) or set(value) != {
        "schema_version",
        "image_ids",
        "runtime_artifacts",
        "compose_contract",
        "prepared_at",
    }:
        raise ValueError("application deployment receipt is invalid")
    if value.get("schema_version") != 1:
        raise ValueError("application deployment receipt schema is invalid")
    validate_app_service_image_ids(value.get("image_ids"))
    validate_app_runtime_artifact_manifest(value.get("runtime_artifacts"))
    validate_app_compose_contract(value.get("compose_contract"))
    prepared_at = value.get("prepared_at")
    if not isinstance(prepared_at, str):
        raise ValueError("application deployment receipt timestamp is invalid")
    try:
        parsed = datetime.fromisoformat(prepared_at.replace("Z", "+00:00"))
    except ValueError as error:
        raise ValueError("application deployment receipt timestamp is invalid") from error
    if parsed.tzinfo is None:
        raise ValueError("application deployment receipt timestamp is invalid")
    return value


def read_app_deployment_receipt(repo_root: Path) -> dict[str, Any] | None:
    path = app_deployment_receipt_path(repo_root)
    try:
        text = read_private_text(path, 16 * 1024)
    except FileNotFoundError:
        return None
    try:
        payload = json.loads(text)
    except json.JSONDecodeError as error:
        raise ValueError(f"application deployment receipt is not valid JSON: {error}") from error
    return validate_app_deployment_receipt(payload)


def write_app_deployment_receipt(
    repo_root: Path,
    image_ids: dict[str, str],
    runtime_artifacts: dict[str, Any],
    *,
    app_env: dict[str, str],
) -> dict[str, Any]:
    ensure_runtime_dirs(repo_root)
    payload = validate_app_deployment_receipt(
        {
            "schema_version": 1,
            "image_ids": validate_app_service_image_ids(image_ids),
            "runtime_artifacts": validate_app_runtime_artifact_manifest(
                runtime_artifacts
            ),
            "compose_contract": app_compose_contract_manifest(
                repo_root, image_ids, app_env=app_env
            ),
            "prepared_at": datetime.now(timezone.utc)
            .replace(microsecond=0)
            .isoformat(),
        }
    )
    write_private_text(
        app_deployment_receipt_path(repo_root),
        json.dumps(payload, indent=2, sort_keys=True) + "\n",
    )
    return payload


def app_deployment_receipt_error(
    repo_root: Path,
    receipt: dict[str, Any],
    *,
    app_env: dict[str, str],
    verify_compose_contract: bool = True,
) -> str | None:
    normalized = validate_app_deployment_receipt(receipt)
    image_error = app_service_image_availability_error(
        repo_root, normalized["image_ids"]
    )
    if image_error is not None:
        return image_error
    artifact = app_runtime_artifact_finding(
        repo_root,
        normalized["runtime_artifacts"],
        check="runtime.app-deployment-artifacts",
    )
    if artifact["status"] != "pass":
        return artifact["message"]
    if verify_compose_contract:
        compose_contract = app_compose_contract_finding(
            repo_root,
            normalized["image_ids"],
            normalized["compose_contract"],
            app_env=app_env,
            check="runtime.app-deployment-compose-contract",
        )
        if compose_contract["status"] != "pass":
            return compose_contract["message"]
    return None


def require_app_deployment_receipt(
    repo_root: Path,
    *,
    app_env: dict[str, str] | None = None,
    verify_compose_contract: bool = True,
) -> tuple[dict[str, Any] | None, str | None]:
    try:
        receipt = read_app_deployment_receipt(repo_root)
    except (OSError, ValueError) as error:
        return None, f"Prepared application deployment receipt is invalid: {error}"
    if receipt is None:
        return None, "Prepared application deployment receipt is missing; run runtime-app-build first"
    app_env = runtime_app_env(repo_root) if app_env is None else app_env
    error = app_deployment_receipt_error(
        repo_root,
        receipt,
        app_env=app_env,
        verify_compose_contract=verify_compose_contract,
    )
    return (None, error) if error is not None else (receipt, None)


def refresh_app_deployment_receipt_after_image_build(
    repo_root: Path,
    receipt: dict[str, Any],
    rebuilt_services: Sequence[str],
    *,
    app_env: dict[str, str],
) -> tuple[dict[str, Any] | None, str | None]:
    normalized = validate_app_deployment_receipt(receipt)
    rebuilt = tuple(dict.fromkeys(rebuilt_services))
    if not rebuilt or any(service not in APP_SERVICES for service in rebuilt):
        return None, "Application deployment receipt refresh requested invalid services"
    artifact = app_runtime_artifact_finding(
        repo_root,
        normalized["runtime_artifacts"],
        check="runtime.app-deployment-artifacts",
    )
    if artifact["status"] != "pass":
        return None, artifact["message"]
    refs, refs_error = configured_app_service_image_refs(repo_root, app_env)
    if refs_error is not None:
        return None, refs_error
    image_ids = dict(normalized["image_ids"])
    for service in rebuilt:
        image_id = docker_image_id(repo_root, refs[service])
        if image_id is None:
            return None, f"Rebuilt image identity is unavailable for {service}"
        image_ids[service] = image_id
    availability_error = app_service_image_availability_error(repo_root, image_ids)
    if availability_error is not None:
        return None, availability_error
    try:
        refreshed = write_app_deployment_receipt(
            repo_root,
            image_ids,
            normalized["runtime_artifacts"],
            app_env=app_env,
        )
    except (OSError, ValueError) as error:
        return None, f"Application deployment receipt refresh failed: {error}"
    return refreshed, None


def container_image_id(repo_root: Path, service: str) -> str | None:
    cid = container_id(repo_root, service)
    if not cid:
        return None
    result = run_command(
        ["docker", "inspect", "--format", "{{.Image}}", cid],
        repo_root,
        env=runtime_env(repo_root),
        timeout=120,
    )
    value = result.stdout.strip().splitlines()[-1] if result.returncode == 0 and result.stdout.strip() else ""
    return value if re.fullmatch(r"sha256:[0-9a-f]{64}", value) else None


def resolve_app_service_image_ids(
    repo_root: Path,
    *,
    prefer_running: bool,
    app_env: dict[str, str] | None = None,
) -> tuple[dict[str, str], str | None]:
    if prefer_running:
        running_ids = {
            service: container_image_id(repo_root, service)
            for service in APP_SERVICES
        }
        present = [service for service, image_id in running_ids.items() if image_id is not None]
        if len(present) == len(APP_SERVICES):
            normalized = validate_app_service_image_ids(running_ids)
            availability_error = app_service_image_availability_error(repo_root, normalized)
            return ({}, availability_error) if availability_error else (normalized, None)
        if present:
            return {}, (
                "Application deployment is partial; feed activation refuses to mix "
                f"running and newly built images ({', '.join(sorted(present))} are present)"
            )
    refs, error = configured_app_service_image_refs(repo_root, app_env)
    if error is not None:
        return {}, error
    image_ids: dict[str, str] = {}
    for service in APP_SERVICES:
        image_id = docker_image_id(repo_root, refs[service])
        if image_id is None:
            return {}, f"No built image identity is available for {service}; run runtime-app-build first"
        image_ids[service] = image_id
    availability_error = app_service_image_availability_error(repo_root, image_ids)
    return ({}, availability_error) if availability_error else (image_ids, None)


def app_service_image_findings(
    repo_root: Path, expected: dict[str, str], *, check: str
) -> list[dict[str, Any]]:
    normalized = validate_app_service_image_ids(expected)
    findings: list[dict[str, Any]] = []
    for service in APP_SERVICES:
        observed = container_image_id(repo_root, service)
        matches = observed == normalized[service]
        findings.append(
            finding(
                "pass" if matches else "fail",
                check,
                f"{service} uses the pinned pre-transition image."
                if matches
                else f"{service} does not use the pinned pre-transition image.",
                details={"service": service, "expected": normalized[service], "observed": observed},
            )
        )
    return findings


def path_is_within(path: Path, parent: Path) -> bool:
    try:
        path.relative_to(parent)
    except ValueError:
        return False
    return True


def open_absolute_directory_nofollow(path: Path) -> tuple[int, Path]:
    absolute = Path(os.path.abspath(path))
    if not absolute.is_absolute():
        raise OSError(errno.EINVAL, f"path is not absolute: {path}")
    flags = os.O_RDONLY | os.O_DIRECTORY | os.O_CLOEXEC | os.O_NOFOLLOW
    current_fd = os.open("/", flags)
    try:
        for part in absolute.parts[1:]:
            before = os.stat(part, dir_fd=current_fd, follow_symlinks=False)
            if stat.S_ISLNK(before.st_mode) or not stat.S_ISDIR(before.st_mode):
                raise OSError(errno.ELOOP, f"directory path component is not a real directory: {absolute}")
            next_fd = os.open(part, flags, dir_fd=current_fd)
            after = os.fstat(next_fd)
            if (before.st_dev, before.st_ino) != (after.st_dev, after.st_ino):
                os.close(next_fd)
                raise OSError(errno.ESTALE, f"directory path changed while opening: {absolute}")
            os.close(current_fd)
            current_fd = next_fd
        return current_fd, absolute
    except BaseException:
        os.close(current_fd)
        raise


def open_directory_beneath(parent_fd: int, parts: Sequence[str]) -> int:
    flags = os.O_RDONLY | os.O_DIRECTORY | os.O_CLOEXEC | os.O_NOFOLLOW
    current_fd = os.dup(parent_fd)
    try:
        for part in parts:
            if not part or part in {".", ".."} or "/" in part:
                raise OSError(errno.EINVAL, f"unsafe relative path component: {part!r}")
            before = os.stat(part, dir_fd=current_fd, follow_symlinks=False)
            if stat.S_ISLNK(before.st_mode) or not stat.S_ISDIR(before.st_mode):
                raise OSError(errno.ELOOP, f"relative path component is not a real directory: {part}")
            next_fd = os.open(part, flags, dir_fd=current_fd)
            after = os.fstat(next_fd)
            if (before.st_dev, before.st_ino) != (after.st_dev, after.st_ino):
                os.close(next_fd)
                raise OSError(errno.ESTALE, f"relative directory changed while opening: {part}")
            os.close(current_fd)
            current_fd = next_fd
        return current_fd
    except BaseException:
        os.close(current_fd)
        raise


def copy_regular_file_at(source_fd: int, destination_fd: int, name: str, mode: int) -> None:
    source_flags = os.O_RDONLY | os.O_CLOEXEC | os.O_NOFOLLOW
    destination_flags = os.O_WRONLY | os.O_CREAT | os.O_EXCL | os.O_CLOEXEC | os.O_NOFOLLOW
    before = os.stat(name, dir_fd=source_fd, follow_symlinks=False)
    input_fd = os.open(name, source_flags, dir_fd=source_fd)
    output_fd = -1
    try:
        after = os.fstat(input_fd)
        if (before.st_dev, before.st_ino) != (after.st_dev, after.st_ino) or not stat.S_ISREG(after.st_mode):
            raise OSError(errno.ESTALE, f"source file changed while opening: {name}")
        output_fd = os.open(name, destination_flags, mode or 0o600, dir_fd=destination_fd)
        while True:
            chunk = os.read(input_fd, 1024 * 1024)
            if not chunk:
                break
            view = memoryview(chunk)
            while view:
                written = os.write(output_fd, view)
                view = view[written:]
        os.fsync(output_fd)
    finally:
        os.close(input_fd)
        if output_fd >= 0:
            os.close(output_fd)


def copy_gvmd_state_tree(source_fd: int, destination_fd: int, relative: tuple[str, ...] = ()) -> tuple[list[str], list[str]]:
    copied: list[str] = []
    skipped: list[str] = []
    for name in sorted(os.listdir(source_fd)):
        if not name or name in {".", ".."} or "/" in name:
            raise OSError(errno.EINVAL, f"unsafe source entry: {name!r}")
        source_stat = os.stat(name, dir_fd=source_fd, follow_symlinks=False)
        relative_name = "/".join((*relative, name))
        if stat.S_ISLNK(source_stat.st_mode) or not (stat.S_ISDIR(source_stat.st_mode) or stat.S_ISREG(source_stat.st_mode)):
            raise OSError(errno.EINVAL, f"gvmd seed source contains a symlink or special file: {relative_name}")
        if stat.S_ISREG(source_stat.st_mode) and (name.startswith("gvm-") or name.startswith("yafvs-task-control-")):
            skipped.append(relative_name)
            continue
        mode = stat.S_IMODE(source_stat.st_mode)
        if stat.S_ISREG(source_stat.st_mode):
            copy_regular_file_at(source_fd, destination_fd, name, mode)
            copied.append(relative_name)
            continue
        os.mkdir(name, mode=mode or 0o700, dir_fd=destination_fd)
        source_child = open_directory_beneath(source_fd, (name,))
        destination_child = open_directory_beneath(destination_fd, (name,))
        try:
            child_copied, child_skipped = copy_gvmd_state_tree(source_child, destination_child, (*relative, name))
            copied.extend(child_copied)
            skipped.extend(child_skipped)
            os.fsync(destination_child)
        finally:
            os.close(source_child)
            os.close(destination_child)
    return copied, skipped


def remove_tree_at(parent_fd: int, name: str) -> None:
    entry = os.stat(name, dir_fd=parent_fd, follow_symlinks=False)
    if not stat.S_ISDIR(entry.st_mode) or stat.S_ISLNK(entry.st_mode):
        os.unlink(name, dir_fd=parent_fd)
        return
    child_fd = open_directory_beneath(parent_fd, (name,))
    try:
        for child in os.listdir(child_fd):
            remove_tree_at(child_fd, child)
    finally:
        os.close(child_fd)
    os.rmdir(name, dir_fd=parent_fd)


def renameat2_noreplace(source_fd: int, source_name: str, destination_fd: int, destination_name: str) -> None:
    libc = ctypes.CDLL(None, use_errno=True)
    renameat2 = getattr(libc, "renameat2", None)
    if renameat2 is None:
        raise OSError(errno.ENOSYS, "renameat2 is unavailable")
    renameat2.argtypes = [ctypes.c_int, ctypes.c_char_p, ctypes.c_int, ctypes.c_char_p, ctypes.c_uint]
    renameat2.restype = ctypes.c_int
    if renameat2(source_fd, os.fsencode(source_name), destination_fd, os.fsencode(destination_name), 1) != 0:
        error = ctypes.get_errno()
        raise OSError(error, os.strerror(error), destination_name)


