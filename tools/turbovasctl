NATIVE_TARGET_XML_CREDENTIAL_FIELDS = {
    "ssh_credential": "ssh",
    "smb_credential": "smb",
    "esxi_credential": "esxi",
    "snmp_credential": "snmp",
}


def native_target_xml_text(element: ET.Element, name: str, *, required: bool = False) -> str:
    child = element.find(name)
    value = child.text.strip() if child is not None and child.text is not None else ""
    if required and not value:
        raise ValueError(f"target row is missing required <{name}> text")
    return value


def native_target_xml_flag(element: ET.Element, name: str) -> bool:
    value = native_target_xml_text(element, name).strip()
    if value in ("", "0"):
        return False
    if value == "1":
        return True
    raise ValueError(f"<{name}> must be empty, 0, or 1")


def native_target_xml_list(value: str) -> tuple[str, ...]:
    return tuple(item.strip() for item in value.split(",") if item.strip())


def load_native_target_xml_rows(xml_file: Path) -> list[NativeTargetXmlRow]:
    try:
        root = ET.parse(xml_file).getroot()
    except ET.ParseError as exc:
        raise ValueError(f"failed to parse target XML file: {exc}") from exc
    except OSError as exc:
        raise ValueError(f"failed to read target XML file: {exc}") from exc

    rows: list[NativeTargetXmlRow] = []
    for row_number, target in enumerate(root.findall("target"), start=1):
        name = native_target_xml_text(target, "name", required=True)
        hosts = native_target_xml_list(native_target_xml_text(target, "hosts", required=True))
        if not hosts:
            raise ValueError(f"target row {row_number} must include at least one host")
        exclude_hosts = native_target_xml_list(native_target_xml_text(target, "exclude_hosts"))
        comment = native_target_xml_text(target, "comment") or None
        alive_test = native_target_xml_text(target, "alive_tests") or NATIVE_TARGET_HOST_LIST_DEFAULT_ALIVE_TEST
        port_list = target.find("port_list")
        port_list_id = (port_list.get("id") or "").strip() if port_list is not None else ""
        if not UUID_VALUE_RE.fullmatch(port_list_id):
            raise ValueError(f"target row {row_number} must include a port_list id UUID")
        port_range = native_target_xml_text(target, "port_range")
        if port_range:
            raise ValueError(f"target row {row_number} port_range is not native-safe; use a port_list id")

        credentials: dict[str, dict[str, Any]] = {}
        for xml_name, native_name in NATIVE_TARGET_XML_CREDENTIAL_FIELDS.items():
            credential = target.find(xml_name)
            if credential is None:
                continue
            credential_id = (credential.get("id") or "").strip()
            if not credential_id:
                continue
            if not UUID_VALUE_RE.fullmatch(credential_id):
                raise ValueError(f"target row {row_number} {xml_name} id must be a UUID")
            link: dict[str, Any] = {"id": credential_id}
            port = credential.find("port")
            port_text = port.text.strip() if port is not None and port.text is not None else ""
            if port_text:
                if native_name != "ssh":
                    raise ValueError(f"target row {row_number} {xml_name} ports are not native-safe yet")
                try:
                    port_value = int(port_text)
                except ValueError as exc:
                    raise ValueError(f"target row {row_number} {xml_name} port must be an integer") from exc
                if not 1 <= port_value <= 65535:
                    raise ValueError(f"target row {row_number} {xml_name} port must be within 1..65535")
                link["port"] = port_value
            credentials[native_name] = link

        rows.append(
            NativeTargetXmlRow(
                row_number=row_number,
                name=name,
                hosts=hosts,
                exclude_hosts=exclude_hosts,
                comment=comment,
                alive_tests=(alive_test,),
                reverse_lookup_only=native_target_xml_flag(target, "reverse_lookup_only"),
                reverse_lookup_unify=native_target_xml_flag(target, "reverse_lookup_unify"),
                port_list_id=port_list_id,
                credentials=credentials,
            )
        )
    if not rows:
        raise ValueError("target XML file does not contain any <target> rows")
    return rows


def load_native_target_csv_rows(csv_file: Path) -> list[NativeTargetCsvRow]:
    rows: list[NativeTargetCsvRow] = []
    try:
        with csv_file.open(encoding="utf-8", newline="") as handle:
            reader = csv.reader(handle, delimiter=",")
            for row_number, row in enumerate(reader, start=1):
                if not row:
                    continue
                if len(row) < 7:
                    raise ValueError(f"row {row_number} must have at least 7 columns")
                name = row[0].strip()
                host = row[1].strip()
                if not name or not host:
                    raise ValueError(f"row {row_number} must include target name and host")
                rows.append(
                    NativeTargetCsvRow(
                        row_number=row_number,
                        name=name,
                        host=host,
                        smb_credential_name=row[2].strip(),
                        ssh_credential_name=row[3].strip(),
                        alive_test=(row[6].strip() or NATIVE_TARGET_HOST_LIST_DEFAULT_ALIVE_TEST),
                    )
                )
    except OSError as exc:
        raise ValueError(f"failed to read target CSV file: {exc}") from exc
    if not rows:
        raise ValueError("target CSV file is empty")
    return rows


