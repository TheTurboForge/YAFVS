def command_runtime_app_down(repo_root: Path) -> dict[str, Any]:
    stop = run_command(compose_command(repo_root, "--profile", "app", "stop", *APP_SERVICES), repo_root, env=runtime_env(repo_root))
    remove = run_command(compose_command(repo_root, "--profile", "app", "rm", "-f", *APP_SERVICES), repo_root, env=runtime_env(repo_root))
    findings = [
        finding("pass" if stop.returncode == 0 else "fail", "compose.app-stop", f"docker compose app stop exit code {stop.returncode}.", details={"output_tail": output_tail(stop.stdout, 80)}),
        finding("pass" if remove.returncode == 0 else "fail", "compose.app-rm", f"docker compose app rm exit code {remove.returncode}.", details={"output_tail": output_tail(remove.stdout, 80)}),
    ]
    return make_result("runtime-app-down", repo_root, "Application runtime shutdown attempted.", findings, [str(runtime_dir(repo_root))])


def command_runtime_app_smoke(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    manager_lock = runtime_lock_status(repo_root, RUNTIME_MANAGER_LOCK)
    if manager_lock["active"]:
        findings.append(finding("fail", "runtime.manager-lock", "A manager initialization or manager operation is active; app smoke would race transient state.", details={"lock": manager_lock}))
    findings.extend(command_feed_state(repo_root)["findings"])
    findings.extend(cert_file_findings(repo_root))
    if not certs_complete(repo_root):
        findings.append(finding("fail", "runtime.cert.complete", "Runtime certificates are incomplete; run just runtime-certs-init."))
    findings.append(pg_gvm_extension_status(repo_root))
    secret_path = runtime_secret_path(repo_root, DEV_ADMIN_SECRET)
    findings.append(finding("pass" if secret_path.is_file() else "warn", "runtime.admin-secret", "Development admin secret exists." if secret_path.is_file() else "Development admin secret is missing; run just runtime-manager-init.", str(secret_path)))

    password = secret_path.read_text(encoding="utf-8").strip() if secret_path.is_file() else ""
    if feed_gnupg_home(repo_root).is_dir() and shutil.which("gpg"):
        fingerprint = run_command(gpg_command(repo_root, "--with-colons", "--fingerprint", GREENBONE_COMMUNITY_KEY_FPR), repo_root, timeout=60)
        fingerprint_ok = fingerprint.returncode == 0 and GREENBONE_COMMUNITY_KEY_FPR in fingerprint.stdout.replace(" ", "").upper()
        findings.append(finding("pass" if fingerprint_ok else "fail", "feed-keyring.fingerprint", "Shared feed signature keyring contains the Greenbone Community signing key." if fingerprint_ok else "Shared feed signature keyring is missing the Greenbone Community signing key.", str(feed_gnupg_home(repo_root)), {"fingerprint": GREENBONE_COMMUNITY_KEY_FPR, "output_tail": output_tail(fingerprint.stdout, 60)}))
    else:
        findings.append(finding("fail", "feed-keyring.fingerprint", "Shared feed signature keyring is not initialized; run just runtime-feed-keyring-init.", str(feed_gnupg_home(repo_root))))
    for service in APP_SERVICES:
        running = container_running(repo_root, service)
        findings.append(finding("pass" if running else "warn", "runtime.app.running", f"{service} container is {'running' if running else 'not running'}.", details={"service": service, "logs_tail": [] if running else service_log_tail(repo_root, service)}))

    gvmd_socket = gvmd_socket_path(repo_root)
    gvmd_socket_finding = socket_readiness_finding("gvmd.socket", "gvmd", gvmd_socket)
    findings.append(gvmd_socket_finding)
    gvmd_ready = gvmd_socket_finding["status"] == "pass"
    if gvmd_ready and password:
        gmp = command_runtime_gmp_smoke(repo_root)
        findings.append(finding(gmp["status"], "gvmd.gmp", gmp["summary"], details={"status": gmp["status"]}))

    ospd_socket = ospd_socket_path(repo_root)
    ospd_socket_finding = socket_readiness_finding("ospd.socket", "ospd-openvas", ospd_socket)
    findings.append(ospd_socket_finding)
    ospd_ready = ospd_socket_finding["status"] == "pass"
    if container_running(repo_root, "ospd-openvas"):
        capability = command_runtime_scanner_capability_check(repo_root)
        findings.append(finding(capability["status"], "ospd.capability-check", capability["summary"], details={"status": capability["status"], "findings": capability["findings"]}))
        process_check = command_runtime_scanner_process_check(repo_root)
        findings.append(finding(process_check["status"], "ospd.process-check", process_check["summary"], details={"status": process_check["status"], "findings": process_check["findings"]}))
        nmap_capability = command_runtime_nmap_capability_check(repo_root)
        findings.append(finding(nmap_capability["status"], "nmap.capability-check", nmap_capability["summary"], details={"status": nmap_capability["status"], "findings": nmap_capability["findings"]}))
        ospd_logs = service_log_tail(repo_root, "ospd-openvas", lines=120)
        ospd_errors = [line for line in ospd_logs if "ERROR" in line]
        ospd_feed_errors = feed_signature_log_errors(ospd_logs)
        known_feed_gap = any("failed to load VTs" in line or "Updating VTs failed" in line for line in ospd_errors)
        if ospd_errors:
            message = "ospd-openvas logs contain errors; current known blocker is missing feed/plugin cache." if known_feed_gap else "ospd-openvas logs contain errors that require investigation."
            findings.append(finding("warn", "ospd.logs", message, details={"known_deferred_feed_state": known_feed_gap, "error_tail": ospd_errors[-20:]}))
        else:
            findings.append(finding("pass", "ospd.logs", "ospd-openvas logs contain no ERROR lines in the inspected tail."))
        findings.append(finding("fail" if ospd_feed_errors else "pass", "ospd.feed-signature-logs", "ospd-openvas logs contain feed signature or Notus advisory load errors." if ospd_feed_errors else "ospd-openvas logs contain no feed signature or Notus advisory load errors in the inspected tail.", details={"error_tail": ospd_feed_errors[-20:]}))
        vt_status, vt_lines = ospd_vt_load_status_from_logs(ospd_logs)
        findings.append(
            finding(
                {"pass": "pass", "fail": "fail", "wait": "warn"}[vt_status],
                "ospd.vt-load",
                "ospd-openvas reports VTs are loaded." if vt_status == "pass" else "ospd-openvas VT loading failed." if vt_status == "fail" else "ospd-openvas is still loading VTs.",
                details={"status": vt_status, "log_lines": vt_lines[-20:]},
            )
        )
    if container_running(repo_root, "notus-scanner"):
        notus_logs = service_log_tail(repo_root, "notus-scanner", lines=120)
        notus_file_logs = runtime_file_tail(runtime_path(repo_root, "logs", "notus", "notus-scanner.log"), lines=120)
        notus_errors = [line for line in [*notus_logs, *notus_file_logs] if "ERROR" in line or "CRITICAL" in line]
        notus_feed_errors = feed_signature_log_errors([*notus_logs, *notus_file_logs])
        findings.append(finding("fail" if notus_errors else "pass", "notus.logs", "notus-scanner logs contain ERROR/CRITICAL lines." if notus_errors else "notus-scanner logs contain no ERROR/CRITICAL lines in the inspected tail.", details={"error_tail": notus_errors[-20:]}))
        findings.append(finding("fail" if notus_feed_errors else "pass", "notus.feed-signature-logs", "notus-scanner logs contain GPG, signature, or advisory-load errors." if notus_feed_errors else "notus-scanner logs contain no GPG, signature, or advisory-load errors in the inspected tail.", details={"error_tail": notus_feed_errors[-20:]}))
    if ospd_ready:
        scanners = run_gvmd_oneoff(repo_root, ["--get-scanners"], no_deps=False)
        findings.append(finding("pass" if scanners.returncode == 0 else "warn", "gvmd.scanners", f"gvmd --get-scanners exit code {scanners.returncode}.", details={"output_tail": output_tail(scanners.stdout, 80, [password])}))
        findings.append(scanner_registration_status(repo_root))

    for base_url in gsad_base_urls(repo_root):
        gsad_http = run_command(["curl", "-kIsS", "--max-time", "10", f"{base_url}/"], repo_root, env=runtime_env(repo_root))
        findings.append(finding("pass" if gsad_http.returncode == 0 else "warn", "gsad.https", f"Configured HTTPS header probe exit code {gsad_http.returncode}.", details={"url": f"{base_url}/", "output_tail": output_tail(gsad_http.stdout, 80, [password])}))
    if container_running(repo_root, "turbovas-api"):
        native_api = command_runtime_native_api_smoke(repo_root)
        findings.append(finding(native_api["status"], "native-api.smoke", native_api["summary"], details={"status": native_api["status"], "findings": native_api["findings"]}))
    return make_result("runtime-app-smoke", repo_root, "Application runtime smoke checks completed.", findings, [str(runtime_dir(repo_root))])


NATIVE_API_REQUEST_ALLOWED_METHODS = {"GET", "POST", "PUT", "PATCH", "DELETE"}


def native_api_curl(
    repo_root: Path,
    path: str,
    *,
    method: str = "GET",
    request_id: str | None = None,
    body: str | None = None,
) -> subprocess.CompletedProcess[str]:
    command = compose_command(
        repo_root,
        "exec",
        "-T",
        "turbovas-api",
        "curl",
        "-fsS",
        "--max-time",
        "10",
    )
    if method != "GET" or body is not None:
        command.extend(["-X", method])
    if request_id is not None:
        command.extend(["-H", f"{DIRECT_API_REQUEST_ID_HEADER}: {request_id}"])
    if body is not None:
        command.extend(["-H", "Content-Type: application/json", "--data-binary", body])
    command.append(f"http://127.0.0.1:{TURBOVAS_API_CONTAINER_PORT}{path}")
    return run_command(
        command,
        repo_root,
        env=runtime_env(repo_root),
        timeout=30,
    )


def native_api_curl_with_http_status(repo_root: Path, path: str) -> subprocess.CompletedProcess[str]:
    command = compose_command(
        repo_root,
        "exec",
        "-T",
        "turbovas-api",
        "curl",
        "-sS",
        "--max-time",
        "10",
        "-w",
        "\n%{http_code}",
    )
    command.append(f"http://127.0.0.1:{TURBOVAS_API_CONTAINER_PORT}{path}")
    return run_command(
        command,
        repo_root,
        env=runtime_env(repo_root),
        timeout=30,
    )


def validate_native_api_request_path(path: str) -> str:
    parsed = urllib.parse.urlsplit(path)
    if parsed.scheme or parsed.netloc:
        raise ValueError("native API path must be relative, not an absolute URL")
    if parsed.fragment:
        raise ValueError("native API path must not contain a fragment")
    if parsed.path != "/api/v1" and not parsed.path.startswith("/api/v1/"):
        raise ValueError("native API path must start with /api/v1/")
    path_segments = parsed.path.split("/")[1:]
    if parsed.path != "/api/v1" and ("" in path_segments or "." in path_segments or ".." in path_segments):
        raise ValueError("native API path must not contain empty, '.', or '..' segments")
    return urllib.parse.urlunsplit(("", "", parsed.path, parsed.query, ""))


def validate_direct_api_request_id(request_id: str) -> str:
    if request_id == "":
        raise ValueError("request ID must not be empty")
    if len(request_id) > MAX_DIRECT_API_REQUEST_ID_LENGTH:
        raise ValueError(f"request ID must be at most {MAX_DIRECT_API_REQUEST_ID_LENGTH} characters")
    if not all(char.isascii() and (char.isalnum() or char in "-_.:") for char in request_id):
        raise ValueError("request ID may contain only ASCII letters, digits, '-', '_', '.', and ':'")
    return request_id


def validate_native_api_request_method(method: str) -> str:
    normalized = method.upper()
    if normalized not in NATIVE_API_REQUEST_ALLOWED_METHODS:
        allowed = ", ".join(sorted(NATIVE_API_REQUEST_ALLOWED_METHODS))
        raise ValueError(f"native API request method must be one of: {allowed}")
    return normalized


def validate_native_api_request_body_json(body_json: str) -> str:
    if body_json == "":
        raise ValueError("request body JSON must not be empty")
    try:
        parsed = json.loads(body_json)
    except json.JSONDecodeError as exc:
        raise ValueError(f"request body must be valid JSON: {exc.msg}") from exc
    return json.dumps(parsed, separators=(",", ":"))


def validate_native_api_request_shape(
    method: str,
    *,
    body: str | None,
    allow_write_control: bool,
    request_path: str | None = None,
) -> None:
    if method == "GET" and body is not None:
        raise ValueError("GET native API requests must not include a request body")
    if method == "DELETE" and body is not None:
        raise ValueError("DELETE native API requests must not include a request body")
    if method != "GET" and request_path is not None and urllib.parse.urlsplit(request_path).query:
        raise ValueError("non-GET native API requests must not include query parameters")
    if method != "GET" and not allow_write_control:
        raise ValueError("non-GET native API requests require --allow-write-control")
    if body is not None and not allow_write_control:
        raise ValueError("native API request bodies require --allow-write-control")


def native_api_request_display_command(
    repo_root: Path,
    request_path: str,
    *,
    method: str = "GET",
    request_id: str | None = None,
    body: str | None = None,
) -> list[str]:
    command = compose_command(
        repo_root,
        "exec",
        "-T",
        "turbovas-api",
        "curl",
        "-fsS",
        "--max-time",
        "10",
    )
    if method != "GET" or body is not None:
        command.extend(["-X", method])
    if request_id is not None:
        command.extend(["-H", f"{DIRECT_API_REQUEST_ID_HEADER}: {request_id}"])
    if body is not None:
        command.extend(["-H", "Content-Type: application/json", "--data-binary", "<redacted-body>"])
    command.append(f"http://127.0.0.1:{TURBOVAS_API_CONTAINER_PORT}{request_path}")
    return command


def command_native_api_request(
    repo_root: Path,
    path: str,
    *,
    direct: bool = False,
    method: str = "GET",
    request_id: str | None = None,
    body_json: str | None = None,
    allow_write_control: bool = False,
    status_only: bool = False,
) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    try:
        method = validate_native_api_request_method(method)
    except ValueError as exc:
        findings.append(finding("fail", "native-api-request.method", str(exc), details={"method": method}))
        return make_result("native-api-request", repo_root, "Native API request rejected before runtime access.", findings)
    try:
        request_path = validate_native_api_request_path(path)
    except ValueError as exc:
        findings.append(finding("fail", "native-api-request.path", str(exc), details={"path": path}))
        return make_result("native-api-request", repo_root, "Native API request rejected before runtime access.", findings)
    try:
        request_id = validate_direct_api_request_id(request_id) if request_id is not None else None
    except ValueError as exc:
        findings.append(finding("fail", "native-api-request.request-id", str(exc), details={"request_id": request_id}))
        return make_result("native-api-request", repo_root, "Native API request rejected before runtime access.", findings)
    try:
        body = validate_native_api_request_body_json(body_json) if body_json is not None else None
        validate_native_api_request_shape(
            method,
            body=body,
            allow_write_control=allow_write_control,
            request_path=request_path if direct else None,
        )
    except ValueError as exc:
        findings.append(
            finding(
                "fail",
                "native-api-request.write-control-intent",
                str(exc),
                details={"method": method, "has_body": body_json is not None, "allow_write_control": allow_write_control},
            )
        )
        return make_result("native-api-request", repo_root, "Native API request rejected before runtime access.", findings)

    if direct:
        env = native_api_direct_runtime_env(repo_root)
        findings.append(native_api_direct_config_shape_finding(env, check="native-api-request.direct-config-shape"))
        if aggregate_status(findings) == "fail":
            return make_result("native-api-request", repo_root, "Direct native API request rejected before runtime access.", findings)
        token = native_api_direct_bearer_token(repo_root, env)
        if not direct_api_bearer_token_is_acceptable(token):
            findings.append(
                finding(
                    "fail",
                    "native-api-request.direct-token-strength",
                    "Direct native API bearer token is too short or contains unsafe characters.",
                    details={"minimum_token_length": TURBOVAS_API_BEARER_TOKEN_MIN_LENGTH},
                )
            )
            return make_result("native-api-request", repo_root, "Direct native API request rejected before runtime access.", findings)
        extra_headers = (("Content-Type", "application/json"),) if body is not None else None
        response = direct_native_api_curl(repo_root, request_path, token=token, env=env, method=method, request_id=request_id, body=body, extra_headers=extra_headers)
        parsed, http_status = parse_json_output_with_http_status(response)
        ok = response.returncode == 0 and isinstance(http_status, int) and 200 <= http_status < 300 and isinstance(parsed, dict)
        findings.append(
            native_api_probe_finding(
                "pass" if ok else "fail",
                "native-api-request.direct",
                f"Direct native API {method} {request_path} returned authenticated JSON."
                if ok
                else f"Direct native API {method} {request_path} failed, returned non-2xx, or returned non-JSON output.",
                response,
                direct_native_api_display_command(request_path, token=token, env=env, method=method, request_id=request_id, body=body, extra_headers=extra_headers),
                parsed,
                {"http_status": http_status, "request_id": request_id, "method": method, "body_bytes": len(body.encode("utf-8")) if body is not None else 0, **summarize_native_api_response(parsed)},
            )
        )
        result = make_result("native-api-request", repo_root, "Direct native API request completed." if ok else "Direct native API request failed.", findings)
        result["details"] = {"path": request_path, "direct": True, "method": method, "http_status": http_status, "request_id": request_id, "body_bytes": len(body.encode("utf-8")) if body is not None else 0, "response": parsed if isinstance(parsed, dict) else None}
        if status_only:
            result = native_api_request_status_only_result(result)
        return result

    response = native_api_curl(repo_root, request_path, method=method, request_id=request_id, body=body)
    parsed = parse_json_output(response)
    ok = response.returncode == 0 and isinstance(parsed, dict)
    findings.append(
        native_api_probe_finding(
            "pass" if ok else "fail",
            "native-api-request.get",
            f"Native API {method} {request_path} returned JSON." if ok else f"Native API {method} {request_path} failed or returned non-JSON output.",
            response,
            native_api_request_display_command(repo_root, request_path, method=method, request_id=request_id, body=body),
            parsed,
            {"request_id": request_id, "method": method, "body_bytes": len(body.encode("utf-8")) if body is not None else 0},
        )
    )
    result = make_result("native-api-request", repo_root, "Native API request completed." if ok else "Native API request failed.", findings)
    result["details"] = {"path": request_path, "method": method, "request_id": request_id, "body_bytes": len(body.encode("utf-8")) if body is not None else 0, "response": parsed if isinstance(parsed, dict) else None}
    if status_only:
        result = native_api_request_status_only_result(result)
    return result


def load_native_target_host_list(hosts_file: Path) -> list[str]:
    try:
        content = hosts_file.read_text(encoding="utf-8")
    except OSError as exc:
        raise ValueError(f"failed to read host file: {exc}") from exc
    hosts = [line.strip() for line in content.splitlines() if line.strip()]
    if not hosts:
        raise ValueError("host file is empty")
    return hosts


def parse_native_target_host_list_port_ranges(port_range: str) -> list[dict[str, Any]]:
    ranges: list[dict[str, Any]] = []
    for raw_token in port_range.split(","):
        token = raw_token.strip()
        if not token:
            continue
        match = re.fullmatch(r"(?i)(T|TCP|U|UDP):(\d+)(?:-(\d+))?", token)
        if not match:
            raise ValueError("port ranges must use comma-separated T:start-end or U:start-end tokens")
        protocol_token, start_text, end_text = match.groups()
        start = int(start_text)
        end = int(end_text or start_text)
        if not (1 <= start <= 65535 and 1 <= end <= 65535 and start <= end):
            raise ValueError("port range start/end must be within 1..65535 and start must not exceed end")
        ranges.append(
            {
                "protocol": "tcp" if protocol_token.lower().startswith("t") else "udp",
                "start": start,
                "end": end,
                "comment": "TurboVAS native host-list target import",
            }
        )
    if not ranges:
        raise ValueError("port range must include at least one T:/U: range")
    return ranges


