    preflight_failures: list[dict[str, Any]] = []
    skipped_existing_targets: list[str] = []
    planned_target_names: set[str] = set()
    for row in rows:
        if row.name in planned_target_names:
            skipped_existing_targets.append(row.name)
            continue
        target_matches, target_failure = native_target_csv_fetch_exact_items(repo_root, "/api/v1/targets", row.name, token=token, env=env)
        if target_failure:
            preflight_failures.append({"row": row.row_number, "name": row.name, **target_failure})
            continue
        if target_matches:
            skipped_existing_targets.append(row.name)
            continue

        credentials: dict[str, dict[str, Any]] = {}
        for field_name, credential_name, allowed_types in (
            ("smb", row.smb_credential_name, NATIVE_TARGET_CSV_SMB_CREDENTIAL_TYPES),
            ("ssh", row.ssh_credential_name, NATIVE_TARGET_CSV_SSH_CREDENTIAL_TYPES),
        ):
            if not credential_name:
                continue
            matches, credential_failure = native_target_csv_fetch_exact_items(
                repo_root,
                "/api/v1/credentials",
                credential_name,
                token=token,
                env=env,
                allowed_types=allowed_types,
            )
            if credential_failure:
                preflight_failures.append({"row": row.row_number, "name": row.name, "credential": credential_name, "field": field_name, **credential_failure})
                continue
            if len(matches) != 1:
                preflight_failures.append({"row": row.row_number, "name": row.name, "credential": credential_name, "field": field_name, "reason": "credential lookup was missing or ambiguous", "match_count": len(matches)})
                continue
            credential_id = matches[0].get("id")
            if not isinstance(credential_id, str):
                preflight_failures.append({"row": row.row_number, "name": row.name, "credential": credential_name, "field": field_name, "reason": "credential response did not include an id"})
                continue
            credentials[field_name] = {"id": credential_id}
        rows_to_create.append((row, credentials))
        planned_target_names.add(row.name)

    details["skipped_existing_targets"] = skipped_existing_targets
    details["skipped_existing_target_count"] = len(skipped_existing_targets)
    if preflight_failures:
        details["preflight_failures"] = preflight_failures
        findings.append(finding("fail", "native-targets-from-csv.preflight", "Native CSV target creation preflight failed before creating targets.", details={"failure_count": len(preflight_failures), "failures": preflight_failures[:10]}))
        result = make_result("native-targets-from-csv", repo_root, "Native CSV target creation rejected before target writes.", findings)
        result["details"] = details
        return native_target_csv_status_only_result(result) if status_only else result

    findings.append(finding("pass", "native-targets-from-csv.preflight", f"Preflight resolved {len(rows_to_create)} target create row(s) and skipped {len(skipped_existing_targets)} existing target(s)."))

    content_type = (("Content-Type", "application/json"),)
    created_target_ids: list[str] = []
    create_failures: list[dict[str, Any]] = []
    for row, credentials in rows_to_create:
        target_body = json.dumps(
            native_target_csv_target_body(row, port_list_id=port_list_id, timestamp=timestamp, credentials=credentials),
            separators=(",", ":"),
        )
        target_create = direct_native_api_curl(repo_root, "/api/v1/targets", token=token, env=env, method="POST", body=target_body, extra_headers=content_type)
        target_create_json, target_create_status = parse_json_output_with_http_status(target_create)
        target_id = target_create_json.get("id") if isinstance(target_create_json, dict) and isinstance(target_create_json.get("id"), str) else None
        if target_create.returncode == 0 and target_create_status == 201 and target_id:
            created_target_ids.append(target_id)
        else:
            create_failures.append({"row": row.row_number, "name": row.name, "http_status": target_create_status, **summarize_native_api_response(target_create_json)})
            break
    details["created_target_ids"] = created_target_ids
    details["created_target_count"] = len(created_target_ids)
    if create_failures:
        details["create_failures"] = create_failures
        findings.append(finding("fail", "native-targets-from-csv.target-create", "One or more native target create requests failed.", details={"failure_count": len(create_failures), "failures": create_failures[:10]}))
    else:
        findings.append(finding("pass", "native-targets-from-csv.target-create", f"Created {len(created_target_ids)} target(s) through the native API."))

    result_status = aggregate_status(findings)
    result = make_result(
        "native-targets-from-csv",
        repo_root,
        "Native CSV target creation completed." if result_status != "fail" else "Native CSV target creation failed.",
        findings,
    )
    result["details"] = details
    return native_target_csv_status_only_result(result) if status_only else result


