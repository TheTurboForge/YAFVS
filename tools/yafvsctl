    findings.append(native_api_probe_finding("pass" if scope_report_detail_ok else "fail", "native-api-direct.internal-only-scope-report-detail", "Direct native API denies the unclassified scope-report detail scaffold with JSON 404." if scope_report_detail_ok else "Direct native API did not deny the unclassified scope-report detail scaffold correctly.", scope_report_detail, direct_native_api_display_command("/api/v1/scopes/scope-id/reports/scope-report-id", token=token, env=env), scope_report_detail_json, {"http_status": scope_report_detail_status, **summarize_native_api_response(scope_report_detail_json)}))

    scope_reports = native_api_curl(repo_root, "/api/v1/scope-reports?page_size=1&sort=-creation_time")
    scope_reports_json = parse_json_output(scope_reports)
    scope_report_items = scope_reports_json.get("items", []) if isinstance(scope_reports_json, dict) else []
    selected_scope_report = scope_report_items[0] if scope_report_items else None
    selected_scope = selected_scope_report.get("scope") if isinstance(selected_scope_report, dict) else None
    if isinstance(selected_scope_report, dict) and selected_scope_report.get("id"):
        scope_report_path = f"/api/v1/scope-reports/{urllib.parse.quote(str(selected_scope_report['id']))}"
        scope_report_direct = direct_native_api_curl(
            repo_root,
            scope_report_path,
            token=token,
            env=env,
        )
        scope_report_direct_json, scope_report_direct_status = parse_json_output_with_http_status(scope_report_direct)
        scope_report_direct_ok = (
            scope_report_direct.returncode == 0
            and scope_report_direct_status == 200
            and isinstance(scope_report_direct_json, dict)
            and scope_report_direct_json.get("id") == selected_scope_report.get("id")
            and isinstance(scope_report_direct_json.get("sources"), list)
        )
        findings.append(
            native_api_probe_finding(
                "pass" if scope_report_direct_ok else "fail",
                "native-api-direct.scope-report-detail",
