def run_git(repo_root: Path, args: list[str]) -> str | None:
    try:
        result = subprocess.run(["git", *args], cwd=repo_root, text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, check=True)
    except (OSError, subprocess.CalledProcessError):
        return None
    return result.stdout.strip()


def git_tracked_files(repo_root: Path) -> list[str] | None:
    output = run_git(repo_root, ["ls-files"])
    if output is None:
        return None
    return [line for line in output.splitlines() if line]


def run_command(
    command: list[str],
    cwd: Path,
    env: dict[str, str] | None = None,
    timeout: int | None = None,
    input_text: str | None = None,
    pass_fds: tuple[int, ...] = (),
) -> subprocess.CompletedProcess[str]:
    try:
        return subprocess.run(command, cwd=cwd, env=env, text=True, input=input_text, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, timeout=timeout, pass_fds=pass_fds)
    except subprocess.TimeoutExpired as error:
        stdout = error.stdout or ""
        if isinstance(stdout, bytes):
            stdout = stdout.decode(errors="replace")
        stdout += f"\nTimed out after {timeout} seconds."
        return subprocess.CompletedProcess(command, 124, stdout)


def find_repo_root(start: Path) -> Path | None:
    git_root = run_git(start, ["rev-parse", "--show-toplevel"])
    if git_root:
        return Path(git_root)
    return None


def metadata(repo_root: Path, command: str) -> dict[str, Any]:
    return {
        "command": command,
        "generated_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat(),
        "repo_root": str(repo_root),
        "head": run_git(repo_root, ["rev-parse", "--short", "HEAD"]),
    }


def status_rank(status: str) -> int:
    return STATUSES.index(status)


def aggregate_status(findings: Iterable[dict[str, Any]]) -> str:
    final = "pass"
    for item in findings:
        status = str(item.get("status", "pass"))
        if status not in STATUSES:
            status = "fail"
        if status_rank(status) > status_rank(final):
            final = status
    return final


def contract_drift_status(alignment_status: Any) -> str:
    return "pass" if alignment_status == "pass" else "fail"


def make_result(command: str, repo_root: Path, summary: str, findings: list[dict[str, Any]], artifacts: list[str] | None = None) -> dict[str, Any]:
    return {"status": aggregate_status(findings), "summary": summary, "findings": findings, "artifacts": artifacts or [], "metadata": metadata(repo_root, command)}


def rust_result_envelope(repo_root: Path, expected_command: str, rust_arguments: list[str]) -> dict[str, Any]:
    command = [
        "cargo",
        "run",
        "--quiet",
        "--locked",
        "--target-dir",
        str(repo_root / "build" / "yafvsctl-rs"),
        "--manifest-path",
        str(repo_root / YAFVSCTL_RUST_CRATE / "Cargo.toml"),
        "--",
        *rust_arguments,
        "--json",
    ]
    try:
        completed = run_command(command, repo_root, timeout=300)
        stdout = completed.stdout
        if not isinstance(stdout, str) or len(stdout.encode("utf-8")) > YAFVSCTL_RUST_BRIDGE_MAX_OUTPUT_BYTES:
            raise ValueError("invalid Rust result output")
        payload = json.loads(stdout, object_pairs_hook=reject_duplicate_json_object_keys)
        if not isinstance(payload, dict):
            raise ValueError("invalid Rust result envelope")
        status = payload.get("status")
        findings = payload.get("findings")
        if (
            status not in STATUSES
            or not isinstance(payload.get("summary"), str)
            or not isinstance(findings, list)
            or not isinstance(payload.get("artifacts"), list)
            or not all(isinstance(artifact, str) for artifact in payload["artifacts"])
            or ("details" in payload and not isinstance(payload["details"], dict))
            or not isinstance(payload.get("metadata"), dict)
            or payload["metadata"].get("command") != expected_command
            or completed.returncode != (1 if status == "fail" else 0)
        ):
            raise ValueError("invalid Rust result envelope")
        for item in findings:
            if (
                not isinstance(item, dict)
                or item.get("status") not in STATUSES
                or not isinstance(item.get("check"), str)
                or not isinstance(item.get("message"), str)
            ):
                raise ValueError("invalid Rust result finding")
        if aggregate_status(findings) != status:
            raise ValueError("invalid Rust result aggregate status")
        return payload
    except (OSError, subprocess.SubprocessError, json.JSONDecodeError, ValueError, UnicodeError):
        return make_result(
            expected_command,
            repo_root,
            f"Rust {expected_command} result was unavailable or invalid.",
            [
                finding(
                    "fail",
                    f"{expected_command}.rust-bridge",
                    f"Rust {expected_command} failed closed because its result was unavailable or invalid.",
                )
            ],
        )


