    findings.append(
        finding(
            "pass" if running else "fail",
            "native-api.running",
            "turbovas-api container is running." if running else "turbovas-api container is not running; run just runtime-app-up.",
            details={"service": "turbovas-api", "logs_tail": [] if running else service_log_tail(repo_root, "turbovas-api")},
        )
    )
    if not running:
        result = make_result("runtime-native-api-smoke", repo_root, "Native API smoke could not run because turbovas-api is not running.", findings, [str(artifact_dir)])
        result["details"] = details
        write_json_artifact(artifact_dir, "native-api-smoke.json", result)
