def run_app_oneoff(repo_root: Path, service: str, command: list[str], no_deps: bool = True) -> subprocess.CompletedProcess[str]:
    args = ["--profile", "app", "run", "--rm", "-T"]
    if no_deps:
        args.append("--no-deps")
    args.extend([service, *command])
    return run_command(compose_command(repo_root, *args), repo_root, env=runtime_env(repo_root), timeout=300)


def run_gvmd_oneoff(repo_root: Path, args: list[str], no_deps: bool = True) -> subprocess.CompletedProcess[str]:
    return run_app_oneoff(repo_root, "gvmd", ["gvmd", *gvmd_db_args(repo_root), *args], no_deps=no_deps)


def parse_user_uuid(output: str, username: str) -> str | None:
    for line in output.splitlines():
        if username in line:
            match = UUID_PATTERN.search(line)
            if match:
                return match.group(0).lower()
    if username in output:
        match = UUID_PATTERN.search(output)
        if match:
            return match.group(0).lower()
    return None


def service_log_tail(repo_root: Path, service: str, lines: int = 80) -> list[str]:
    result = run_command(compose_command(repo_root, "logs", "--tail", str(lines), service), repo_root, env=runtime_env(repo_root))
    return result.stdout.splitlines()[-lines:]


