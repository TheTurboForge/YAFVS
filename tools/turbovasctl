def split_gsad_hosts(value: str | None) -> tuple[str, ...]:
    if not value:
        return ()
    hosts: list[str] = []
    seen: set[str] = set()
    for raw_host in value.split(","):
        host = raw_host.strip()
        if not host or host in seen:
            continue
        hosts.append(host)
        seen.add(host)
    return tuple(hosts)


