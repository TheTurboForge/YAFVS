        findings.append(finding("fail", "runtime-rbac.artifact-dir", f"Runtime RBAC smoke artifact directory is not usable: {error}", str(artifact_dir)))

    if aggregate_status(findings) == "fail":
        return make_result("runtime-rbac-smoke", repo_root, "Runtime RBAC smoke stopped at prerequisites.", findings, [str(artifact_dir)])

    args = [
        str(python),
        str(probe),
        "--socket",
        str(gvmd_socket_path(repo_root)),
        "--username",
        DEV_ADMIN_USER,
        "--password-file",
        str(secret_path),
        "--artifact-dir",
        str(artifact_dir),
    ]
    result = run_command(args, repo_root, env=build_env(repo_root), timeout=180)
    try:
        parsed = json.loads(result.stdout)
    except json.JSONDecodeError:
        parsed = None
    helper_status = parsed.get("status") if parsed else None
    finding_status = helper_status if result.returncode == 0 and helper_status in {"pass", "warn"} else "fail"
    password = secret_path.read_text(encoding="utf-8").strip() if secret_path.is_file() else ""
    findings.append(
        finding(
            finding_status,
            "runtime-rbac.operator-account",
            parsed.get("summary", f"Runtime RBAC smoke helper exit code {result.returncode}.") if parsed else f"Runtime RBAC smoke helper exit code {result.returncode}.",
            details={"helper": parsed, "output_tail": output_tail(result.stdout, 120, [password])},
        )
    )
    artifacts = list(parsed.get("artifacts", [])) if parsed and isinstance(parsed.get("artifacts"), list) else [str(artifact_dir)]
    summary = parsed.get("summary") if parsed else f"Runtime RBAC smoke completed with exit code {result.returncode}."
    return make_result("runtime-rbac-smoke", repo_root, summary, findings, artifacts)

