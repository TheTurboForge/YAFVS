    if service:
        patterns.extend(LOG_REVIEW_SERVICE_PATTERNS.get(service, ()))
    for status, key, pattern, message in patterns:
        regex = re.compile(pattern, re.IGNORECASE)
        matched = [line for line in material if regex.search(line)]
        if matched:
