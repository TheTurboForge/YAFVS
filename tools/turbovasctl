def command_runtime_feed_import_init(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    feed_state = command_feed_state(repo_root)
    findings.extend(feed_state["findings"])
    runtime_findings = [item for item in feed_state["findings"] if item["check"].startswith("feed.runtime.")]
    runtime_class_findings = [item for item in runtime_findings if item["check"] != "feed.runtime.root"]
    if any(item["status"] != "pass" for item in runtime_class_findings):
        findings.append(finding("fail", "feed.runtime.ready", "Runtime feed copy is incomplete; refusing local feed import."))
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped because runtime feed classes are missing.", findings, [str(feed_runtime_root(repo_root))])
    findings.append(finding("pass", "feed.runtime.ready", "Runtime feed copy has all required feed classes."))

    findings.extend(ensure_runtime_feed_mappings(repo_root))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped while mapping runtime feed paths.", findings, [str(feed_runtime_root(repo_root))])

    pre_manager_stop = run_command(compose_command(repo_root, "--profile", "app", "stop", "gvmd"), repo_root, env=runtime_env(repo_root), timeout=120)
    findings.append(finding("pass" if pre_manager_stop.returncode == 0 else "fail", "gvmd.stop-for-manager-init", f"Stop gvmd service before manager one-shot initialization exit code {pre_manager_stop.returncode}.", details={"output_tail": output_tail(pre_manager_stop.stdout, 80)}))
    if pre_manager_stop.returncode != 0:
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped because gvmd could not be stopped before manager initialization.", findings, [str(runtime_dir(repo_root))])

    manager = command_runtime_manager_init(repo_root)
    findings.append(finding(manager["status"], "runtime.manager-init", manager["summary"], details={"status": manager["status"]}))
    scanner_redis = command_runtime_scanner_redis_init(repo_root, probe_openvas=False)
    findings.append(finding(scanner_redis["status"], "runtime.scanner-redis", scanner_redis["summary"], details={"status": scanner_redis["status"]}))
    keyring = command_runtime_feed_keyring_init(repo_root)
    findings.append(finding(keyring["status"], "runtime.feed-keyring", keyring["summary"], details={"status": keyring["status"]}))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped at runtime prerequisites.", findings, [str(runtime_dir(repo_root))])

    scanner_services = ("ospd-openvas", "notus-scanner")
    scanner_up = run_command(compose_command(repo_root, "--profile", "app", "up", "-d", "--no-deps", "--build", *scanner_services), repo_root, env=runtime_env(repo_root), timeout=900)
    findings.append(finding("pass" if scanner_up.returncode == 0 else "fail", "runtime.scanner-services-up", f"Start scanner-side app services for feed import exit code {scanner_up.returncode}.", details={"services": list(scanner_services), "output_tail": output_tail(scanner_up.stdout, 120)}))
    for service in scanner_services:
        running = container_running(repo_root, service)
        findings.append(finding("pass" if running else "fail", "runtime.scanner-service.running", f"{service} container is {'running' if running else 'not running'}.", details={"service": service, "logs_tail": [] if running else service_log_tail(repo_root, service)}))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped because scanner-side services are not ready.", findings, [str(runtime_dir(repo_root))])

    ospd_ready = wait_for_socket(ospd_socket_path(repo_root), timeout_seconds=30)
    findings.append(finding("pass" if ospd_ready else "fail", "ospd.socket", "ospd-openvas socket is ready for VT metadata rebuild." if ospd_ready else "ospd-openvas socket is not ready; cannot rebuild VT metadata.", str(ospd_socket_path(repo_root))))
    if not ospd_ready:
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped because OSPD is not ready.", findings, [str(runtime_dir(repo_root))])

    vt_status, vt_lines = wait_for_ospd_vt_load(repo_root, timeout_seconds=300)
    findings.append(
        finding(
            "pass" if vt_status == "pass" else "fail",
            "ospd.vt-load",
            "ospd-openvas finished loading VTs before manager rebuild." if vt_status == "pass" else "ospd-openvas did not finish loading VTs before manager rebuild.",
            details={"status": vt_status, "log_lines": vt_lines[-20:]},
        )
    )
    if vt_status != "pass":
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped because OSPD did not finish loading VTs.", findings, [str(runtime_dir(repo_root))])

    gvm_cli = gvm_cli_path(repo_root)
    findings.append(finding("pass" if gvm_cli.is_file() else "fail", "gvm-tools.cli", "gvm-cli is available for direct OSP readiness probes." if gvm_cli.is_file() else "gvm-cli is missing; run just build-python or just build-baseline.", str(gvm_cli.relative_to(repo_root)) if gvm_cli.exists() else str(gvm_cli)))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped because the OSP readiness probe is unavailable.", findings, [str(runtime_dir(repo_root))])

    ospd_feed_version, ospd_probe_tail = wait_for_ospd_vts_version(repo_root, timeout_seconds=180)
    findings.append(
        finding(
            "pass" if ospd_feed_version else "fail",
            "ospd.vts-version",
            f"ospd-openvas reports VT feed version {ospd_feed_version}." if ospd_feed_version else "ospd-openvas did not report a VT feed version before the readiness timeout.",
            details={"feed_version": ospd_feed_version, "output_tail": ospd_probe_tail},
        )
    )

    db_version_result = psql(repo_root, nvts_feed_version_query())
    db_feed_version = psql_value(db_version_result) if db_version_result.returncode == 0 else ""
    findings.append(
        finding(
            "pass" if db_version_result.returncode == 0 else "warn",
            "gvmd.nvts-feed-version",
            f"gvmd NVT database feed version is {db_feed_version or 'empty'}." if db_version_result.returncode == 0 else f"gvmd NVT database feed version query exit code {db_version_result.returncode}.",
            details={"feed_version": db_feed_version, "output_tail": output_tail(db_version_result.stdout, 40)},
        )
    )
    if not ospd_feed_version:
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped because OSPD did not report a VT feed version.", findings, [str(runtime_dir(repo_root))])

    stop_gvmd = run_command(compose_command(repo_root, "--profile", "app", "stop", "gvmd"), repo_root, env=runtime_env(repo_root), timeout=120)
    findings.append(finding("pass" if stop_gvmd.returncode == 0 else "fail", "gvmd.stop-for-import", f"Stop gvmd service before one-shot feed import exit code {stop_gvmd.returncode}.", details={"output_tail": output_tail(stop_gvmd.stdout, 80)}))
    if stop_gvmd.returncode != 0:
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped because gvmd could not be stopped cleanly.", findings, [str(runtime_dir(repo_root))])

    import_steps: list[tuple[str, list[str]]] = []
    if db_feed_version == ospd_feed_version:
        findings.append(finding("pass", "gvmd.rebuild-nvt", f"NVT database already matches OSPD feed version {ospd_feed_version}; skipped full NVT rebuild."))
    else:
        import_steps.append(("gvmd.rebuild-nvt", ["--rebuild", f"--osp-vt-update=/runtime/run/ospd/{ospd_socket_path(repo_root).name}"]))
    import_steps.extend([
        ("gvmd.rebuild-gvmd-data", ["--rebuild-gvmd-data=all"]),
        ("gvmd.rebuild-scap", ["--rebuild-scap"]),
    ])
    import_failed = False
    for check, args in import_steps:
        result = run_gvmd_runtime_oneoff(repo_root, args, no_deps=False, timeout=GVMD_IMPORT_TIMEOUT_SECONDS)
        findings.append(finding("pass" if result.returncode == 0 else "fail", check, f"gvmd {' '.join(args)} exit code {result.returncode}.", details={"output_tail": output_tail(result.stdout, 120)}))
        if result.returncode != 0:
            import_failed = True
            break

    findings.extend(compose_app_services_up_with_retry(repo_root, "runtime.app-restart", "Restart app services after feed import"))
    for service in APP_SERVICES:
        running = container_running(repo_root, service)
        findings.append(finding("pass" if running else "fail", "runtime.app.running", f"{service} container is {'running' if running else 'not running'} after feed import.", details={"service": service, "logs_tail": [] if running else service_log_tail(repo_root, service)}))
    if import_failed or restart.returncode != 0:
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped because a rebuild/import step failed.", findings, [str(runtime_dir(repo_root))])

    gvmd_ready = wait_for_socket(gvmd_socket_path(repo_root), timeout_seconds=180)
    findings.append(finding("pass" if gvmd_ready else "fail", "gvmd.socket-wait", "gvmd socket became ready after feed import restart." if gvmd_ready else "gvmd socket did not become ready after feed import restart.", str(gvmd_socket_path(repo_root))))

    native_ready = container_running(repo_root, "turbovas-api")
    findings.append(finding("pass" if native_ready else "fail", "native-api.container", "turbovas-api is running for native feed object verification." if native_ready else "turbovas-api is not running; native feed object verification cannot start."))
    if native_ready:
        findings.extend(native_required_feed_object_findings(repo_root))
    summary = "Runtime feed import and native verification completed."
    if aggregate_status(findings) == "fail":
        summary = "Feed import completed but native feed object verification failed."
    return make_result("runtime-feed-import-init", repo_root, summary, findings, [str(runtime_dir(repo_root)), str(feed_runtime_root(repo_root))])


def command_runtime_scanner_capability_check(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    service = "ospd-openvas"
    running = container_running(repo_root, service)
    findings.append(finding("pass" if running else "fail", "ospd.running", "ospd-openvas container is running." if running else "ospd-openvas container is not running; run just runtime-app-up.", details={"service": service}))
    if not running:
        return make_result("runtime-scanner-capability-check", repo_root, "Scanner capability check stopped because ospd-openvas is not running.", findings)

    pid_probe = exec_in_service(repo_root, service, ["sh", "-lc", "ps -eo pid,comm,args | awk '$2 == \"ospd-openvas\" && /--foreground/ { print $1; exit }'"])
    scanner_pid = pid_probe.stdout.strip().splitlines()[0] if pid_probe.stdout.strip() else ""
    findings.append(finding("pass" if pid_probe.returncode == 0 and scanner_pid else "fail", "ospd.pid", f"ospd-openvas scanner process PID is {scanner_pid}." if scanner_pid else "ospd-openvas scanner process PID could not be found.", details={"output_tail": output_tail(pid_probe.stdout, 20)}))
    status_path = f"/proc/{scanner_pid}/status" if scanner_pid else "/proc/1/status"
    status = exec_in_service(repo_root, service, ["sh", "-lc", f"sed -n 's/^Uid:/Uid:/p; s/^Gid:/Gid:/p; s/^CapInh:/CapInh:/p; s/^CapPrm:/CapPrm:/p; s/^CapEff:/CapEff:/p; s/^CapBnd:/CapBnd:/p; s/^CapAmb:/CapAmb:/p' {shlex.quote(status_path)}"])
    values = parse_proc_status(status.stdout)
    expected_uid = runtime_env(repo_root)["TURBOVAS_UID"]
    expected_gid = runtime_env(repo_root)["TURBOVAS_GID"]
    actual_uid = first_proc_status_id(values.get("Uid"))
    actual_gid = first_proc_status_id(values.get("Gid"))
    findings.append(finding("pass" if status.returncode == 0 else "fail", "ospd.proc-status", f"{status_path} read exit code {status.returncode}.", details={"output_tail": output_tail(status.stdout, 40)}))
    findings.append(finding("pass" if actual_uid == expected_uid else "fail", "ospd.uid", f"ospd-openvas scanner process UID is {actual_uid}; expected {expected_uid}.", details={"uid_line": values.get("Uid"), "expected": expected_uid, "pid": scanner_pid}))
    findings.append(finding("pass" if actual_gid == expected_gid else "fail", "ospd.gid", f"ospd-openvas scanner process GID is {actual_gid}; expected {expected_gid}.", details={"gid_line": values.get("Gid"), "expected": expected_gid, "pid": scanner_pid}))

    hostname_probe = exec_in_service(repo_root, service, ["sh", "-lc", "hostname; getent hosts $(hostname)"])
    hostname_lines = hostname_probe.stdout.strip().splitlines()
    scanner_hostname = hostname_lines[0].strip() if hostname_lines else ""
    hostname_ok = hostname_probe.returncode == 0 and scanner_hostname == OSPD_STABLE_HOSTNAME and not hostname_looks_like_docker_short_id(scanner_hostname)
    findings.append(
        finding(
            "pass" if hostname_ok else "fail",
            "ospd.hostname",
            f"ospd-openvas hostname is the stable value {OSPD_STABLE_HOSTNAME}." if hostname_ok else f"ospd-openvas hostname is {scanner_hostname or 'unreadable'}; expected {OSPD_STABLE_HOSTNAME}.",
            details={"hostname": scanner_hostname, "expected": OSPD_STABLE_HOSTNAME, "output_tail": output_tail(hostname_probe.stdout, 20)},
        )
    )

    for cap_field in ("CapPrm", "CapEff", "CapAmb"):
        missing = missing_required_caps(values.get(cap_field))
        findings.append(
            finding(
                "pass" if not missing else "fail",
                f"ospd.{cap_field.lower()}",
                f"{cap_field} includes NET_RAW and NET_ADMIN." if not missing else f"{cap_field} is missing required capabilities: {', '.join(missing)}.",
                details={"value": values.get(cap_field), "missing": missing},
            )
        )

    raw_probe = exec_in_service(repo_root, service, ospd_setpriv_raw_socket_probe_command(repo_root))
    findings.append(finding("pass" if raw_probe.returncode == 0 and "raw-ok" in raw_probe.stdout else "fail", "ospd.raw-socket-probe", f"Service-user raw ICMP socket probe exit code {raw_probe.returncode}.", details={"output_tail": output_tail(raw_probe.stdout, 40)}))
    return make_result("runtime-scanner-capability-check", repo_root, "Scanner capability check completed.", findings)


def command_runtime_scanner_process_check(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    service = "ospd-openvas"
    running = container_running(repo_root, service)
    findings.append(finding("pass" if running else "fail", "ospd.running", "ospd-openvas container is running." if running else "ospd-openvas container is not running; run just runtime-app-up.", details={"service": service}))
    if not running:
        return make_result("runtime-scanner-process-check", repo_root, "Scanner process check stopped because ospd-openvas is not running.", findings)

    process_probe = exec_in_service(repo_root, service, ["ps", "-eo", "pid,ppid,stat,comm,args"])
    summary = summarize_scanner_processes(process_probe.stdout)
    zombie_count = summary["zombie_count"]
    active_count = summary["active_scanner_child_count"]
    if process_probe.returncode != 0:
        status = "fail"
        message = f"Scanner process table probe exit code {process_probe.returncode}."
    elif zombie_count and active_count:
        status = "warn"
        message = f"ospd-openvas has {zombie_count} zombie child process(es) while scanner children are active."
    elif zombie_count:
        status = "fail"
        message = f"ospd-openvas has {zombie_count} zombie child process(es) with no active scanner children."
    else:
        status = "pass"
        message = "ospd-openvas has no zombie child processes."
    findings.append(
        finding(
            status,
            "ospd.process-zombies",
            message,
            details={"process_summary": summary, "output_tail": output_tail(process_probe.stdout, 80)},
        )
    )
    return make_result("runtime-scanner-process-check", repo_root, "Scanner process check completed.", findings)


def command_runtime_nmap_capability_check(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    service = "ospd-openvas"
    running = container_running(repo_root, service)
    findings.append(finding("pass" if running else "fail", "ospd.running", "ospd-openvas container is running." if running else "ospd-openvas container is not running; run just runtime-app-up.", details={"service": service}))
    if not running:
        return make_result("runtime-nmap-capability-check", repo_root, "Nmap capability check stopped because ospd-openvas is not running.", findings)

    nmap_path = exec_in_service(repo_root, service, ["sh", "-lc", "command -v nmap"])
    path = nmap_path.stdout.strip().splitlines()[-1] if nmap_path.stdout.strip() else ""
    findings.append(finding("pass" if nmap_path.returncode == 0 and path else "fail", "nmap.path", f"nmap path probe exit code {nmap_path.returncode}.", details={"path": path, "output_tail": output_tail(nmap_path.stdout, 20)}))

    getcap = exec_in_service(repo_root, service, ["sh", "-lc", "command -v getcap >/dev/null 2>&1 && getcap /usr/bin/nmap || true"])
    caps_output = getcap.stdout.strip()
    file_caps_ok = "cap_net_raw" in caps_output and "cap_net_admin" in caps_output
    findings.append(
        finding(
            "pass" if getcap.returncode == 0 and file_caps_ok else "fail",
            "nmap.file-capabilities",
            "nmap has file capabilities for NET_RAW and NET_ADMIN." if file_caps_ok else "nmap is missing expected NET_RAW/NET_ADMIN file capabilities.",
            details={"output_tail": output_tail(getcap.stdout, 40)},
        )
    )

    env_probe = exec_in_service(repo_root, service, ["sh", "-lc", f"printf '%s' \"${{{NMAP_PRIVILEGED_ENV}:-}}\""])
    env_ok = env_probe.returncode == 0 and env_probe.stdout.strip() == "1"
    findings.append(
        finding(
            "pass" if env_ok else "fail",
            "nmap.env",
            f"{NMAP_PRIVILEGED_ENV}=1 is present in the scanner service environment." if env_ok else f"{NMAP_PRIVILEGED_ENV}=1 is missing from the scanner service environment.",
            details={"output_tail": output_tail(env_probe.stdout, 20)},
        )
    )

    for check, command in ospd_setpriv_nmap_probe_commands(repo_root):
        probe = exec_in_service(repo_root, service, command)
        privilege_warning = nmap_privilege_warning_present(probe.stdout)
        findings.append(
            finding(
                "pass" if probe.returncode == 0 and not privilege_warning else "fail",
                check,
                f"{check} probe exit code {probe.returncode}." if not privilege_warning else f"{check} probe still reports that root privileges are required.",
                details={"privilege_warning": privilege_warning, "output_tail": output_tail(probe.stdout, 80)},
            )
        )

    return make_result("runtime-nmap-capability-check", repo_root, "Nmap capability check completed.", findings)


def command_runtime_full_test_scan(repo_root: Path, action: str, confirm_authorized_lan: bool = False) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    secret_path = runtime_secret_path(repo_root, DEV_ADMIN_SECRET)
    python = venv_python(repo_root, "python-gvm")
    probe = runtime_full_test_scan_probe_path(repo_root)
    artifact_dir = full_test_scan_artifact_dir(repo_root)
    findings.append(finding("pass" if gvmd_socket_path(repo_root).is_socket() else "fail", "gvmd.socket", "gvmd socket is ready." if gvmd_socket_path(repo_root).is_socket() else "gvmd socket is not ready.", str(gvmd_socket_path(repo_root))))
    findings.append(finding("pass" if secret_path.is_file() else "fail", "runtime.admin-secret", "Development admin secret exists." if secret_path.is_file() else "Development admin secret is missing.", str(secret_path)))
    findings.append(finding("pass" if python.is_file() else "fail", "python-gvm.venv", "python-gvm runtime venv exists." if python.is_file() else "python-gvm venv is missing.", str(python.relative_to(repo_root)) if python.exists() else str(python)))
    findings.append(finding("pass" if probe.is_file() else "fail", "full-test-scan.probe", "Full test scan helper exists." if probe.is_file() else "Full test scan helper is missing.", str(probe.relative_to(repo_root)) if probe.exists() else str(probe)))
    try:
        artifact_dir.mkdir(parents=True, exist_ok=True)
        findings.append(finding("pass", "full-test-scan.artifact-dir", "Full test scan artifact directory is ready.", str(artifact_dir)))
    except OSError as error:
        findings.append(finding("fail", "full-test-scan.artifact-dir", f"Full test scan artifact directory is not usable: {error}", str(artifact_dir)))

    if action in {"preflight", "start"}:
        capability = command_runtime_scanner_capability_check(repo_root)
        findings.append(finding(capability["status"], "ospd.capability-check", capability["summary"], details={"status": capability["status"], "findings": capability["findings"]}))
        process_check = command_runtime_scanner_process_check(repo_root)
        findings.append(finding(process_check["status"], "ospd.process-check", process_check["summary"], details={"status": process_check["status"], "findings": process_check["findings"]}))
        nmap_capability = command_runtime_nmap_capability_check(repo_root)
        findings.append(finding(nmap_capability["status"], "nmap.capability-check", nmap_capability["summary"], details={"status": nmap_capability["status"], "findings": nmap_capability["findings"]}))

    command_name = f"runtime-full-test-scan-{action}"
    if aggregate_status(findings) == "fail":
        return make_result(command_name, repo_root, "Full test scan command stopped at prerequisites.", findings, [str(artifact_dir)])

    args = [
        str(python),
        str(probe),
        action,
        "--socket",
        str(gvmd_socket_path(repo_root)),
        "--username",
        DEV_ADMIN_USER,
        "--password-file",
        str(secret_path),
        "--artifact-dir",
        str(artifact_dir),
        "--ospd-log-file",
        str(runtime_path(repo_root, "logs", "ospd", "ospd-openvas.log")),
    ]
    if confirm_authorized_lan:
        args.append("--confirm-authorized-lan")
    result = run_command(args, repo_root, env=build_env(repo_root), timeout=120)
    try:
        parsed = json.loads(result.stdout)
    except json.JSONDecodeError:
        parsed = None
    helper_status = parsed.get("status") if parsed else None
    finding_status = helper_status if result.returncode == 0 and helper_status in {"pass", "warn"} else "fail"
    password = secret_path.read_text(encoding="utf-8").strip() if secret_path.is_file() else ""
    findings.append(
        finding(
            finding_status,
            f"full-test-scan.{action}",
            parsed.get("summary", f"Full test scan helper exit code {result.returncode}.") if parsed else f"Full test scan helper exit code {result.returncode}.",
            details={"helper": parsed, "output_tail": output_tail(result.stdout, 120, [password])},
        )
    )
    artifacts = list(parsed.get("artifacts", [])) if parsed and isinstance(parsed.get("artifacts"), list) else [str(artifact_dir)]
    summary = parsed.get("summary") if parsed else f"Full test scan {action} command completed with exit code {result.returncode}."
    return make_result(command_name, repo_root, summary, findings, artifacts)


