        ),
        finding(
            "fail" if row_drift else "pass",
            "native-api-migration-matrix.coverage",
            "Native API migration matrix rows are present in both endpoint inventory and OpenAPI."
            if not row_drift
            else "Native API migration matrix has endpoint inventory/OpenAPI row gaps.",
            details={
                "rows_missing_openapi_count": summary["rows_missing_openapi_count"],
