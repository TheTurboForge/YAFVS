def command_native_api_client_contract(repo_root: Path, status_only: bool = False) -> dict[str, Any]:
    contract = native_api_openapi_contract_summary(repo_root)
    auth_contract = contract.get("auth_contract", {}) if isinstance(contract.get("auth_contract"), dict) else {}
    write_control_contract = contract.get("write_control_contract", {}) if isinstance(contract.get("write_control_contract"), dict) else {}
    tooling_summary = summarize_native_tooling(native_tooling_inventory(repo_root), repo_root)
    annotate_native_tooling_direct_api(tooling_summary, repo_root)
    direct_runtime_contract = tooling_summary.get("direct_api_contract", {}) if isinstance(tooling_summary.get("direct_api_contract"), dict) else {}
    segment_guard = direct_runtime_contract.get("segment_guard", {}) if isinstance(direct_runtime_contract.get("segment_guard"), dict) else {}
    body_limit = direct_runtime_contract.get("body_limit", {}) if isinstance(direct_runtime_contract.get("body_limit"), dict) else {}
    operations = openapi_contract_operations(repo_root)
    direct_operations = [
        operation
        for operation in operations
        if "x-yafvs-direct" in set(operation.get("x_yafvs_fields", []))
    ]
    direct_read_operations = [operation for operation in direct_operations if operation.get("method") == "get"]
    non_get_direct = [openapi_operation_label(operation) for operation in direct_operations if operation.get("method") != "get"]
    direct_count = len(direct_operations)
    direct_read_count = len(direct_read_operations)
    openapi_status = contract_drift_status(contract.get("alignment_status"))
    auth_status = contract_drift_status(auth_contract.get("alignment_status"))
    write_control_status = contract_drift_status(write_control_contract.get("alignment_status"))
    direct_runtime_status = contract_drift_status(direct_runtime_contract.get("alignment_status"))
    direct_status = "pass" if direct_count > 0 else "fail"
    details = {
        "openapi_version": openapi_info_version(repo_root),
        "operation_count": contract.get("operation_count", 0),
        "direct_operation_count": direct_count,
        "direct_read_operation_count": direct_read_count,
        "non_get_direct_operations": non_get_direct,
        "write_control_operation_count": len(write_control_contract.get("write_control_operations", [])),
        "direct_write_control_operation_count": len(write_control_contract.get("direct_write_control_operations", [])),
        "servers": auth_contract.get("servers", []),
        "security_requirements": auth_contract.get("security_requirements", []),
        "security_schemes": auth_contract.get("security_schemes", {}),
        "openapi_alignment_status": contract.get("alignment_status", "unknown"),
        "auth_contract_alignment_status": auth_contract.get("alignment_status", "unknown"),
        "write_control_alignment_status": write_control_contract.get("alignment_status", "unknown"),
        "direct_runtime_alignment_status": direct_runtime_contract.get("alignment_status", "unknown"),
        "direct_segment_guard_alignment_status": segment_guard.get("alignment_status", "unknown"),
        "direct_segment_guard_missing_property_count": len(segment_guard.get("missing_guard_properties", [])),
        "direct_body_limit_alignment_status": body_limit.get("alignment_status", "unknown"),
        "direct_body_limit_missing_property_count": len(body_limit.get("missing_body_limit_properties", [])),
        "missing_operation_id_count": len(contract.get("missing_operation_ids", [])),
        "duplicate_operation_id_count": len(contract.get("duplicate_operation_ids", [])),
        "operation_request_body_count": len(contract.get("operations_with_request_bodies", [])),
        "get_request_body_count": len(contract.get("get_operations_with_request_bodies", [])),
        "operations_missing_error_response_count": len(contract.get("operations_missing_error_responses", [])),
        "missing_error_schema_field_count": len(contract.get("missing_error_schema_fields", [])),
        "missing_write_control_metadata_count": len(write_control_contract.get("missing_write_control_metadata", [])),
        "invalid_write_control_metadata_count": len(write_control_contract.get("invalid_write_control_metadata", [])),
        "invalid_write_control_path_parameter_count": len(write_control_contract.get("invalid_write_control_path_parameters", [])),
        "missing_server_count": len(auth_contract.get("missing_servers", [])),
        "missing_security_scheme_count": len(auth_contract.get("missing_security_schemes", [])),
    }
    findings = [
        finding(
            openapi_status,
            "native-api-client-contract.openapi",
            "OpenAPI operation IDs, Error responses, and collection contracts are generated-client ready."
            if openapi_status == "pass"
            else "OpenAPI operation IDs, Error responses, or collection contracts need attention before generated-client use.",
            details={
                "operation_count": details["operation_count"],
                "missing_operation_id_count": details["missing_operation_id_count"],
                "duplicate_operation_id_count": details["duplicate_operation_id_count"],
                "operations_missing_error_response_count": details["operations_missing_error_response_count"],
                "missing_error_schema_field_count": details["missing_error_schema_field_count"],
            },
        ),
        finding(
            auth_status,
