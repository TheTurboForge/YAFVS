        return finding("fail", "postgres.pg-gvm", f"pg-gvm extension status query exit code {result.returncode}.", details={"output_tail": result.stdout.splitlines()[-40:]})
    version = psql_value(result)
    return finding("pass" if version and version != "missing" else "warn", "postgres.pg-gvm", f"pg-gvm extension is {version}.", details={"version": version})


