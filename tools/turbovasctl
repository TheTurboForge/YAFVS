    if aggregate_status(findings) == "fail":
        return make_result("runtime-credential-smoke", repo_root, "Runtime credential smoke stopped at prerequisites.", findings, [str(artifact_dir)])

    credential_name = "turbovas-credential-smoke-" + secrets.token_hex(4)
