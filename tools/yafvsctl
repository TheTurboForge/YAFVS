def wait_for_runtime_gmp_smoke(repo_root: Path, *, attempts: int = 3, interval_seconds: int = 5) -> tuple[dict[str, Any], int]:
    last_result: dict[str, Any] | None = None
    for attempt in range(1, attempts + 1):
        last_result = command_runtime_gmp_smoke(repo_root)
        if last_result.get("status") == "pass":
            return last_result, attempt
        if attempt < attempts:
            time.sleep(interval_seconds)
    return last_result or make_result("runtime-gmp-smoke", repo_root, "Runtime GMP smoke did not run.", []), attempts


def wait_for_runtime_native_api_smoke(repo_root: Path, *, attempts: int = 2, interval_seconds: int = 3) -> tuple[dict[str, Any], int]:
    last_result: dict[str, Any] | None = None
    for attempt in range(1, attempts + 1):
        last_result = command_runtime_native_api_smoke(repo_root, status_only=True)
        if last_result.get("status") in {"pass", "warn"} and not any(
            item.get("status") == "fail" for item in last_result.get("findings", [])
        ):
            return last_result, attempt
        if attempt < attempts:
            time.sleep(interval_seconds)
    return last_result or make_result("runtime-native-api-smoke", repo_root, "Runtime native API smoke did not run.", []), attempts


def browser_native_api_readiness_finding(repo_root: Path, *, check: str) -> dict[str, Any]:
    native_result, attempts = wait_for_runtime_native_api_smoke(repo_root)
    failed_checks = [item for item in native_result.get("findings", []) if item.get("status") == "fail"]
    ready = native_result.get("status") in {"pass", "warn"} and not failed_checks
    status = "pass" if ready else "fail"
    return finding(
        status,
        check,
        "Native API readiness was verified before browser validation." if status == "pass" else "Native API readiness did not become available before browser validation.",
        details={
            "attempts": attempts,
            "status": native_result.get("status"),
            "summary": native_result.get("summary"),
            "failed_checks": failed_checks,
        },
    )


