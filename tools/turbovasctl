    findings.append(finding("pass" if probe.is_file() else "fail", "credential-smoke.probe", "Credential browser smoke helper exists." if probe.is_file() else "Credential browser smoke helper is missing.", str(probe.relative_to(repo_root)) if probe.exists() else str(probe)))
    findings.append(finding("pass" if shutil.which("node") else "fail", "node.available", "node is available for credential browser smoke." if shutil.which("node") else "node is not available on PATH."))
    try:
        artifact_dir.mkdir(parents=True, exist_ok=True)
        probe_file = artifact_dir / ".turbovas-write-test"
        probe_file.write_text("ok\n", encoding="utf-8")
        probe_file.unlink()
        findings.append(finding("pass", "credential-smoke.artifact-dir", "Credential smoke artifact directory is ready.", str(artifact_dir)))
    except OSError as error:
