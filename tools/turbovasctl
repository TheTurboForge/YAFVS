def cap_hex_has(mask_hex: str | None, cap_bit: int) -> bool:
    if not mask_hex:
        return False
    try:
        mask = int(mask_hex, 16)
    except ValueError:
        return False
    return bool(mask & (1 << cap_bit))


def missing_required_caps(mask_hex: str | None) -> list[str]:
    return [name for name, bit in OSPD_REQUIRED_CAPS.items() if not cap_hex_has(mask_hex, bit)]


