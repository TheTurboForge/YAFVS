def stage_gsa_static(repo_root: Path) -> list[dict[str, Any]]:
    findings: list[dict[str, Any]] = []
    source = gsa_build_dir(repo_root)
    destination = gsad_static_dir(repo_root)
    index = source / "index.html"
    findings.append(finding("pass" if index.is_file() else "fail", "gsa.build.index", "GSA production build index.html exists." if index.is_file() else "GSA production build is missing index.html; run just build-ui.", str(index)))
    if aggregate_status(findings) == "fail":
        return findings
    if destination.exists():
        shutil.rmtree(destination)
    destination.parent.mkdir(parents=True, exist_ok=True)
    shutil.copytree(source, destination)
    config_js = destination / "config.js"
    fallback_api_server = f"{gsad_host(repo_root)}:{GSAD_PORT}"
    config_js.write_text(
        "config = {\n"
        "  apiProtocol: (window.location.protocol || 'https:').replace(':', ''),\n"
        f"  apiServer: window.location.host || '{fallback_api_server}',\n"
        "};\n",
        encoding="utf-8",
    )
    findings.append(finding("pass", "gsa.static-stage", "GSA production build is staged for gsad.", str(destination)))
    findings.append(finding("pass", "gsa.config-js", "GSA config.js uses the browser host with a fallback gsad endpoint.", str(config_js), {"api_protocol": "browser", "api_server_fallback": fallback_api_server, "hosts": list(gsad_hosts(repo_root))}))
    return findings


def first_gsa_asset_rel(index_html: str) -> str | None:
    match = re.search(r"""(?:src|href)=["']/(assets/[^"']+)["']""", index_html)
    return match.group(1) if match else None


def path_latest_mtime(path: Path, *, skip_dirs: frozenset[str] = frozenset()) -> float | None:
    try:
        if path.is_file():
            return path.stat().st_mtime
        if not path.is_dir():
            return None
    except OSError:
        return None
    latest: float | None = None
    for root, dirs, files in os.walk(path):
        dirs[:] = [dirname for dirname in dirs if dirname not in skip_dirs]
        root_path = Path(root)
        for filename in files:
            try:
                mtime = (root_path / filename).stat().st_mtime
            except OSError:
                continue
            latest = mtime if latest is None else max(latest, mtime)
    return latest


def paths_latest_mtime(repo_root: Path, rel_paths: Iterable[str], *, skip_dirs: frozenset[str] = frozenset()) -> tuple[float | None, str | None]:
    latest: float | None = None
    latest_path: str | None = None
    for rel_path in rel_paths:
        mtime = path_latest_mtime(repo_root / rel_path, skip_dirs=skip_dirs)
        if mtime is None:
            continue
        if latest is None or mtime > latest:
            latest = mtime
            latest_path = rel_path
    return latest, latest_path


def iso_mtime(mtime: float | None) -> str | None:
    return datetime.fromtimestamp(mtime, timezone.utc).replace(microsecond=0).isoformat() if mtime is not None else None


def parse_container_started_at(value: Any) -> float | None:
    if not isinstance(value, str) or not value:
        return None
    try:
        parsed = datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        return None
    return parsed.timestamp()


def qualified_table_name(schema: str, table: str) -> str:
    return f"{sql_identifier(schema)}.{sql_identifier(table)}"


def qualified_table_row_count(repo_root: Path, schema: str, table: str) -> int | None:
    result = psql(repo_root, f"SELECT count(*) FROM {qualified_table_name(schema, table)};")
    if result.returncode != 0:
        return None
    value = psql_value(result)
    try:
        return int(value)
    except ValueError:
        return None


def introspection_table_presence(repo_root: Path) -> tuple[subprocess.CompletedProcess[str], dict[str, bool]]:
    values = ",".join(f"({sql_literal(schema)}, {sql_literal(table)})" for schema, table in DB_INTROSPECT_TABLES)
    query = (
        f"WITH wanted(schema_name, table_name) AS (VALUES {values}) "
        "SELECT wanted.schema_name || '.' || wanted.table_name || '|' || (tables.table_name IS NOT NULL) "
        "FROM wanted LEFT JOIN information_schema.tables tables "
        "ON tables.table_schema = wanted.schema_name AND tables.table_name = wanted.table_name "
        "ORDER BY wanted.schema_name, wanted.table_name;"
    )
    result = psql(repo_root, query)
    rows: dict[str, bool] = {}
    if result.returncode == 0:
        for line in result.stdout.splitlines():
            if "|" not in line:
                continue
            name, value = line.strip().split("|", 1)
            rows[name] = value.strip().lower() in ("t", "true", "1")
    return result, rows


def introspection_column_presence(repo_root: Path) -> tuple[subprocess.CompletedProcess[str], dict[str, bool]]:
    values = ",".join(f"({sql_literal(schema)}, {sql_literal(table)}, {sql_literal(column)})" for schema, table, column in DB_INTROSPECT_COLUMNS)
