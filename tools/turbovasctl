def path_tree_summary(path: Path, recursive: bool = True) -> dict[str, Any]:
    summary: dict[str, Any] = {
        "path": str(path),
        "exists": path.exists(),
        "kind": "missing",
        "file_count": 0,
        "directory_count": 0,
        "byte_count": 0,
        "latest_mtime": None,
    }
    if not path.exists():
        return summary
    latest = 0.0
    if path.is_file():
        stat = path.stat()
        latest = stat.st_mtime
        summary.update({"kind": "file", "file_count": 1, "byte_count": stat.st_size})
    elif path.is_dir():
        summary["kind"] = "directory"
        if recursive:
            for root, dirs, files in os.walk(path):
                summary["directory_count"] += len(dirs)
                for filename in files:
                    candidate = Path(root) / filename
                    try:
                        stat = candidate.stat()
                    except OSError:
                        continue
                    summary["file_count"] += 1
                    summary["byte_count"] += stat.st_size
                    latest = max(latest, stat.st_mtime)
        else:
            try:
                children = list(path.iterdir())
            except OSError:
                children = []
            summary["file_count"] = sum(1 for child in children if child.is_file())
            summary["directory_count"] = sum(1 for child in children if child.is_dir())
            try:
                latest = max((child.stat().st_mtime for child in children), default=path.stat().st_mtime)
            except OSError:
                latest = path.stat().st_mtime
    if latest:
        summary["latest_mtime"] = datetime.fromtimestamp(latest, timezone.utc).replace(microsecond=0).isoformat()
    return summary


def parse_percent(value: str | None) -> float | None:
    if value is None:
        return None
    value = value.strip()
    if not value.endswith("%"):
        return None
    try:
        return float(value[:-1])
    except ValueError:
        return None


def parse_byte_quantity(value: str | None) -> int | None:
    if value is None:
        return None
    value = value.strip()
    match = re.fullmatch(r"([0-9]+(?:\.[0-9]+)?)\s*([A-Za-z]+)", value)
    if not match:
        return None
    number, unit = match.groups()
    multiplier = BYTE_UNITS.get(unit)
    if multiplier is None:
        return None
    return int(float(number) * multiplier)


def parse_byte_pair(value: str | None, first_key: str, second_key: str) -> dict[str, int | None]:
    if value is None or "/" not in value:
        return {first_key: None, second_key: None}
    first, second = value.split("/", 1)
    return {first_key: parse_byte_quantity(first), second_key: parse_byte_quantity(second)}


def normalize_docker_stat(row: dict[str, str]) -> dict[str, Any]:
    normalized: dict[str, Any] = {
        "name": row.get("Name"),
        "id": row.get("ID"),
        "cpu_percent": parse_percent(row.get("CPUPerc")),
        "memory_percent": parse_percent(row.get("MemPerc")),
        "pids": None,
    }
    try:
        normalized["pids"] = int(row.get("PIDs", ""))
    except ValueError:
        normalized["pids"] = None
    normalized.update(parse_byte_pair(row.get("MemUsage"), "memory_usage_bytes", "memory_limit_bytes"))
    normalized.update(parse_byte_pair(row.get("NetIO"), "network_rx_bytes", "network_tx_bytes"))
    normalized.update(parse_byte_pair(row.get("BlockIO"), "block_read_bytes", "block_write_bytes"))
    return normalized


def top_numeric_rows(rows: list[dict[str, Any]], key: str, limit: int = 5) -> list[dict[str, Any]]:
    return sorted(rows, key=lambda row: row.get(key) if row.get(key) is not None else -1, reverse=True)[:limit]


def largest_files(path: Path, limit: int = 10) -> list[dict[str, Any]]:
    if not path.exists():
        return []
    files: list[dict[str, Any]] = []
    if path.is_file():
        try:
            return [{"path": str(path), "byte_count": path.stat().st_size}]
        except OSError:
            return []
    for root, _, filenames in os.walk(path):
        for filename in filenames:
            candidate = Path(root) / filename
            try:
                size = candidate.stat().st_size
            except OSError:
                continue
            try:
                display_path = str(candidate.relative_to(path))
            except ValueError:
                display_path = str(candidate)
            files.append({"path": display_path, "byte_count": size})
    return sorted(files, key=lambda item: item["byte_count"], reverse=True)[:limit]


def parse_relation_size_rows(output: str) -> list[dict[str, Any]]:
    rows: list[dict[str, Any]] = []
    for line in output.splitlines():
        if "|" not in line:
            continue
        name, size = line.strip().split("|", 1)
        try:
            byte_count: int | None = int(size)
        except ValueError:
            byte_count = None
        rows.append({"name": name, "byte_count": byte_count})
    return rows


def parse_pipe_int_rows(output: str) -> dict[str, int]:
    rows: dict[str, int] = {}
    for line in output.splitlines():
        if "|" not in line:
            continue
        name, value = line.strip().split("|", 1)
        try:
            rows[name] = int(value)
        except ValueError:
            continue
    return rows


def summarize_data_outside_db(paths: dict[str, dict[str, Any]]) -> dict[str, Any]:
    summary: dict[str, Any] = {"by_classification": {}, "total_byte_count": 0, "total_file_count": 0}
    for name, path_summary in paths.items():
        classification = path_summary.get("classification", "unknown")
        bucket = summary["by_classification"].setdefault(
            classification,
            {"path_count": 0, "existing_path_count": 0, "file_count": 0, "byte_count": 0, "paths": []},
        )
        bucket["path_count"] += 1
        if path_summary.get("exists"):
            bucket["existing_path_count"] += 1
        bucket["file_count"] += int(path_summary.get("file_count") or 0)
        bucket["byte_count"] += int(path_summary.get("byte_count") or 0)
        bucket["paths"].append(name)
        summary["total_file_count"] += int(path_summary.get("file_count") or 0)
        summary["total_byte_count"] += int(path_summary.get("byte_count") or 0)
    return summary


def database_table_exists(database: dict[str, Any], table: str) -> bool:
    for group in ("core_tables", "scope_tables"):
        table_info = database.get(group, {}).get(table, {})
        if table_info.get("exists") is True:
            return True
    return False


def product_data_audit(details: dict[str, Any]) -> dict[str, Any]:
    database = details.get("database", {})
    paths = details.get("paths", {})
    audit: dict[str, Any] = {
        "db_owned_exports": {},
        "unowned_product_data": [],
    }
    for name, path_summary in paths.items():
        if path_summary.get("classification") != "db_owned_export":
            continue
        required_tables = DATA_STATE_DB_OWNED_EXPORT_SOURCES.get(name, ())
        missing_tables = [table for table in required_tables if not database_table_exists(database, table)]
        export = {
            "exists": bool(path_summary.get("exists")),
            "path": path_summary.get("path"),
            "source_of_record": "gvmd/postgresql",
            "required_tables": list(required_tables),
            "missing_tables": missing_tables,
        }
        audit["db_owned_exports"][name] = export
        if export["exists"] and missing_tables:
            audit["unowned_product_data"].append({"path": name, "missing_tables": missing_tables})
    audit["status"] = "warn" if audit["unowned_product_data"] else "pass"
    return audit


