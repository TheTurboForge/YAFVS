def ensure_runtime_feed_mappings(repo_root: Path) -> list[dict[str, Any]]:
    findings: list[dict[str, Any]] = []
    for mapping, path in runtime_feed_mapping_paths(repo_root):
        desired = mapping.container_target
        try:
            path.parent.mkdir(parents=True, exist_ok=True)
        except OSError as error:
            findings.append(finding("fail", f"feed-map.{mapping.key}", f"Could not create parent directory for {mapping.label}: {error}", str(path)))
            continue

        if path.is_symlink():
            current = os.readlink(path)
            if current == desired:
                findings.append(finding("pass", f"feed-map.{mapping.key}", f"{mapping.label} mapping points at runtime feed copy.", str(path), {"target": current, "expected_target": desired}))
            else:
                try:
                    path.unlink()
                    path.symlink_to(desired)
                    findings.append(finding("pass", f"feed-map.{mapping.key}", f"Stale {mapping.label} symlink retargeted to runtime feed copy.", str(path), {"old_target": current, "target": desired}))
                except OSError as error:
                    findings.append(finding("fail", f"feed-map.{mapping.key}", f"Could not retarget stale {mapping.label} symlink: {error}", str(path), {"target": current, "expected_target": desired}))
            continue

        if not path.exists():
            try:
                path.symlink_to(desired)
                findings.append(finding("pass", f"feed-map.{mapping.key}", f"{mapping.label} mapping created.", str(path), {"target": desired}))
            except OSError as error:
                findings.append(finding("fail", f"feed-map.{mapping.key}", f"Could not create {mapping.label} mapping: {error}", str(path), {"target": desired}))
            continue

        if path.is_dir() and directory_is_empty(path):
            try:
                path.rmdir()
                path.symlink_to(desired)
                findings.append(finding("pass", f"feed-map.{mapping.key}", f"Empty {mapping.label} directory replaced with runtime feed mapping.", str(path), {"target": desired}))
            except OSError as error:
                findings.append(finding("fail", f"feed-map.{mapping.key}", f"Could not replace empty {mapping.label} directory with mapping: {error}", str(path), {"target": desired}))
            continue

        findings.append(
            finding(
                "fail",
                f"feed-map.{mapping.key}",
                f"{mapping.label} path already exists and is not an empty directory or expected symlink; refusing to replace it.",
                str(path),
                {"expected_target": desired},
            )
        )
    return findings


