def native_api_module_ownership_summary(repo_root: Path) -> dict[str, Any]:
    missing_owner_symbols: list[dict[str, str]] = []
    misplaced_symbols: list[dict[str, str]] = []
    checked_symbol_count = 0
    for contract in NATIVE_API_MODULE_OWNERSHIP_CONTRACTS:
        owner = str(contract["owner"])
        owner_path = repo_root / owner
        owner_source = owner_path.read_text(encoding="utf-8", errors="ignore") if owner_path.is_file() else ""
        forbidden_sources = []
        for forbidden in contract.get("forbidden", ()):
            forbidden_path = repo_root / str(forbidden)
            source = forbidden_path.read_text(encoding="utf-8", errors="ignore") if forbidden_path.is_file() else ""
            forbidden_sources.append((str(forbidden), source))
        for symbol in contract.get("symbols", ()):
            checked_symbol_count += 1
            symbol_text = str(symbol)
            if symbol_text not in owner_source:
                missing_owner_symbols.append({"owner": owner, "symbol": symbol_text})
            for forbidden, source in forbidden_sources:
                if symbol_text in source:
                    misplaced_symbols.append({"path": forbidden, "owner": owner, "symbol": symbol_text})
    return {
        "alignment_status": "pass" if not missing_owner_symbols and not misplaced_symbols else "warn",
        "checked_symbol_count": checked_symbol_count,
        "contract_count": len(NATIVE_API_MODULE_OWNERSHIP_CONTRACTS),
        "missing_owner_symbols": missing_owner_symbols,
        "misplaced_symbols": misplaced_symbols,
    }


def native_api_browser_access_from_status(status: str | None) -> str:
    if status == "planned_internal_and_browser_proxied":
        return "planned_browser_proxied"
    if status == "partial_internal_browser_proxy_mismatch":
        return "partial_browser_proxy_mismatch"
    if status in {"implemented_internal_and_browser_proxied", "implemented_internal_browser_proxied_and_scriptable_read"}:
        return "browser_proxied"
    if status == "implemented_internal":
        return "internal_only"
    if status == "implemented_internal_and_scriptable_read":
        return "not_browser_proxied"
    if status == "implemented_direct_write_control":
        return "not_browser_proxied"
    return "unknown"


def compact_license_status_finding(item: dict[str, Any]) -> dict[str, Any]:
    compact = {key: value for key, value in item.items() if key != "details"}
    details = item.get("details")
    if isinstance(details, dict):
        compact_details = dict(details)
        manifest = compact_details.pop("manifest", None)
        if isinstance(manifest, dict):
            compact_details["manifest_entry_count"] = len(manifest)
        compact["details"] = compact_details
    return compact


def native_api_semgrep_audit_status_only_result(result: dict[str, Any]) -> dict[str, Any]:
    compact = dict(result)
    findings = result.get("findings", [])
    non_pass = [compact_doctor_finding(item) for item in findings if item.get("status") != "pass"]
    details = result.get("details", {}) if isinstance(result.get("details"), dict) else {}
    top_findings = details.get("top_findings") if isinstance(details.get("top_findings"), list) else []
    if top_findings:
        for item in non_pass:
            if item.get("check") == "native-api-semgrep-audit.findings":
                item["top_findings"] = top_findings[:5]
