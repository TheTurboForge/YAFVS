def source_gvmd_database_version(repo_root: Path) -> int | None:
    cmake_path = repo_root / "components" / "gvmd" / "CMakeLists.txt"
    try:
        cmake = cmake_path.read_text(encoding="utf-8")
    except OSError:
        return None
    match = re.search(
        r"(?m)^\s*set\(GVMD_DATABASE_VERSION\s+([0-9]+)\s*\)\s*$",
        cmake,
    )
    return int(match.group(1)) if match else None


def gvmd_database_version_finding(repo_root: Path) -> dict[str, Any]:
    expected = source_gvmd_database_version(repo_root)
    query = psql(
        repo_root,
        "SELECT COALESCE((SELECT value FROM meta WHERE name = 'database_version'), 'missing');",
    )
    observed = psql_value(query) if query.returncode == 0 else ""
    matches = expected is not None and observed == str(expected)
    details = {
        "expected": expected,
        "observed": observed or None,
        "output_tail": output_tail(query.stdout, 40),
    }
    if matches:
        return finding(
            "pass",
            "gvmd.migrate-version",
            f"Manager database version matches source schema {expected}.",
            details=details,
        )
    return finding(
        "fail",
        "gvmd.migrate-version",
        "Manager migration exited without proving the source database schema version.",
        details=details,
    )


