def rust_direct_api_allowed_endpoint_templates(repo_root: Path | None) -> list[str]:
    source = rust_direct_api_source(repo_root)
    if not source:
        return []

    templates: set[str] = set()
    function_body = rust_source_function_body(source, "direct_api_v1_path_is_allowed")
    for match in re.finditer(r"\[([^\]]+)\]", function_body):
        pattern_source = match.group(1)
        if "section" in pattern_source:
            continue
        endpoint = rust_match_pattern_to_endpoint(pattern_source)
        if endpoint and endpoint.startswith("/api/v1"):
            templates.add(endpoint)
    templates.update(rust_direct_scope_report_section_templates(function_body))

    write_function_body = rust_source_function_body(source, "direct_api_v1_write_method_path_is_allowed")
    for match in re.finditer(r"\[([^\]]+)\]", write_function_body):
        endpoint = rust_match_pattern_to_endpoint(match.group(1))
        if endpoint and endpoint.startswith("/api/v1"):
            templates.add(endpoint)

    wildcard_body = rust_source_function_body(source, "direct_api_wildcard_detail_path_is_allowed")
    for prefix in re.findall(r'"(/api/v1/[^"]+/)"', wildcard_body):
        templates.add(f"{prefix.rstrip('/')}/{{}}")
    return sorted(templates)


def native_api_direct_contract_summary(repo_root: Path | None, endpoints: list[dict[str, Any]]) -> dict[str, Any]:
    inventory = sorted(
        item["endpoint"]
        for item in endpoints
        if isinstance(item.get("endpoint"), str) and item["endpoint"].startswith("/api/v1")
    )
    scriptable = sorted(
        item["endpoint"]
        for item in endpoints
        if item.get("direct_access") == "scriptable_read" and isinstance(item.get("endpoint"), str)
    )
    direct_path_allowed = sorted(
        item["endpoint"]
        for item in endpoints
        if item.get("direct_access") in {"scriptable_read", "direct_write_control"}
        and isinstance(item.get("endpoint"), str)
    )
    internal_only = sorted(
        item["endpoint"]
        for item in endpoints
        if item.get("direct_access") == "internal_only" and isinstance(item.get("endpoint"), str)
    )
    openapi_direct_operations = openapi_direct_operation_templates(repo_root)
    openapi_direct_operation_labels = [f"{item['method'].upper()} {item['endpoint']}" for item in openapi_direct_operations]
    openapi_direct_read_operations = [label for item, label in zip(openapi_direct_operations, openapi_direct_operation_labels) if item["method"] == "get"]
    openapi_direct_write_control_operations = [
        label
        for item, label in zip(openapi_direct_operations, openapi_direct_operation_labels)
        if item["method"] in OPENAPI_WRITE_CONTROL_METHODS or item["exposure"] == "direct-write"
    ]
    openapi_non_get_direct_operations = [
        label for item, label in zip(openapi_direct_operations, openapi_direct_operation_labels) if item["method"] != "get"
    ]
    openapi_marked = openapi_direct_endpoint_templates(repo_root)
    rust_routes = rust_native_api_route_templates(repo_root)
    rust_direct_allowed = rust_direct_api_allowed_endpoint_templates(repo_root)
    segment_guard = rust_direct_api_segment_guard_summary(repo_root)
    body_limit = rust_direct_api_body_limit_summary(repo_root)
    inventory_by_normalized = {normalize_native_api_endpoint_template(endpoint): endpoint for endpoint in inventory}
    scriptable_by_normalized = {normalize_native_api_endpoint_template(endpoint): endpoint for endpoint in scriptable}
    direct_path_allowed_by_normalized = {
        normalize_native_api_endpoint_template(endpoint): endpoint for endpoint in direct_path_allowed
    }
    openapi_by_normalized = {normalize_native_api_endpoint_template(endpoint): endpoint for endpoint in openapi_marked}
    rust_route_by_normalized = {normalize_native_api_endpoint_template(endpoint): endpoint for endpoint in rust_routes}
    rust_direct_by_normalized = {normalize_native_api_endpoint_template(endpoint): endpoint for endpoint in rust_direct_allowed}
    missing = [scriptable_by_normalized[key] for key in sorted(set(scriptable_by_normalized) - set(openapi_by_normalized))]
    unexpected = [
        openapi_by_normalized[key]
        for key in sorted(set(openapi_by_normalized) - set(direct_path_allowed_by_normalized))
    ]
    missing_rust_routes = [inventory_by_normalized[key] for key in sorted(set(inventory_by_normalized) - set(rust_route_by_normalized))]
    untracked_rust_routes = [rust_route_by_normalized[key] for key in sorted(set(rust_route_by_normalized) - set(inventory_by_normalized))]
    missing_rust_direct = [
        direct_path_allowed_by_normalized[key]
        for key in sorted(set(direct_path_allowed_by_normalized) - set(rust_direct_by_normalized))
    ]
    unexpected_rust_direct = [
        rust_direct_by_normalized[key]
        for key in sorted(set(rust_direct_by_normalized) - set(direct_path_allowed_by_normalized))
    ]
    drift = (
        missing
        or unexpected
        or missing_rust_routes
        or untracked_rust_routes
        or missing_rust_direct
        or unexpected_rust_direct
        or segment_guard["alignment_status"] != "pass"
        or body_limit["alignment_status"] != "pass"
    )
    return {
        "alignment_status": "pass" if not drift else "warn",
        "inventory_endpoint_count": len(inventory),
        "scriptable_read_count": len(scriptable),
        "internal_only_count": len(internal_only),
        "openapi_marked_direct_count": len(openapi_marked),
        "openapi_marked_direct_operation_count": len(openapi_direct_operations),
        "openapi_marked_direct_read_operation_count": len(openapi_direct_read_operations),
        "openapi_marked_direct_write_control_count": len(openapi_direct_write_control_operations),
        "non_get_openapi_marked_direct_count": len(openapi_non_get_direct_operations),
        "rust_route_count": len(rust_routes),
        "rust_direct_allowlist_count": len(rust_direct_allowed),
        "inventory_endpoints": inventory,
        "scriptable_read_endpoints": scriptable,
        "internal_only_endpoints": internal_only,
        "openapi_marked_direct_endpoints": openapi_marked,
        "openapi_marked_direct_operations": openapi_direct_operation_labels,
        "openapi_marked_direct_read_operations": openapi_direct_read_operations,
        "openapi_marked_direct_write_control_operations": openapi_direct_write_control_operations,
        "non_get_openapi_marked_direct_operations": openapi_non_get_direct_operations,
        "rust_route_endpoints": rust_routes,
        "rust_direct_allowlist_endpoints": rust_direct_allowed,
        "missing_openapi_direct_markers": missing,
        "unexpected_openapi_direct_markers": unexpected,
        "missing_rust_routes": missing_rust_routes,
        "untracked_rust_routes": untracked_rust_routes,
        "missing_rust_direct_allowlist": missing_rust_direct,
        "unexpected_rust_direct_allowlist": unexpected_rust_direct,
        "segment_guard": segment_guard,
        "body_limit": body_limit,
    }


def c_source_function_body(source: str, name: str) -> str:
    match = re.search(rf"\b{re.escape(name)}\s*\([^)]*\)\s*{{", source)
    if match is None:
        return ""
    start = source.find("{", match.start())
    depth = 0
    for index in range(start, len(source)):
        char = source[index]
        if char == "{":
            depth += 1
        elif char == "}":
            depth -= 1
            if depth == 0:
                return source[start + 1 : index]
    return ""


def c_string_constants(function_body: str) -> dict[str, str]:
    return {
        match.group(1): match.group(2)
        for match in re.finditer(r'const\s+gchar\s+\*\s*(\w+)\s*=\s*"([^"]*)"\s*;', function_body)
    }


def c_string_array_values(function_body: str, name: str) -> list[str]:
    match = re.search(rf"const\s+gchar\s+\*\s*{re.escape(name)}\s*\[\]\s*=\s*{{(?P<body>.*?)}};", function_body, re.DOTALL)
    if match is None:
        return []
    return re.findall(r'"([^"]+)"', match.group("body"))


def native_api_gsad_proxy_allowlist_templates(repo_root: Path | None) -> tuple[list[str], list[str]]:
    if repo_root is None:
        return [], []
    relative_path = "components/gsad/src/gsad_native_api.c"
    try:
        source = (repo_root / relative_path).read_text(encoding="utf-8")
    except OSError:
        return [], [f"missing_source:{relative_path}"]

    function_body = c_source_function_body(source, "native_api_path_is_allowed")
    if not function_body:
        return [], ["missing_function:native_api_path_is_allowed"]

    constants = c_string_constants(function_body)
    templates: set[str] = set()
    errors: list[str] = []

    for match in re.finditer(
        r"if\s*\(\s*g_strcmp0\s*\(\s*path\s*,\s*(\w+)\s*\)\s*==\s*0\s*\)\s*return\s+TRUE\s*;",
        function_body,
        re.DOTALL,
    ):
        variable = match.group(1)
        value = constants.get(variable)
        if value and value.startswith("/api/v1"):
            templates.add(value)
        else:
            errors.append(f"unresolved_exact_path:{variable}")

    if "results_path" in constants and "g_str_has_prefix (path, results_path)" in function_body:
        templates.add(f"{constants['results_path']}/{{}}")
        if "result_export_suffix" in constants and "g_str_has_suffix (id, result_export_suffix)" in function_body:
