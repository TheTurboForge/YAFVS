    for base_url in base_urls:
        args.extend(["--base-url", base_url])
    result = run_command(args, repo_root, env=runtime_env(repo_root), timeout=300)
    try:
        parsed = json.loads(result.stdout.strip().splitlines()[-1])
    except (IndexError, json.JSONDecodeError):
        parsed = None
    helper_status = parsed.get("status") if parsed else None
    finding_status = helper_status if result.returncode == 0 and helper_status in {"pass", "warn"} else "fail"
    admin_password = secret_path.read_text(encoding="utf-8").strip() if secret_path.is_file() else ""
    findings.append(
        finding(
            finding_status,
            "credential-smoke.run",
            parsed.get("summary", f"Credential browser smoke helper exit code {result.returncode}.") if parsed else f"Credential browser smoke helper exit code {result.returncode}.",
            details={"helper": parsed, "output_tail": output_tail(result.stdout, 120, [admin_password, credential_password])},
        )
    )
    artifacts = list(parsed.get("artifacts", [])) if parsed and isinstance(parsed.get("artifacts"), list) else [str(artifact_dir)]
    summary = parsed.get("summary") if parsed else f"Runtime credential smoke completed with exit code {result.returncode}."
    return make_result("runtime-credential-smoke", repo_root, summary, findings, artifacts)


