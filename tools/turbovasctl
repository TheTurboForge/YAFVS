    if command is not None:
        details["command"] = " ".join(shlex.quote(part) for part in command)
    return finding(status, check, message, details=details)


def log_review_matches(lines: Iterable[str], service: str | None = None) -> list[dict[str, Any]]:
    matches: list[dict[str, Any]] = []
    material = list(lines)
    patterns = [*LOG_REVIEW_PATTERNS]
    if service:
        patterns.extend(LOG_REVIEW_SERVICE_PATTERNS.get(service, ()))
    for status, key, pattern, message in patterns:
        regex = re.compile(pattern, re.IGNORECASE)
        matched = [line for line in material if regex.search(line)]
        if matched:
            matches.append({"status": status, "key": key, "message": message, "matches": matched[-20:]})
    return matches


