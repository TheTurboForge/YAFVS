    matches: list[dict[str, Any]] = []
    for item in parsed["items"]:
        if not isinstance(item, dict):
            continue
        if item.get("name") == value or item.get("id") == value:
            matches.append(item)
    return matches


def native_tag_csv_fetch_exact_items(
    repo_root: Path,
    base_path: str,
    value: str,
    *,
    token: str,
    env: dict[str, str],
) -> tuple[list[dict[str, Any]], dict[str, Any] | None]:
    matches: list[dict[str, Any]] = []
    page = 1
    page_size = 100
    encoded_value = urllib.parse.quote(value)
    while True:
        separator = "&" if "?" in base_path else "?"
        path = f"{base_path}{separator}filter={encoded_value}&page={page}&page_size={page_size}"
        response = direct_native_api_curl(repo_root, path, token=token, env=env)
        parsed, http_status = parse_json_output_with_http_status(response)
        if response.returncode != 0 or http_status != 200 or not isinstance(parsed, dict) or not isinstance(parsed.get("items"), list):
            return matches, {"reason": "lookup failed", "http_status": http_status, "page": page, **summarize_native_api_response(parsed)}
        matches.extend(native_tag_csv_exact_items(parsed, value))
        page_info = parsed.get("page") if isinstance(parsed.get("page"), dict) else {}
        total = page_info.get("total") if isinstance(page_info.get("total"), int) else len(parsed["items"])
        actual_page_size = page_info.get("page_size") if isinstance(page_info.get("page_size"), int) and page_info.get("page_size") else page_size
        actual_page = page_info.get("page") if isinstance(page_info.get("page"), int) and page_info.get("page") else page
        if actual_page * actual_page_size >= total or not parsed["items"]:
            return matches, None
        page += 1
        if page > 1000:
            return matches, {"reason": "lookup pagination exceeded safety limit", "page": page, "total": total}


def command_native_tags_from_csv(
    repo_root: Path,
    csv_file: Path,
    *,
    allow_write_control: bool = False,
    dry_run: bool = False,
    status_only: bool = False,
) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    details: dict[str, Any] = {
        "csv_file": str(csv_file),
        "dry_run": dry_run,
        "skipped_existing_tag_count": 0,
        "created_tag_count": 0,
        "created_tag_ids": [],
        "assigned_resource_count": 0,
    }
    try:
        rows = load_native_tag_csv_rows(csv_file)
        details["row_count"] = len(rows)
        findings.append(finding("pass", "native-tags-from-csv.rows", f"Loaded {len(rows)} non-empty CSV row(s)."))
    except ValueError as exc:
        findings.append(finding("fail", "native-tags-from-csv.rows", str(exc), details={"csv_file": str(csv_file)}))
        result = make_result("native-tags-from-csv", repo_root, "Native CSV tag creation rejected before runtime access.", findings)
        result["details"] = details
        return native_tag_csv_status_only_result(result) if status_only else result

    timestamp = datetime.now(timezone.utc).replace(microsecond=0).isoformat()
    if dry_run:
        details["planned_tags"] = [
            {
                "tag": native_tag_csv_tag_body(row, timestamp=timestamp),
                "resource_names": list(row.resource_names),
            }
            for row in rows
        ]
        findings.append(finding("pass", "native-tags-from-csv.dry-run", "Dry run planned native tag writes without runtime access or resource-name resolution."))
        result = make_result("native-tags-from-csv", repo_root, "Native CSV tag creation dry run completed.", findings)
        result["details"] = details
        return native_tag_csv_status_only_result(result) if status_only else result

    if not allow_write_control:
        findings.append(finding("fail", "native-tags-from-csv.write-control-intent", "Creating tags requires --allow-write-control."))
        result = make_result("native-tags-from-csv", repo_root, "Native CSV tag creation rejected before runtime access.", findings)
        result["details"] = details
        return native_tag_csv_status_only_result(result) if status_only else result

    env = native_api_direct_runtime_env(repo_root)
    findings.append(native_api_direct_config_shape_finding(env, check="native-tags-from-csv.direct-config-shape"))
    if aggregate_status(findings) == "fail":
        result = make_result("native-tags-from-csv", repo_root, "Direct native API CSV tag creation rejected before runtime access.", findings)
        result["details"] = details
        return native_tag_csv_status_only_result(result) if status_only else result
    token = native_api_direct_bearer_token(repo_root, env)
    if not direct_api_bearer_token_is_acceptable(token):
        findings.append(
            finding(
                "fail",
                "native-tags-from-csv.direct-token-strength",
                "Direct native API bearer token is too short or contains unsafe characters.",
                details={"minimum_token_length": TURBOVAS_API_BEARER_TOKEN_MIN_LENGTH},
            )
        )
        result = make_result("native-tags-from-csv", repo_root, "Direct native API CSV tag creation rejected before runtime access.", findings)
        result["details"] = details
        return native_tag_csv_status_only_result(result) if status_only else result

    rows_to_create: list[tuple[NativeTagCsvRow, list[str]]] = []
    preflight_failures: list[dict[str, Any]] = []
    skipped_existing_tags: list[str] = []
    planned_tag_names: set[str] = set()
    for row in rows:
        if row.tag_name in planned_tag_names:
            skipped_existing_tags.append(row.tag_name)
            continue
        tag_matches, tag_failure = native_tag_csv_fetch_exact_items(repo_root, "/api/v1/tags", row.tag_name, token=token, env=env)
        if tag_failure:
            preflight_failures.append({"row": row.row_number, "tag": row.tag_name, **tag_failure})
            continue
        if tag_matches:
            skipped_existing_tags.append(row.tag_name)
            continue

        resource_ids: list[str] = []
        for resource_name in row.resource_names:
            lookup_path = f"/api/v1/tags/resource-names/{urllib.parse.quote(row.resource_type, safe='')}"
            resource_matches, resource_failure = native_tag_csv_fetch_exact_items(repo_root, lookup_path, resource_name, token=token, env=env)
            if resource_failure:
                preflight_failures.append({"row": row.row_number, "tag": row.tag_name, "resource": resource_name, **resource_failure})
                continue
            if len(resource_matches) != 1:
                preflight_failures.append({"row": row.row_number, "tag": row.tag_name, "resource": resource_name, "reason": "resource lookup was missing or ambiguous", "match_count": len(resource_matches)})
                continue
            resource_id = resource_matches[0].get("id")
            if not isinstance(resource_id, str) or not resource_id:
                preflight_failures.append({"row": row.row_number, "tag": row.tag_name, "resource": resource_name, "reason": "resource response did not include an id"})
                continue
            resource_ids.append(resource_id)
        rows_to_create.append((row, resource_ids))
        planned_tag_names.add(row.tag_name)

    details["skipped_existing_tags"] = skipped_existing_tags
    details["skipped_existing_tag_count"] = len(skipped_existing_tags)
    if preflight_failures:
        details["preflight_failures"] = preflight_failures
        findings.append(finding("fail", "native-tags-from-csv.preflight", "Native CSV tag creation preflight failed before creating tags.", details={"failure_count": len(preflight_failures), "failures": preflight_failures[:10]}))
        result = make_result("native-tags-from-csv", repo_root, "Native CSV tag creation rejected before tag writes.", findings)
        result["details"] = details
        return native_tag_csv_status_only_result(result) if status_only else result

    findings.append(finding("pass", "native-tags-from-csv.preflight", f"Preflight resolved {len(rows_to_create)} tag create row(s) and skipped {len(skipped_existing_tags)} existing tag(s)."))

    content_type = (("Content-Type", "application/json"),)
    created_tag_ids: list[str] = []
    assigned_resource_count = 0
    create_failures: list[dict[str, Any]] = []
    for row, resource_ids in rows_to_create:
        tag_body = json.dumps(native_tag_csv_tag_body(row, timestamp=timestamp), separators=(",", ":"))
        tag_create = direct_native_api_curl(repo_root, "/api/v1/tags", token=token, env=env, method="POST", body=tag_body, extra_headers=content_type)
        tag_create_json, tag_create_status = parse_json_output_with_http_status(tag_create)
        tag_id = tag_create_json.get("id") if isinstance(tag_create_json, dict) and isinstance(tag_create_json.get("id"), str) else None
        if tag_create.returncode != 0 or tag_create_status != 201 or not tag_id:
            create_failures.append({"row": row.row_number, "tag": row.tag_name, "stage": "create", "http_status": tag_create_status, **summarize_native_api_response(tag_create_json)})
            break
        created_tag_ids.append(tag_id)
        if resource_ids:
            resource_body = json.dumps({"action": "add", "resource_ids": resource_ids}, separators=(",", ":"))
            resource_add = direct_native_api_curl(repo_root, f"/api/v1/tags/{urllib.parse.quote(tag_id)}/resources", token=token, env=env, method="POST", body=resource_body, extra_headers=content_type)
            resource_add_json, resource_add_status = parse_json_output_with_http_status(resource_add)
            if resource_add.returncode != 0 or resource_add_status != 200:
                create_failures.append({"row": row.row_number, "tag": row.tag_name, "tag_id": tag_id, "stage": "resource-add", "http_status": resource_add_status, **summarize_native_api_response(resource_add_json)})
                break
            assigned_resource_count += len(resource_ids)
    details["created_tag_ids"] = created_tag_ids
    details["created_tag_count"] = len(created_tag_ids)
    details["assigned_resource_count"] = assigned_resource_count
    if create_failures:
        details["create_failures"] = create_failures
        findings.append(finding("fail", "native-tags-from-csv.tag-create", "One or more native tag create/resource requests failed.", details={"failure_count": len(create_failures), "failures": create_failures[:10]}))
    else:
        findings.append(finding("pass", "native-tags-from-csv.tag-create", f"Created {len(created_tag_ids)} tag(s) and assigned {assigned_resource_count} resource(s) through the native API."))

    result_status = aggregate_status(findings)
    result = make_result(
        "native-tags-from-csv",
        repo_root,
        "Native CSV tag creation completed." if result_status != "fail" else "Native CSV tag creation failed.",
        findings,
    )
    result["details"] = details
    return native_tag_csv_status_only_result(result) if status_only else result


def native_targets_from_host_list_status_only_result(result: dict[str, Any]) -> dict[str, Any]:
    details = result.get("details") if isinstance(result.get("details"), dict) else {}
    compact = dict(result)
    compact["details"] = {
        "hosts_file": details.get("hosts_file"),
        "host_count": details.get("host_count", 0),
        "dry_run": details.get("dry_run", False),
        "port_list_id": details.get("port_list_id"),
        "port_list_created": details.get("port_list_created", False),
        "created_target_count": details.get("created_target_count", 0),
    }
