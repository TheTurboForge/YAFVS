    findings: list[dict[str, Any]] = []
    details: dict[str, Any] = {"docker_stats": [], "database": {}, "paths": {}}
    artifact_dir.mkdir(parents=True, exist_ok=True)

    stats = run_command(["docker", "stats", "--no-stream", "--format", "json"], repo_root, env=runtime_env(repo_root), timeout=120)
    if stats.returncode == 0:
        for line in stats.stdout.splitlines():
            try:
                details["docker_stats"].append(json.loads(line))
            except json.JSONDecodeError:
                continue
    details["docker_stats_numeric"] = [normalize_docker_stat(row) for row in details["docker_stats"]]
    details["docker_top"] = {
        "cpu_percent": top_numeric_rows(details["docker_stats_numeric"], "cpu_percent"),
        "memory_usage_bytes": top_numeric_rows(details["docker_stats_numeric"], "memory_usage_bytes"),
        "network_rx_bytes": top_numeric_rows(details["docker_stats_numeric"], "network_rx_bytes"),
        "network_tx_bytes": top_numeric_rows(details["docker_stats_numeric"], "network_tx_bytes"),
        "block_read_bytes": top_numeric_rows(details["docker_stats_numeric"], "block_read_bytes"),
        "block_write_bytes": top_numeric_rows(details["docker_stats_numeric"], "block_write_bytes"),
        "pids": top_numeric_rows(details["docker_stats_numeric"], "pids"),
    }
    findings.append(process_step_finding("pass" if stats.returncode == 0 else "warn", "performance.docker-stats", f"docker stats snapshot exit code {stats.returncode}.", stats, ["docker", "stats", "--no-stream", "--format", "json"]))
    if stats.returncode == 0:
        findings.append(finding("pass", "performance.docker-stats-numeric", "Docker stats numeric summary captured.", details={"container_count": len(details["docker_stats_numeric"]), "top": details["docker_top"]}))

    if container_running(repo_root, "postgres"):
        db_size = psql(repo_root, "SELECT pg_database_size(current_database());")
        details["database"]["byte_count"] = int(psql_value(db_size) or "0") if db_size.returncode == 0 and psql_value(db_size).isdigit() else None
        findings.append(finding("pass" if db_size.returncode == 0 else "warn", "performance.database-size", "Database size captured." if db_size.returncode == 0 else "Database size query failed.", details={"output_tail": output_tail(db_size.stdout, 40), "byte_count": details["database"].get("byte_count")}))
        table_query, presence = table_presence_rows(repo_root, (*DATABASE_CORE_TABLES, *DATABASE_SCOPE_TABLES))
        if table_query.returncode == 0:
            details["database"]["row_counts"] = {table: table_row_count(repo_root, table) for table, exists in presence.items() if exists}
            findings.append(finding("pass", "performance.table-row-counts", "Database row-count estimates captured for known tables.", details={"table_count": len(details["database"]["row_counts"])}))
        else:
            findings.append(finding("warn", "performance.table-row-counts", "Could not inspect database row counts.", details={"output_tail": output_tail(table_query.stdout, 80)}))
        largest_relations = psql(
            repo_root,
            "SELECT relname || '|' || pg_total_relation_size(c.oid) FROM pg_class c JOIN pg_namespace n ON n.oid = c.relnamespace WHERE n.nspname = 'public' AND c.relkind IN ('r','m','i','t') ORDER BY pg_total_relation_size(c.oid) DESC LIMIT 10;",
        )
        details["database"]["largest_relations"] = parse_relation_size_rows(largest_relations.stdout) if largest_relations.returncode == 0 else []
        findings.append(finding("pass" if largest_relations.returncode == 0 else "warn", "performance.database-largest-relations", "Largest database relations captured." if largest_relations.returncode == 0 else "Largest database relation query failed.", details={"relations": details["database"].get("largest_relations", []), "output_tail": output_tail(largest_relations.stdout, 80)}))
        report_workflow = psql(
            repo_root,
            "SELECT 'reports|' || count (*) FROM reports "
            "UNION ALL SELECT 'scope_reports|' || count (*) FROM scope_reports "
            "UNION ALL SELECT 'scope_report_sources|' || count (*) FROM scope_report_sources "
            "UNION ALL SELECT 'max_sources_per_scope_report|' || coalesce ((SELECT max (source_count) FROM (SELECT count (*) AS source_count FROM scope_report_sources GROUP BY scope_report) x), 0) "
            "UNION ALL SELECT 'max_results_per_report|' || coalesce ((SELECT max (result_count) FROM (SELECT count (*) AS result_count FROM results GROUP BY report) x), 0) "
            "UNION ALL SELECT 'max_scope_report_result_count|' || coalesce ((SELECT max (result_count) FROM scope_reports), 0) "
            "UNION ALL SELECT 'max_scope_report_source_host_count|' || coalesce ((SELECT max (evidence_host_count) FROM scope_reports), 0);",
        )
        details["report_workflow"] = parse_pipe_int_rows(report_workflow.stdout) if report_workflow.returncode == 0 else {}
        findings.append(finding("pass" if report_workflow.returncode == 0 else "warn", "performance.report-workflow", "Report workflow baseline captured." if report_workflow.returncode == 0 else "Report workflow baseline query failed.", details={"report_workflow": details.get("report_workflow", {}), "output_tail": output_tail(report_workflow.stdout, 80)}))
    else:
        findings.append(finding("warn", "performance.database", "Postgres is not running; database size and row counts are unavailable."))

    if container_running(repo_root, "redis-openvas"):
        scanner_redis = scanner_redis_metrics(repo_root)
        details["scanner_redis"] = scanner_redis
        metrics_ready = scanner_redis.get("dbsize_status") == "pass" and scanner_redis.get("info_status") == "pass"
        findings.append(
            finding(
                "pass" if metrics_ready else "warn",
                "performance.scanner-redis",
                "Scanner Redis performance counters captured without key names or values."
                if metrics_ready
                else "Scanner Redis performance counters could not be fully captured.",
                str(scanner_redis_socket_path(repo_root)),
                {"scanner_redis": scanner_redis},
            )
        )
    else:
        findings.append(finding("warn", "performance.scanner-redis", "Scanner Redis is not running; performance counters are unavailable.", str(scanner_redis_socket_path(repo_root))))

    for name, path, recursive in (
        ("runtime-artifacts", runtime_path(repo_root, "artifacts"), True),
        ("runtime-logs", runtime_path(repo_root, "logs"), True),
        ("gsa-static", gsad_static_dir(repo_root), True),
        ("build-prefix", repo_root / "build" / "prefix", False),
    ):
        summary = path_tree_summary(path, recursive=recursive)
        if name == "gsa-static":
            summary["largest_files"] = largest_files(path)
        details["paths"][name] = summary
        findings.append(finding("pass" if summary["exists"] else "warn", "performance.path", f"{name} size snapshot captured." if summary["exists"] else f"{name} path is missing.", summary["path"], {"summary": summary}))

    latest_path, timestamped_path = retained_json_artifact_paths(artifact_dir, "performance-snapshot", "performance-snapshot.json")
    result = make_result("runtime-performance-snapshot", repo_root, "Runtime performance snapshot completed.", findings, [str(latest_path), str(timestamped_path)])
    result["details"] = details
    write_retained_json_artifact(latest_path, timestamped_path, result, "performance-snapshot", RETAINED_PERFORMANCE_ARTIFACTS)
    return result


def command_runtime_status(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    manager_lock = runtime_lock_status(repo_root, RUNTIME_MANAGER_LOCK)
    findings.append(finding("warn" if manager_lock["active"] else "pass", "runtime.manager-lock", "A manager operation is currently active." if manager_lock["active"] else "No manager operation lock is active.", details={"lock": manager_lock}))
    findings.append(finding("pass" if shutil.which("docker") else "fail", "docker.available", "docker is available." if shutil.which("docker") else "docker is not available."))
    docker = run_command(["docker", "info"], repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if docker.returncode == 0 else "fail", "docker.daemon", f"docker info exit code {docker.returncode}.", details={"output_tail": docker.stdout.splitlines()[-40:]}))
    config = run_command(compose_command(repo_root, "config", "--quiet"), repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if config.returncode == 0 else "fail", "compose.config", f"Compose config validation exit code {config.returncode}.", str(compose_file(repo_root).relative_to(repo_root)), {"output_tail": config.stdout.splitlines()[-40:]}))
    findings.extend(ensure_runtime_dirs(repo_root))
    ps = run_command(compose_command(repo_root, "ps", "--format", "json"), repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if ps.returncode == 0 else "fail", "compose.ps", f"docker compose ps exit code {ps.returncode}.", details={"output_tail": ps.stdout.splitlines()[-80:]}))
    for service in RUNTIME_SERVICES:
        findings.append(finding("pass" if container_running(repo_root, service) else "warn", "runtime.running", f"{service} container is {'running' if container_running(repo_root, service) else 'not running'}.", details={"service": service}))
    if container_running(repo_root, "postgres"):
        ready = postgres_ready(repo_root)
        findings.append(finding("pass" if ready.returncode == 0 else "warn", "postgres.ready", f"pg_isready exit code {ready.returncode}.", details={"output_tail": ready.stdout.splitlines()[-20:]}))
        findings.extend(ensure_postgres_collation(repo_root, refresh_empty=False))
        dba = psql(repo_root, "SELECT EXISTS (SELECT FROM pg_roles WHERE rolname = 'dba');")
        dba_value = psql_value(dba)
        findings.append(finding("pass" if dba.returncode == 0 and dba_value == "t" else "warn", "postgres.role.dba", f"dba role exists: {dba_value or 'unknown'}.", details={"output_tail": dba.stdout.splitlines()[-20:]}))
        membership = psql(repo_root, f"SELECT pg_has_role({sql_literal(postgres_user(repo_root))}, 'dba', 'member');")
        membership_value = psql_value(membership)
        findings.append(finding("pass" if membership.returncode == 0 and membership_value == "t" else "warn", "postgres.role.membership", f"{postgres_user(repo_root)} has dba role membership: {membership_value or 'unknown'}.", details={"output_tail": membership.stdout.splitlines()[-20:]}))
        findings.append(pg_gvm_extension_status(repo_root))
    findings.extend(cert_file_findings(repo_root))
    secret_path = runtime_secret_path(repo_root, DEV_ADMIN_SECRET)
    findings.append(finding("pass" if secret_path.is_file() else "warn", "runtime.admin-secret", "Development admin secret exists." if secret_path.is_file() else "Development admin secret is not initialized yet.", str(secret_path)))
    for service in APP_SERVICES:
        findings.append(finding("pass" if container_running(repo_root, service) else "warn", "runtime.app.running", f"{service} container is {'running' if container_running(repo_root, service) else 'not running'}.", details={"service": service}))
    findings.append(socket_readiness_finding("gvmd.socket", "gvmd", gvmd_socket_path(repo_root)))
    findings.append(socket_readiness_finding("ospd.socket", "ospd-openvas", ospd_socket_path(repo_root)))
    return make_result("runtime-status", repo_root, "Runtime status collected.", findings, [str(runtime_dir(repo_root))])


def command_runtime_smoke(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    findings.extend(ensure_runtime_dirs(repo_root))
    config = run_command(compose_command(repo_root, "config", "--quiet"), repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if config.returncode == 0 else "fail", "compose.config", f"Compose config validation exit code {config.returncode}.", str(compose_file(repo_root).relative_to(repo_root)), {"output_tail": config.stdout.splitlines()[-40:]}))
    port_config = run_command(compose_command(repo_root, "config"), repo_root, env=runtime_env(repo_root))
    broad_bindings = [line.strip() for line in port_config.stdout.splitlines() if "0.0.0.0:" in line or "[::]:" in line]
    findings.append(finding("fail" if broad_bindings else "pass", "runtime.ports", "No broad host port bindings found." if not broad_bindings else "Broad host port bindings found.", details={"broad_bindings": broad_bindings}))
    for service in RUNTIME_SERVICES:
        findings.append(finding("pass" if container_running(repo_root, service) else "fail", "runtime.running", f"{service} container is running.", details={"service": service}))
    if container_running(repo_root, "postgres"):
        result = postgres_ready(repo_root)
        findings.append(finding("pass" if result.returncode == 0 else "fail", "postgres.ready", f"pg_isready exit code {result.returncode}.", details={"output_tail": result.stdout.splitlines()[-20:]}))
        for collation in ensure_postgres_collation(repo_root, refresh_empty=False):
            if collation["status"] == "warn":
                collation = dict(collation)
                collation["status"] = "fail"
            findings.append(collation)
        extension = pg_gvm_extension_status(repo_root)
        if extension["status"] == "warn":
            extension = dict(extension)
            extension["status"] = "fail"
        findings.append(extension)
    if container_running(repo_root, "redis-openvas"):
        result = scanner_redis_ping(repo_root)
        findings.append(finding("pass" if result.returncode == 0 and "PONG" in result.stdout else "fail", "redis-openvas.ready", f"scanner Redis Unix socket ping exit code {result.returncode}.", str(scanner_redis_socket_path(repo_root)), {"output_tail": result.stdout.splitlines()[-20:]}))
        findings.append(finding("pass" if scanner_redis_socket_path(repo_root).is_socket() else "fail", "redis-openvas.socket", "scanner Redis Unix socket exists." if scanner_redis_socket_path(repo_root).is_socket() else "scanner Redis Unix socket is missing.", str(scanner_redis_socket_path(repo_root))))
    if container_running(repo_root, "mosquitto"):
        result = exec_in_service(repo_root, "mosquitto", ["mosquitto_pub", "-h", "127.0.0.1", "-p", "1883", "-t", "turbovas/smoke", "-m", "ok"])
        findings.append(finding("pass" if result.returncode == 0 else "fail", "mosquitto.ready", f"mosquitto_pub broker check exit code {result.returncode}.", details={"output_tail": result.stdout.splitlines()[-20:]}))
    return make_result("runtime-smoke", repo_root, "Runtime smoke checks completed.", findings, [str(runtime_dir(repo_root))])


def command_gvmd_smoke(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    if pg_gvm_extension_status(repo_root)["status"] != "pass":
        findings.append(finding("fail", "gvmd.pg-gvm", "pg-gvm extension is not initialized; run just runtime-init before gvmd smoke."))
        return make_result("gvmd-smoke", repo_root, "gvmd smoke stopped before service startup.", findings)
    result = run_command(compose_command(repo_root, "--profile", "app", "up", "-d", "gvmd"), repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if result.returncode == 0 else "fail", "gvmd.up", f"docker compose up gvmd exit code {result.returncode}.", details={"output_tail": result.stdout.splitlines()[-80:]}))
    if result.returncode != 0:
        return make_result("gvmd-smoke", repo_root, "gvmd smoke stopped at container startup.", findings)
    probe = exec_in_service(repo_root, "gvmd", ["sh", "-lc", "command -v gvmd && gvmd --version"])
    findings.append(finding("pass" if probe.returncode == 0 else "warn", "gvmd.binary", f"gvmd binary probe exit code {probe.returncode}.", details={"output_tail": probe.stdout.splitlines()[-40:]}))
    db_probe = exec_in_service(
        repo_root,
        "gvmd",
        [
            "sh",
            "-lc",
            "env PGPASSWORD=${POSTGRES_PASSWORD:-turbovas-dev} psql -h postgres -U ${POSTGRES_USER:-turbovas} -d ${POSTGRES_DB:-turbovas} -At -c \"SELECT extversion FROM pg_extension WHERE extname = 'pg-gvm';\"",
        ],
    )
    findings.append(finding("pass" if db_probe.returncode == 0 and db_probe.stdout.strip() else "warn", "gvmd.database", f"gvmd profile DB probe exit code {db_probe.returncode}.", details={"output_tail": db_probe.stdout.splitlines()[-40:]}))
    findings.append(finding("warn", "gvmd.deferred", "This smoke does not start the full manager daemon yet; certificates, scanner registration, feeds, and runtime paths remain follow-up work."))
    return make_result("gvmd-smoke", repo_root, "gvmd profile smoke completed.", findings, [str(runtime_dir(repo_root))])


