def command_runtime_native_api_direct_smoke(repo_root: Path, status_only: bool = False) -> dict[str, Any]:
    artifact_dir = native_api_artifact_dir(repo_root)
    artifact_dir.mkdir(parents=True, exist_ok=True)
    findings = ensure_runtime_dirs(repo_root)
    findings.extend(ensure_build_runtime_dirs(repo_root))
    env = native_api_direct_runtime_env(repo_root)
    token_from_env = bool(env.get(TURBOVAS_API_BEARER_TOKEN_ENV))
    token_source = "environment" if token_from_env else "runtime-secret-file"
    token = native_api_direct_bearer_token(repo_root, env)
    findings.append(native_api_direct_config_shape_finding(env, check="native-api-direct.config-shape"))
    config_errors = native_api_direct_config_errors(env)
    host = native_api_direct_host(env)
    wildcard_host = host_is_wildcard(host)
    non_loopback_host = not wildcard_host and not host_is_loopback(host)
    if config_errors:
        host_status = "fail"
        host_message = "Direct native API host binding must have valid host, port, and bind settings."
    elif wildcard_host:
        host_status = "fail"
        host_message = "Direct native API host binding must not use a wildcard host in this development helper."
    elif non_loopback_host:
        host_status = "fail"
        host_message = "Direct native API host binding must remain loopback-bounded until production TLS/bootstrap/host-binding hardening exists."
    else:
        host_status = "pass"
        host_message = "Direct native API host binding is explicit and loopback-bounded."
    findings.append(
        finding(
            host_status,
            "native-api-direct.host-binding",
            host_message,
            details={
                "host": host,
                "host_port": native_api_direct_port(env),
                "container_bind": env.get(TURBOVAS_API_DIRECT_BIND_ENV),
                "token_source": token_source,
            },
        )
    )
    token_ok = direct_api_bearer_token_is_acceptable(token)
    findings.append(
        finding(
            "pass" if token_ok else "fail",
            "native-api-direct.bearer-token-strength",
            "Direct native API bearer token satisfies the minimum local strength contract."
            if token_ok
            else "Direct native API bearer token is too short or contains unsafe characters.",
            details={
                "minimum_token_length": TURBOVAS_API_BEARER_TOKEN_MIN_LENGTH,
                "token_source": token_source,
            },
        )
    )
    config = run_command(compose_command(repo_root, "config", "--quiet", env=env), repo_root, env=env)
    findings.append(finding("pass" if config.returncode == 0 else "fail", "compose.config", f"Compose direct native API config validation exit code {config.returncode}.", str(compose_file(repo_root).relative_to(repo_root)), {"output_tail": output_tail(config.stdout, 40)}))
    if aggregate_status(findings) == "fail":
        result = make_result("runtime-native-api-direct-smoke", repo_root, "Direct native API smoke stopped at prerequisites.", findings, [str(artifact_dir)])
        result["details"] = {"base_url": native_api_direct_base_url(env)}
        write_json_artifact(artifact_dir, "native-api-direct-smoke-failed.json", result)
        if status_only:
            result = direct_smoke_status_only_result(result)
        return result

    build = run_command(compose_command(repo_root, "build", "turbovas-api", env=env), repo_root, env=env, timeout=1200)
    findings.append(process_step_finding("pass" if build.returncode == 0 else "fail", "compose.turbovas-api-build", f"docker compose build turbovas-api exit code {build.returncode}.", build, compose_command(repo_root, "build", "turbovas-api", env=env)))
    if build.returncode != 0:
        result = make_result("runtime-native-api-direct-smoke", repo_root, "Direct native API smoke stopped because image build failed.", findings, [str(artifact_dir)])
        result["details"] = {"base_url": native_api_direct_base_url(env)}
        write_json_artifact(artifact_dir, "native-api-direct-smoke-failed.json", result)
        if status_only:
            result = direct_smoke_status_only_result(result)
        return result

    up = run_command(compose_command(repo_root, "--profile", "app", "up", "-d", "--no-deps", "--force-recreate", "turbovas-api", env=env), repo_root, env=env, timeout=300)
    findings.append(process_step_finding("pass" if up.returncode == 0 else "fail", "compose.turbovas-api-direct-up", f"docker compose direct turbovas-api up exit code {up.returncode}.", up, compose_command(repo_root, "--profile", "app", "up", "-d", "--no-deps", "--force-recreate", "turbovas-api", env=env)))
    if up.returncode != 0:
        result = make_result("runtime-native-api-direct-smoke", repo_root, "Direct native API smoke stopped because turbovas-api restart failed.", findings, [str(artifact_dir)])
        result["details"] = {"base_url": native_api_direct_base_url(env)}
        write_json_artifact(artifact_dir, "native-api-direct-smoke-failed.json", result)
        if status_only:
            result = direct_smoke_status_only_result(result)
        return result

    health = direct_native_api_curl(repo_root, "/healthz", token=None, env=env)
    health_json, health_status = parse_json_output_with_http_status(health)
    health_ok = health.returncode == 0 and health_status == 200 and isinstance(health_json, dict) and health_json.get("status") == "ok"
    findings.append(native_api_probe_finding("pass" if health_ok else "fail", "native-api-direct.healthz", "Direct native API health endpoint is reachable without bearer auth." if health_ok else "Direct native API health endpoint failed.", health, direct_native_api_display_command("/healthz", token=None, env=env), health_json, {"http_status": health_status, **summarize_native_api_response(health_json)}))

    missing = direct_native_api_curl(repo_root, "/api/v1/reports?page_size=1", token=None, env=env, include_response_headers=True)
    missing_json, missing_status, missing_headers = parse_json_output_with_headers_and_http_status(missing)
    missing_ok = missing.returncode == 0 and missing_status == 401 and isinstance(missing_json, dict) and missing_json.get("error", {}).get("code") == "unauthorized"
    missing_request_id = direct_api_response_request_id(missing_headers)
    findings.append(native_api_probe_finding("pass" if missing_ok else "fail", "native-api-direct.missing-token", "Direct native API rejects missing bearer token with JSON 401." if missing_ok else "Direct native API did not reject a missing bearer token correctly.", missing, direct_native_api_display_command("/api/v1/reports?page_size=1", token=None, env=env, include_response_headers=True), missing_json, {"http_status": missing_status, "request_id": missing_request_id, **summarize_native_api_response(missing_json)}))
    missing_request_id_ok = missing_ok and missing_request_id.startswith("tv-") and len(missing_request_id) <= MAX_DIRECT_API_REQUEST_ID_LENGTH
    findings.append(finding("pass" if missing_request_id_ok else "fail", "native-api-direct.request-id-unauthorized", "Direct native API attaches a generated safe X-Request-Id to missing-token JSON 401 responses." if missing_request_id_ok else "Direct native API missing-token response did not include a generated safe X-Request-Id.", details={"http_status": missing_status, "request_id": missing_request_id}))

    wrong = direct_native_api_curl(repo_root, "/api/v1/reports?page_size=1", token="wrong-token", env=env)
    wrong_json, wrong_status = parse_json_output_with_http_status(wrong)
    wrong_ok = wrong.returncode == 0 and wrong_status == 401 and isinstance(wrong_json, dict) and wrong_json.get("error", {}).get("code") == "unauthorized"
    findings.append(native_api_probe_finding("pass" if wrong_ok else "fail", "native-api-direct.wrong-token", "Direct native API rejects wrong bearer token with JSON 401." if wrong_ok else "Direct native API did not reject a wrong bearer token correctly.", wrong, direct_native_api_display_command("/api/v1/reports?page_size=1", token="wrong-token", env=env), wrong_json, {"http_status": wrong_status, **summarize_native_api_response(wrong_json)}))

    client_request_id = "direct-smoke-1"
    valid = direct_native_api_curl(repo_root, "/api/v1/reports?page_size=1", token=token, env=env, request_id=client_request_id, include_response_headers=True)
    valid_json, valid_status, valid_headers = parse_json_output_with_headers_and_http_status(valid)
    valid_ok = valid.returncode == 0 and valid_status == 200 and isinstance(valid_json, dict) and isinstance(valid_json.get("items"), list)
    valid_request_id = direct_api_response_request_id(valid_headers)
    findings.append(native_api_probe_finding("pass" if valid_ok else "fail", "native-api-direct.valid-token", "Direct native API accepts the configured bearer token and returns JSON." if valid_ok else "Direct native API did not return JSON for the configured bearer token.", valid, direct_native_api_display_command("/api/v1/reports?page_size=1", token=token, env=env, request_id=client_request_id, include_response_headers=True), valid_json, {"http_status": valid_status, "request_id": valid_request_id, **summarize_native_api_response(valid_json)}))
    findings.append(finding("pass" if valid_ok and valid_request_id == client_request_id else "fail", "native-api-direct.request-id-client", "Direct native API echoes a bounded safe client X-Request-Id on valid-token JSON responses." if valid_ok and valid_request_id == client_request_id else "Direct native API did not echo the safe client X-Request-Id on a valid-token response.", details={"http_status": valid_status, "request_id": valid_request_id}))
    cors_header_names = ("access-control-allow-origin", "access-control-allow-credentials")
    present_cors_headers = {name: valid_headers[name] for name in cors_header_names if name in valid_headers}
    cors_headers_ok = valid_ok and not present_cors_headers
    findings.append(
        finding(
            "pass" if cors_headers_ok else "fail",
            "native-api-direct.cors-disabled",
            "Direct native API valid-token responses do not advertise browser CORS access."
            if cors_headers_ok
