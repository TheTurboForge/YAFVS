def product_data_audit(details: dict[str, Any]) -> dict[str, Any]:
    database = details.get("database", {})
    paths = details.get("paths", {})
    audit: dict[str, Any] = {
        "db_owned_exports": {},
        "unowned_product_data": [],
    }
    for name, path_summary in paths.items():
        if path_summary.get("classification") != "db_owned_export":
            continue
        required_tables = DATA_STATE_DB_OWNED_EXPORT_SOURCES.get(name, ())
        missing_tables = [table for table in required_tables if not database_table_exists(database, table)]
        export = {
            "exists": bool(path_summary.get("exists")),
            "path": path_summary.get("path"),
            "source_of_record": "gvmd/postgresql",
            "required_tables": list(required_tables),
            "missing_tables": missing_tables,
        }
        audit["db_owned_exports"][name] = export
        if export["exists"] and missing_tables:
            audit["unowned_product_data"].append({"path": name, "missing_tables": missing_tables})
    audit["status"] = "warn" if audit["unowned_product_data"] else "pass"
    return audit


