def rust_direct_api_body_limit_summary(repo_root: Path | None) -> dict[str, Any]:
    route_source = rust_native_api_route_source(repo_root, "direct_native_api_router")
    request_shape_source = rust_repo_file_source(repo_root, "services/turbovas-api/src/request_shapes.rs")
    direct_router_body = rust_source_function_body(route_source, "direct_native_api_router")
    properties = {
