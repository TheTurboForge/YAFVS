class RuntimeLockTimeout(TimeoutError):
    """Raised when another runtime command holds a named operation lock."""

    def __init__(self, lock_name: str, operation: str, metadata: dict[str, Any] | None):
        self.lock_name = lock_name
        self.operation = operation
        self.metadata = metadata or {}
        super().__init__(f"Timed out waiting for runtime lock {lock_name!r} for {operation}.")


@dataclass
class RuntimeOperationLock:
    path: Path
    metadata_path: Path
    handle: Any

    def __enter__(self) -> "RuntimeOperationLock":
        return self

    def __exit__(self, exc_type: Any, exc: Any, tb: Any) -> None:
        try:
            self.metadata_path.unlink(missing_ok=True)
        finally:
            fcntl.flock(self.handle.fileno(), fcntl.LOCK_UN)
            self.handle.close()


def runtime_lock_dir(repo_root: Path) -> Path:
    return runtime_path(repo_root, "run", "locks")


def runtime_lock_paths(repo_root: Path, name: str) -> tuple[Path, Path]:
    safe_name = re.sub(r"[^A-Za-z0-9_.-]+", "-", name).strip(".-") or "runtime"
    directory = runtime_lock_dir(repo_root)
    return directory / f"{safe_name}.lock", directory / f"{safe_name}.json"


def read_runtime_lock_metadata(repo_root: Path, name: str) -> dict[str, Any] | None:
    _, metadata_path = runtime_lock_paths(repo_root, name)
    try:
        data = json.loads(metadata_path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None
    return data if isinstance(data, dict) else None


def runtime_lock_status(repo_root: Path, name: str) -> dict[str, Any]:
    lock_path, metadata_path = runtime_lock_paths(repo_root, name)
    metadata = read_runtime_lock_metadata(repo_root, name)
    lock_path.parent.mkdir(parents=True, exist_ok=True)
    with lock_path.open("a+", encoding="utf-8") as handle:
        try:
            fcntl.flock(handle.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
        except BlockingIOError:
            return {
                "name": name,
                "active": True,
                "path": str(lock_path),
                "metadata_path": str(metadata_path),
                "metadata": metadata or {},
            }
        else:
            fcntl.flock(handle.fileno(), fcntl.LOCK_UN)
            return {
                "name": name,
                "active": False,
                "path": str(lock_path),
                "metadata_path": str(metadata_path),
                "metadata": metadata or {},
            }


def acquire_runtime_lock(
    repo_root: Path,
    name: str,
    operation: str,
    *,
    timeout_seconds: int = DEFAULT_RUNTIME_LOCK_TIMEOUT_SECONDS,
) -> RuntimeOperationLock:
    lock_path, metadata_path = runtime_lock_paths(repo_root, name)
    lock_path.parent.mkdir(parents=True, exist_ok=True)
    handle = lock_path.open("a+", encoding="utf-8")
    deadline = time.monotonic() + timeout_seconds
    while True:
        try:
            fcntl.flock(handle.fileno(), fcntl.LOCK_EX | fcntl.LOCK_NB)
            break
        except BlockingIOError:
            if time.monotonic() >= deadline:
                metadata = read_runtime_lock_metadata(repo_root, name)
                handle.close()
                raise RuntimeLockTimeout(name, operation, metadata)
            time.sleep(1)
    metadata = {
        "name": name,
        "operation": operation,
        "pid": os.getpid(),
        "started_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat(),
    }
    metadata_path.write_text(json.dumps(metadata, indent=2, sort_keys=True) + "\n", encoding="utf-8")
    return RuntimeOperationLock(lock_path, metadata_path, handle)


def runtime_lock_timeout_finding(exc: RuntimeLockTimeout, check: str) -> dict[str, Any]:
    return finding(
        "fail",
        check,
        f"Timed out waiting for runtime lock {exc.lock_name!r}; another operation may still be running.",
        details={"operation": exc.operation, "holder": exc.metadata},
    )


def direct_native_api_curl(
    repo_root: Path,
    path: str,
    *,
    token: str | None,
    env: dict[str, str],
    method: str = "GET",
    request_id: str | None = None,
    body: str | None = None,
    extra_headers: Iterable[tuple[str, str]] | None = None,
    include_response_headers: bool = False,
) -> subprocess.CompletedProcess[str]:
    command = ["curl", "-sS", "--max-time", "10", "-w", "\n%{http_code}"]
    if include_response_headers:
        command.extend(["-D", "-"])
    if method != "GET" or body is not None:
        command.extend(["-X", method])
    if token is not None:
        command.extend(["-H", f"Authorization: Bearer {token}"])
    if request_id is not None:
        command.extend(["-H", f"{DIRECT_API_REQUEST_ID_HEADER}: {request_id}"])
    for name, value in extra_headers or ():
        command.extend(["-H", f"{name}: {value}"])
    if body is not None:
        command.extend(["--data-binary", body])
    command.append(f"{native_api_direct_base_url(env)}{path}")
    return run_command(command, repo_root, env=env, timeout=30)


def direct_native_api_display_command(
    path: str,
    *,
    token: str | None,
    env: dict[str, str],
    method: str = "GET",
    request_id: str | None = None,
    body: str | None = None,
    extra_headers: Iterable[tuple[str, str]] | None = None,
    include_response_headers: bool = False,
) -> list[str]:
    command = ["curl", "-sS", "--max-time", "10", "-w", "\\n%{http_code}"]
    if include_response_headers:
        command.extend(["-D", "-"])
    if method != "GET" or body is not None:
        command.extend(["-X", method])
    if token is not None:
        command.extend(["-H", "Authorization: Bearer <redacted>"])
    if request_id is not None:
        command.extend(["-H", f"{DIRECT_API_REQUEST_ID_HEADER}: {request_id}"])
    for name, value in extra_headers or ():
        command.extend(["-H", f"{name}: {value}"])
    if body is not None:
        command.extend(["--data-binary", "<redacted-body>"])
    command.append(f"{native_api_direct_base_url(env)}{path}")
    return command


def direct_native_api_health_probe(
    repo_root: Path,
    env: dict[str, str],
) -> tuple[subprocess.CompletedProcess[str], dict[str, Any] | None, int | None, bool]:
    health = direct_native_api_curl(repo_root, "/healthz", token=None, env=env)
    health_json, health_status = parse_json_output_with_http_status(health)
    health_ok = (
        health.returncode == 0
        and health_status == 200
        and isinstance(health_json, dict)
        and health_json.get("status") == "ok"
    )
    return health, health_json, health_status, health_ok


def wait_for_direct_native_api_health(
    repo_root: Path,
    env: dict[str, str],
    *,
    check: str,
    ready_message: str,
    failed_message: str,
    attempts: int = 20,
    delay_seconds: float = 1.0,
) -> dict[str, Any]:
    last_health: subprocess.CompletedProcess[str] | None = None
    last_health_json: dict[str, Any] | None = None
    last_health_status: int | None = None
    for attempt in range(1, attempts + 1):
        health, health_json, health_status, health_ok = direct_native_api_health_probe(repo_root, env)
        last_health = health
        last_health_json = health_json
        last_health_status = health_status
        if health_ok:
            return native_api_probe_finding(
                "pass",
                check,
                ready_message,
                health,
                direct_native_api_display_command("/healthz", token=None, env=env),
                health_json,
                {"http_status": health_status, "attempt": attempt, "max_attempts": attempts, **summarize_native_api_response(health_json)},
            )
        if attempt < attempts:
            time.sleep(delay_seconds)
    if last_health is None:
        last_health = subprocess.CompletedProcess([], 1, "", "direct native API health probe was not attempted")
    return native_api_probe_finding(
        "fail",
        check,
        failed_message,
        last_health,
        direct_native_api_display_command("/healthz", token=None, env=env),
        last_health_json,
        {"http_status": last_health_status, "attempts": attempts, **summarize_native_api_response(last_health_json)},
    )


def parse_json_output_with_http_status(result: subprocess.CompletedProcess[str]) -> tuple[dict[str, Any] | None, int | None]:
    body, separator, status_text = result.stdout.rstrip().rpartition("\n")
    if not separator:
        return parse_json_output(result), None
    try:
        status_code = int(status_text)
    except ValueError:
        return parse_json_output(result), None
    try:
        parsed = json.loads(body)
    except json.JSONDecodeError:
        return None, status_code
    return (parsed if isinstance(parsed, dict) else None), status_code


def parse_json_output_with_headers_and_http_status(result: subprocess.CompletedProcess[str]) -> tuple[dict[str, Any] | None, int | None, dict[str, str]]:
    payload, separator, status_text = result.stdout.rstrip().rpartition("\n")
    if not separator:
        parsed, status = parse_json_output_with_http_status(result)
        return parsed, status, {}
    try:
        status_code = int(status_text)
    except ValueError:
        parsed, status = parse_json_output_with_http_status(result)
        return parsed, status, {}
    blocks = payload.replace("\r\n", "\n").split("\n\n")
    if len(blocks) < 2:
        try:
            parsed = json.loads(payload)
        except json.JSONDecodeError:
            parsed = None
        return (parsed if isinstance(parsed, dict) else None), status_code, {}
    header_block = blocks[-2]
    body = "\n\n".join(blocks[-1:])
    headers: dict[str, str] = {}
    for line in header_block.splitlines()[1:]:
        name, sep, value = line.partition(":")
        if sep:
            headers[name.strip().lower()] = value.strip()
    try:
        parsed = json.loads(body)
    except json.JSONDecodeError:
        parsed = None
    return (parsed if isinstance(parsed, dict) else None), status_code, headers


