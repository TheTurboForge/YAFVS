def posix_path_within(path: str, parent: str) -> bool:
    candidate = PurePosixPath(path)
    root = PurePosixPath(parent)
    return candidate == root or root in candidate.parents


def normalize_compose_mount_target(target: Any) -> str:
    value = str(target or "")
    if not value.startswith("/") or value.startswith("//"):
        raise ValueError("mount target must be a normalized absolute path")
    if any(part in {".", ".."} for part in value.split("/")):
        raise ValueError("mount target contains dot path components")
    return str(PurePosixPath(value))


def canonical_nofollow_mount_source(source: Any) -> tuple[Path, str]:
    path = Path(str(source or ""))
    if not path.is_absolute():
        raise OSError(errno.EINVAL, "bind source must be absolute")
    parent_fd, canonical_parent = open_absolute_directory_nofollow(path.parent)
    descriptor = -1
    try:
        before = os.stat(path.name, dir_fd=parent_fd, follow_symlinks=False)
        if stat.S_ISLNK(before.st_mode) or not (stat.S_ISDIR(before.st_mode) or stat.S_ISREG(before.st_mode)):
            raise OSError(errno.EINVAL, "bind source is a symlink or special file")
        descriptor = os.open(path.name, os.O_PATH | os.O_CLOEXEC | os.O_NOFOLLOW, dir_fd=parent_fd)
        after = os.fstat(descriptor)
        if (before.st_dev, before.st_ino) != (after.st_dev, after.st_ino):
            raise OSError(errno.ESTALE, "bind source changed while inspecting it")
        return canonical_parent / path.name, "directory" if stat.S_ISDIR(after.st_mode) else "file"
    finally:
        if descriptor >= 0:
            os.close(descriptor)
        os.close(parent_fd)


def app_execution_overlay_contract(repo_root: Path, service_name: str) -> dict[str, tuple[Path, bool]]:
    alias = PurePosixPath(str(repo_root))
    root = runtime_dir(repo_root)
    overlays: dict[str, tuple[Path, bool]] = {}
    if service_name == "gvmd":
        overlays = {
            str(alias / "build" / "run" / "gvmd"): (root / "run" / "gvmd", False),
            str(alias / "build" / "logs"): (root / "logs" / "gvmd", False),
            str(alias / "build" / "var" / "lib" / "gvm" / "gvmd"): (root / "state" / "gvmd", False),
            str(alias / "build" / "var" / "lib" / "gvm" / "gvmd.sem"): (root / "state" / "gvmd-bind-files" / "gvmd.sem", False),
        }
    elif service_name == "ospd-openvas":
        overlays = {
            "/workspace/build/prefix/etc/openvas/openvas.conf": (root / "state" / "ospd" / "openvas.conf", True),
        }
    elif service_name == "gsad":
        overlays = {
            str(alias / "build" / "logs"): (root / "logs" / "gsad", False),
            str(alias / "build" / "run" / "gsad"): (root / "run" / "gsad", False),
        }
    return overlays


def app_execution_mount_finding(repo_root: Path, compose_config: dict[str, Any]) -> dict[str, Any]:
    services = compose_config.get("services", {}) if isinstance(compose_config, dict) else {}
    missing_services: list[str] = []
    violations: list[dict[str, Any]] = []
    validated_mounts: list[dict[str, Any]] = []
    try:
        repo_fd, canonical_repo = open_absolute_directory_nofollow(repo_root)
        os.close(repo_fd)
        runtime_fd, canonical_runtime = open_absolute_directory_nofollow(runtime_dir(repo_root))
        os.close(runtime_fd)
    except OSError as error:
        return finding(
            "fail",
            "production.app-execution-mounts",
            "Canonical repository or runtime mount roots could not be validated.",
            str(compose_file(repo_root).relative_to(repo_root)),
            {"services": list(APP_EXECUTION_MOUNT_SERVICES), "violations": [{"reason": str(error)}]},
        )
    if path_is_within(canonical_runtime, canonical_repo):
        violations.append({"reason": "runtime root is inside the repository", "source": str(canonical_runtime)})

    alias_target = str(PurePosixPath(str(canonical_repo)))
    required_mounts = {
        "/workspace": (canonical_repo, True),
        "/workspace/build": (canonical_repo / "build", True),
        alias_target: (canonical_repo, True),
    }

    for service_name in APP_EXECUTION_MOUNT_SERVICES:
        service = services.get(service_name) if isinstance(services, dict) else None
        if not isinstance(service, dict):
            missing_services.append(service_name)
            continue
        volumes = service.get("volumes", [])
        if not isinstance(volumes, list):
            violations.append({"service": service_name, "reason": "service volumes are not a list"})
            volumes = []
        overlays = app_execution_overlay_contract(canonical_repo, service_name)
        expected_mounts = {**required_mounts, **overlays}
        target_counts: dict[str, int] = {}
        for index, volume in enumerate(volumes):
            if not isinstance(volume, dict):
                violations.append({"service": service_name, "index": index, "reason": "mount entry is not an object"})
                continue
            try:
                target = normalize_compose_mount_target(volume.get("target"))
            except ValueError as error:
                violations.append({"service": service_name, "index": index, "target": str(volume.get("target") or ""), "reason": str(error)})
                continue
            target_counts[target] = target_counts.get(target, 0) + 1
            protected = posix_path_within(target, "/workspace") or posix_path_within(target, alias_target)
            if target not in expected_mounts:
                if protected:
                    violations.append({"service": service_name, "index": index, "target": target, "reason": "non-allowlisted mount is nested under a protected target"})
                elif volume.get("type") == "bind":
                    try:
                        source, _kind = canonical_nofollow_mount_source(volume.get("source"))
                    except OSError:
                        source = None
                    if source is not None and path_is_within(source, canonical_repo):
                        violations.append({"service": service_name, "index": index, "target": target, "reason": "repository source is mounted outside the exact execution-mount contract"})
                continue
            expected_source, expected_read_only = expected_mounts[target]
            if volume.get("type") != "bind":
                violations.append({"service": service_name, "index": index, "target": target, "reason": "protected mount must be a bind mount", "type": volume.get("type")})
                continue
            try:
                source, _kind = canonical_nofollow_mount_source(volume.get("source"))
            except OSError as error:
                violations.append({"service": service_name, "index": index, "target": target, "reason": f"bind source is unsafe: {error}"})
                continue
            if source != Path(os.path.abspath(expected_source)):
                violations.append({"service": service_name, "index": index, "target": target, "source": str(source), "reason": f"bind source must be {expected_source}"})
                continue
            if target in overlays:
                if not path_is_within(source, canonical_runtime) or path_is_within(source, canonical_repo):
                    violations.append({"service": service_name, "index": index, "target": target, "source": str(source), "reason": "runtime overlay source is not canonically outside the repository"})
                    continue
            if bool(volume.get("read_only")) != expected_read_only:
                violations.append({"service": service_name, "index": index, "target": target, "reason": f"read_only must be {str(expected_read_only).lower()}"})
                continue
            validated_mounts.append({"service": service_name, "source": str(source), "target": target, "read_only": expected_read_only})

        for target in expected_mounts:
            count = target_counts.get(target, 0)
            if count != 1:
                violations.append({"service": service_name, "target": target, "count": count, "reason": "required mount must appear exactly once"})

    status = "pass" if not missing_services and not violations else "fail"
    message = (
        "Target-facing application services match the exact source/build mount graph."
        if status == "pass"
        else "One or more target-facing application services violate the exact source/build mount graph."
    )
    return finding(
        status,
        "production.app-execution-mounts",
        message,
        str(compose_file(repo_root).relative_to(repo_root)),
        {
            "services": list(APP_EXECUTION_MOUNT_SERVICES),
            "missing_services": missing_services,
            "violations": violations,
            "validated_mounts": validated_mounts,
        },
    )


def rendered_app_execution_mount_finding(repo_root: Path, env: dict[str, str]) -> dict[str, Any]:
    rendered = run_command(
        compose_command(repo_root, "--profile", "app", "config", "--format", "json", env=env),
        repo_root,
        env=env,
    )
    path = str(compose_file(repo_root).relative_to(repo_root))
    if rendered.returncode != 0:
        return finding(
            "fail",
            "production.app-execution-mounts",
            "Rendered Compose configuration could not be inspected for the exact source/build mount graph.",
            path,
        )
    try:
        payload = json.loads(rendered.stdout)
    except json.JSONDecodeError:
        return finding(
            "fail",
            "production.app-execution-mounts",
            "Rendered Compose configuration was not valid JSON.",
            path,
        )
    return app_execution_mount_finding(repo_root, payload)


def command_up(repo_root: Path) -> dict[str, Any]:
    findings = ensure_runtime_dirs(repo_root)
    findings.extend(ensure_build_runtime_dirs(repo_root))
    config = run_command(compose_command(repo_root, "config", "--quiet"), repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if config.returncode == 0 else "fail", "compose.config", f"Compose config validation exit code {config.returncode}.", str(compose_file(repo_root).relative_to(repo_root)), {"output_tail": config.stdout.splitlines()[-40:]}))
    if aggregate_status(findings) == "fail":
        return make_result("up", repo_root, "Runtime startup stopped before docker compose up.", findings)
    result = run_command(compose_command(repo_root, "up", "-d", "--build", *RUNTIME_SERVICES), repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if result.returncode == 0 else "fail", "compose.up", f"docker compose up exit code {result.returncode}.", details={"output_tail": result.stdout.splitlines()[-80:]}))
    for service in RUNTIME_SERVICES:
        findings.append(finding("pass" if container_running(repo_root, service) else "fail", "runtime.running", f"{service} container is running.", details={"service": service}))
    return make_result("up", repo_root, "Runtime infrastructure startup attempted.", findings)


def command_runtime_init(repo_root: Path) -> dict[str, Any]:
    findings = ensure_runtime_dirs(repo_root)
    config = run_command(compose_command(repo_root, "config", "--quiet"), repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if config.returncode == 0 else "fail", "compose.config", f"Compose config validation exit code {config.returncode}.", str(compose_file(repo_root).relative_to(repo_root)), {"output_tail": config.stdout.splitlines()[-40:]}))
    findings.extend(pg_gvm_artifacts(repo_root)[0])
    if aggregate_status(findings) == "fail":
        return make_result("runtime-init", repo_root, "Runtime initialization stopped before Postgres changes.", findings)

    result = run_command(compose_command(repo_root, "up", "-d", "--build", "postgres"), repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if result.returncode == 0 else "fail", "postgres.up", f"docker compose up postgres exit code {result.returncode}.", details={"output_tail": result.stdout.splitlines()[-80:]}))
    if result.returncode != 0:
        return make_result("runtime-init", repo_root, "Runtime initialization stopped at Postgres startup.", findings)

    ready_result: subprocess.CompletedProcess[str] | None = None
    for _ in range(30):
        ready_result = postgres_ready(repo_root)
        if ready_result.returncode == 0:
            break
        import time

        time.sleep(2)
    findings.append(finding("pass" if ready_result and ready_result.returncode == 0 else "fail", "postgres.ready", f"pg_isready exit code {ready_result.returncode if ready_result else 'unavailable'}.", details={"output_tail": ready_result.stdout.splitlines()[-20:] if ready_result else []}))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-init", repo_root, "Runtime initialization stopped before database setup.", findings)

    findings.extend(ensure_postgres_collation(repo_root))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-init", repo_root, "Runtime initialization stopped at Postgres collation check.", findings)

    findings.extend(copy_pg_gvm_extension(repo_root))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-init", repo_root, "Runtime initialization stopped while installing pg-gvm files.", findings)

    create_dba = psql(repo_root, "DO $$ BEGIN CREATE ROLE dba WITH SUPERUSER NOINHERIT; EXCEPTION WHEN duplicate_object THEN NULL; END $$;")
    findings.append(finding("pass" if create_dba.returncode == 0 else "fail", "postgres.role.dba", f"Create/verify dba role exit code {create_dba.returncode}.", details={"output_tail": create_dba.stdout.splitlines()[-40:]}))
    grant_dba = psql(repo_root, f"GRANT dba TO {sql_identifier(postgres_user(repo_root))};")
    findings.append(finding("pass" if grant_dba.returncode == 0 else "fail", "postgres.role.grant", f"Grant dba to {postgres_user(repo_root)} exit code {grant_dba.returncode}.", details={"output_tail": grant_dba.stdout.splitlines()[-40:]}))
    create_extension = psql(repo_root, f'CREATE EXTENSION IF NOT EXISTS "{PG_GVM_EXTENSION}";')
    findings.append(finding("pass" if create_extension.returncode == 0 else "fail", "postgres.extension.pg-gvm", f"Create/verify pg-gvm extension exit code {create_extension.returncode}.", details={"output_tail": create_extension.stdout.splitlines()[-80:]}))
    findings.append(pg_gvm_extension_status(repo_root))
    return make_result("runtime-init", repo_root, "Runtime database initialization completed.", findings, [str(runtime_dir(repo_root)), "build/prefix"])


def _command_runtime_scanner_redis_init_unlocked(
    repo_root: Path,
    probe_openvas: bool = True,
    *,
    app_image_ids: dict[str, str] | None = None,
) -> dict[str, Any]:
    findings = ensure_runtime_dirs(repo_root)
    config = run_command(compose_command(repo_root, "config", "--quiet"), repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if config.returncode == 0 else "fail", "compose.config", f"Compose config validation exit code {config.returncode}.", str(compose_file(repo_root).relative_to(repo_root)), {"output_tail": output_tail(config.stdout, 40)}))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-scanner-redis-init", repo_root, "Scanner Redis initialization stopped before service startup.", findings, [str(runtime_dir(repo_root))])

    result = run_command(compose_command(repo_root, "up", "-d", "redis-openvas"), repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if result.returncode == 0 else "fail", "redis-openvas.up", f"docker compose up redis-openvas exit code {result.returncode}.", details={"output_tail": output_tail(result.stdout, 80)}))
    if result.returncode != 0:
        return make_result("runtime-scanner-redis-init", repo_root, "Scanner Redis initialization stopped at service startup.", findings, [str(runtime_dir(repo_root))])

    ping: subprocess.CompletedProcess[str] | None = None
    for _ in range(20):
        if container_running(repo_root, "redis-openvas"):
            ping = scanner_redis_ping(repo_root)
            if ping.returncode == 0 and "PONG" in ping.stdout:
                break
        time.sleep(1)
    findings.append(finding("pass" if ping and ping.returncode == 0 and "PONG" in ping.stdout else "fail", "redis-openvas.ready", f"scanner Redis Unix socket ping exit code {ping.returncode if ping else 'unavailable'}.", str(scanner_redis_socket_path(repo_root)), {"output_tail": output_tail(ping.stdout if ping else "", 20)}))

    config_path = write_openvas_runtime_config(repo_root)
    config_artifact = str(config_path.relative_to(runtime_dir(repo_root)))
    findings.append(finding("pass", "openvas.config", "OpenVAS runtime config points db_address and feed plugin paths to runtime state.", config_artifact))
    if not probe_openvas:
        findings.append(finding("pass", "openvas.config-probe", "OpenVAS settings probe deferred until app services are built and started."))
        return make_result("runtime-scanner-redis-init", repo_root, "Scanner Redis initialization completed.", findings, [str(runtime_dir(repo_root)), config_artifact])
    if app_image_ids is None:
        receipt, image_error = require_app_deployment_receipt(
            repo_root, app_env=deployed_app_env(repo_root)
        )
        if image_error is not None or receipt is None:
            findings.append(finding("fail", "compose.app-images", image_error))
            return make_result("runtime-scanner-redis-init", repo_root, "Scanner Redis initialization stopped because a verified application deployment receipt is unavailable.", findings, [str(runtime_dir(repo_root))])
        app_image_ids = receipt["image_ids"]
    findings.append(finding("pass", "compose.app-images", "OpenVAS settings probe uses prepared application images without building."))
    openvas_settings = run_app_oneoff(
        repo_root,
        "ospd-openvas",
        ["openvas", "-s"],
        no_deps=False,
        app_image_ids=app_image_ids,
    )
    db_lines = [line for line in openvas_settings.stdout.splitlines() if line.startswith("db_address")]
    plugin_lines = [line for line in openvas_settings.stdout.splitlines() if line.startswith("plugins_folder")]
    include_lines = [line for line in openvas_settings.stdout.splitlines() if line.startswith("include_folders")]
    db_ok = openvas_settings.returncode == 0 and any("/runtime/run/redis-openvas/redis.sock" in line for line in db_lines)
    plugins_ok = openvas_settings.returncode == 0 and any("/runtime/feeds/openvas/plugins" in line for line in plugin_lines)
    include_ok = openvas_settings.returncode == 0 and any("/runtime/feeds/openvas/plugins" in line for line in include_lines)
    findings.append(finding("pass" if db_ok else "fail", "openvas.db_address", f"openvas -s runtime db_address check exit code {openvas_settings.returncode}.", details={"db_address_lines": db_lines, "output_tail": output_tail(openvas_settings.stdout, 80)}))
    findings.append(finding("pass" if plugins_ok else "fail", "openvas.plugins_folder", f"openvas -s runtime plugins_folder check exit code {openvas_settings.returncode}.", details={"plugins_folder_lines": plugin_lines, "output_tail": output_tail(openvas_settings.stdout, 80)}))
    findings.append(finding("pass" if include_ok else "fail", "openvas.include_folders", f"openvas -s runtime include_folders check exit code {openvas_settings.returncode}.", details={"include_folders_lines": include_lines, "output_tail": output_tail(openvas_settings.stdout, 80)}))
    return make_result("runtime-scanner-redis-init", repo_root, "Scanner Redis initialization completed.", findings, [str(runtime_dir(repo_root)), config_artifact])


def command_runtime_scanner_redis_init(
    repo_root: Path,
    probe_openvas: bool = True,
    *,
    lifecycle_managed: bool = False,
    app_image_ids: dict[str, str] | None = None,
) -> dict[str, Any]:
    if lifecycle_managed:
        return _command_runtime_scanner_redis_init_unlocked(
            repo_root, probe_openvas, app_image_ids=app_image_ids
        )
