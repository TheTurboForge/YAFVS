def native_target_csv_exact_item(parsed: dict[str, Any] | None, name: str, *, allowed_types: frozenset[str] | None = None) -> list[dict[str, Any]]:
    if not isinstance(parsed, dict) or not isinstance(parsed.get("items"), list):
        return []
    matches: list[dict[str, Any]] = []
    for item in parsed["items"]:
        if not isinstance(item, dict) or item.get("name") != name:
            continue
        credential_type = item.get("credential_type")
        if allowed_types is not None and credential_type not in allowed_types:
            continue
        matches.append(item)
    return matches


def native_target_csv_direct_get(
    repo_root: Path,
    path: str,
    *,
    token: str,
    env: dict[str, str],
) -> tuple[subprocess.CompletedProcess[str], dict[str, Any] | None, int | None]:
    response = direct_native_api_curl(repo_root, path, token=token, env=env)
    parsed, http_status = parse_json_output_with_http_status(response)
    return response, parsed, http_status


def native_target_csv_fetch_exact_items(
    repo_root: Path,
    base_path: str,
    name: str,
    *,
    token: str,
    env: dict[str, str],
    allowed_types: frozenset[str] | None = None,
) -> tuple[list[dict[str, Any]], dict[str, Any] | None]:
    matches: list[dict[str, Any]] = []
    page = 1
    page_size = 100
    encoded_name = urllib.parse.quote(name)
    while True:
        separator = "&" if "?" in base_path else "?"
        path = f"{base_path}{separator}filter={encoded_name}&page={page}&page_size={page_size}"
        response, parsed, http_status = native_target_csv_direct_get(repo_root, path, token=token, env=env)
        if response.returncode != 0 or http_status != 200 or not isinstance(parsed, dict) or not isinstance(parsed.get("items"), list):
            return matches, {"reason": "lookup failed", "http_status": http_status, "page": page, **summarize_native_api_response(parsed)}
        matches.extend(native_target_csv_exact_item(parsed, name, allowed_types=allowed_types))
        page_info = parsed.get("page") if isinstance(parsed.get("page"), dict) else {}
        total = page_info.get("total") if isinstance(page_info.get("total"), int) else len(parsed["items"])
        actual_page_size = page_info.get("page_size") if isinstance(page_info.get("page_size"), int) and page_info.get("page_size") else page_size
        actual_page = page_info.get("page") if isinstance(page_info.get("page"), int) and page_info.get("page") else page
        if actual_page * actual_page_size >= total or not parsed["items"]:
            return matches, None
        page += 1
        if page > 1000:
            return matches, {"reason": "lookup pagination exceeded safety limit", "page": page, "total": total}


NATIVE_TAG_CSV_RESOURCE_TYPES: dict[str, str] = {
    "ALERT": "alert",
    "CONFIG": "config",
    "CREDENTIAL": "credential",
    "SCANNER": "scanner",
    "SCHEDULE": "schedule",
    "TARGET": "target",
    "TASK": "task",
}
NATIVE_TAG_CSV_UNSUPPORTED_INHERITED_TYPES = frozenset({"REPORT"})


@dataclass(frozen=True)
