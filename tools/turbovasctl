def command_runtime_webui_smoke(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    static_dir = gsad_static_dir(repo_root)
    index_path = static_dir / "index.html"
    config_path = static_dir / "config.js"
    findings.append(finding("pass" if index_path.is_file() else "fail", "webui.static-index", "Staged GSA index.html exists." if index_path.is_file() else "Staged GSA index.html is missing; run just build-ui.", str(index_path)))
    findings.append(finding("pass" if config_path.is_file() else "fail", "webui.static-config", "Staged GSA config.js exists." if config_path.is_file() else "Staged GSA config.js is missing; run just build-ui.", str(config_path)))
    findings.extend(runtime_gsa_freshness_findings(repo_root))

    index_text = index_path.read_text(encoding="utf-8") if index_path.is_file() else ""
    asset_rel = first_gsa_asset_rel(index_text)
    findings.append(finding("pass" if asset_rel else "fail", "webui.static-asset-ref", f"Found GSA asset reference {asset_rel}." if asset_rel else "No GSA asset reference found in index.html.", str(index_path)))

    for base_url in gsad_base_urls(repo_root):
        index_http = run_command(["curl", "-kfsS", "--max-time", "10", f"{base_url}/"], repo_root, env=runtime_env(repo_root))
        findings.append(finding("pass" if index_http.returncode == 0 and '<div id="app">' in index_http.stdout else "fail", "webui.http-index", f"GSA index HTTP probe exit code {index_http.returncode}.", details={"url": f"{base_url}/", "output_tail": output_tail(index_http.stdout, 40)}))

        config_http = run_command(["curl", "-kfsS", "--max-time", "10", f"{base_url}/config.js"], repo_root, env=runtime_env(repo_root))
        expected_api_server = "apiServer: window.location.host"
        findings.append(finding("pass" if config_http.returncode == 0 and expected_api_server in config_http.stdout else "fail", "webui.http-config", f"GSA config.js HTTP probe exit code {config_http.returncode}.", details={"url": f"{base_url}/config.js", "expected": expected_api_server, "output_tail": output_tail(config_http.stdout, 40)}))

        if asset_rel:
            asset_http = run_command(["curl", "-kfsS", "--max-time", "10", "-o", "/dev/null", f"{base_url}/{asset_rel}"], repo_root, env=runtime_env(repo_root))
            findings.append(finding("pass" if asset_http.returncode == 0 else "fail", "webui.http-asset", f"GSA asset HTTP probe exit code {asset_http.returncode}.", details={"url": f"{base_url}/{asset_rel}", "output_tail": output_tail(asset_http.stdout, 40)}))

    return make_result("runtime-webui-smoke", repo_root, "Runtime web UI smoke checks completed.", findings, [str(static_dir), *gsad_base_urls(repo_root)])


def command_runtime_browser_smoke(repo_root: Path, routes: list[str] | None = None) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    secret_path = runtime_secret_path(repo_root, DEV_ADMIN_SECRET)
    probe = runtime_browser_smoke_probe_path(repo_root)
    artifact_parent_dir = browser_smoke_artifact_dir(repo_root)
    artifact_dir = browser_smoke_run_artifact_dir(repo_root, routes)
    findings.append(finding("pass" if secret_path.is_file() else "fail", "runtime.admin-secret", "Development admin secret exists." if secret_path.is_file() else "Development admin secret is missing.", str(secret_path)))
    findings.append(finding("pass" if probe.is_file() else "fail", "browser-smoke.probe", "Browser smoke helper exists." if probe.is_file() else "Browser smoke helper is missing.", str(probe.relative_to(repo_root)) if probe.exists() else str(probe)))
    findings.append(finding("pass" if shutil.which("node") else "fail", "node.available", "node is available for Playwright browser smoke." if shutil.which("node") else "node is not available on PATH."))
    try:
        artifact_dir.mkdir(parents=True, exist_ok=True)
        probe_file = artifact_dir / ".turbovas-write-test"
        probe_file.write_text("ok\n", encoding="utf-8")
        probe_file.unlink()
        findings.append(finding("pass", "browser-smoke.artifact-dir", "Browser smoke per-run artifact directory is ready.", str(artifact_dir), {"parent": str(artifact_parent_dir), "routes": list(routes or [])}))
    except OSError as error:
        findings.append(finding("fail", "browser-smoke.artifact-dir", f"Browser smoke artifact directory is not usable: {error}", str(artifact_dir)))

    base_urls = gsad_base_urls(repo_root)
    findings.append(finding("pass" if base_urls else "fail", "gsad.urls", "Configured gsad base URLs are available." if base_urls else "No gsad base URLs are configured.", details={"base_urls": list(base_urls)}))
    findings.extend(runtime_gsa_freshness_findings(repo_root))
    findings.append(browser_gmp_readiness_finding(repo_root, check="browser-smoke.gmp-ready"))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-browser-smoke", repo_root, "Runtime browser smoke stopped at prerequisites.", findings, [str(artifact_dir)])

    scope_report_path, expect_result_row, scope_target_finding = native_scope_report_browser_target(
        repo_root,
        "browser-smoke.scope-report-target",
        "Latest Organization scope-report route selected for browser smoke.",
        "Latest Organization scope-report route could not be resolved; browser smoke will use the first visible link.",
    )
    findings.append(scope_target_finding)

    args = [
        sys.executable,
        str(probe),
        "--username",
        DEV_ADMIN_USER,
        "--password-file",
        str(secret_path),
        "--artifact-dir",
        str(artifact_dir),
    ]
    if scope_report_path:
        args.extend(["--scope-report-path", scope_report_path])
    if expect_result_row:
        args.append("--expect-result-row")
    for route in routes or []:
        args.extend(["--route", route])
    for base_url in base_urls:
        args.extend(["--base-url", base_url])
    result = run_command(args, repo_root, env=runtime_env(repo_root), timeout=420)
    try:
        parsed = json.loads(result.stdout.strip().splitlines()[-1])
    except (IndexError, json.JSONDecodeError):
        parsed = None
    helper_status = parsed.get("status") if parsed else None
    finding_status = helper_status if result.returncode == 0 and helper_status in {"pass", "warn"} else "fail"
    password = secret_path.read_text(encoding="utf-8").strip() if secret_path.is_file() else ""
    findings.append(
        finding(
            finding_status,
            "browser-smoke.run",
            parsed.get("summary", f"Browser smoke helper exit code {result.returncode}.") if parsed else f"Browser smoke helper exit code {result.returncode}.",
            details={"helper": parsed, "output_tail": output_tail(result.stdout, 120, [password])},
        )
    )
    artifacts = list(parsed.get("artifacts", [])) if parsed and isinstance(parsed.get("artifacts"), list) else [str(artifact_dir)]
    summary = parsed.get("summary") if parsed else f"Runtime browser smoke completed with exit code {result.returncode}."
    return make_result("runtime-browser-smoke", repo_root, summary, findings, artifacts)


