[Unit]
Description=Run the TurboVAS local quality gate daily
Documentation=file:@REPO_ROOT@/README.md

[Timer]
OnCalendar=*-*-* 03:30:00
Persistent=true
RandomizedDelaySec=20m
Unit=turbovas-quality-gate.service

[Install]
WantedBy=timers.target
