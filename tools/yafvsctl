def _command_runtime_app_up_unlocked(repo_root: Path, status_only: bool = False) -> dict[str, Any]:
    findings = ensure_runtime_dirs(repo_root)
    findings.extend(ensure_build_runtime_dirs(repo_root))
    findings.append(active_feed_generation_selector_journal_finding(repo_root))
    app_env = deployed_app_env(repo_root)
    receipt, receipt_error = require_app_deployment_receipt(
        repo_root, app_env=app_env
    )
    app_image_ids = receipt["image_ids"] if receipt is not None else {}
    findings.append(
        finding(
            "pass" if receipt_error is None else "fail",
            "runtime.app-deployment-receipt",
            "Prepared application deployment receipt matches the current images and runtime artifacts."
            if receipt_error is None
            else receipt_error,
            str(app_deployment_receipt_path(repo_root)),
            {"image_ids": app_image_ids},
        )
    )
    config = run_command(compose_command(repo_root, "config", "--quiet", env=app_env), repo_root, env=app_env)
    findings.append(finding("pass" if config.returncode == 0 else "fail", "compose.config", f"Compose config validation exit code {config.returncode}.", str(compose_file(repo_root).relative_to(repo_root)), {"output_tail": output_tail(config.stdout, 40)}))
    findings.append(rendered_app_execution_mount_finding(repo_root, app_env))
    if aggregate_status(findings) == "fail":
        result = make_result("runtime-app-up", repo_root, "Application runtime startup stopped at mount prerequisites.", findings, [str(runtime_dir(repo_root))])
        return runtime_app_up_status_only_result(result) if status_only else result
    infra = command_up(repo_root)
    findings.append(finding(infra["status"], "runtime.infrastructure", infra["summary"], details={"status": infra["status"]}))
    findings.append(refresh_mqtt_broker(repo_root))
    db_init = command_runtime_init(repo_root)
    findings.append(finding(db_init["status"], "runtime.database-init", db_init["summary"], details={"status": db_init["status"]}))
    findings.append(active_feed_generation_finding(repo_root))
    if aggregate_status(findings) == "fail":
        result = make_result(
            "runtime-app-up",
            repo_root,
            "Application runtime startup stopped because the database import attestation is unavailable or inconsistent.",
            findings,
            [str(runtime_dir(repo_root))],
        )
        return runtime_app_up_status_only_result(result) if status_only else result
    scanner_redis = command_runtime_scanner_redis_init(
        repo_root, probe_openvas=False, lifecycle_managed=True
    )
    findings.append(finding(scanner_redis["status"], "runtime.scanner-redis", scanner_redis["summary"], details={"status": scanner_redis["status"]}))
    keyring = command_runtime_feed_keyring_init(repo_root)
    findings.append(finding(keyring["status"], "runtime.feed-keyring", keyring["summary"], details={"status": keyring["status"]}))
    cert_findings = cert_file_findings(repo_root)
    if not certs_complete(repo_root):
        cert_findings = [dict(item, status="fail") for item in cert_findings]
    findings.extend(cert_findings)
    findings.extend(gsad_binding_transition_findings(repo_root))
    if receipt_error is None:
        try:
            override_command = compose_command_with_app_images(
                repo_root,
                app_image_ids,
                "--profile",
                "app",
                "config",
                "--quiet",
                env=app_env,
            )
            override_config = run_command(
                override_command, repo_root, env=app_env, timeout=120
            )
        except (OSError, ValueError) as error:
            findings.append(finding("fail", "compose.app-image-override", f"Pinned application image override could not be prepared: {error}"))
        else:
            findings.append(
                process_step_finding(
                    "pass" if override_config.returncode == 0 else "fail",
                    "compose.app-image-override",
                    f"Pinned application image Compose validation exit code {override_config.returncode}.",
                    override_config,
                    override_command,
                )
            )
    if aggregate_status(findings) == "fail":
        result = make_result("runtime-app-up", repo_root, "Application runtime startup stopped at prerequisites.", findings, [str(runtime_dir(repo_root))])
        return runtime_app_up_status_only_result(result) if status_only else result

    pre_start_identity = [
        app_runtime_artifact_finding(
            repo_root,
            receipt["runtime_artifacts"],
            check="runtime.app.artifacts-before-start",
        ),
        app_compose_contract_finding(
            repo_root,
            app_image_ids,
            receipt["compose_contract"],
            app_env=app_env,
            check="runtime.app.compose-before-start",
        ),
    ]
    findings.extend(pre_start_identity)
    if aggregate_status(pre_start_identity) == "fail":
        result = make_result("runtime-app-up", repo_root, "Application runtime startup stopped because deployment identity changed before container start.", findings, [str(runtime_dir(repo_root))])
        return runtime_app_up_status_only_result(result) if status_only else result

    findings.extend(
        compose_app_services_up_with_retry(
            repo_root,
            "compose.app-up",
            "docker compose app up",
            app_env=app_env,
            app_image_ids=app_image_ids,
        )
    )
    findings.extend(
        app_service_image_findings(
            repo_root, app_image_ids, check="runtime.app.image"
        )
    )
    post_start_identity = [
        app_runtime_artifact_finding(
            repo_root,
            receipt["runtime_artifacts"],
            check="runtime.app.artifacts-after-start",
        ),
        app_compose_contract_finding(
            repo_root,
            app_image_ids,
            receipt["compose_contract"],
            app_env=app_env,
            check="runtime.app.compose-after-start",
        ),
    ]
    findings.extend(post_start_identity)
    if aggregate_status(post_start_identity) == "fail":
        findings.append(
            stop_app_services_after_identity_failure(
                repo_root,
                app_env=app_env,
                check="runtime.app.identity-failure-stop",
            )
        )
        result = make_result("runtime-app-up", repo_root, "Application deployment identity changed during startup; application services were stopped.", findings, [str(runtime_dir(repo_root))])
        return runtime_app_up_status_only_result(result) if status_only else result
    for service in APP_SERVICES:
        running = container_running(repo_root, service)
        findings.append(finding("pass" if running else "warn", "runtime.app.running", f"{service} container is {'running' if running else 'not running'}.", details={"service": service, "logs_tail": [] if running else service_log_tail(repo_root, service)}))
    control_socket = runtime_dir(repo_root) / "run" / "gvmd-control" / "yafvs-control.sock"
    wait_for_socket(control_socket, timeout_seconds=20)
    findings.append(
        socket_readiness_finding(
            "runtime.gvmd-control-socket",
            "gvmd native control",
            control_socket,
            missing_status="fail",
        )
    )
    result = make_result("runtime-app-up", repo_root, "Application runtime startup attempted.", findings, [str(runtime_dir(repo_root))])
    return runtime_app_up_status_only_result(result) if status_only else result


