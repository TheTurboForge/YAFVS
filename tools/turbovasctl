            "native-api-direct.scope-write-update",
            "native-api-direct.scope-write-delete",
            "native-api-direct.scope-write-post-delete",
            "native-api-direct.tag-write-create",
            "native-api-direct.tag-write-update",
            "native-api-direct.tag-write-query-denied",
            "native-api-direct.tag-delete-body-denied",
            "native-api-direct.tag-write-delete",
            "native-api-direct.tag-write-post-delete",
            "native-api-direct.write-control-restore",
