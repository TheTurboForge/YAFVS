def stage_gsa_static(repo_root: Path) -> list[dict[str, Any]]:
    findings: list[dict[str, Any]] = []
    source = gsa_build_dir(repo_root)
    destination = gsad_static_dir(repo_root)
    index = source / "index.html"
    findings.append(finding("pass" if index.is_file() else "fail", "gsa.build.index", "GSA production build index.html exists." if index.is_file() else "GSA production build is missing index.html; run just build-ui.", str(index)))
    if aggregate_status(findings) == "fail":
        return findings
    if destination.exists():
        shutil.rmtree(destination)
    destination.parent.mkdir(parents=True, exist_ok=True)
    shutil.copytree(source, destination)
    config_js = destination / "config.js"
    fallback_api_server = f"{gsad_host(repo_root)}:{GSAD_PORT}"
    config_js.write_text(
        "config = {\n"
        "  apiProtocol: (window.location.protocol || 'https:').replace(':', ''),\n"
        f"  apiServer: window.location.host || '{fallback_api_server}',\n"
        "};\n",
        encoding="utf-8",
    )
    findings.append(finding("pass", "gsa.static-stage", "GSA production build is staged for gsad.", str(destination)))
    findings.append(finding("pass", "gsa.config-js", "GSA config.js uses the browser host with a fallback gsad endpoint.", str(config_js), {"api_protocol": "browser", "api_server_fallback": fallback_api_server, "hosts": list(gsad_hosts(repo_root))}))
    return findings


def gsa_freshness_should_skip_source_file(path: Path) -> bool:
    parts = set(path.parts)
    if "__tests__" in parts or "__mocks__" in parts:
        return True
    return path.name.endswith(GSA_FRESHNESS_SKIP_FILE_SUFFIXES)


def path_latest_mtime(path: Path, *, skip_dirs: frozenset[str] = frozenset(), skip_file: Callable[[Path], bool] | None = None) -> float | None:
    try:
        if path.is_file():
            if skip_file and skip_file(path):
                return None
            return path.stat().st_mtime
        if not path.is_dir():
            return None
    except OSError:
        return None
    latest: float | None = None
    for root, dirs, files in os.walk(path):
        dirs[:] = [dirname for dirname in dirs if dirname not in skip_dirs]
        root_path = Path(root)
        for filename in files:
            candidate = root_path / filename
            if skip_file and skip_file(candidate):
                continue
            try:
                mtime = candidate.stat().st_mtime
            except OSError:
                continue
            latest = mtime if latest is None else max(latest, mtime)
    return latest


def paths_latest_mtime(repo_root: Path, rel_paths: Iterable[str], *, skip_dirs: frozenset[str] = frozenset(), skip_file: Callable[[Path], bool] | None = None) -> tuple[float | None, str | None]:
    latest: float | None = None
    latest_path: str | None = None
    for rel_path in rel_paths:
        mtime = path_latest_mtime(repo_root / rel_path, skip_dirs=skip_dirs, skip_file=skip_file)
        if mtime is None:
            continue
        if latest is None or mtime > latest:
            latest = mtime
            latest_path = rel_path
    return latest, latest_path


def iso_mtime(mtime: float | None) -> str | None:
    return datetime.fromtimestamp(mtime, timezone.utc).replace(microsecond=0).isoformat() if mtime is not None else None


def parse_container_started_at(value: Any) -> float | None:
    if not isinstance(value, str) or not value:
        return None
    try:
        parsed = datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        return None
    return parsed.timestamp()


def runtime_gsa_freshness_findings(repo_root: Path) -> list[dict[str, Any]]:
    findings: list[dict[str, Any]] = []
    staged = gsad_static_dir(repo_root)
    staged_latest, staged_latest_path = paths_latest_mtime(repo_root, (str(staged.relative_to(repo_root)),)) if staged.exists() else (None, None)
    source_latest, source_latest_path = paths_latest_mtime(repo_root, GSA_FRESHNESS_SOURCE_PATHS, skip_dirs=GSA_FRESHNESS_SKIP_DIRS, skip_file=gsa_freshness_should_skip_source_file)
    if staged_latest is not None and source_latest is not None and source_latest > staged_latest:
        findings.append(
            finding(
                "warn",
                "gsa.static-freshness",
                "GSA source inputs are newer than staged gsad static assets; run just build-ui before browser validation.",
                str(staged),
                {
                    "latest_source_path": source_latest_path,
                    "latest_source_mtime": iso_mtime(source_latest),
                    "latest_staged_path": staged_latest_path,
                    "latest_staged_mtime": iso_mtime(staged_latest),
                },
            )
        )
    elif staged_latest is not None:
        findings.append(finding("pass", "gsa.static-freshness", "Staged GSA static assets are not older than tracked GSA source inputs.", str(staged), {"latest_staged_mtime": iso_mtime(staged_latest), "latest_source_mtime": iso_mtime(source_latest)}))

    gsad_state = docker_container_state(repo_root, "gsad")
    started_at = parse_container_started_at(gsad_state.get("StartedAt") if gsad_state else None)
    gsad_source_latest, gsad_source_latest_path = paths_latest_mtime(repo_root, GSAD_FRESHNESS_SOURCE_PATHS)
    gsad_build_latest, gsad_build_latest_path = paths_latest_mtime(repo_root, GSAD_FRESHNESS_BUILD_PATHS)
    compare_latest = max([value for value in (staged_latest, gsad_source_latest, gsad_build_latest) if value is not None], default=None)
    if started_at is not None and compare_latest is not None and compare_latest > started_at:
        findings.append(
            finding(
                "warn",
                "gsad.runtime-freshness",
                "Running gsad predates relevant static or native-proxy build inputs; run just build-c-services, just build-ui, then refresh runtime-app-up before browser validation.",
                details={
                    "container_id": gsad_state.get("container_id") if gsad_state else None,
                    "started_at": gsad_state.get("StartedAt") if gsad_state else None,
                    "latest_gsad_source_path": gsad_source_latest_path,
                    "latest_gsad_source_mtime": iso_mtime(gsad_source_latest),
                    "latest_gsad_build_path": gsad_build_latest_path,
                    "latest_gsad_build_mtime": iso_mtime(gsad_build_latest),
                    "latest_staged_mtime": iso_mtime(staged_latest),
                },
            )
        )
    elif started_at is not None:
