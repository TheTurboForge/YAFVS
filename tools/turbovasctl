    findings = [
        finding("pass" if artifacts["control"].is_file() else "fail", "pg-gvm.control", f"{PG_GVM_CONTROL} is available in build/prefix.", str(artifacts["control"].relative_to(repo_root)) if artifacts["control"].exists() else str(artifacts["control"])),
        finding("pass" if library.is_file() else "fail", "pg-gvm.library", f"{PG_GVM_LIBRARY} is available in build/prefix.", str(library.relative_to(repo_root)) if library.exists() else str(library)),
        finding("pass" if sql_files else "fail", "pg-gvm.sql", "pg-gvm extension SQL files are available in build/prefix.", details={"files": [str(path.relative_to(repo_root)) for path in sql_files]}),
    ]
