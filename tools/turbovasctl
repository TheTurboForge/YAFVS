    result = run_command([str(python), str(probe), "--socket", str(socket_path), "--username", DEV_ADMIN_USER, "--password-file", str(secret_path)], repo_root, env=build_env(repo_root), timeout=60)
    try:
        parsed = json.loads(result.stdout)
    except json.JSONDecodeError:
        parsed = None
    probe_status = parsed.get("status") if parsed else None
    findings.append(finding("pass" if result.returncode == 0 and probe_status == "pass" else "fail", "gvmd.gmp", f"python-gvm authenticated get_version exit code {result.returncode}.", details={"probe": parsed, "output_tail": output_tail(result.stdout, 60)}))
    return make_result("runtime-gmp-smoke", repo_root, "Runtime GMP smoke completed.", findings, [str(runtime_dir(repo_root))])


def command_runtime_scanner_register(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    socket_path = ospd_socket_path(repo_root)
    findings.append(finding("pass" if socket_path.is_socket() else "fail", "ospd.socket", "ospd-openvas socket is ready." if socket_path.is_socket() else "ospd-openvas socket is not ready; run just runtime-app-up and inspect ospd-openvas logs.", str(socket_path)))
    gmp_smoke = command_runtime_gmp_smoke(repo_root)
    findings.append(finding(gmp_smoke["status"], "gvmd.gmp", gmp_smoke["summary"], details={"status": gmp_smoke["status"]}))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-scanner-register", repo_root, "Scanner registration stopped at prerequisites.", findings, [str(runtime_dir(repo_root))])

    scanners = run_gvmd_oneoff(repo_root, ["--get-scanners"], no_deps=False)
    scanner_uuid = parse_named_uuid(scanners.stdout, "OpenVAS Default") if scanners.returncode == 0 else None
    findings.append(finding("pass" if scanners.returncode == 0 else "fail", "gvmd.get-scanners", f"gvmd --get-scanners exit code {scanners.returncode}.", details={"scanner_uuid": scanner_uuid, "output_tail": output_tail(scanners.stdout, 80)}))
    if scanners.returncode != 0:
        return make_result("runtime-scanner-register", repo_root, "Scanner registration stopped while listing scanners.", findings, [str(runtime_dir(repo_root))])

    scanner_args = [
        "--scanner-name=OpenVAS Default",
        "--scanner-type=OpenVAS",
        "--scanner-host=/runtime/run/ospd/ospd-openvas.sock",
        "--scanner-port=0",
        "--no-default-certs",
    ]
    if scanner_uuid:
        change = run_gvmd_oneoff(repo_root, [f"--modify-scanner={scanner_uuid}", *scanner_args], no_deps=False)
        findings.append(finding("pass" if change.returncode == 0 else "fail", "gvmd.modify-scanner", f"Modify OpenVAS Default scanner exit code {change.returncode}.", details={"scanner_uuid": scanner_uuid, "output_tail": output_tail(change.stdout, 80)}))
    else:
        change = run_gvmd_oneoff(repo_root, ["--create-scanner=OpenVAS Default", *scanner_args[1:]], no_deps=False)
        scanner_uuid = parse_named_uuid(change.stdout, "OpenVAS Default") or parse_named_uuid(change.stdout, "Scanner")
        findings.append(finding("pass" if change.returncode == 0 else "fail", "gvmd.create-scanner", f"Create OpenVAS Default scanner exit code {change.returncode}.", details={"scanner_uuid": scanner_uuid, "output_tail": output_tail(change.stdout, 80)}))

    scanners_after = run_gvmd_oneoff(repo_root, ["--get-scanners"], no_deps=False)
    scanner_uuid = parse_named_uuid(scanners_after.stdout, "OpenVAS Default") if scanners_after.returncode == 0 else scanner_uuid
    findings.append(finding("pass" if scanner_uuid else "fail", "gvmd.scanner.openvas-default", "OpenVAS Default scanner is registered." if scanner_uuid else "OpenVAS Default scanner registration could not be confirmed.", details={"scanner_uuid": scanner_uuid, "output_tail": output_tail(scanners_after.stdout, 80)}))
    if scanner_uuid:
        verify = run_gvmd_oneoff(repo_root, [f"--verify-scanner={scanner_uuid}"], no_deps=False)
        findings.append(finding("pass" if verify.returncode == 0 else "warn", "gvmd.verify-scanner", f"Verify OpenVAS Default scanner exit code {verify.returncode}.", details={"scanner_uuid": scanner_uuid, "output_tail": output_tail(verify.stdout, 100)}))
    return make_result("runtime-scanner-register", repo_root, "Runtime scanner registration completed.", findings, [str(runtime_dir(repo_root))])


