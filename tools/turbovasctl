    findings.append(
        native_api_probe_finding(
            "pass" if feeds_ok else "fail",
            "native-api.feeds",
            "Native API feed inventory probe returned fixed feed metadata/status rows."
            if feeds_ok
            else "Native API feed inventory probe failed or returned unexpected payload data.",
            feeds,
            compose_command(repo_root, "exec", "-T", "turbovas-api", "curl", "-fsS", "http://127.0.0.1:9080/api/v1/feeds"),
            feeds_json,
            {"expected_types": sorted(expected_feed_types), "observed_types": sorted(str(item) for item in feed_item_types), **summarize_native_api_response(feeds_json)},
        )
    )

    if source_file_contains(repo_root, "services/turbovas-api/src/read_api_routes.rs", '.route("/api/v1/trashcan/summary"'):
