def native_api_gsad_proxy_methods(repo_root: Path | None) -> tuple[list[str], list[str]]:
    if repo_root is None:
        return [], ["missing_repo_root"]
    relative_path = "components/gsad/src/gsad_http_handle_request.c"
    try:
        source = (repo_root / relative_path).read_text(encoding="utf-8")
    except OSError:
        return [], [f"missing_source:{relative_path}"]

    if '"^/api/v1/.+$"' not in source:
        return [], ["missing_native_api_url_handler"]

    methods: set[str] = set()
    if (
        "gsad_http_method_handler_new_get (native_api_get_handler)" in source
        or "gsad_http_method_handler_new_with_handlers (native_api_get_handler" in source
        or "gsad_http_method_handler_new_with_patch_handler (native_api_get_handler" in source
        or "gsad_http_method_handler_new_with_delete_handler (native_api_get_handler" in source
        or "gsad_http_method_handler_new_with_put_and_delete_handler (native_api_get_handler" in source
    ):
        methods.add("GET")
    if "gsad_http_method_handler_new_post (native_api_post_handler)" in source or "native_api_post_handler" in source:
        methods.add("POST")
    if "native_api_patch_handler" in source:
        methods.add("PATCH")
    if "native_api_put_handler" in source:
        methods.add("PUT")
    if "native_api_delete_handler" in source or "gsad_http_method_handler_new_with_delete_handler" in source:
        methods.add("DELETE")
    return sorted(methods), [] if methods else ["missing_native_api_method_handler"]


def native_api_browser_proxy_contract_summary(repo_root: Path | None, endpoints: list[dict[str, Any]]) -> dict[str, Any]:
    def item_status(item: dict[str, Any]) -> str:
        return native_api_effective_browser_proxy_status(repo_root, item)

    browser_proxied = sorted(
        item["endpoint"]
        for item in endpoints
        if isinstance(item.get("endpoint"), str)
        and native_api_browser_access_from_status(item_status(item)) == "browser_proxied"
    )
    internal_only = sorted(
        item["endpoint"]
        for item in endpoints
        if isinstance(item.get("endpoint"), str)
        and native_api_browser_access_from_status(item_status(item)) == "internal_only"
    )
    browser_write_proxied = sorted(
        f"{str(item.get('method', '')).upper()} {item['endpoint']}"
        for item in endpoints
        if isinstance(item.get("endpoint"), str)
        and str(item.get("method", "get")).lower() != "get"
        and native_api_browser_access_from_status(item_status(item)) == "browser_proxied"
    )
    direct_write_control = sorted(
        f"{str(item.get('method', '')).upper()} {item['endpoint']}"
        for item in endpoints
        if isinstance(item.get("endpoint"), str)
        and item.get("direct_access") == "direct_write_control"
    )
    browser_delete_proxy_design = sorted(
        f"DELETE {item['endpoint']}"
        for item in endpoints
        if isinstance(item.get("endpoint"), str)
        and str(item.get("method", "get")).lower() == "delete"
        and item.get("direct_access") == "direct_write_control"
        and native_api_browser_access_from_status(item_status(item)) != "browser_proxied"
    )
    openapi_internal_only = sorted(
        f"/api/v1{operation.get('path')}"
        for operation in openapi_contract_operations(repo_root)
        if isinstance(operation.get("path"), str)
        and operation.get("method") == "get"
        and isinstance(operation.get("x_yafvs_values"), dict)
        and operation["x_yafvs_values"].get("x-yafvs-exposure") == "internal-only"
    )
    gsad_allowed, parse_errors = native_api_gsad_proxy_allowlist_templates(repo_root)
    gsad_write_allowed, write_parse_errors = native_api_gsad_proxy_write_allowlist_operations(repo_root)
    gsad_methods, method_errors = native_api_gsad_proxy_methods(repo_root)

    browser_by_normalized = {normalize_native_api_endpoint_template(endpoint): endpoint for endpoint in browser_proxied}
    internal_by_normalized = {normalize_native_api_endpoint_template(endpoint): endpoint for endpoint in openapi_internal_only}
    internal_by_normalized.update({normalize_native_api_endpoint_template(endpoint): endpoint for endpoint in internal_only})
    gsad_by_normalized = {normalize_native_api_endpoint_template(endpoint): endpoint for endpoint in gsad_allowed}
    for operation in gsad_write_allowed:
        _method, separator, endpoint = operation.partition(" ")
        if separator and endpoint:
            gsad_by_normalized.setdefault(normalize_native_api_endpoint_template(endpoint), endpoint)
    browser_write_by_normalized = {normalize_native_api_operation_template(operation): operation for operation in browser_write_proxied}
    gsad_write_by_normalized = {normalize_native_api_operation_template(operation): operation for operation in gsad_write_allowed}

    missing_gsad = [browser_by_normalized[key] for key in sorted(set(browser_by_normalized) - set(gsad_by_normalized))]
    missing_gsad_write = [browser_write_by_normalized[key] for key in sorted(set(browser_write_by_normalized) - set(gsad_write_by_normalized))]
    unexpected_gsad_write = [gsad_write_by_normalized[key] for key in sorted(set(gsad_write_by_normalized) - set(browser_write_by_normalized))]
    internal_only_in_gsad = [internal_by_normalized[key] for key in sorted(set(internal_by_normalized) & set(gsad_by_normalized))]
    unexpected_gsad = [gsad_by_normalized[key] for key in sorted(set(gsad_by_normalized) - set(browser_by_normalized) - set(internal_by_normalized))]
    write_boundary_drift = method_errors or (browser_write_proxied and gsad_methods == ["GET"])
    drift = parse_errors or write_parse_errors or missing_gsad or missing_gsad_write or unexpected_gsad or unexpected_gsad_write or internal_only_in_gsad or write_boundary_drift
    return {
        "alignment_status": "pass" if not drift else "warn",
        "browser_proxied_count": len(browser_proxied),
        "browser_write_proxy_count": len(browser_write_proxied),
        "direct_write_control_count": len(direct_write_control),
        "internal_only_count": len(internal_only),
        "openapi_internal_only_count": len(openapi_internal_only),
        "gsad_proxy_allowlist_count": len(gsad_allowed),
        "gsad_proxy_methods": gsad_methods,
        "gsad_proxy_method_parse_errors": method_errors,
        "gsad_proxy_write_allowlist_operations": gsad_write_allowed,
        "gsad_proxy_write_parse_errors": write_parse_errors,
        "write_proxy_boundary_status": "pass" if not write_boundary_drift else "warn",
        "write_proxy_requires_design": bool(direct_write_control and gsad_methods == ["GET"]),
        "browser_delete_proxy_requires_design": bool(browser_delete_proxy_design),
        "browser_proxied_endpoints": browser_proxied,
        "browser_write_proxy_operations": browser_write_proxied,
        "browser_delete_proxy_design_operations": browser_delete_proxy_design,
        "direct_write_control_operations": direct_write_control,
        "internal_only_endpoints": internal_only,
        "openapi_internal_only_endpoints": openapi_internal_only,
        "gsad_proxy_allowlist_endpoints": gsad_allowed,
        "missing_gsad_proxy_allowlist": missing_gsad,
        "missing_gsad_proxy_write_allowlist": missing_gsad_write,
        "unexpected_gsad_proxy_allowlist": unexpected_gsad,
        "unexpected_gsad_proxy_write_allowlist": unexpected_gsad_write,
        "internal_only_gsad_proxy_allowlist": internal_only_in_gsad,
        "parse_errors": parse_errors,
    }


def annotate_native_tooling_direct_api(summary: dict[str, Any], repo_root: Path | None) -> None:
    endpoints = summary.get("implemented_native_endpoints", [])
    if not isinstance(endpoints, list):
        summary["direct_api_contract"] = native_api_direct_contract_summary(repo_root, [])
        return
    for item in endpoints:
        if isinstance(item, dict) and isinstance(item.get("endpoint"), str):
            item.setdefault("direct_access", native_api_direct_access(item["endpoint"]))
            effective_status = native_api_effective_browser_proxy_status(repo_root, item)
            if effective_status != str(item.get("status", "unknown")):
                item["status"] = effective_status
    summary["direct_api_contract"] = native_api_direct_contract_summary(repo_root, [item for item in endpoints if isinstance(item, dict)])


def native_api_endpoint_declared(repo_root: Path | None, endpoint: str) -> bool:
    normalized = normalize_native_api_endpoint_template(endpoint)
    return normalized in {
        normalize_native_api_endpoint_template(route)
        for route in rust_native_api_route_templates(repo_root)
    }


def native_browser_proxy_endpoint_status(repo_root: Path | None, endpoint: str) -> str:
    if repo_root is None:
        return "planned_internal_and_browser_proxied"
    api_declared = native_api_endpoint_declared(repo_root, endpoint)
    normalized = normalize_native_api_endpoint_template(endpoint)
    proxy_declared = normalized in {
        normalize_native_api_endpoint_template(template)
        for template in native_api_gsad_proxy_allowlist_templates(repo_root)[0]
    }
    if api_declared and proxy_declared:
        return "implemented_internal_and_browser_proxied"
    if api_declared or proxy_declared:
        return "partial_internal_browser_proxy_mismatch"
    return "planned_internal_and_browser_proxied"


def native_api_effective_browser_proxy_status(repo_root: Path | None, item: dict[str, Any]) -> str:
    status = str(item.get("status", "unknown"))
    endpoint = item.get("endpoint")
    method = str(item.get("method", "get")).lower()
    if method == "get" or not isinstance(endpoint, str):
        return status
    if item.get("direct_access") == "browser_write":
        if repo_root is None:
            return "planned_internal_and_browser_proxied"
        direct_declared = rust_native_api_route_operation_declared(
            repo_root, method, endpoint, "direct_native_api_router"
        )
        proxy_declared = rust_native_api_route_operation_declared(
            repo_root, method, endpoint, "browser_proxy_native_api_router"
        )
        if proxy_declared and not direct_declared:
            return "implemented_internal_and_browser_proxied"
        if proxy_declared or direct_declared:
            return "partial_internal_browser_proxy_mismatch"
        return "planned_internal_and_browser_proxied"
    operation_status = native_browser_proxy_operation_status(repo_root, method, endpoint)
    return status if operation_status == "planned_internal_and_browser_proxied" else operation_status


def native_browser_proxy_operation_status(repo_root: Path | None, method: str, endpoint: str) -> str:
    if method.lower() == "get":
        return native_browser_proxy_endpoint_status(repo_root, endpoint)
    if repo_root is None:
        return "planned_internal_and_browser_proxied"
    api_declared = rust_native_api_route_operation_declared(
        repo_root,
        method,
        endpoint,
        "direct_native_api_router",
    )
    proxy_declared = rust_native_api_route_operation_declared(
        repo_root,
        method,
        endpoint,
        "browser_proxy_native_api_router",
    )
    if api_declared and proxy_declared:
        return "implemented_internal_and_browser_proxied"
    if api_declared:
        return "implemented_direct_write_control"
    if proxy_declared:
        return "partial_internal_browser_proxy_mismatch"
    return "planned_internal_and_browser_proxied"


