        item["endpoint"]
        for item in endpoints
        if isinstance(item.get("endpoint"), str)
        and native_api_browser_access_from_status(str(item.get("status", "unknown"))) == "internal_only"
    )
    openapi_internal_only = sorted(
        f"/api/v1{operation.get('path')}"
        for operation in openapi_contract_operations(repo_root)
        if isinstance(operation.get("path"), str)
        and operation.get("method") == "get"
        and isinstance(operation.get("x_turbovas_values"), dict)
        and operation["x_turbovas_values"].get("x-turbovas-exposure") == "internal-only"
    )
    gsad_allowed, parse_errors = native_api_gsad_proxy_allowlist_templates(repo_root)

    browser_by_normalized = {normalize_native_api_endpoint_template(endpoint): endpoint for endpoint in browser_proxied}
