    arguments.extend(["--mode", mode, "--diff-scope", diff_scope])
    if modified_imported_only:
        arguments.append("--modified-imported-only")
    if status_only:
        arguments.append("--status-only")
    return rust_result_envelope(repo_root, "license-report", arguments)


def rust_runtime_data_state_result(repo_root: Path) -> dict[str, Any]:
    command = [
        "cargo",
        "run",
        "--quiet",
        "--locked",
        "--target-dir",
        str(repo_root / "build" / "yafvsctl-rs"),
        "--manifest-path",
        str(repo_root / YAFVSCTL_RUST_CRATE / "Cargo.toml"),
        "--",
        "runtime-data-state",
        "--json",
    ]
    try:
        completed = run_command(command, repo_root, timeout=300)
        stdout = completed.stdout
        if not isinstance(stdout, str) or len(stdout.encode("utf-8")) > YAFVSCTL_RUST_BRIDGE_MAX_OUTPUT_BYTES:
            raise ValueError("invalid Rust runtime data-state output")
        payload = json.loads(stdout, object_pairs_hook=reject_duplicate_json_object_keys)
        if not isinstance(payload, dict):
            raise ValueError("invalid Rust runtime data-state envelope")
        status = payload.get("status")
        findings = payload.get("findings")
        if (
            status not in STATUSES
            or not isinstance(payload.get("summary"), str)
            or not isinstance(findings, list)
            or not isinstance(payload.get("artifacts"), list)
            or not all(isinstance(artifact, str) for artifact in payload["artifacts"])
            or not isinstance(payload.get("details"), dict)
            or not isinstance(payload.get("metadata"), dict)
            or payload["metadata"].get("command") != "runtime-data-state"
            or completed.returncode != (1 if status == "fail" else 0)
        ):
            raise ValueError("invalid Rust runtime data-state envelope")
        for item in findings:
            if (
                not isinstance(item, dict)
                or item.get("status") not in STATUSES
                or not isinstance(item.get("check"), str)
                or not isinstance(item.get("message"), str)
            ):
                raise ValueError("invalid Rust runtime data-state finding")
        if aggregate_status(findings) != status:
            raise ValueError("invalid Rust runtime data-state aggregate status")
        return payload
    except (OSError, subprocess.SubprocessError, json.JSONDecodeError, ValueError, UnicodeError):
        return make_result(
            "runtime-data-state",
            repo_root,
            "Rust runtime data-state diagnostic result was unavailable or invalid.",
            [
                finding(
                    "fail",
                    "data-state.rust-bridge",
                    "Rust runtime data-state diagnostic failed closed because its result was unavailable or invalid.",
                )
            ],
        )


