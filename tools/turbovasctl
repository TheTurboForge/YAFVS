def load_native_tag_csv_rows(csv_file: Path) -> list[NativeTagCsvRow]:
    rows: list[NativeTagCsvRow] = []
    try:
        with csv_file.open(encoding="utf-8", newline="") as handle:
            reader = csv.reader(handle, delimiter=",")
            for row_number, row in enumerate(reader, start=1):
                if not row:
                    continue
                if len(row) < 3:
                    raise ValueError(f"row {row_number} must include tag type, tag value, and description")
                inherited_type = row[0].strip().upper()
                tag_value = row[1].strip()
                description = row[2].strip()
                if not inherited_type or not tag_value:
                    raise ValueError(f"row {row_number} must include tag type and tag value")
                if inherited_type in NATIVE_TAG_CSV_UNSUPPORTED_INHERITED_TYPES:
                    raise ValueError(
                        f"row {row_number} uses inherited {inherited_type} tag semantics that are not native-safe yet"
                    )
                resource_type = NATIVE_TAG_CSV_RESOURCE_TYPES.get(inherited_type)
                if resource_type is None:
                    supported = ", ".join(sorted(NATIVE_TAG_CSV_RESOURCE_TYPES))
                    raise ValueError(f"row {row_number} has unsupported tag type {inherited_type}; supported native-safe types: {supported}")
                resource_names = tuple(cell.strip() for cell in row[3:13] if cell.strip())
                tag_name = f"{tag_value}:{description}:{inherited_type}"
                rows.append(
                    NativeTagCsvRow(
                        row_number=row_number,
                        inherited_type=inherited_type,
                        resource_type=resource_type,
                        tag_value=tag_value,
                        description=description,
                        tag_name=tag_name,
                        resource_names=resource_names,
                    )
                )
    except OSError as exc:
        raise ValueError(f"failed to read tag CSV file: {exc}") from exc
    if not rows:
        raise ValueError("tag CSV file is empty")
    return rows


