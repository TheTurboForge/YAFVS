  <command>
    <name>get_resource_names</name>
    <summary>Get one or many names and IDs for items of given type</summary>
    <description>
      The client uses the get_resource_names command to get the
      names and IDs for items of the given type.
    </description>
    <pattern>
      <attrib>
        <name>type</name>
        <summary>
        Type must be one of ALERT, CERT_BUND_ADV, CONFIG, CPE, CREDENTIAL, CVE,
        DFN_CERT_ADV, FILTER, GROUP, HOST, NOTE, NVT, OS, OVERRIDE, PERMISSION,
        PORT_LIST, REPORT_FORMAT, REPORT, RESULT, ROLE, SCANNER,
        SCHEDULE, TARGET, TASK, TLS_CERTIFICATE or USER</summary>
        <type>text</type>
        <required>1</required>
      </attrib>
      <attrib>
        <name>resource_id</name>
        <summary>ID of single resource to get</summary>
        <type>text</type>
      </attrib>
      <attrib>
        <name>filter</name>
        <summary>Filter term to use to filter query</summary>
        <type>text</type>
        <filter_keywords>
          <option>
            <name>first</name>
            <type>integer</type>
            <summary>
              Index of the first item returned, starting at 1 (e.g. first=5
              starts at the 5th item)
            </summary>
          </option>
          <option>
            <name>rows</name>
            <type>integer</type>
            <summary>Number of items to return</summary>
          </option>
          <option>
            <name>sort</name>
            <type>text</type>
            <summary>Column to sort by in ascending order</summary>
          </option>
          <option>
            <name>sort-reverse</name>
            <type>text</type>
            <summary>Column to sort by in descending order</summary>
          </option>
          <column>
            <name>uuid</name>
            <type>uuid</type>
            <summary>Unique ID</summary>
          </column>
          <column>
            <name>name</name>
            <type>name</type>
            <summary>Name</summary>
          </column>
          <column>
            <name>owner</name>
            <type>name</type>
            <summary>Name of the owner</summary>
          </column>
        </filter_keywords>
      </attrib>
    </pattern>
    <response>
      <pattern>
        <attrib>
          <name>status</name>
          <type>status</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>status_text</name>
          <type>text</type>
          <required>1</required>
        </attrib>
        <e>type</e>
        <any><e>resource</e></any>
      </pattern>
      <ele>
        <name>type</name>
        <summary>The type of the resource</summary>
        <pattern><t>type</t></pattern>
      </ele>
      <ele>
        <name>resource</name>
        <pattern>
          <attrib>
            <name>id</name>
            <type>integer</type>
            <summary>A unique number identifying the resource, if available</summary>
          </attrib>
          <e>name</e>
        </pattern>
        <ele>
          <name>name</name>
          <summary>The name of the resource</summary>
          <pattern><t>name</t></pattern>
        </ele>
      </ele>
    </response>
    <example>
      <summary>Get all resource names for operating systems</summary>
      <request>
        <get_resource_names type="os" filter="first=1, rows=-1"/>
      </request>
      <response>
        <get_resource_names_response status_text="OK" status="200">
          <type>os</type>
          <resource id="5b6b6aef-b320-42ca-899f-3161ee2a4195">
            <name>cpe:/h:hp:jetdirect</name>
          </resource>
          <resource id="5be25864-9249-431e-8a91-039e334371ad">
            <name>cpe:/o:canonical:ubuntu_linux:18.04</name>
          </resource>
          <resource id="89ccbfe3-9bbb-4c99-b4c7-fb85ca021093">
            <name>cpe:/o:canonical:ubuntu_linux:8.04</name>
          </resource>
          <resource id="f2fa6833-fe34-4e04-a60c-6c5dc1ed0fcf">
            <name>cpe:/o:debian:debian_linux</name>
          </resource>
          <resource id="d29f3e4e-07e0-4eb6-b040-5e179f890784">
            <name>cpe:/o:debian:debian_linux:8</name>
          </resource>
          <resource id="2aa54229-0041-492f-8c81-df0289563512">
            <name>cpe:/o:debian:debian_linux:9</name>
          </resource>
          <resource id="39ff8a64-54c2-405d-8e95-7b086e9a3eca">
            <name>cpe:/o:linux:kernel</name>
          </resource>
          <resource id="19c091f0-a687-4dc3-b482-7d191ead4bb3">
            <name>cpe:/o:microsoft:windows</name>
          </resource>
        </get_resource_names_response>
      </response>
    </example>
  </command>
  <command>
    <name>get_settings</name>
    <summary>Get one or many settings</summary>
    <description>
      <p>
        The client uses the get_settings command to get the settings.
      </p>
    </description>
    <pattern>
      <attrib>
        <name>setting_id</name>
        <summary>ID of single setting to get</summary>
        <type>uuid</type>
      </attrib>
      <attrib>
        <name>filter</name>
        <summary>Filter term</summary>
        <type>text</type>
        <filter_keywords>
          <option>
            <name>first</name>
            <type>integer</type>
            <summary>
              Index of the first item returned, starting at 1 (e.g. first=5
              starts at the 5th item)
            </summary>
          </option>
          <option>
            <name>rows</name>
            <type>integer</type>
            <summary>Number of items to return</summary>
          </option>
          <option>
            <name>sort</name>
            <type>text</type>
            <summary>Column to sort by in ascending order</summary>
          </option>
          <option>
            <name>sort-reverse</name>
            <type>text</type>
            <summary>Column to sort by in descending order</summary>
          </option>
          <column>
            <name>name</name>
            <type>name</type>
            <summary>Name</summary>
          </column>
          <column>
            <name>comment</name>
            <type>text</type>
            <summary>Comment text</summary>
          </column>
          <column>
            <name>value</name>
            <type>text</type>
            <summary>Current value of the setting</summary>
          </column>
        </filter_keywords>
      </attrib>
      <attrib>
        <name>first</name>
        <summary>First result</summary>
        <type>integer</type>
      </attrib>
      <attrib>
        <name>max</name>
        <summary>Maximum number of results in response</summary>
        <type>integer</type>
      </attrib>
      <attrib>
        <name>sort_order</name>
        <type>sort_order</type>
      </attrib>
      <attrib>
        <name>sort_field</name>
        <type>text</type>
      </attrib>
    </pattern>
    <response>
      <pattern>
        <attrib>
          <name>status</name>
          <type>status</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>status_text</name>
          <type>text</type>
          <required>1</required>
        </attrib>
        <e>filters</e>
        <e>settings</e>
        <any><e>setting</e></any>
        <e>setting_count</e>
      </pattern>
      <ele>
        <name>filters</name>
        <pattern>
          <e>term</e>
        </pattern>
        <ele>
          <name>term</name>
          <summary>Filter term</summary>
          <pattern>text</pattern>
        </ele>
      </ele>
      <ele>
        <name>settings</name>
        <pattern>
          <attrib>
            <name>start</name>
            <summary>First setting</summary>
            <type>integer</type>
            <required>1</required>
          </attrib>
          <attrib>
            <name>max</name>
            <summary>Maximum number of settings</summary>
            <type>integer</type>
            <required>1</required>
          </attrib>
        </pattern>
      </ele>
      <ele>
        <name>setting</name>
        <pattern>
          <e>name</e>
          <e>comment</e>
          <e>value</e>
        </pattern>
        <ele>
          <name>name</name>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>comment</name>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>value</name>
          <pattern>text</pattern>
        </ele>
      </ele>
      <ele>
        <name>setting_count</name>
        <pattern>
          <e>filtered</e>
          <e>page</e>
        </pattern>
        <ele>
          <name>filtered</name>
          <summary>Number of settings after filtering</summary>
          <pattern><t>integer</t></pattern>
        </ele>
        <ele>
          <name>page</name>
          <summary>Number of settings on current page</summary>
          <pattern><t>integer</t></pattern>
        </ele>
      </ele>
    </response>
    <example>
      <summary>Get one or many settings</summary>
      <request>
        <get_settings></get_settings>
      </request>
      <response>
        <get_settings_response status="200" status_text="OK">
          <settings>
            <setting id="5f5a8712-8017-11e1-8556-406186ea4fc5">
              <name>Rows Per Page</name>
              <value>15</value>
            </setting>
          </settings>
        </get_settings_response>
      </response>
    </example>
  </command>
  <command>
    <name>get_targets</name>
    <summary>Get one or many targets</summary>
    <description>
      The client uses the get_targets command to get target information.
    </description>
    <pattern>
      <attrib>
        <name>target_id</name>
        <summary>ID of single target to get</summary>
        <type>uuid</type>
      </attrib>
      <attrib>
        <name>filter</name>
        <summary>Filter term to use to filter query</summary>
        <type>text</type>
        <filter_keywords>
          <option>
            <name>first</name>
            <type>integer</type>
            <summary>
              Index of the first item returned, starting at 1 (e.g. first=5
              starts at the 5th item)
            </summary>
          </option>
          <option>
            <name>rows</name>
            <type>integer</type>
            <summary>Number of items to return</summary>
          </option>
          <option>
            <name>sort</name>
            <type>text</type>
            <summary>Column to sort by in ascending order</summary>
          </option>
          <option>
            <name>sort-reverse</name>
            <type>text</type>
            <summary>Column to sort by in descending order</summary>
          </option>
          <column>
            <name>tag</name>
            <type>text</type>
            <summary>
              Name and optional "=" separted value of an attached tag
              (e.g. "mytag" or "mytag=myvalue")
            </summary>
          </column>
          <column>
            <name>tag_id</name>
            <type>UUID</type>
            <summary>
              UUID of an attached tag
            </summary>
          </column>
          <column>
            <name>uuid</name>
            <type>uuid</type>
            <summary>Unique ID</summary>
          </column>
          <column>
            <name>name</name>
            <type>name</type>
            <summary>Name</summary>
          </column>
          <column>
            <name>comment</name>
            <type>text</type>
            <summary>Comment text</summary>
          </column>
          <column>
            <name>created</name>
            <type>iso_time</type>
            <summary>Creation time</summary>
          </column>
          <column>
            <name>modified</name>
            <type>iso_time</type>
            <summary>Modification time</summary>
          </column>
          <column>
            <name>owner</name>
            <type>name</type>
            <summary>Name of the owner</summary>
          </column>
          <column>
            <name>hosts</name>
            <type>text</type>
            <summary>Comma-separated list of hosts</summary>
          </column>
          <column>
            <name>exclude_hosts</name>
            <type>text</type>
            <summary>Comma-separated list of excluded hosts</summary>
          </column>
          <column>
            <name>ips</name>
            <type>integer</type>
            <summary>Number of hosts</summary>
          </column>
          <column>
            <name>port_list</name>
            <type>name</type>
            <summary>Name of the port list</summary>
          </column>
          <column>
            <name>ssh_credential</name>
            <type>name</type>
            <summary>Name of the SSH credential</summary>
          </column>
          <column>
            <name>smb_credential</name>
            <type>name</type>
            <summary>Name of the SMB credential</summary>
          </column>
          <column>
            <name>esxi_credential</name>
            <type>name</type>
            <summary>Name of the ESXi credential</summary>
          </column>
          <column>
            <name>snmp_credential</name>
            <type>name</type>
            <summary>Name of the SNMP credential</summary>
          </column>
          <column>
            <name>ssh_elevate_credential</name>
            <type>name</type>
            <summary>Name of the SSH credential to elevate privileges after initial login</summary>
          </column>
        </filter_keywords>
      </attrib>
      <attrib>
        <name>filt_id</name>
        <summary>ID of filter to use to filter query</summary>
        <type>uuid</type>
      </attrib>
      <attrib>
        <name>trash</name>
        <summary>Whether to get the trashcan targets instead</summary>
        <type>boolean</type>
      </attrib>
      <attrib>
        <name>tasks</name>
        <summary>Whether to include list of tasks that use the target</summary>
        <type>boolean</type>
      </attrib>
      <attrib>
        <name>details</name>
        <summary>Whether to include port range and tag info</summary>
        <type>boolean</type>
      </attrib>
    </pattern>
    <response>
      <pattern>
        <attrib>
          <name>status</name>
          <type>status</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>status_text</name>
          <type>text</type>
          <required>1</required>
        </attrib>
        <any><e>target</e></any>
        <e>filters</e>
        <e>sort</e>
        <e>targets</e>
        <e>target_count</e>
      </pattern>
      <ele>
        <name>target</name>
        <pattern>
          <attrib>
            <name>id</name>
            <type>uuid</type>
            <required>1</required>
          </attrib>
          <e>owner</e>
          <e>name</e>
          <e>comment</e>
          <e>creation_time</e>
          <e>modification_time</e>
          <e>writable</e>
          <e>in_use</e>
          <e>permissions</e>
          <o><e>user_tags</e></o>
          <e>hosts</e>
          <e>exclude_hosts</e>
          <e>max_hosts</e>
          <e>ssh_credential</e>
          <e>smb_credential</e>
          <e>esxi_credential</e>
          <e>krb5_credential</e>
          <e>snmp_credential</e>
          <e>ssh_elevate_credential</e>
          <e>permissions</e>
          <e>port_range</e>
          <e>port_list</e>
          <e>alive_tests</e>
          <e>reverse_lookup_only</e>
          <e>reverse_lookup_unify</e>
          <e>allow_simultaneous_ips</e>
          <o><e>tasks</e></o>
        </pattern>
        <ele>
          <name>owner</name>
          <summary>Owner of the target</summary>
          <pattern>
            <e>name</e>
          </pattern>
          <ele>
            <name>name</name>
            <summary>The name of the owner</summary>
            <pattern><t>name</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>name</name>
          <summary>The name of the target</summary>
          <pattern><t>name</t></pattern>
        </ele>
        <ele>
          <name>comment</name>
          <summary>The comment on the target</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>creation_time</name>
          <summary>Date and time the target was created</summary>
          <pattern><t>iso_time</t></pattern>
        </ele>
        <ele>
          <name>modification_time</name>
          <summary>Date and time the target was last modified</summary>
          <pattern><t>iso_time</t></pattern>
        </ele>
        <ele>
          <name>hosts</name>
          <summary>A list of hosts</summary>
          <pattern>
            text
          </pattern>
        </ele>
        <ele>
          <name>exclude_hosts</name>
          <summary>A list of hosts to exclude</summary>
          <pattern>
            text
          </pattern>
        </ele>
        <ele>
          <name>max_hosts</name>
          <summary>The maximum number of hosts defined by the target</summary>
          <pattern>
            <t>integer</t>
          </pattern>
        </ele>
        <ele>
          <name>writable</name>
          <summary>Whether the target is writable</summary>
          <pattern><t>boolean</t></pattern>
        </ele>
        <ele>
          <name>in_use</name>
          <summary>Whether any tasks are using the target</summary>
          <pattern><t>boolean</t></pattern>
        </ele>
        <ele>
          <name>permissions</name>
          <summary>
            Permissions that the current user has on the target
          </summary>
          <pattern>
            <any><e>permission</e></any>
          </pattern>
          <ele>
            <name>permission</name>
            <pattern>
              <e>name</e>
            </pattern>
            <ele>
              <name>name</name>
              <summary>The name of the permission</summary>
              <pattern><t>name</t></pattern>
            </ele>
          </ele>
        </ele>
        <ele>
          <name>user_tags</name>
          <summary>Info on tags attached to the target</summary>
          <pattern>
            <e>count</e>
            <any><e>tag</e></any>
          </pattern>
          <ele>
            <name>count</name>
            <summary>Number of attached tags</summary>
            <pattern><t>integer</t></pattern>
          </ele>
          <ele>
            <name>tag</name>
            <summary>
              Short info on an individual tag
              (only if details were requested)
            </summary>
            <pattern>
              <attrib>
                <name>id</name>
                <type>uuid</type>
                <summary>UUID of the tag</summary>
                <required>1</required>
              </attrib>
              <e>name</e>
              <e>value</e>
              <e>comment</e>
            </pattern>
            <ele>
              <name>name</name>
              <summary>Name of the tag (usually namespace:predicate)</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>value</name>
              <summary>Value of the tag</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>comment</name>
              <summary>Comment for the tag</summary>
              <pattern>text</pattern>
            </ele>
          </ele>
        </ele>
        <ele>
          <name>ssh_credential</name>
          <pattern>
            <attrib>
              <name>id</name>
              <comment>
                A UUID if there is a credential, otherwise the empty string
              </comment>
              <type>uuid_or_empty</type>
              <required>1</required>
            </attrib>
            <e>name</e>
            <o><e>permissions</e></o>
            <e>port</e>
            <e>trash</e>
          </pattern>
          <ele>
            <name>name</name>
            <summary>The name of the SSH LSC credential</summary>
            <pattern><t>name</t></pattern>
          </ele>
          <ele>
            <name>permissions</name>
            <summary>Permissions the user has on the credential</summary>
            <pattern></pattern>
          </ele>
          <ele>
            <name>port</name>
            <summary>The port the LSCs will use</summary>
            <pattern>text</pattern>
          </ele>
          <ele>
            <name>trash</name>
            <summary>Whether the LSC credential is in the trashcan</summary>
            <pattern><t>boolean</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>smb_credential</name>
          <pattern>
            <attrib>
              <name>id</name>
              <comment>
                A UUID if there is a credential, otherwise the empty string
              </comment>
              <type>uuid_or_empty</type>
              <required>1</required>
            </attrib>
            <e>name</e>
            <o><e>permissions</e></o>
            <e>trash</e>
          </pattern>
          <ele>
            <name>name</name>
            <summary>The name of the SMB LSC credential</summary>
            <pattern><t>name</t></pattern>
          </ele>
          <ele>
            <name>permissions</name>
            <summary>Permissions the user has on the credential</summary>
            <pattern></pattern>
          </ele>
          <ele>
            <name>trash</name>
            <summary>Whether the LSC credential is in the trashcan</summary>
            <pattern><t>boolean</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>esxi_credential</name>
          <pattern>
            <attrib>
              <name>id</name>
              <comment>
                A UUID if there is a credential, otherwise the empty string
              </comment>
              <type>uuid_or_empty</type>
              <required>1</required>
            </attrib>
            <e>name</e>
            <o><e>permissions</e></o>
            <e>trash</e>
          </pattern>
          <ele>
            <name>name</name>
            <summary>The name of the ESXi LSC credential</summary>
            <pattern><t>name</t></pattern>
          </ele>
          <ele>
            <name>permissions</name>
            <summary>Permissions the user has on the credential</summary>
            <pattern></pattern>
          </ele>
          <ele>
            <name>trash</name>
            <summary>Whether the LSC credential is in the trashcan</summary>
            <pattern><t>boolean</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>krb5_credential</name>
          <pattern>
            <attrib>
              <name>id</name>
              <comment>
                A UUID if there is a credential, otherwise the empty string
              </comment>
              <type>uuid_or_empty</type>
              <required>1</required>
            </attrib>
            <e>name</e>
            <o><e>permissions</e></o>
            <e>trash</e>
          </pattern>
          <ele>
            <name>name</name>
            <summary>The name of the Kerberos 5 LSC credential</summary>
            <pattern><t>name</t></pattern>
          </ele>
          <ele>
            <name>permissions</name>
            <summary>Permissions the user has on the credential</summary>
            <pattern></pattern>
          </ele>
          <ele>
            <name>trash</name>
            <summary>Whether the LSC credential is in the trashcan</summary>
            <pattern><t>boolean</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>snmp_credential</name>
          <pattern>
            <attrib>
              <name>id</name>
              <comment>
                A UUID if there is a credential, otherwise the empty string
              </comment>
              <type>uuid_or_empty</type>
              <required>1</required>
            </attrib>
            <e>name</e>
            <o><e>permissions</e></o>
            <e>trash</e>
          </pattern>
          <ele>
            <name>name</name>
            <summary>The name of the SNMP credential</summary>
            <pattern><t>name</t></pattern>
          </ele>
          <ele>
            <name>permissions</name>
            <summary>Permissions the user has on the credential</summary>
            <pattern></pattern>
          </ele>
          <ele>
            <name>trash</name>
            <summary>Whether the credential is in the trashcan</summary>
            <pattern><t>boolean</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>ssh_elevate_credential</name>
          <summary>
            SSH LSC credential used to elevate privileges after initial login
          </summary>
          <pattern>
            <attrib>
              <name>id</name>
              <comment>
                A UUID if there is a credential, otherwise the empty string
              </comment>
              <type>uuid_or_empty</type>
              <required>1</required>
            </attrib>
            <e>name</e>
            <o><e>permissions</e></o>
            <e>trash</e>
          </pattern>
          <ele>
            <name>name</name>
            <summary>The name of the SSH LSC credential</summary>
            <pattern><t>name</t></pattern>
          </ele>
          <ele>
            <name>permissions</name>
            <summary>Permissions the user has on the credential</summary>
            <pattern></pattern>
          </ele>
          <ele>
            <name>trash</name>
            <summary>Whether the LSC credential is in the trashcan</summary>
            <pattern><t>boolean</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>port_range</name>
          <summary>Port range of the target</summary>
          <pattern><t>name</t></pattern>
        </ele>
        <ele>
          <name>port_list</name>
          <pattern>
            <attrib>
              <name>id</name>
              <type>uuid</type>
              <required>1</required>
            </attrib>
            <e>name</e>
            <o><e>permissions</e></o>
            <e>trash</e>
          </pattern>
          <ele>
            <name>name</name>
            <summary>The name of the port_list</summary>
            <pattern><t>name</t></pattern>
          </ele>
          <ele>
            <name>permissions</name>
            <summary>Permissions the user has on the port_list</summary>
            <pattern></pattern>
          </ele>
          <ele>
            <name>trash</name>
            <summary>Whether the port_list is in the trashcan</summary>
            <pattern><t>boolean</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>alive_tests</name>
          <summary>Which alive tests to use</summary>
          <description>
            A string representation in the format of the old predefined
            alive test selections is also included, but its use is deprecated.
          </description>
          <pattern>
            <any><e>alive_test</e></any>
          </pattern>
          <ele>
            <name>alive_test</name>
            <summary>
              A single alive test to use
            </summary>
            <pattern>
              <t>alive_test</t>
            </pattern>
          </ele>
        </ele>
        <ele>
          <name>reverse_lookup_only</name>
          <summary>Whether to scan only hosts that have names</summary>
          <pattern><t>boolean</t></pattern>
        </ele>
        <ele>
          <name>reverse_lookup_unify</name>
          <summary>
            Whether to scan only one IP when multiple IPs have the same name
          </summary>
          <pattern><t>boolean</t></pattern>
        </ele>
        <ele>
          <name>allow_simultaneous_ips</name>
          <summary>
            Whether to scan multiple IPs of the same host simultaneously
          </summary>
          <pattern><t>boolean</t></pattern>
        </ele>
        <ele>
          <name>tasks</name>
          <summary>All tasks using the target</summary>
          <pattern>
            <any><e>task</e></any>
          </pattern>
          <ele>
            <name>task</name>
            <pattern>
              <attrib>
                <name>id</name>
                <type>uuid</type>
                <required>1</required>
              </attrib>
              <e>name</e>
              <o><e>permissions</e></o>
            </pattern>
            <ele>
              <name>name</name>
              <summary>The name of the task</summary>
              <pattern><t>name</t></pattern>
            </ele>
            <ele>
              <name>permissions</name>
              <summary>Permissions the user has on the task</summary>
              <pattern></pattern>
            </ele>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>filters</name>
        <pattern>
          <attrib>
            <name>id</name>
            <summary>UUID of filter if any, else 0</summary>
            <type>uuid</type>
            <required>1</required>
          </attrib>
          <e>term</e>
          <o><e>name</e></o>
          <e>keywords</e>
        </pattern>
        <ele>
          <name>term</name>
          <summary>Filter term</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>name</name>
          <summary>Filter name, if applicable</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>keywords</name>
          <summary>Filter broken down into keywords</summary>
          <pattern><any><e>keyword</e></any></pattern>
          <ele>
            <name>keyword</name>
            <pattern>
              <e>column</e>
              <e>relation</e>
              <e>value</e>
            </pattern>
            <ele>
              <name>column</name>
              <summary>Column prefix</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>relation</name>
              <summary>Relation operator</summary>
              <pattern>
                <alts>
                  <alt>=</alt>
                  <alt>:</alt>
                  <alt>~</alt>
                  <alt>&gt;</alt>
                  <alt>&lt;</alt>
                </alts>
              </pattern>
            </ele>
            <ele>
              <name>value</name>
              <summary>The filter text</summary>
              <pattern>text</pattern>
            </ele>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>sort</name>
        <pattern>
          text
          <e>field</e>
        </pattern>
        <ele>
          <name>field</name>
          <pattern>
            <e>order</e>
          </pattern>
          <ele>
            <name>order</name>
            <pattern>
              <alts>
                <alt>ascending</alt>
                <alt>descending</alt>
              </alts>
            </pattern>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>targets</name>
        <pattern>
          <attrib>
            <name>start</name>
            <summary>First target</summary>
            <type>integer</type>
            <required>1</required>
          </attrib>
          <attrib>
            <name>max</name>
            <summary>Maximum number of targets</summary>
            <type>integer</type>
            <required>1</required>
          </attrib>
        </pattern>
      </ele>
      <ele>
        <name>target_count</name>
        <pattern>
          <e>filtered</e>
          <e>page</e>
        </pattern>
        <ele>
          <name>filtered</name>
          <summary>Number of targets after filtering</summary>
          <pattern><t>integer</t></pattern>
        </ele>
        <ele>
          <name>page</name>
          <summary>Number of targets on current page</summary>
          <pattern><t>integer</t></pattern>
        </ele>
      </ele>
    </response>
    <example>
      <summary>Get one or many targets</summary>
      <request>
        <get_targets></get_targets>
      </request>
      <response>
        <get_targets_response status="200" status_text="OK">
          <target id="b493b7a8-7489-11df-a3ec-002264764cea">
            <name>Localhost</name>
            <comment></comment>
            <creation_time>2018-08-29T20:21:33Z</creation_time>
            <modification_time>2018-08-29T20:21:33Z</modification_time>
            <writable>0</writable>
            <in_use>7</in_use>
            <hosts>localhost</hosts>
            <max_hosts>1</max_hosts>
            <ssh_credential id="">
              <name></name>
            </ssh_credential>
            <smb_credential id="">
              <name></name>
            </smb_credential>
            <esxi_credential id="">
              <name></name>
            </esxi_credential>
          </target>
          <truncated>...</truncated>
        </get_targets_response>
      </response>
    </example>
    <example>
      <summary>Get a single target, including tasks using the target</summary>
      <request>
        <get_targets target_id="1f28d970-17ef-4c69-ba8a-13827059f2b9" tasks="1">
        </get_targets>
      </request>
      <response>
        <get_targets_response status="200" status_text="OK">
          <target id="1f28d970-17ef-4c69-ba8a-13827059f2b9">
            <name>dik</name>
            <comment>dik mm</comment>
            <creation_time>2018-08-29T20:21:33Z</creation_time>
            <modification_time>2018-08-29T20:21:33Z</modification_time>
            <writable>0</writable>
            <in_use>4</in_use>
            <hosts>dik.example.org</hosts>
            <max_hosts>1</max_hosts>
            <ssh_credential id="58ff2793-2dc7-43fe-85f9-20bfac5a87e4">
              <name>mm</name>
            </ssh_credential>
            <smb_credential id="">
              <name></name>
            </smb_credential>
            <esxi_credential id="">
              <name></name>
            </esxi_credential>
            <tasks>
              <task id="13bb418a-4220-4575-b35b-ec398bff7417">
                <name>dik mm</name>
              </task>
              <truncated>...</truncated>
            </tasks>
          </target>
        </get_targets_response>
      </response>
    </example>
  </command>
  <command>
    <name>get_tasks</name>
    <summary>Get one or many tasks</summary>
    <description>
      <p>
        The client uses the get_tasks command to get task information.
      </p>
      <p>
        As a convenience for clients the response includes a task count and
        the values of the sort order, sort field and apply overrides flag
        that the manager applied when selecting the tasks.
      </p>
    </description>
    <pattern>
      <attrib>
        <name>task_id</name>
        <summary>ID of single task to get</summary>
        <type>uuid</type>
      </attrib>
      <attrib>
        <name>filter</name>
        <summary>Filter term to use to filter query</summary>
        <type>text</type>
        <filter_keywords>
          <option>
            <name>first</name>
            <type>integer</type>
            <summary>
              Index of the first item returned, starting at 1 (e.g. first=5
              starts at the 5th item)
            </summary>
          </option>
          <option>
            <name>rows</name>
            <type>integer</type>
            <summary>Number of items to return</summary>
          </option>
          <option>
            <name>sort</name>
            <type>text</type>
            <summary>Column to sort by in ascending order</summary>
          </option>
          <option>
            <name>sort-reverse</name>
            <type>text</type>
            <summary>Column to sort by in descending order</summary>
          </option>
          <option>
            <name>apply_overrides</name>
            <type>boolean</type>
            <summary>Whether to apply Overrides</summary>
          </option>
          <option>
            <name>min_qod</name>
            <type>integer</type>
            <summary>Minimum QoD of the results</summary>
          </option>
          <column>
            <name>tag</name>
            <type>text</type>
            <summary>
              Name and optional "=" separted value of an attached tag
              (e.g. "mytag" or "mytag=myvalue")
            </summary>
          </column>
          <column>
            <name>tag_id</name>
            <type>UUID</type>
            <summary>
              UUID of an attached tag
            </summary>
          </column>
          <column>
            <name>uuid</name>
            <type>uuid</type>
            <summary>Unique ID</summary>
          </column>
          <column>
            <name>name</name>
            <type>name</type>
            <summary>Name</summary>
          </column>
          <column>
            <name>comment</name>
            <type>text</type>
            <summary>Comment text</summary>
          </column>
          <column>
            <name>created</name>
            <type>iso_time</type>
            <summary>Creation time</summary>
          </column>
          <column>
            <name>modified</name>
            <type>iso_time</type>
            <summary>Modification time</summary>
          </column>
          <column>
            <name>owner</name>
            <type>name</type>
            <summary>Name of the owner</summary>
          </column>
          <column>
            <name>status</name>
            <type>text</type>
            <summary>Status of the current scan</summary>
          </column>
          <column>
            <name>total</name>
            <type>integer</type>
            <summary>Total number of results</summary>
          </column>
          <column>
            <name>first_report</name>
            <type>uuid</type>
            <summary>UUID of the first report</summary>
          </column>
          <column>
            <name>last_report</name>
            <type>uuid</type>
            <summary>UUID of the last finished report</summary>
          </column>
          <column>
            <name>threat</name>
            <type>threat</type>
            <summary>Severity level of the last finished report</summary>
          </column>
          <column>
            <name>trend</name>
            <type>
              <alts>
                <alt>up</alt>
                <alt>down</alt>
                <alt>more</alt>
                <alt>less</alt>
                <alt>same</alt>
              </alts>
            </type>
            <summary>Trend of the task</summary>
          </column>
          <column>
            <name>severity</name>
            <type>severity</type>
            <summary>Severity of the last finished report</summary>
          </column>
          <column>
            <name>schedule</name>
            <type>name</type>
            <summary>Name of the schedule</summary>
          </column>
          <column>
            <name>next_due</name>
            <type>iso_time</type>
            <summary>Time the task is next due to run</summary>
          </column>
          <column>
            <name>first_report_created</name>
            <type>iso_time</type>
            <summary>Timestamp of the first report</summary>
          </column>
          <column>
            <name>last_report_created</name>
            <type>iso_time</type>
            <summary>Timestamp of the last finished report</summary>
          </column>
          <column>
            <name>first</name>
            <type>iso_time</type>
            <summary>Timestamp of the first report (deprecated, use first_report_created)</summary>
          </column>
          <column>
            <name>last</name>
            <type>iso_time</type>
            <summary>Timestamp of the last finished report (deprecated, use last_report_created)</summary>
          </column>
          <column>
            <name>false_positive</name>
            <type>integer</type>
            <summary>Number of false positive results</summary>
          </column>
          <column>
            <name>log</name>
            <type>integer</type>
            <summary>Number of log results</summary>
          </column>
          <column>
            <name>low</name>
            <type>integer</type>
            <summary>Number of low severity results</summary>
          </column>
          <column>
            <name>medium</name>
            <type>integer</type>
            <summary>Number of medium severity results</summary>
          </column>
          <column>
            <name>high</name>
            <type>integer</type>
            <summary>Number of high severity results</summary>
          </column>
          <column>
            <name>critical</name>
            <type>integer</type>
            <summary>Number of critical severity results</summary>
          </column>
          <column>
            <name>hosts</name>
            <type>integer</type>
            <summary>Total number of hosts</summary>
          </column>
          <column>
            <name>result_hosts</name>
            <type>integer</type>
            <summary>Number of hosts with results matching the min_qod</summary>
          </column>
          <column>
            <name>fp_per_host</name>
            <type>integer</type>
            <summary>Number of false positive results per host with results</summary>
          </column>
          <column>
            <name>log_per_host</name>
            <type>integer</type>
            <summary>Number of log results per host with results</summary>
          </column>
          <column>
            <name>low_per_host</name>
            <type>integer</type>
            <summary>Number of low severity results per host with results</summary>
          </column>
          <column>
            <name>medium_per_host</name>
            <type>integer</type>
            <summary>Number of medium severity results per host with results</summary>
          </column>
          <column>
            <name>high_per_host</name>
            <type>integer</type>
            <summary>Number of high severity results per host with results</summary>
          </column>
          <column>
            <name>critical_per_host</name>
            <type>integer</type>
            <summary>Number of critical severity results per host with results</summary>
          </column>
          <column>
            <name>target</name>
            <type>name</type>
            <summary>Name of the target</summary>
          </column>
          <column>
            <name>usage_type</name>
            <type>
              <alts>
                <alt>scan</alt>
              </alts>
            </type>
            <summary>Usage type</summary>
          </column>
        </filter_keywords>
      </attrib>
      <attrib>
        <name>filt_id</name>
        <summary>ID of filter to use to filter query</summary>
        <type>uuid</type>
      </attrib>
      <attrib>
        <name>trash</name>
        <summary>Whether to get the trashcan tasks instead</summary>
        <type>boolean</type>
      </attrib>
      <attrib>
        <name>details</name>
        <summary>Whether to include full task details</summary>
        <type>boolean</type>
      </attrib>
      <attrib>
        <name>ignore_pagination</name>
        <summary>
          Whether to ignore info used to split the report into pages
          like the filter terms "first" and "rows"
        </summary>
        <type>boolean</type>
      </attrib>
      <attrib>
        <name>schedules_only</name>
        <summary>Whether to only include id, name and schedule details</summary>
        <type>boolean</type>
      </attrib>
      <attrib>
        <name>usage_type</name>
        <summary>Optional usage type to limit the tasks to. Affects total count unlike filter</summary>
        <type>
          <alts>
            <alt>scan</alt>
            <alt></alt>
          </alts>
        </type>
      </attrib>
    </pattern>
    <response>
      <pattern>
        <attrib>
          <name>status</name>
          <type>status</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>status_text</name>
          <type>text</type>
          <required>1</required>
        </attrib>
        <e>apply_overrides</e>
        <any><e>task</e></any>
        <e>filters</e>
        <e>sort</e>
        <e>tasks</e>
        <e>task_count</e>
      </pattern>
      <ele>
        <name>apply_overrides</name>
        <pattern>
          <alts><alt>0</alt><alt>1</alt></alts>
        </pattern>
      </ele>
      <ele>
        <name>filters</name>
        <pattern>
          <attrib>
            <name>id</name>
            <summary>UUID of filter if any, else 0</summary>
            <type>uuid</type>
            <required>1</required>
          </attrib>
          <e>term</e>
          <o><e>name</e></o>
          <e>keywords</e>
        </pattern>
        <ele>
          <name>term</name>
          <summary>Filter term</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>name</name>
          <summary>Filter name, if applicable</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>keywords</name>
          <summary>Filter broken down into keywords</summary>
          <pattern><any><e>keyword</e></any></pattern>
          <ele>
            <name>keyword</name>
            <pattern>
              <e>column</e>
              <e>relation</e>
              <e>value</e>
            </pattern>
            <ele>
              <name>column</name>
              <summary>Column prefix</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>relation</name>
              <summary>Relation operator</summary>
              <pattern>
                <alts>
                  <alt>=</alt>
                  <alt>:</alt>
                  <alt>~</alt>
                  <alt>&gt;</alt>
                  <alt>&lt;</alt>
                </alts>
              </pattern>
            </ele>
            <ele>
              <name>value</name>
              <summary>The filter text</summary>
              <pattern>text</pattern>
            </ele>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>sort</name>
        <pattern>
          text
          <e>field</e>
        </pattern>
        <ele>
          <name>field</name>
          <pattern>
            <e>order</e>
          </pattern>
          <ele>
            <name>order</name>
            <pattern>
              <alts>
                <alt>ascending</alt>
                <alt>descending</alt>
              </alts>
            </pattern>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>tasks</name>
        <pattern>
          <attrib>
            <name>start</name>
            <summary>First task</summary>
            <type>integer</type>
            <required>1</required>
          </attrib>
          <attrib>
            <name>max</name>
            <summary>Maximum number of tasks</summary>
            <type>integer</type>
            <required>1</required>
          </attrib>
        </pattern>
      </ele>
      <ele>
        <name>task_count</name>
        <pattern>
          <e>filtered</e>
          <e>page</e>
        </pattern>
        <ele>
          <name>filtered</name>
          <summary>Number of tasks after filtering</summary>
          <pattern><t>integer</t></pattern>
        </ele>
        <ele>
          <name>page</name>
          <summary>Number of tasks on current page</summary>
          <pattern><t>integer</t></pattern>
        </ele>
      </ele>
    </response>
    <example>
      <summary>Get one or many tasks</summary>
      <request>
        <get_tasks></get_tasks>
      </request>
      <response>
        <get_tasks_response status="200" status_text="OK">
          <apply_overrides>0</apply_overrides>
          <task id="254cd3ef-bbe1-4d58-859d-21b8d0c046c6">
            <name>Scan Webserver</name>
            <comment>Scan of the web server.</comment>
