def openapi_components_response_refs(repo_root: Path | None) -> dict[str, str | None]:
    lines = openapi_contract_lines(repo_root)
    in_components = False
    in_responses = False
    current_response: str | None = None
    refs: dict[str, str | None] = {}
    for line in lines:
        if line == "components:":
            in_components = True
            in_responses = False
            current_response = None
            continue
        if in_components and line and not line.startswith(" "):
            break
        if not in_components:
            continue
        top_key_match = re.match(r"^  ([A-Za-z][A-Za-z0-9_-]*):$", line)
        if top_key_match:
            in_responses = top_key_match.group(1) == "responses"
            current_response = None
            continue
        if not in_responses:
            continue
        response_match = re.match(r"^    ([A-Za-z][A-Za-z0-9]*):$", line)
        if response_match:
            current_response = response_match.group(1)
            refs.setdefault(current_response, None)
            continue
        ref_match = re.match(r"^\s+\$ref: ['\"]([^'\"]+)['\"]$", line)
        if ref_match and current_response:
            refs[current_response] = ref_match.group(1)
    return refs


def openapi_component_schema_block(repo_root: Path | None, schema_name: str) -> list[str]:
    lines = openapi_contract_lines(repo_root)
    in_components = False
    in_schemas = False
    in_schema = False
    block: list[str] = []
    for line in lines:
        if line == "components:":
            in_components = True
            in_schemas = False
            in_schema = False
            continue
        if in_components and line and not line.startswith(" "):
            break
        if not in_components:
            continue
        top_key_match = re.match(r"^  ([A-Za-z][A-Za-z0-9_-]*):$", line)
        if top_key_match:
            in_schemas = top_key_match.group(1) == "schemas"
            in_schema = False
            continue
        if not in_schemas:
            continue
        schema_match = re.match(r"^    ([A-Za-z][A-Za-z0-9_-]*):$", line)
        if schema_match:
            if in_schema:
                break
            in_schema = schema_match.group(1) == schema_name
            continue
        if in_schema:
            block.append(line)
    return block


def openapi_indented_scalar_fields(block: list[str]) -> dict[str, str]:
    stack: list[tuple[int, str]] = []
    values: dict[str, str] = {}
    for line in block:
        if not line.strip() or line.lstrip().startswith("#"):
            continue
        indent = len(line) - len(line.lstrip(" "))
        text = line.strip()
        if ":" not in text or text.startswith("-"):
            continue
        key, raw_value = text.split(":", 1)
        key = key.strip().strip("'\"")
        value = raw_value.strip().strip("'\"")
        while stack and indent <= stack[-1][0]:
            stack.pop()
        path = ".".join([item[1] for item in stack] + [key])
        if value:
            values[path] = value
        else:
            stack.append((indent, key))
    return values


def openapi_error_schema_contract_drift(repo_root: Path | None) -> dict[str, Any]:
    block = openapi_component_schema_block(repo_root, "Error")
    values = openapi_indented_scalar_fields(block)
    missing = []
    invalid = []
    for field, expected in sorted(OPENAPI_ERROR_SCHEMA_EXPECTED_FIELDS.items()):
        if field not in values:
            missing.append({"field": field, "expected": expected})
            continue
        actual = values[field]
        if actual != expected:
            invalid.append({"field": field, "actual": actual, "expected": expected})
    return {
        "expected_error_schema_fields": dict(sorted(OPENAPI_ERROR_SCHEMA_EXPECTED_FIELDS.items())),
        "error_schema_fields": dict(sorted(values.items())),
        "missing_error_schema_fields": missing,
        "invalid_error_schema_fields": invalid,
    }


def openapi_schema_top_level_keys(block: list[str]) -> set[str]:
    keys: set[str] = set()
    for line in block:
        match = re.match(r"^      ([A-Za-z][A-Za-z0-9_-]*):", line)
        if match:
            keys.add(match.group(1))
    return keys


def openapi_request_body_schema_contract_drift(repo_root: Path | None, operations: list[dict[str, Any]]) -> dict[str, Any]:
    request_body_schema_refs = sorted(
        {
            str(operation.get("request_body_schema_ref"))
            for operation in operations
            if isinstance(operation.get("request_body_schema_ref"), str)
        }
    )
    missing: list[dict[str, Any]] = []
    invalid: list[dict[str, Any]] = []

    for operation in operations:
        if not operation.get("request_body"):
            continue
        ref = operation.get("request_body_schema_ref")
        label = openapi_operation_label(operation)
        if not isinstance(ref, str):
            missing.append({"operation": label, "field": "requestBody.schema.$ref", "expected": "#/components/schemas/..."})
            continue
        match = re.fullmatch(r"#/components/schemas/([A-Za-z][A-Za-z0-9_-]*)", ref)
        if not match:
            invalid.append({"operation": label, "field": "requestBody.schema.$ref", "actual": ref, "expected": "#/components/schemas/..."})
            continue
        schema_name = match.group(1)
        block = openapi_component_schema_block(repo_root, schema_name)
        if not block:
            missing.append({"operation": label, "field": f"components.schemas.{schema_name}", "expected": "top-level schema"})
            continue
        values = openapi_indented_scalar_fields(block)
        top_level_keys = openapi_schema_top_level_keys(block)
        if values.get("type") != "object":
            invalid.append({"operation": label, "field": f"components.schemas.{schema_name}.type", "actual": values.get("type"), "expected": "object"})
        if "properties" not in top_level_keys:
            invalid.append({"operation": label, "field": f"components.schemas.{schema_name}.properties", "actual": None, "expected": "top-level properties"})

    return {
        "request_body_schema_refs": request_body_schema_refs,
        "missing_request_body_schema_refs": missing,
        "invalid_request_body_schema_refs": invalid,
    }


def rust_collection_contract_constants(repo_root: Path | None) -> dict[str, int | None]:
    if repo_root is None:
        return {"default_page_size": None, "max_page_size": None, "max_filter_length": None}
    path = repo_root / "services" / "turbovas-api" / "src" / "collections.rs"
    try:
        source = path.read_text(encoding="utf-8")
    except OSError:
        source = ""

    def const_int(name: str) -> int | None:
        match = re.search(rf"pub\(crate\)\s+const\s+{re.escape(name)}\s*:\s*(?:i64|usize)\s*=\s*([0-9]+)\s*;", source)
        return int(match.group(1)) if match else None

    return {
        "default_page_size": const_int("DEFAULT_COLLECTION_PAGE_SIZE"),
        "max_page_size": const_int("MAX_COLLECTION_PAGE_SIZE"),
        "max_filter_length": const_int("MAX_COLLECTION_FILTER_LENGTH"),
    }


def rust_collection_contract_paths(repo_root: Path | None) -> list[str]:
    if repo_root is None:
        return []
    source = ""
    for relative_path in (
        "services/turbovas-api/src/collection_contract_tests.rs",
        "services/turbovas-api/src/main.rs",
    ):
        try:
            source += "\n" + (repo_root / relative_path).read_text(encoding="utf-8")
        except OSError:
            continue
    return sorted(
        {
            path
            for path in re.findall(r'path:\s*"(/api/v1[^"]+)"', source)
            if ":" not in path
        }
    )


def openapi_component_parameter_block(repo_root: Path | None, parameter_name: str) -> list[str]:
    lines = openapi_contract_lines(repo_root)
    in_components = False
    in_parameters = False
    in_parameter = False
    block: list[str] = []
    for line in lines:
        if line == "components:":
            in_components = True
            in_parameters = False
            in_parameter = False
            continue
        if in_components and line and not line.startswith(" "):
            break
        if not in_components:
            continue
        top_key_match = re.match(r"^  ([A-Za-z][A-Za-z0-9_-]*):$", line)
        if top_key_match:
            in_parameters = top_key_match.group(1) == "parameters"
            in_parameter = False
            continue
        if not in_parameters:
            continue
        parameter_match = re.match(r"^    ([A-Za-z][A-Za-z0-9_-]*):$", line)
        if parameter_match:
            if in_parameter:
                break
            in_parameter = parameter_match.group(1) == parameter_name
            continue
        if in_parameter:
            block.append(line)
    return block


def openapi_collection_query_contract_summary(repo_root: Path | None, operations: list[dict[str, Any]]) -> dict[str, Any]:
    rust_constants = rust_collection_contract_constants(repo_root)
    rust_contract_paths = rust_collection_contract_paths(repo_root)
    page_size_fields = openapi_indented_scalar_fields(openapi_component_parameter_block(repo_root, "PageSize"))
    filter_fields = openapi_indented_scalar_fields(openapi_component_parameter_block(repo_root, "Filter"))

    def int_value(value: str | None) -> int | None:
        return int(value) if isinstance(value, str) and re.fullmatch(r"[0-9]+", value) else None

    openapi_values = {
        "default_page_size": int_value(page_size_fields.get("schema.default")),
        "max_page_size": int_value(page_size_fields.get("schema.maximum")),
        "max_filter_length": int_value(filter_fields.get("schema.maxLength")),
    }
    mismatches = [
        {"field": field, "openapi": openapi_values.get(field), "rust": rust_constants.get(field)}
        for field in sorted(openapi_values)
        if openapi_values.get(field) != rust_constants.get(field)
    ]

    required = set(OPENAPI_COLLECTION_PARAMETER_REFS)
    incomplete_collection_parameters = []
    openapi_collection_paths = []
    for operation in operations:
        if operation.get("method") != "get":
            continue
        parameters = set(operation.get("parameters", [])) if isinstance(operation.get("parameters"), list) else set()
        present = parameters & required
        if present == required and isinstance(operation.get("path"), str):
            openapi_collection_paths.append(f"/api/v1{operation['path']}")
        if present and present != required:
            incomplete_collection_parameters.append(
                {
                    "operation": openapi_operation_label(operation),
                    "present": sorted(present),
                    "missing": sorted(required - present),
                }
            )
    openapi_collection_paths = sorted(set(openapi_collection_paths))
    missing_openapi_collection_parameters = sorted(set(rust_contract_paths) - set(openapi_collection_paths))
    missing_rust_collection_contracts = sorted(set(openapi_collection_paths) - set(rust_contract_paths))
    return {
        "alignment_status": "pass" if not mismatches and not incomplete_collection_parameters and not missing_openapi_collection_parameters and not missing_rust_collection_contracts else "warn",
        "rust_collection_constants": rust_constants,
        "openapi_collection_values": openapi_values,
        "rust_collection_contract_count": len(rust_contract_paths),
        "openapi_collection_operation_count": len(openapi_collection_paths),
        "rust_collection_contract_paths": rust_contract_paths,
        "openapi_collection_paths": openapi_collection_paths,
        "collection_limit_mismatches": mismatches,
        "incomplete_collection_parameters": incomplete_collection_parameters,
        "missing_openapi_collection_parameters": missing_openapi_collection_parameters,
        "missing_rust_collection_contracts": missing_rust_collection_contracts,
    }


def openapi_required_error_response_refs(path: str) -> dict[str, str]:
    required = dict(OPENAPI_COMMON_ERROR_RESPONSE_REFS)
    if "{" in path:
        required.update(OPENAPI_PARAMETERIZED_ERROR_RESPONSE_REFS)
