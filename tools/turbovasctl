def native_api_migration_matrix_focus_terms(focus: str | Iterable[str] | None = None) -> list[str]:
    terms: list[str] = []
    for value in native_api_migration_matrix_focus_values(focus):
        terms.extend(term.strip().lower() for term in value.split(",") if term.strip())
    return terms


NATIVE_API_MIGRATION_RESIDUAL_BUCKET_TOKENS = {
    "write_or_mutation": ("write", "writes", "mutation", "mutations", "create", "creation", "delete", "deletes", "import"),
    "control_or_operation": ("control", "actions", "feed-sync", "scan-control", "delivery"),
    "export_or_download": ("export", "exports", "download", "downloads"),
    "credential_or_secret": ("credential", "credentials", "secret", "secrets"),
    "rich_context_or_history": ("rich", "history", "raw", "xml", "row-data"),
    "report_generation_or_retention": ("generation", "report-generation", "retention"),
}


def native_api_migration_matrix_residual_buckets(row: dict[str, Any]) -> list[str]:
    residue = row.get("x_turbovas_inherited_still_owns")
    if not isinstance(residue, str) or not residue:
        return []
    residue_words = residue.lower()
    return [
        bucket
        for bucket, tokens in NATIVE_API_MIGRATION_RESIDUAL_BUCKET_TOKENS.items()
        if any(token in residue_words for token in tokens)
    ]


def native_api_migration_matrix_filter_rows(rows: list[dict[str, Any]], focus: str | Iterable[str] | None = None) -> list[dict[str, Any]]:
    terms = native_api_migration_matrix_focus_terms(focus)
    if not terms:
        return rows

    def searchable_text(row: dict[str, Any]) -> str:
        values: list[str] = []
        for key in (
            "endpoint",
            "method",
            "status",
            "browser_access",
            "direct_access",
            "operation_id",
            "openapi_path",
            "x_turbovas_exposure",
            "x_turbovas_maturity",
            "x_turbovas_operator_identity",
            "x_turbovas_owner_semantics",
            "x_turbovas_replaces",
            "x_turbovas_inherited_still_owns",
            "x_turbovas_safety_contract",
            "x_turbovas_side_effect",
        ):
            value = row.get(key)
            if value is not None:
                values.append(str(value))
        candidates = row.get("replacement_candidates")
        if isinstance(candidates, list):
            values.extend(str(candidate) for candidate in candidates)
        values.extend(native_api_migration_matrix_residual_buckets(row))
        return "\n".join(values).lower()

    return [row for row in rows if any(term in searchable_text(row) for term in terms)]


def openapi_operation_is_pending_write_control(operation: dict[str, Any] | None) -> bool:
    if not isinstance(operation, dict):
        return False
    values = operation.get("x_turbovas_values", {}) if isinstance(operation.get("x_turbovas_values"), dict) else {}
    maturity = values.get("x-turbovas-maturity")
    exposure = values.get("x-turbovas-exposure")
    return exposure == "internal-only" and maturity in {"preview-write", "preview-control"}


def native_api_migration_matrix_remaining_surface(rows: list[dict[str, Any]]) -> dict[str, Any]:
    bucket_counts = {bucket: 0 for bucket in NATIVE_API_MIGRATION_RESIDUAL_BUCKET_TOKENS}
    residue_counts: dict[str, int] = {}
    examples: dict[str, str] = {}
    for row in rows:
        residue = row.get("x_turbovas_inherited_still_owns")
        if not isinstance(residue, str) or not residue:
            continue
        residue_counts[residue] = residue_counts.get(residue, 0) + 1
        endpoint = row.get("endpoint")
        if isinstance(endpoint, str):
            examples.setdefault(residue, endpoint)
        for bucket in native_api_migration_matrix_residual_buckets(row):
            bucket_counts[bucket] += 1

    top_residuals = [
        {"residue": residue, "count": count, "example_endpoint": examples.get(residue)}
        for residue, count in sorted(residue_counts.items(), key=lambda item: (-item[1], item[0]))[:8]
    ]
    return {
        "rows_with_inherited_owner_tail": sum(residue_counts.values()),
        "distinct_owner_tails": len(residue_counts),
        "bucket_counts": bucket_counts,
        "top_residuals": top_residuals,
        "planning_hint": (
            "Current native rows are metadata-complete; remaining inherited tails are mostly "
            "writes, control, exports, rich context, credentials, report generation, or retention. "
            "Skip candidates that cross those boundaries unless a dedicated design packet authorizes them."
        ),
    }


def native_api_migration_matrix_compact_focus_row(row: dict[str, Any]) -> dict[str, Any]:
    keys = (
        "method",
        "endpoint",
        "status",
        "direct_access",
        "browser_access",
        "x_turbovas_replaces",
        "x_turbovas_inherited_still_owns",
