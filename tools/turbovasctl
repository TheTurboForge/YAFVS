def command_runtime_native_api_direct_bootstrap(repo_root: Path, status_only: bool = False) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    env = native_api_direct_runtime_env(repo_root)
    try:
        token = native_api_direct_bearer_token(repo_root, env)
    except OSError:
        token = ""
    token_file_metadata = native_api_direct_token_file_metadata(repo_root, env)
    token_source = "environment" if env.get(TURBOVAS_API_BEARER_TOKEN_ENV) else token_file_metadata["source"]
    secret_path = runtime_secret_path(repo_root, TURBOVAS_API_BEARER_TOKEN_SECRET)

    findings.append(native_api_direct_config_shape_finding(env, check="native-api-direct-bootstrap.config-shape"))
    config_errors = native_api_direct_config_errors(env)
    host = native_api_direct_host(env)
    if config_errors:
        host_status = "fail"
        host_message = "Direct native API bootstrap refuses malformed host, port, or bind settings."
    elif host_is_wildcard(host):
        host_status = "fail"
        host_message = "Direct native API bootstrap refuses wildcard host publication."
    elif not host_is_loopback(host):
        host_status = "fail"
        host_message = "Direct native API bootstrap refuses non-loopback publication until production TLS/bootstrap/host-binding hardening exists."
    else:
        host_status = "pass"
        host_message = "Direct native API bootstrap is loopback-bounded."
    findings.append(
        finding(
            host_status,
            "native-api-direct-bootstrap.host-binding",
            host_message,
            details={
                "host": host,
                "host_port": native_api_direct_port(env),
                "host_binding": native_api_direct_port_binding(env),
                "container_bind": env.get(TURBOVAS_API_DIRECT_BIND_ENV),
            },
        )
    )

    token_ok = direct_api_bearer_token_is_acceptable(token)
    token_permission_ok = token_source == "environment" or not token_file_metadata["host_metadata_available"] or token_file_metadata["permission_ok"]
    token_status = "pass" if token_ok and token_permission_ok else "fail"
    findings.append(
        finding(
            token_status,
            "native-api-direct-bootstrap.token",
            "Direct native API bootstrap has a bearer token that satisfies the local strength contract and is not group/world accessible."
            if token_status == "pass"
            else "Direct native API bootstrap bearer token is missing, weak, or group/world accessible.",
            token_file_metadata["host_path"] if token_source != "environment" else None,
            {
                "token_source": token_source,
                "minimum_token_length": TURBOVAS_API_BEARER_TOKEN_MIN_LENGTH,
                "runtime_secret": str(secret_path),
                "token_file_configured_value": token_file_metadata["configured_value"],
                "token_file_host_path": token_file_metadata["host_path"],
                "token_file_host_metadata_available": token_file_metadata["host_metadata_available"],
                "runtime_secret_mode": token_file_metadata["mode"],
                "runtime_secret_permission_ok": token_file_metadata["permission_ok"],
                "runtime_secret_group_or_world_accessible": token_file_metadata["group_or_world_accessible"],
                "token_value_reported": False,
            },
        )
    )

    findings.extend(direct_native_api_posture_findings(repo_root, env))
    result = make_result("runtime-native-api-direct-bootstrap", repo_root, "Direct native API bootstrap guardrails checked.", findings)
    result["details"] = {
        "base_url": native_api_direct_base_url(env),
        "direct_enabled": env.get(TURBOVAS_API_DIRECT_ENV) == "1",
        "token_source": token_source,
        "token_value_reported": False,
    }
    if status_only:
        result = direct_bootstrap_status_only_result(result)
    return result


def native_api_direct_admin_operator_uuid(repo_root: Path) -> tuple[subprocess.CompletedProcess[str], str | None]:
    returncode_only = run_gvmd_oneoff(repo_root, ["--get-users", "--verbose"], no_deps=False)
    admin_uuid = parse_user_uuid(returncode_only.stdout, DEV_ADMIN_USER) if returncode_only.returncode == 0 else None
    return returncode_only, admin_uuid


