    inspect = run_command(["docker", "inspect", "--format", "{{json .State}}", cid], repo_root, env=runtime_env(repo_root))
    if inspect.returncode != 0:
        return {"container_id": cid, "inspect_error": output_tail(inspect.stdout, 40)}
