def wait_for_socket(path: Path, timeout_seconds: int = 20) -> bool:
    deadline = time.monotonic() + timeout_seconds
    while time.monotonic() < deadline:
        if path.is_socket():
            return True
        time.sleep(1)
    return path.is_socket()


