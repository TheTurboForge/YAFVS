# Non-secret local development defaults for Docker Compose.
#
# The default runtime directory is intentionally outside the repository when
# commands are run through tools/yafvsctl. If using docker compose directly,
# set both paths explicitly. YAFVS_REPO_MOUNT_PATH must be an absolute path;
# tools/yafvsctl supplies the current checkout automatically.
YAFVS_RUNTIME_DIR=../../YAFVS-runtime
YAFVS_REPO_MOUNT_PATH=
YAFVS_UID=1000
YAFVS_GID=1000
POSTGRES_USER=yafvs
POSTGRES_PASSWORD=yafvs-dev
POSTGRES_DB=yafvs

# Experimental app profile exposes gsad on 127.0.0.1:19392.
# Development admin credentials are generated under the runtime secrets directory.
