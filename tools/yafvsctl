        for match in re.finditer(r'\.route\(\s*"(/api/v1[^"]*)"', source)
    }
    return sorted(routes)


def rust_native_api_route_operations(
    repo_root: Path | None,
    function_name: str | None = None,
) -> set[tuple[str, str]]:
    source = rust_native_api_route_source(repo_root, function_name)
    route_source = rust_source_function_body(source, function_name) if function_name else source
    if function_name and not route_source:
        return set()
    operations = {
        (match.group(2).lower(), rust_route_to_endpoint_template(match.group(1)))
        for match in re.finditer(
            r'\.route\(\s*"(/api/v1[^"]*)"\s*,\s*([a-z]+)\s*\(',
            route_source,
        )
    }
    operations.update(
        (match.group(2).lower(), rust_route_to_endpoint_template(match.group(1)))
        for match in re.finditer(
            r'\.route\(\s*"(/api/v1[^"]*)"\s*,\s*[a-z]+\s*\([^)]*\)\s*\.\s*([a-z]+)\s*\(',
            route_source,
            re.DOTALL,
        )
    )
    return operations


def rust_native_api_route_operation_declared(
