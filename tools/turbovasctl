def psql_value(result: subprocess.CompletedProcess[str]) -> str:
    ignored_prefixes = ("WARNING:", "DETAIL:", "HINT:", "NOTICE:")
    for line in reversed(result.stdout.splitlines()):
        clean = line.strip()
        if clean and not clean.startswith(ignored_prefixes):
            return clean
    return ""


