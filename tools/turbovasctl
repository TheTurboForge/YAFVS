            findings.append(native_api_probe_finding("pass" if delete_body_ok else "fail", "native-api-direct.tag-delete-body-denied", "Direct write-control rejects DELETE request bodies before tag deletion." if delete_body_ok else "Direct write-control did not reject a DELETE request body before tag deletion.", delete_body, direct_native_api_display_command(f"/api/v1/tags/{urllib.parse.quote(tag_id)}", token=token, env=env, method="DELETE", body="probe-body", extra_headers=content_type), delete_body_json, {"http_status": delete_body_status, "tag_id": tag_id, **summarize_native_api_response(delete_body_json)}))

