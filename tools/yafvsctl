def runtime_secret_file_metadata(path: Path) -> dict[str, Any]:
    try:
        metadata = path.lstat()
    except FileNotFoundError:
        return {
            "exists": False,
            "mode": None,
            "permission_ok": False,
            "group_or_world_accessible": False,
            "regular_file": False,
            "symlink": False,
        }
    mode = stat.S_IMODE(metadata.st_mode)
    regular_file = stat.S_ISREG(metadata.st_mode)
    symlink = stat.S_ISLNK(metadata.st_mode)
    group_or_world_accessible = bool(mode & 0o077)
    return {
        "exists": True,
        "mode": f"{mode:04o}",
        "permission_ok": regular_file and not group_or_world_accessible,
        "group_or_world_accessible": group_or_world_accessible,
        "regular_file": regular_file,
        "symlink": symlink,
    }


def open_private_directory(path: Path) -> int:
    path.mkdir(parents=True, mode=0o700, exist_ok=True)
    metadata = path.lstat()
    if stat.S_ISLNK(metadata.st_mode) or not stat.S_ISDIR(metadata.st_mode):
        raise OSError(
            errno.EINVAL, f"Private path is not a real directory: {path}"
        )
    if metadata.st_uid != os.geteuid():
        raise PermissionError(
            f"Private directory is not owned by the current user: {path}"
        )
    path.chmod(0o700)
    descriptor = os.open(
        path,
        os.O_RDONLY | os.O_DIRECTORY | os.O_NOFOLLOW | os.O_CLOEXEC,
    )
    descriptor_metadata = os.fstat(descriptor)
    if (
        not stat.S_ISDIR(descriptor_metadata.st_mode)
        or descriptor_metadata.st_uid != os.geteuid()
        or stat.S_IMODE(descriptor_metadata.st_mode) != 0o700
    ):
        os.close(descriptor)
        raise PermissionError(f"Private directory validation failed: {path}")
    return descriptor


@contextmanager
def locked_private_directory(path: Path):
    parent_fd = open_private_directory(path)
    lock_fd = -1
    try:
        lock_fd = os.open(
            ".yafvs-private.lock",
            os.O_RDWR
            | os.O_CREAT
            | os.O_NOFOLLOW
            | os.O_CLOEXEC,
            0o600,
            dir_fd=parent_fd,
        )
        lock_metadata = os.fstat(lock_fd)
        if (
            not stat.S_ISREG(lock_metadata.st_mode)
            or lock_metadata.st_uid != os.geteuid()
            or stat.S_IMODE(lock_metadata.st_mode) & 0o077
        ):
            raise PermissionError(
                f"Private directory lock is not owner-only: {path}"
            )
        fcntl.flock(lock_fd, fcntl.LOCK_EX)
        yield parent_fd
    finally:
        if lock_fd >= 0:
            fcntl.flock(lock_fd, fcntl.LOCK_UN)
            os.close(lock_fd)
        os.close(parent_fd)


def read_private_text(path: Path, max_bytes: int) -> str:
    parent_fd = open_private_directory(path.parent)
    file_fd = -1
    try:
        file_fd = os.open(
            path.name,
            os.O_RDONLY | os.O_NOFOLLOW | os.O_CLOEXEC,
            dir_fd=parent_fd,
        )
        metadata = os.fstat(file_fd)
        if not stat.S_ISREG(metadata.st_mode):
            raise OSError(
                errno.EINVAL, f"Private path is not a file: {path}"
            )
        if metadata.st_uid != os.geteuid():
            raise PermissionError(
                f"Private file is not owned by the current user: {path}"
            )
        if stat.S_IMODE(metadata.st_mode) & 0o077:
            raise PermissionError(
                f"Private file is accessible outside its owner: {path}"
            )
        chunks: list[bytes] = []
        remaining = max_bytes + 1
        while remaining:
            chunk = os.read(file_fd, remaining)
            if not chunk:
                break
            chunks.append(chunk)
            remaining -= len(chunk)
        content = b"".join(chunks)
        if len(content) > max_bytes or os.read(file_fd, 1):
            raise OSError(
                errno.EFBIG, f"Private file is too large: {path}"
            )
        return content.decode("utf-8")
    finally:
        if file_fd >= 0:
            os.close(file_fd)
        os.close(parent_fd)


def read_or_create_runtime_secret(repo_root: Path, name: str, default: str | None = None) -> tuple[str, bool]:
    path = runtime_secret_path(repo_root, name)
    try:
        content = read_private_text(path, MAX_RUNTIME_SECRET_BYTES)
    except FileNotFoundError:
        found = False
        content = ""
    else:
        found = True
    if found:
        if content.endswith("\n"):
            content = content[:-1]
        if (
            not content
            or "\x00" in content
            or "\n" in content
            or "\r" in content
        ):
            raise ValueError(
                f"Runtime secret must contain one line with an optional terminal LF: {path}"
            )
        return content, False
    secret = default if default is not None else secrets.token_urlsafe(24)
    write_private_text(path, secret + "\n")
    return secret, True


def write_private_text(path: Path, text: str) -> None:
    temporary_name = (
        f".{path.name}.tmp-{os.getpid()}-{secrets.token_hex(8)}"
    )
    file_fd = -1
    with locked_private_directory(path.parent) as parent_fd:
        try:
            file_fd = os.open(
                temporary_name,
                os.O_WRONLY
                | os.O_CREAT
                | os.O_EXCL
                | os.O_NOFOLLOW
                | os.O_CLOEXEC,
                0o600,
                dir_fd=parent_fd,
            )
            with os.fdopen(file_fd, "w", encoding="utf-8") as stream:
                file_fd = -1
                # Runtime/dev service secrets are stored only in ignored,
                # owner-readable local runtime files for container consumption.
                # codeql[py/clear-text-storage-sensitive-data]
                stream.write(text)
                stream.flush()
                os.fsync(stream.fileno())
            os.replace(
                temporary_name,
                path.name,
                src_dir_fd=parent_fd,
                dst_dir_fd=parent_fd,
            )
            temporary_name = ""
            os.fsync(parent_fd)
        finally:
            if file_fd >= 0:
                os.close(file_fd)
            if temporary_name:
                try:
                    os.unlink(temporary_name, dir_fd=parent_fd)
                except FileNotFoundError:
                    pass


def write_runtime_secret(repo_root: Path, name: str, secret: str) -> Path:
    path = runtime_secret_path(repo_root, name)
