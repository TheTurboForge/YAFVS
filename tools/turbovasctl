def tool_version(program: str) -> str | None:
    probes = {
        "node": ["node", "--version"],
        "npm": ["npm", "--version"],
        "python3": ["python3", "--version"],
        "uv": ["uv", "--version"],
    }
    command = probes.get(program)
    if not command or not shutil.which(command[0]):
        return None
    result = run_command(command, Path.cwd())
    if result.returncode == 0:
        return result.stdout.strip()
    return None


def version_tuple(version: str) -> tuple[int, ...]:
    clean = version.strip().lstrip("v")
    parts: list[int] = []
    for piece in clean.split("."):
        number = ""
        for character in piece:
            if character.isdigit():
                number += character
            else:
                break
        if number:
            parts.append(int(number))
        else:
            break
    return tuple(parts)


def python_version_finding() -> dict[str, Any]:
    version = tool_version("python3")
    if not version:
        return finding("warn", "tool.python-version", "python3 version could not be detected.")
    parsed = version_tuple(version.removeprefix("Python "))
    status = "pass" if parsed >= MINIMUM_TURBOVASCTL_PYTHON else "warn"
    required = ".".join(str(part) for part in MINIMUM_TURBOVASCTL_PYTHON)
    message = (
        f"python3 version {version} satisfies TurboVAS tooling requirement >= {required}."
        if status == "pass"
        else f"python3 version {version} is older than TurboVAS tooling requirement >= {required}; TOML-backed checks need Python 3.11+."
    )
    return finding(status, "tool.python-version", message, details={"version": version, "minimum": required})


def command_status(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    branch = run_git(repo_root, ["branch", "--show-current"]) or "(detached or unavailable)"
    head = run_git(repo_root, ["rev-parse", "--short", "HEAD"]) or "unavailable"
    porcelain = run_git(repo_root, ["status", "--short"]) or ""
    upstream = run_git(repo_root, ["rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{upstream}"])
    findings.append(finding("pass", "git.repository", f"Repository root: {repo_root}"))
    findings.append(finding("pass", "git.head", f"Current branch {branch} at {head}"))
    findings.append(finding("pass" if upstream else "warn", "git.upstream", f"Tracking upstream: {upstream}" if upstream else "No upstream tracking branch is configured."))
    if porcelain:
        findings.append(finding("warn", "git.worktree", "Worktree has uncommitted changes.", details={"changed_files": porcelain.splitlines()}))
    else:
        findings.append(finding("pass", "git.worktree", "Worktree is clean."))
    return make_result("status", repo_root, "Repository status collected.", findings)


def command_inventory(repo_root: Path, scope: str | None = None) -> dict[str, Any]:
    rows = component_inventory(repo_root, scope)
    findings: list[dict[str, Any]] = []
    if scope and not rows:
        findings.append(finding("warn", "inventory.scope", f"No expected components matched scope {scope}."))
    for row in rows:
        findings.append(finding("pass" if row["exists"] else "fail", "component.exists", f"{row['name']}: {row['role']}", row["path"]))
    return make_result("inventory", repo_root, f"Inventory contains {len(rows)} expected component(s).", findings)


def native_tooling_markers(path: Path) -> list[str]:
    try:
        text = path.read_text(encoding="utf-8", errors="ignore")
    except OSError:
        return []
    lower = text.lower()
    return [marker for marker in NATIVE_TOOLING_MARKERS if marker.lower() in lower]


def native_tooling_category(relative_path: str) -> tuple[str, str] | None:
    path = Path(relative_path)
    if relative_path.startswith(GSA_NATIVE_API_CLIENT_PREFIX):
        return None
    if relative_path == "tools/turbovasctl" or (relative_path.startswith("tools/runtime_") and relative_path.endswith(".py")):
        return "required_runtime", "TurboVAS runtime/helper command path still depends on inherited GMP/python-gvm plumbing."
    if relative_path.startswith("tools/tests/"):
        return "required_test", "Regression tests still characterize inherited GMP/python-gvm/gvm-tools behavior."
    if relative_path.startswith("components/gsa/src/gmp/"):
        return "product_workflow", "GSA product workflow still reads or writes through inherited GMP command clients."
    if relative_path.startswith("components/gvm-tools/scripts/"):
        if path.name in NATIVE_TOOLING_PRODUCT_GVM_TOOLS_SCRIPTS:
            return "product_workflow", "gvm-tools script supports a retained TurboVAS report/scope workflow until native APIs replace it."
        if path.suffix == ".py":
            return "candidate_for_removal", "Inherited gvm-tools operator script is a removal candidate once native tooling covers retained needs."
    if relative_path.startswith("components/python-gvm/") or relative_path.startswith("components/gvm-tools/gvmtools/"):
        return "compatibility_bridge", "Inherited client library remains as temporary compatibility plumbing, not the desired product API."
    if relative_path.startswith("components/gvm-tools/"):
        return "compatibility_bridge", "Inherited gvm-tools component remains only as temporary compatibility plumbing."
    if relative_path.startswith("docs/") or relative_path in {"README.md", "UPSTREAMS.md", "LICENSE_AUDIT.md", "BUILDING.md"}:
        return "compatibility_bridge", "Documentation references inherited tooling while the native API retirement map is active."
    return None


def native_tooling_scan_candidate(relative_path: str) -> bool:
    if relative_path.startswith(GSA_NATIVE_API_CLIENT_PREFIX):
        return False
    return relative_path in NATIVE_TOOLING_SCAN_FILES or any(relative_path.startswith(prefix) for prefix in NATIVE_TOOLING_SCAN_PREFIXES)


def native_tooling_inventory(repo_root: Path) -> list[dict[str, Any]]:
    tracked = git_tracked_files(repo_root) or []
    items: list[dict[str, Any]] = []
    for relative_path in tracked:
        if not native_tooling_scan_candidate(relative_path):
            continue
        path = repo_root / relative_path
        if not path.is_file():
            continue
        markers = native_tooling_markers(path)
        if not markers:
            continue
        classified = native_tooling_category(relative_path)
        category, reason = classified if classified else ("unknown", "Inherited tooling marker appears outside the current retirement map classification.")
        item = {"category": category, "path": relative_path, "markers": markers, "reason": reason}
        residue = native_tooling_residue(relative_path, category)
        if residue is not None:
            residue_kind, residue_reason = residue
            item["residue_kind"] = residue_kind
            item["residue_reason"] = residue_reason
        items.append(item)
    return sorted(items, key=lambda item: (NATIVE_TOOLING_CATEGORIES.index(item["category"]), item["path"]))


