def product_data_audit(details: dict[str, Any]) -> dict[str, Any]:
    database = details.get("database", {})
    paths = details.get("paths", {})
    audit: dict[str, Any] = {
        "db_owned_exports": {},
        "unowned_product_data": [],
    }
    for name, path_summary in paths.items():
        if path_summary.get("classification") != "db_owned_export":
            continue
        required_tables = DATA_STATE_DB_OWNED_EXPORT_SOURCES.get(name, ())
        missing_tables = [table for table in required_tables if not database_table_exists(database, table)]
        export = {
            "exists": bool(path_summary.get("exists")),
            "path": path_summary.get("path"),
            "source_of_record": "gvmd/postgresql",
            "required_tables": list(required_tables),
            "missing_tables": missing_tables,
        }
        audit["db_owned_exports"][name] = export
        if export["exists"] and missing_tables:
            audit["unowned_product_data"].append({"path": name, "missing_tables": missing_tables})
    audit["status"] = "warn" if audit["unowned_product_data"] else "pass"
    return audit


def process_step_finding(status: str, check: str, message: str, result: subprocess.CompletedProcess[str], command: list[str] | None = None) -> dict[str, Any]:
    details: dict[str, Any] = {"exit_code": result.returncode, "output_tail": output_tail(result.stdout, 100)}
    if command is not None:
        details["command"] = " ".join(shlex.quote(part) for part in command)
    return finding(status, check, message, details=details)


def compose_app_up_transient_error(output: str) -> bool:
    return any(fragment in output for fragment in COMPOSE_APP_UP_TRANSIENT_ERRORS)


def app_services_running(repo_root: Path) -> bool:
    return all(container_running(repo_root, service) for service in APP_SERVICES)


def compose_app_services_up_with_retry(repo_root: Path, check: str, message: str, timeout: int = 900) -> list[dict[str, Any]]:
    command = compose_command(repo_root, "--profile", "app", "up", "-d", "--no-deps", "--build", *APP_SERVICES)
    result = run_command(command, repo_root, env=runtime_app_env(repo_root), timeout=timeout)
    if result.returncode == 0:
        return [process_step_finding("pass", check, f"{message} exit code 0.", result, command)]

    if not compose_app_up_transient_error(result.stdout):
        return [process_step_finding("fail", check, f"{message} exit code {result.returncode}.", result, command)]

    findings = [
        process_step_finding(
            "warn",
            f"{check}.transient",
            f"{message} hit Docker container-removal race exit code {result.returncode}; retrying with already-built images.",
            result,
            command,
        )
    ]
    retry_command = compose_command(repo_root, "--profile", "app", "up", "-d", "--no-deps", *APP_SERVICES)
    for attempt in range(1, 3):
        time.sleep(8 * attempt)
        retry = run_command(retry_command, repo_root, env=runtime_app_env(repo_root), timeout=300)
        if retry.returncode == 0:
            findings.append(process_step_finding("pass", f"{check}.retry", f"{message} retry {attempt} exit code 0.", retry, retry_command))
            return findings
        if app_services_running(repo_root):
            findings.append(
                process_step_finding(
                    "warn",
                    f"{check}.retry",
                    f"{message} retry {attempt} reported exit code {retry.returncode}, but all app services are running after Docker settled.",
                    retry,
                    retry_command,
                )
            )
            return findings
        findings.append(
            process_step_finding(
                "warn" if attempt == 1 and compose_app_up_transient_error(retry.stdout) else "fail",
                f"{check}.retry-{attempt}",
                f"{message} retry {attempt} exit code {retry.returncode}.",
                retry,
                retry_command,
            )
        )
        if not compose_app_up_transient_error(retry.stdout):
            return findings
    return findings


def log_review_matches(lines: Iterable[str], service: str | None = None) -> list[dict[str, Any]]:
