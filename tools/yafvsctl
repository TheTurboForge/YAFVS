def direct_task_target_replace_runtime_findings(
    repo_root: Path,
    *,
    token: str,
    env: dict[str, str],
    admin_uuid: str,
) -> list[dict[str, Any]]:
    """Exercise task target replacement with an isolated, no-scan fixture."""
    findings: list[dict[str, Any]] = []
    content_type = (("Content-Type", "application/json"),)
    fixture_suffix = f"{int(time.time())}-{os.getpid()}"
    source_target_name = f"yafvs-direct-write-smoke-replace-source-{fixture_suffix}"
    task_name = f"yafvs-direct-write-smoke-replace-task-{fixture_suffix}"
    source_target_id: str | None = None
    task_id: str | None = None
    new_target_id: str | None = None

    port_lists = direct_native_api_curl(
        repo_root, "/api/v1/port-lists?page_size=25&sort=name", token=token, env=env
    )
    port_lists_json, port_lists_status = parse_json_output_with_http_status(port_lists)
    port_list_id = next(
        (
            item.get("id")
            for item in port_lists_json.get("items", [])
            if isinstance(item, dict)
            and item.get("predefined") is True
            and isinstance(item.get("id"), str)
        ),
        None,
    ) if isinstance(port_lists_json, dict) else None
    scanners = direct_native_api_curl(
        repo_root, "/api/v1/scanners?page_size=25&sort=name", token=token, env=env
    )
    scanners_json, scanners_status = parse_json_output_with_http_status(scanners)
    scanner_id = next(
        (
            item.get("id")
            for item in scanners_json.get("items", [])
            if isinstance(item, dict)
            and item.get("scanner_type") in {2, 5, 6, 8}
            and isinstance(item.get("id"), str)
        ),
        None,
    ) if isinstance(scanners_json, dict) else None
    fixtures_ready = (
        port_lists.returncode == 0
        and port_lists_status == 200
        and isinstance(port_list_id, str)
        and scanners.returncode == 0
        and scanners_status == 200
        and isinstance(scanner_id, str)
    )
    findings.append(
        native_api_probe_finding(
            "pass" if fixtures_ready else "fail",
            "native-api-direct.task-target-replace-fixtures",
            "Direct write-control found owned fixture inputs for task-target replacement."
            if fixtures_ready
            else "Direct write-control could not find the predefined port-list or task-capable scanner needed for task-target replacement.",
            scanners,
            direct_native_api_display_command(
                "/api/v1/scanners?page_size=25&sort=name", token=token, env=env
            ),
            scanners_json,
            {
                "port_lists_http_status": port_lists_status,
                "scanners_http_status": scanners_status,
                "port_list_id": port_list_id,
                "scanner_id": scanner_id,
                **summarize_native_api_response(scanners_json),
            },
        )
    )
    if not fixtures_ready:
        return findings

    try:
        source_body = json.dumps(
            {
                "name": source_target_name,
                "comment": "YAFVS direct write smoke task-target replacement source",
                "port_list_id": port_list_id,
                "hosts": ["192.0.2.60"],
                "exclude_hosts": [],
                "alive_tests": ["TCP-ACK Service Ping"],
                "allow_simultaneous_ips": False,
                "reverse_lookup_only": True,
                "reverse_lookup_unify": True,
            },
            separators=(",", ":"),
        )
        source_create = direct_native_api_curl(
            repo_root,
            "/api/v1/targets",
            token=token,
            env=env,
            method="POST",
            body=source_body,
            extra_headers=content_type,
        )
        source_create_json, source_create_status = parse_json_output_with_http_status(source_create)
        source_target_id = (
            source_create_json.get("id")
            if isinstance(source_create_json, dict)
            and isinstance(source_create_json.get("id"), str)
            else None
        )
        source_create_ok = (
            source_create.returncode == 0
            and source_create_status == 201
            and bool(source_target_id)
            and isinstance(source_create_json, dict)
            and source_create_json.get("name") == source_target_name
        )
        findings.append(
            native_api_probe_finding(
                "pass" if source_create_ok else "fail",
                "native-api-direct.task-target-replace-source-create",
                "Direct write-control created the isolated task-target replacement source target."
                if source_create_ok
                else "Direct write-control failed to create the isolated task-target replacement source target.",
                source_create,
                direct_native_api_display_command(
                    "/api/v1/targets",
                    token=token,
                    env=env,
                    method="POST",
                    body=source_body,
                    extra_headers=content_type,
                ),
                source_create_json,
                {
                    "http_status": source_create_status,
                    "source_target_id": source_target_id,
                    **summarize_native_api_response(source_create_json),
                },
            )
        )
        if not source_create_ok or not source_target_id:
            return findings

        task_body = json.dumps(
            {
                "name": task_name,
                "comment": "YAFVS direct write smoke task-target replacement task",
                "target_id": source_target_id,
                "config_id": FULL_AND_FAST_SCAN_CONFIG_ID,
                "scanner_id": scanner_id,
            },
            separators=(",", ":"),
        )
        task_create = direct_native_api_curl(
            repo_root,
            "/api/v1/tasks",
            token=token,
            env=env,
            method="POST",
            body=task_body,
            extra_headers=content_type,
        )
        task_create_json, task_create_status = parse_json_output_with_http_status(task_create)
        task_id = (
            task_create_json.get("id")
            if isinstance(task_create_json, dict) and isinstance(task_create_json.get("id"), str)
            else None
        )
        task_create_ok = (
            task_create.returncode == 0
            and task_create_status == 201
            and bool(task_id)
            and isinstance(task_create_json, dict)
            and task_create_json.get("name") == task_name
        )
        findings.append(
            native_api_probe_finding(
                "pass" if task_create_ok else "fail",
                "native-api-direct.task-target-replace-task-create",
                "Direct write-control created the isolated task-target replacement task without starting it."
                if task_create_ok
                else "Direct write-control failed to create the isolated task-target replacement task.",
                task_create,
                direct_native_api_display_command(
                    "/api/v1/tasks",
                    token=token,
                    env=env,
                    method="POST",
                    body=task_body,
                    extra_headers=content_type,
                ),
                task_create_json,
                {
                    "http_status": task_create_status,
                    "task_id": task_id,
                    "source_target_id": source_target_id,
                    "config_id": FULL_AND_FAST_SCAN_CONFIG_ID,
                    "scanner_id": scanner_id,
                    **summarize_native_api_response(task_create_json),
                },
            )
        )
        if not task_create_ok or not task_id:
            return findings

        task_precondition_sql = (
            "SELECT coalesce(t.run_status, 1)::text || '|' || "
            "(SELECT count(*)::text FROM reports WHERE task = t.id) || '|' || "
            "coalesce(source.uuid::text, '') "
            "FROM tasks t LEFT JOIN targets source ON source.id = t.target "
            f"WHERE t.uuid = {sql_literal(task_id)};"
        )
        task_precondition = psql_value(psql(repo_root, task_precondition_sql))
        task_precondition_ok = task_precondition == f"1|0|{source_target_id}"
        findings.append(
            finding(
                "pass" if task_precondition_ok else "fail",
                "native-api-direct.task-target-replace-preconditions",
                "Replacement fixture task is exactly New, has zero reports, and is bound to its owned source target."
                if task_precondition_ok
                else "Replacement fixture task was not exactly New with zero reports and its owned source target.",
                details={"task_id": task_id, "state": task_precondition},
            )
        )
        if not task_precondition_ok:
            return findings

        target_config_sql = lambda target_uuid: (
            "SELECT md5(coalesce(owner::text, '') || '|' || coalesce(port_list::text, '') || '|' || "
            "coalesce(alive_test::text, '') || '|' || coalesce(reverse_lookup_only::text, '') || '|' || "
            "coalesce(reverse_lookup_unify::text, '') || '|' || coalesce(allow_simultaneous_ips::text, '') || '|' || "
            "coalesce(comment, '') || '|' || (SELECT count(*)::text FROM targets_login_data WHERE target = targets.id)) "
            "FROM targets "
            f"WHERE uuid = {sql_literal(target_uuid)};"
        )
        source_config_before = psql_value(psql(repo_root, target_config_sql(source_target_id)))
        replacement_hosts = ["192.0.2.61", "192.0.2.62"]
        replacement_exclusions = ["192.0.2.62"]
        replace_body = json.dumps(
            {"hosts": replacement_hosts, "exclude_hosts": replacement_exclusions},
            separators=(",", ":"),
        )
        replace_path = f"/api/v1/tasks/{urllib.parse.quote(task_id)}/replace-target"
        replacement = direct_native_api_curl(
            repo_root,
            replace_path,
            token=token,
            env=env,
            method="POST",
            body=replace_body,
            extra_headers=content_type,
        )
        replacement_json, replacement_status = parse_json_output_with_http_status(replacement)
        old_target_id = replacement_json.get("old_target_id") if isinstance(replacement_json, dict) else None
        new_target_id = replacement_json.get("new_target_id") if isinstance(replacement_json, dict) else None
        old_target_disposition = replacement_json.get("old_target_disposition") if isinstance(replacement_json, dict) else None
        replacement_ack_ok = (
            replacement.returncode == 0
            and replacement_status == 200
            and isinstance(replacement_json, dict)
            and replacement_json.get("task_id") == task_id
            and old_target_id == source_target_id
            and isinstance(new_target_id, str)
            and bool(UUID_VALUE_RE.fullmatch(new_target_id))
            and replacement_json.get("status") == "replaced"
            and old_target_disposition in {"trashed", "retained"}
        )
        findings.append(
            native_api_probe_finding(
                "pass" if replacement_ack_ok else "fail",
                "native-api-direct.task-target-replace-acknowledgement",
                "Direct native API returned the typed task-target replacement acknowledgement."
                if replacement_ack_ok
                else "Direct native API task-target replacement did not return the typed acknowledgement.",
                replacement,
                direct_native_api_display_command(
                    replace_path,
                    token=token,
                    env=env,
                    method="POST",
                    body=replace_body,
                    extra_headers=content_type,
                ),
                replacement_json,
                {
                    "http_status": replacement_status,
                    "task_id": task_id,
                    "old_target_id": old_target_id,
                    "new_target_id": new_target_id,
                    "old_target_disposition": old_target_disposition,
                    **summarize_native_api_response(replacement_json),
                },
            )
        )
        if not replacement_ack_ok or not isinstance(new_target_id, str):
            return findings

        task_rebind_sql = (
            "SELECT coalesce(target.uuid::text, '') || '|' || coalesce(config.uuid::text, '') || '|' || "
            "coalesce(scanner.uuid::text, '') || '|' || coalesce(t.run_status, 1)::text || '|' || "
            "(SELECT count(*)::text FROM reports WHERE task = t.id) "
            "FROM tasks t "
            "LEFT JOIN targets target ON target.id = t.target "
            "LEFT JOIN configs config ON config.id = t.config "
            "LEFT JOIN scanners scanner ON scanner.id = t.scanner "
            f"WHERE t.uuid = {sql_literal(task_id)};"
        )
        task_rebind_state = psql_value(psql(repo_root, task_rebind_sql))
        task_rebind_ok = task_rebind_state == f"{new_target_id}|{FULL_AND_FAST_SCAN_CONFIG_ID}|{scanner_id}|1|0"
        findings.append(
            finding(
                "pass" if task_rebind_ok else "fail",
                "native-api-direct.task-target-replace-rebind",
                "PostgreSQL confirms the New zero-report task rebound to the replacement target without changing scan config or scanner."
                if task_rebind_ok
                else "PostgreSQL did not confirm the expected task rebind and preserved New zero-report state.",
                details={"task_id": task_id, "state": task_rebind_state},
            )
        )

        new_target_config = psql_value(psql(repo_root, target_config_sql(new_target_id)))
        new_target_inputs = psql_value(
            psql(
                repo_root,
                "SELECT coalesce(hosts, '') || '|' || coalesce(exclude_hosts, '') "
                "FROM targets "
                f"WHERE uuid = {sql_literal(new_target_id)};",
            )
        )
        target_preservation_ok = (
            bool(source_config_before)
            and source_config_before == new_target_config
            and new_target_inputs == "192.0.2.61, 192.0.2.62|192.0.2.62"
        )
        findings.append(
            finding(
                "pass" if target_preservation_ok else "fail",
                "native-api-direct.task-target-replace-target-preservation",
                "PostgreSQL confirms replacement hosts/exclusions and preservation of source target scan-input configuration."
                if target_preservation_ok
                else "PostgreSQL did not confirm replacement hosts/exclusions and preserved source target scan-input configuration.",
                details={
                    "new_target_id": new_target_id,
                    "source_config_checksum": source_config_before,
                    "new_target_config_checksum": new_target_config,
                    "new_target_inputs": new_target_inputs,
                },
            )
        )

        source_reference_state = psql_value(
            psql(
                repo_root,
                "SELECT (SELECT count(*)::text FROM tasks WHERE target = "
                f"(SELECT id FROM targets WHERE uuid = {sql_literal(source_target_id)}) "
                "AND coalesce(target_location, 0) = 0 AND coalesce(hidden, 0) = 0) || '|' || "
                "(SELECT count(*)::text FROM scope_targets WHERE target = "
                f"(SELECT id FROM targets WHERE uuid = {sql_literal(source_target_id)}));",
            )
        )
        source_disposition_state = psql_value(
            psql(
                repo_root,
                "SELECT (SELECT count(*)::text FROM targets "
                f"WHERE uuid = {sql_literal(source_target_id)}) || '|' || "
                "(SELECT count(*)::text FROM targets_trash "
                f"WHERE uuid = {sql_literal(source_target_id)});",
            )
        )
        source_disposition_ok = (
            old_target_disposition == "trashed"
            and source_reference_state == "0|0"
            and source_disposition_state == "0|1"
        )
        findings.append(
            finding(
                "pass" if source_disposition_ok else "fail",
                "native-api-direct.task-target-replace-old-target-disposition",
                "PostgreSQL confirms the unreferenced old target was trashed after the task rebind."
                if source_disposition_ok
                else "Old-target acknowledgement disposition was inconsistent with PostgreSQL task/scope references.",
                details={
                    "old_target_id": source_target_id,
                    "acknowledged_disposition": old_target_disposition,
                    "reference_state": source_reference_state,
                    "live_trash_state": source_disposition_state,
                },
            )
        )
    finally:
        target_name_pattern = f"{source_target_name}%"
        owner_sql = f"(SELECT id FROM users WHERE uuid = {sql_literal(admin_uuid)})"
        task_selector = (
            f"SELECT id FROM tasks WHERE (uuid = {sql_literal(task_id or '')} "
            f"OR name = {sql_literal(task_name)}) AND owner = {owner_sql}"
        )
        live_target_selector = (
            "SELECT id FROM targets WHERE "
            f"(uuid IN ({sql_literal(source_target_id or '')}, {sql_literal(new_target_id or '')}) "
            f"OR name LIKE {sql_literal(target_name_pattern)}) AND owner = {owner_sql}"
        )
        trash_target_selector = (
            "SELECT id FROM targets_trash WHERE "
            f"(uuid IN ({sql_literal(source_target_id or '')}, {sql_literal(new_target_id or '')}) "
            f"OR name LIKE {sql_literal(target_name_pattern)}) AND owner = {owner_sql}"
        )
        cleanup_sql = (
            "BEGIN; "
            "LOCK TABLE users IN ROW SHARE MODE; "
            f"DELETE FROM task_alerts WHERE task IN ({task_selector}); "
            f"DELETE FROM task_preferences WHERE task IN ({task_selector}); "
            f"DELETE FROM tag_resources WHERE resource_type = 'task' AND resource IN ({task_selector}); "
            f"DELETE FROM tag_resources_trash WHERE resource_type = 'task' AND resource IN ({task_selector}); "
            f"DELETE FROM tasks WHERE id IN ({task_selector}); "
            f"DELETE FROM scope_targets WHERE target IN ({live_target_selector}); "
            f"DELETE FROM targets_login_data WHERE target IN ({live_target_selector}); "
            f"DELETE FROM tag_resources WHERE resource_type = 'target' AND resource IN ({live_target_selector}); "
            f"DELETE FROM tag_resources_trash WHERE resource_type = 'target' AND resource IN ({live_target_selector}); "
            f"DELETE FROM targets WHERE id IN ({live_target_selector}); "
            f"DELETE FROM targets_trash_login_data WHERE target IN ({trash_target_selector}); "
            f"DELETE FROM tag_resources WHERE resource_type = 'target' AND resource IN ({trash_target_selector}); "
            f"DELETE FROM tag_resources_trash WHERE resource_type = 'target' AND resource IN ({trash_target_selector}); "
            f"DELETE FROM targets_trash WHERE id IN ({trash_target_selector}); "
            "COMMIT;"
        )
        cleanup = psql(repo_root, cleanup_sql)
        cleanup_residue_sql = (
            "SELECT (SELECT count(*)::text FROM tasks WHERE name = "
            f"{sql_literal(task_name)} AND owner = (SELECT id FROM users WHERE uuid = {sql_literal(admin_uuid)})) || '|' || "
            "(SELECT count(*)::text FROM targets WHERE name LIKE "
            f"{sql_literal(target_name_pattern)} AND owner = {owner_sql}) || '|' || "
            "(SELECT count(*)::text FROM targets_trash WHERE name LIKE "
            f"{sql_literal(target_name_pattern)} AND owner = {owner_sql});"
        )
        cleanup_residue = psql(repo_root, cleanup_residue_sql)
        cleanup_state = psql_value(cleanup_residue)
        cleanup_ok = cleanup.returncode == 0 and cleanup_residue.returncode == 0 and cleanup_state == "0|0|0"
        cleanup_finding = process_step_finding(
            "pass" if cleanup_ok else "fail",
            "native-api-direct.task-target-replace-fixture-cleanup",
            "Direct write-control smoke removed all isolated task-target replacement fixture residue."
            if cleanup_ok
            else "Direct write-control smoke failed to remove isolated task-target replacement fixture residue.",
            cleanup,
            ["psql", "fixed-task-target-replace-smoke-cleanup"],
        )
        cleanup_details = cleanup_finding.setdefault("details", {})
        if isinstance(cleanup_details, dict):
            cleanup_details.update(
                {
                    "task_id": task_id,
                    "source_target_id": source_target_id,
                    "new_target_id": new_target_id,
                    "residue_state": cleanup_state,
                }
            )
        findings.append(cleanup_finding)
    return findings


def direct_trash_empty_runtime_findings(
    repo_root: Path,
    *,
    token: str,
    env: dict[str, str],
    operator_uuid: str,
) -> list[dict[str, Any]]:
    """Exercise the global empty contract without ever touching pre-existing operator trash."""
    findings: list[dict[str, Any]] = []
    preview, preview_payload, preview_status = native_empty_trash_fetch_preview(
        repo_root,
        token=token,
        env=env,
    )
    preflight_ok = preview.returncode == 0 and preview_status == 200 and preview_payload is not None
    findings.append(
        finding(
            "pass" if preflight_ok else "fail",
            "native-api-direct.trash-empty-preflight",
            "Direct write-control smoke obtained a typed operator Trashcan preview."
            if preflight_ok
            else "Direct write-control smoke could not obtain a typed operator Trashcan preview.",
            details={
                "http_status": preview_status,
                "scope": preview_payload.get("scope") if preview_payload else None,
                "total": preview_payload.get("total") if preview_payload else None,
                "item_count": len(preview_payload.get("items", [])) if preview_payload else 0,
            },
        )
    )
    if not preflight_ok or preview_payload is None:
        return findings
    if preview_payload["total"] != 0:
        mismatch_body = json.dumps(
            {
                "acknowledge_permanent_deletion": True,
                "expected_total": 0,
                "expected_snapshot_digest": preview_payload["snapshot_digest"],
            },
            separators=(",", ":"),
        )
        mismatch = direct_native_api_curl(
            repo_root,
            NATIVE_EMPTY_TRASH_PATH,
            token=token,
            env=env,
            method="POST",
            body=mismatch_body,
            extra_headers=(("Content-Type", "application/json"),),
        )
        mismatch_json, mismatch_status = parse_json_output_with_http_status(mismatch)
        mismatch_ok = (
            mismatch.returncode == 0
            and mismatch_status == 409
            and isinstance(mismatch_json, dict)
            and isinstance(mismatch_json.get("error"), dict)
        )
        findings.append(
            finding(
                "pass" if mismatch_ok else "fail",
                "native-api-direct.trash-empty-preexisting-mismatch",
                "Direct write-control rejected a deliberately wrong total without touching pre-existing Trashcan data."
                if mismatch_ok
                else "Direct write-control did not reject the deliberately wrong total for pre-existing Trashcan data.",
                details={"http_status": mismatch_status, "operator_total": preview_payload["total"]},
            )
        )
        if not mismatch_ok:
            return findings
        after_mismatch, after_payload, after_status = native_empty_trash_fetch_preview(
            repo_root,
            token=token,
            env=env,
        )
        unchanged = (
            after_mismatch.returncode == 0
            and after_status == 200
            and after_payload is not None
            and after_payload["total"] == preview_payload["total"]
        )
        findings.append(
            finding(
                "pass" if unchanged else "fail",
                "native-api-direct.trash-empty-preexisting-unchanged",
                "Direct write-control confirmed the operator Trashcan total stayed unchanged after mismatch rejection."
                if unchanged
                else "Direct write-control could not confirm pre-existing Trashcan data remained unchanged after mismatch rejection.",
                details={
                    "http_status": after_status,
                    "expected_total": preview_payload["total"],
                    "observed_total": after_payload.get("total") if after_payload else None,
                },
            )
        )
        if not unchanged:
            return findings
        findings.append(
            finding(
                "warn",
                "native-api-direct.trash-empty-preflight-skipped",
                "Direct write-control smoke did not create or empty a Trashcan fixture because this operator already has Trashcan items.",
                details={"operator_total": preview_payload["total"]},
            )
        )
        return findings

    content_type = (("Content-Type", "application/json"),)
    fixture_name = f"yafvs-direct-write-smoke-trash-empty-{int(time.time())}-{os.getpid()}"
    owner_sql = f"(SELECT id FROM users WHERE uuid = {sql_literal(operator_uuid)})"
    live_fixture_selector = (
        "SELECT id FROM tags WHERE "
        f"name = {sql_literal(fixture_name)} AND owner = {owner_sql}"
    )
    trash_fixture_selector = (
        "SELECT id FROM tags_trash WHERE "
        f"name = {sql_literal(fixture_name)} AND owner = {owner_sql}"
    )
    fixture_started = False
    try:
        fixture_started = True
        create_body = json.dumps(
            {
                "name": fixture_name,
                "resource_type": "cpe",
                "comment": "YAFVS direct write smoke isolated Trashcan fixture",
                "value": "trash-empty-fixture",
                "active": True,
            },
            separators=(",", ":"),
        )
        created = direct_native_api_curl(
            repo_root,
            "/api/v1/tags",
            token=token,
            env=env,
            method="POST",
            body=create_body,
            extra_headers=content_type,
        )
        created_json, created_status = parse_json_output_with_http_status(created)
        fixture_tag_id = created_json.get("id") if isinstance(created_json, dict) and isinstance(created_json.get("id"), str) else None
        create_ok = created.returncode == 0 and created_status == 201 and fixture_tag_id is not None
        findings.append(
            finding(
                "pass" if create_ok else "fail",
                "native-api-direct.trash-empty-fixture-create",
                "Direct write-control smoke created an isolated operator-owned tag fixture."
                if create_ok
                else "Direct write-control smoke failed to create its isolated operator-owned tag fixture.",
                details={"http_status": created_status, "fixture_tag_id": fixture_tag_id},
            )
        )
        if not create_ok or fixture_tag_id is None:
            return findings

        trashed = direct_native_api_curl(
            repo_root,
            f"/api/v1/tags/{urllib.parse.quote(fixture_tag_id)}",
            token=token,
            env=env,
            method="DELETE",
        )
        _trashed_json, trashed_status = parse_json_output_with_http_status(trashed)
        trashed_ok = trashed.returncode == 0 and trashed_status == 204
        findings.append(
            finding(
                "pass" if trashed_ok else "fail",
                "native-api-direct.trash-empty-fixture-trash",
                "Direct write-control smoke moved its isolated tag fixture into the operator Trashcan."
                if trashed_ok
                else "Direct write-control smoke failed to move its isolated tag fixture into the operator Trashcan.",
                details={"http_status": trashed_status, "fixture_tag_id": fixture_tag_id},
            )
        )
        if not trashed_ok:
            return findings

        fixture_preview, fixture_payload, fixture_preview_status = native_empty_trash_fetch_preview(
            repo_root,
            token=token,
            env=env,
        )
        fixture_preview_ok = (
            fixture_preview.returncode == 0
            and fixture_preview_status == 200
            and fixture_payload is not None
            and fixture_payload["total"] == 1
        )
        findings.append(
            finding(
                "pass" if fixture_preview_ok else "fail",
                "native-api-direct.trash-empty-fixture-preview",
                "Direct write-control smoke previewed exactly its isolated Trashcan fixture."
                if fixture_preview_ok
                else "Direct write-control smoke did not observe exactly one isolated Trashcan fixture before emptying.",
                details={
                    "http_status": fixture_preview_status,
                    "preview_total": fixture_payload.get("total") if fixture_payload else None,
                    "preview_item_count": len(fixture_payload.get("items", [])) if fixture_payload else 0,
                },
            )
        )
        if not fixture_preview_ok or fixture_payload is None:
            return findings

        mismatch_body = json.dumps(
            {
                "acknowledge_permanent_deletion": True,
                "expected_total": 0,
                "expected_snapshot_digest": fixture_payload["snapshot_digest"],
            },
            separators=(",", ":"),
        )
        mismatch = direct_native_api_curl(
            repo_root,
            NATIVE_EMPTY_TRASH_PATH,
            token=token,
            env=env,
            method="POST",
            body=mismatch_body,
            extra_headers=content_type,
        )
        mismatch_json, mismatch_status = parse_json_output_with_http_status(mismatch)
        mismatch_ok = (
            mismatch.returncode == 0
            and mismatch_status == 409
            and isinstance(mismatch_json, dict)
            and isinstance(mismatch_json.get("error"), dict)
        )
        findings.append(
            finding(
                "pass" if mismatch_ok else "fail",
                "native-api-direct.trash-empty-expected-total-mismatch",
                "Direct write-control smoke confirmed that an incorrect expected total is rejected before deletion."
                if mismatch_ok
                else "Direct write-control smoke did not receive the required expected-total mismatch rejection.",
                details={"http_status": mismatch_status},
            )
        )
        if not mismatch_ok:
            return findings

        post_mismatch_preview, post_mismatch_payload, post_mismatch_status = native_empty_trash_fetch_preview(
            repo_root,
            token=token,
            env=env,
        )
        zero_deletion_ok = (
            post_mismatch_preview.returncode == 0
            and post_mismatch_status == 200
            and post_mismatch_payload is not None
            and post_mismatch_payload["total"] == 1
        )
        findings.append(
            finding(
                "pass" if zero_deletion_ok else "fail",
                "native-api-direct.trash-empty-mismatch-zero-deletion",
                "Direct write-control smoke confirmed the mismatch left its isolated Trashcan fixture untouched."
                if zero_deletion_ok
                else "Direct write-control smoke could not confirm zero deletion after the expected-total mismatch.",
                details={"http_status": post_mismatch_status, "preview_total": post_mismatch_payload.get("total") if post_mismatch_payload else None},
            )
        )
        if not zero_deletion_ok:
            return findings

        confirmed_body = json.dumps(
            {
                "acknowledge_permanent_deletion": True,
                "expected_total": 1,
                "expected_snapshot_digest": post_mismatch_payload["snapshot_digest"],
            },
            separators=(",", ":"),
        )
        confirmed = direct_native_api_curl(
            repo_root,
            NATIVE_EMPTY_TRASH_PATH,
            token=token,
            env=env,
            method="POST",
            body=confirmed_body,
            extra_headers=content_type,
        )
        confirmed_json, confirmed_status = parse_json_output_with_http_status(confirmed)
        confirmed_ok = (
            confirmed.returncode == 0
            and confirmed_status == 200
            and isinstance(confirmed_json, dict)
            and set(confirmed_json) == {"scope", "deleted_total"}
            and confirmed_json.get("scope") == NATIVE_EMPTY_TRASH_SCOPE
            and confirmed_json.get("deleted_total") == 1
        )
        findings.append(
            finding(
                "pass" if confirmed_ok else "fail",
                "native-api-direct.trash-empty-confirmed",
                "Direct write-control smoke confirmed permanent deletion of its isolated Trashcan fixture."
                if confirmed_ok
                else "Direct write-control smoke did not receive a confirmed isolated Trashcan deletion acknowledgement.",
                details={"http_status": confirmed_status, "deleted_total": confirmed_json.get("deleted_total") if isinstance(confirmed_json, dict) else None},
            )
        )
        if not confirmed_ok:
            return findings

        final_preview, final_payload, final_status = native_empty_trash_fetch_preview(
            repo_root,
            token=token,
            env=env,
        )
        final_preview_ok = (
            final_preview.returncode == 0
            and final_status == 200
            and final_payload is not None
            and final_payload["total"] == 0
        )
        findings.append(
            finding(
                "pass" if final_preview_ok else "fail",
                "native-api-direct.trash-empty-confirmed-zero-residue",
                "Direct write-control smoke confirmed a zero-residue operator Trashcan after the one permanent-delete POST."
                if final_preview_ok
                else "Direct write-control smoke could not confirm zero operator Trashcan residue after permanent deletion.",
                details={"http_status": final_status, "preview_total": final_payload.get("total") if final_payload else None},
            )
        )
    finally:
        if fixture_started:
            cleanup_sql = (
                "BEGIN; "
                "LOCK TABLE users IN ROW SHARE MODE; "
                f"DELETE FROM tag_resources WHERE tag IN ({live_fixture_selector}); "
                f"DELETE FROM tag_resources_trash WHERE tag IN ({trash_fixture_selector}); "
                f"DELETE FROM tags WHERE id IN ({live_fixture_selector}); "
                f"DELETE FROM tags_trash WHERE id IN ({trash_fixture_selector}); "
                "COMMIT;"
            )
            cleanup = psql(repo_root, cleanup_sql)
            residue_sql = (
                "SELECT (SELECT count(*)::text FROM tags WHERE "
                f"name = {sql_literal(fixture_name)} AND owner = {owner_sql}) || '|' || "
                "(SELECT count(*)::text FROM tags_trash WHERE "
                f"name = {sql_literal(fixture_name)} AND owner = {owner_sql});"
            )
            residue = psql(repo_root, residue_sql)
            residue_state = psql_value(residue)
            cleanup_ok = cleanup.returncode == 0 and residue.returncode == 0 and residue_state == "0|0"
            cleanup_finding = process_step_finding(
                "pass" if cleanup_ok else "fail",
                "native-api-direct.trash-empty-fixture-cleanup",
                "Direct write-control smoke removed all isolated Trashcan fixture residue."
                if cleanup_ok
                else "Direct write-control smoke failed to remove isolated Trashcan fixture residue.",
                cleanup,
                ["psql", "isolated-trash-empty-fixture-cleanup"],
            )
            cleanup_finding.setdefault("details", {}).update({"residue_state": residue_state})
            findings.append(cleanup_finding)
    return findings


def native_api_cleanup_identity_predicate(
    resource_id: str | None,
    value: str,
    *,
    value_column: str = "name",
) -> str:
    if value_column not in {"name", "text"}:
        raise ValueError("cleanup identity column is not allowed")
    if resource_id:
        return f"uuid = {sql_literal(resource_id)} AND {value_column} = {sql_literal(value)}"
    return f"{value_column} = {sql_literal(value)}"


def native_api_create_cleanup_state(
    response: subprocess.CompletedProcess[str],
    parsed: dict[str, Any] | None,
    http_status: int | None,
    response_ok: bool,
) -> tuple[bool, bool]:
    error = parsed.get("error") if isinstance(parsed, dict) else None
    error_code = error.get("code") if isinstance(error, dict) else None
    committed = http_status == 201 or error_code == "committed_response_unavailable"
    uncertain = (
        response.returncode != 0
        or http_status is None
        or http_status >= 500
        or error_code in {"committed_response_unavailable", "mutation_outcome_indeterminate"}
        or (http_status == 201 and not response_ok)
    )
    return committed, uncertain


def native_api_direct_write_smb_fixture_cleanup(
    repo_root: Path,
    *,
    admin_uuid: str,
    smb_alert_attempted: bool,
    smb_alert_name: str,
    smb_report_format_cleanup_required: bool,
    smb_report_format_id: str | None,
    smb_report_format_name: str,
    credential_cleanup_required: bool,
    credential_create_committed: bool,
    credential_id: str | None,
    credential_name: str,
) -> list[dict[str, Any]]:
    findings: list[dict[str, Any]] = []
    smb_alert_cleanup_proven = not smb_alert_attempted
    if smb_alert_attempted:
        # Keep residue verification in a second statement: data-modifying CTEs share one snapshot.
        smb_alert_cleanup_sql = (
            "LOCK TABLE users IN ROW SHARE MODE; "
            "WITH operator_owner AS (SELECT id FROM users "
            f"WHERE uuid = {sql_literal(admin_uuid)}), "
            "live_alert AS (SELECT id FROM alerts "
            f"WHERE name = {sql_literal(smb_alert_name)} AND owner = (SELECT id FROM operator_owner)), "
            "deleted_method_data AS (DELETE FROM alert_method_data WHERE alert IN (SELECT id FROM live_alert)), "
            "deleted_event_data AS (DELETE FROM alert_event_data WHERE alert IN (SELECT id FROM live_alert)), "
            "deleted_condition_data AS (DELETE FROM alert_condition_data WHERE alert IN (SELECT id FROM live_alert)), "
            "deleted_alert AS (DELETE FROM alerts WHERE id IN (SELECT id FROM live_alert) RETURNING id) "
            "SELECT count(*) FROM deleted_alert; "
            "WITH operator_owner AS (SELECT id FROM users "
            f"WHERE uuid = {sql_literal(admin_uuid)}), "
            "live_alert AS (SELECT id FROM alerts "
            f"WHERE name = {sql_literal(smb_alert_name)} AND owner = (SELECT id FROM operator_owner)) "
            "SELECT (SELECT count(*) FROM live_alert) || '|' || "
            "((SELECT count(*) FROM alert_method_data WHERE alert IN (SELECT id FROM live_alert)) + "
            "(SELECT count(*) FROM alert_event_data WHERE alert IN (SELECT id FROM live_alert)) + "
            "(SELECT count(*) FROM alert_condition_data WHERE alert IN (SELECT id FROM live_alert)));"
        )
        smb_alert_cleanup = psql(repo_root, smb_alert_cleanup_sql)
        smb_alert_cleanup_counts = psql_value(smb_alert_cleanup)
        smb_alert_cleanup_proven = (
            smb_alert_cleanup.returncode == 0
            and smb_alert_cleanup_counts == "0|0"
        )
        findings.append(process_step_finding(
            "pass" if smb_alert_cleanup_proven else "fail",
            "native-api-direct.alert-smb-write-cleanup",
            "Direct write-control smoke proved no owner-scoped SMB alert or child-row residue remains."
            if smb_alert_cleanup_proven
            else "Direct write-control smoke failed to prove removal of the owner-scoped SMB alert and child rows.",
            smb_alert_cleanup,
            ["psql", "fixed-smb-alert-smoke-cleanup"],
        ))

    if smb_report_format_cleanup_required:
        if smb_alert_cleanup_proven:
            report_format_identity = native_api_cleanup_identity_predicate(
                smb_report_format_id,
                smb_report_format_name,
            )
            smb_report_format_cleanup = psql(
                repo_root,
                "LOCK TABLE users IN ROW SHARE MODE; "
                "WITH operator_owner AS (SELECT id FROM users "
                f"WHERE uuid = {sql_literal(admin_uuid)}), "
                "target AS (SELECT id FROM report_formats "
                f"WHERE {report_format_identity} AND owner = (SELECT id FROM operator_owner)), "
                "deleted_params AS (DELETE FROM report_format_params WHERE report_format IN (SELECT id FROM target)), "
                "deleted_format AS (DELETE FROM report_formats WHERE id IN (SELECT id FROM target) RETURNING id) "
                "SELECT count(*) FROM deleted_format;",
            )
            smb_report_format_cleanup_ok = (
                smb_report_format_cleanup.returncode == 0
                and psql_value(smb_report_format_cleanup) == "1"
            )
            findings.append(process_step_finding(
                "pass" if smb_report_format_cleanup_ok else "fail",
                "native-api-direct.alert-smb-report-format-cleanup",
                "Direct write-control smoke removed the owner-scoped temporary SMB report format after alert cleanup."
                if smb_report_format_cleanup_ok
                else "Direct write-control smoke failed to remove the owner-scoped temporary SMB report format after alert cleanup.",
                smb_report_format_cleanup,
                ["psql", "fixed-smb-alert-report-format-cleanup"],
            ))
        else:
            findings.append(finding(
                "fail",
                "native-api-direct.alert-smb-report-format-cleanup",
                "Direct write-control smoke retained the temporary SMB report format because alert cleanup was not proven.",
            ))

    if credential_cleanup_required:
        if smb_alert_cleanup_proven:
            credential_identity = native_api_cleanup_identity_predicate(
                credential_id,
                credential_name,
            )
            credential_cleanup_sql = (
                "LOCK TABLE users IN ROW SHARE MODE; "
                "WITH operator_owner AS (SELECT id FROM users "
                f"WHERE uuid = {sql_literal(admin_uuid)}), "
                "live_credential AS (SELECT id FROM credentials "
                f"WHERE {credential_identity} AND owner = (SELECT id FROM operator_owner)), "
                "deleted_data AS (DELETE FROM credentials_data WHERE credential IN (SELECT id FROM live_credential)), "
                "deleted_credential AS (DELETE FROM credentials WHERE id IN (SELECT id FROM live_credential) RETURNING id) "
                "SELECT count(*) FROM deleted_credential;"
            )
            credential_cleanup = psql(repo_root, credential_cleanup_sql)
            credential_cleanup_deleted = psql_value(credential_cleanup)
            expected_credential_counts = {"1"} if credential_create_committed else {"0", "1"}
            credential_cleanup_ok = (
                credential_cleanup.returncode == 0
                and credential_cleanup_deleted in expected_credential_counts
            )
            credential_cleanup_finding = process_step_finding(
                "pass" if credential_cleanup_ok else "fail",
                "native-api-direct.credential-fixture-cleanup",
                "Direct write-control smoke removed owner-scoped temporary credential residue by deterministic ID/name or name fallback."
                if credential_cleanup_ok
                else "Direct write-control smoke failed to clean owner-scoped temporary credential residue.",
                credential_cleanup,
                ["psql", "fixed-credential-smoke-cleanup"],
            )
            credential_cleanup_details = credential_cleanup_finding.setdefault("details", {})
            if isinstance(credential_cleanup_details, dict):
                credential_cleanup_details.update({
                    "credential_id": credential_id,
                    "credential_name": credential_name,
                    "deleted_count": credential_cleanup_deleted,
                })
            findings.append(credential_cleanup_finding)
        else:
            findings.append(finding(
                "fail",
                "native-api-direct.credential-fixture-cleanup",
                "Direct write-control smoke retained the temporary credential because SMB alert cleanup was not proven.",
            ))
    return findings


def _command_runtime_native_api_direct_write_smoke_unlocked(repo_root: Path, status_only: bool = False) -> dict[str, Any]:
    artifact_dir = native_api_artifact_dir(repo_root)
    artifact_dir.mkdir(parents=True, exist_ok=True)
    findings = ensure_runtime_dirs(repo_root)
    findings.extend(ensure_build_runtime_dirs(repo_root))
    findings.append(active_feed_generation_finding(repo_root))
    base_env = native_api_direct_runtime_env(repo_root)
    receipt, receipt_error = require_app_deployment_receipt(
        repo_root, app_env=base_env
    )
    findings.append(
        finding(
            "pass" if receipt_error is None else "fail",
            "runtime.app-deployment-receipt",
            "Prepared application deployment receipt is valid before the direct write-control smoke."
            if receipt_error is None
            else receipt_error,
            str(app_deployment_receipt_path(repo_root)),
        )
    )

    token_from_env = bool(base_env.get(YAFVS_API_BEARER_TOKEN_ENV))
    token_source = "environment" if token_from_env else "runtime-secret-file"
    token = native_api_direct_bearer_token(repo_root, base_env)
    token_ok = direct_api_bearer_token_is_acceptable(token)
    findings.append(
        finding(
            "pass" if token_ok else "fail",
            "native-api-direct.bearer-token-strength",
            "Direct native API bearer token satisfies the minimum local strength contract."
            if token_ok
            else "Direct native API bearer token is too short or contains unsafe characters.",
            details={"minimum_token_length": YAFVS_API_BEARER_TOKEN_MIN_LENGTH, "token_source": token_source},
        )
    )

    users, admin_uuid = native_api_direct_admin_operator_uuid(
        repo_root,
        app_image_ids=receipt["image_ids"] if receipt is not None else None,
    )
    findings.append(
        finding(
            "pass" if admin_uuid else "fail",
            "native-api-direct.write-control-operator",
            "Direct write-control smoke found the development admin operator UUID."
            if admin_uuid
            else "Direct write-control smoke could not find the development admin operator UUID; run runtime-manager-init.",
            details={"admin_uuid_found": bool(admin_uuid), "output_tail": output_tail(users.stdout, 80, [DEV_ADMIN_PASSWORD])},
        )
    )

    env = dict(base_env)
    env[YAFVS_API_DIRECT_WRITE_CONTROL_ENV] = "1"
    if admin_uuid:
        env[YAFVS_API_OPERATOR_UUID_ENV] = admin_uuid
        env[YAFVS_API_OPERATOR_NAME_ENV] = DEV_ADMIN_USER
    findings.append(native_api_direct_config_shape_finding(env, check="native-api-direct.write-control-config-shape"))
    host = native_api_direct_host(env)
    if host_is_wildcard(host):
        host_status = "fail"
        host_message = "Direct write-control smoke refuses wildcard host publication."
    elif not host_is_loopback(host):
        host_status = "fail"
        host_message = "Direct write-control smoke refuses non-loopback publication until production TLS/bootstrap/host-binding hardening exists."
    else:
        host_status = "pass"
        host_message = "Direct write-control smoke is loopback-bounded."
    findings.append(
        finding(
            host_status,
            "native-api-direct.write-control-host-binding",
            host_message,
            details={"host": host, "host_port": native_api_direct_port(env), "container_bind": env.get(YAFVS_API_DIRECT_BIND_ENV)},
        )
    )

    started_write_control = False
    scope_id: str | None = None
    tag_id: str | None = None
    tag_clone_id: str | None = None
