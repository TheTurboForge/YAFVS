    if name == "task.ts":
        return "task-target-scan-control-or-credential", "Task start/stop/write and credential-linked behavior remains inherited."
    if name == "hosts.js":
        return "asset-action-or-rich-context", "Host actions and richer inherited context remain outside the current native read contract."
    if name == "overrides.js":
        return "asset-action-or-rich-context", "Override writes and result-expansion behavior remain inherited."
    if name == "port-lists.ts":
        return "asset-action-or-rich-context", "Port-list imports, exports, and UI actions remain inherited."
    if name == "report.ts":
        return "report-export-delete-or-rich-context", "Report export/delete/upload and rich inherited report context remain inherited."
    if name in {"report-config.ts", "report-format.ts"}:
