def compact_browser_smoke_finding(item: dict[str, Any]) -> dict[str, Any]:
    compact = {
        key: item[key]
        for key in ("status", "check", "message", "path")
        if key in item and item[key] not in (None, "")
    }
    details = item.get("details")
    if isinstance(details, dict):
        compact_details: dict[str, Any] = {}
        for key, value in details.items():
            if key == "helper" and isinstance(value, dict):
                compact_details["helper"] = {
                    "status": value.get("status"),
                    "summary": value.get("summary"),
                    "finding_count": len(value.get("findings", [])) if isinstance(value.get("findings"), list) else 0,
                    "artifact_count": len(value.get("artifacts", [])) if isinstance(value.get("artifacts"), list) else 0,
                }
            elif key == "output_tail":
                continue
            elif isinstance(value, (str, int, float, bool)) or value is None:
                compact_details[key] = value
            elif isinstance(value, list):
                compact_details[key] = {"type": "list", "count": len(value)}
            elif isinstance(value, dict):
                compact_details[key] = {"type": "object", "key_count": len(value)}
        if compact_details:
            compact["details"] = compact_details
    return compact


def compact_status_artifacts(artifacts: Any, *, max_items: int = 5) -> list[str]:
    if not isinstance(artifacts, list):
        return []
    artifact_paths = [str(item) for item in artifacts if isinstance(item, str) and item]
    preferred = [
        item
        for item in artifact_paths
        if item.endswith((".json", ".log", ".txt"))
    ]
    return (preferred or artifact_paths)[:max_items]


def runtime_browser_smoke_status_only_result(result: dict[str, Any]) -> dict[str, Any]:
    compact = dict(result)
    findings = result.get("findings", [])
    top_non_pass = [
        compact_browser_smoke_finding(item)
        for item in findings
        if isinstance(item, dict) and item.get("status") != "pass"
    ]
    helper: dict[str, Any] | None = None
    for item in findings:
        if (
            isinstance(item, dict)
            and item.get("check") == "browser-smoke.run"
            and isinstance(item.get("details"), dict)
            and isinstance(item.get("details", {}).get("helper"), dict)
        ):
            helper = item["details"]["helper"]
            break
    helper_findings = helper.get("findings", []) if isinstance(helper, dict) else []
    helper_non_pass = [
        compact_doctor_finding(item)
        for item in helper_findings
        if isinstance(item, dict) and item.get("status") != "pass"
    ]
    route_details = next(
        (
            item.get("details", {})
            for item in findings
            if isinstance(item, dict) and item.get("check") == "browser-smoke.artifact-dir" and isinstance(item.get("details"), dict)
        ),
        {},
    )
    gsad_details = next(
        (
            item.get("details", {})
            for item in findings
            if isinstance(item, dict) and item.get("check") == "gsad.urls" and isinstance(item.get("details"), dict)
        ),
        {},
    )
    compact["details"] = {
        "finding_count": len(findings),
        "non_pass_count": len(top_non_pass),
        "helper_status": helper.get("status") if isinstance(helper, dict) else None,
        "helper_summary": helper.get("summary") if isinstance(helper, dict) else None,
        "helper_finding_count": len(helper_findings) if isinstance(helper_findings, list) else 0,
        "helper_non_pass_count": len(helper_non_pass),
        "artifact_count": len(result.get("artifacts", [])) if isinstance(result.get("artifacts"), list) else 0,
        "routes": route_details.get("routes", []),
        "base_url_count": len(gsad_details.get("base_urls", [])) if isinstance(gsad_details.get("base_urls"), list) else 0,
    }
    compact["artifacts"] = compact_status_artifacts(result.get("artifacts"))
    compact["findings"] = top_non_pass + helper_non_pass[:10] or [
        finding("pass", "runtime-browser-smoke.status-only", "Runtime browser smoke passed with compact status-only output.")
    ]
    return compact


