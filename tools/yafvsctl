def open_or_create_regular_file_at(parent_fd: int, name: str, mode: int = 0o600) -> int:
    try:
        before = os.stat(name, dir_fd=parent_fd, follow_symlinks=False)
    except FileNotFoundError:
        try:
            descriptor = os.open(
                name,
                os.O_RDWR | os.O_CREAT | os.O_EXCL | os.O_CLOEXEC | os.O_NOFOLLOW,
                mode,
                dir_fd=parent_fd,
            )
            created = os.fstat(descriptor)
            if not stat.S_ISREG(created.st_mode):
                os.close(descriptor)
                raise OSError(errno.EINVAL, f"created bind file is not regular: {name}")
            os.fchmod(descriptor, mode)
            return descriptor
        except FileExistsError:
            before = os.stat(name, dir_fd=parent_fd, follow_symlinks=False)
    if stat.S_ISLNK(before.st_mode) or not stat.S_ISREG(before.st_mode):
        raise OSError(errno.EINVAL, f"bind file is a symlink or special file: {name}")
    descriptor = os.open(name, os.O_RDWR | os.O_CLOEXEC | os.O_NOFOLLOW, dir_fd=parent_fd)
    after = os.fstat(descriptor)
    if (before.st_dev, before.st_ino) != (after.st_dev, after.st_ino) or not stat.S_ISREG(after.st_mode):
        os.close(descriptor)
        raise OSError(errno.ESTALE, f"bind file changed while opening: {name}")
    os.fchmod(descriptor, mode)
    return descriptor


def ensure_gvmd_semaphore_bind_file(
    repo_root: Path,
    state_fd: int,
    canonical_repo: Path,
    canonical_runtime: Path,
) -> Path:
    bind_parent = canonical_runtime / "state" / "gvmd-bind-files"
    if path_is_within(bind_parent, canonical_repo):
        raise OSError(errno.EINVAL, "gvmd bind-file parent must be outside the repository")
    for writable_source in app_writable_runtime_sources(repo_root):
        try:
            writable, _kind = canonical_nofollow_mount_source(writable_source)
        except FileNotFoundError:
            writable = Path(os.path.abspath(writable_source))
        if path_is_within(bind_parent, writable):
            raise OSError(errno.EINVAL, f"gvmd bind-file parent is nested under app-writable source {writable}")

    bind_parent_fd = open_directory_beneath(state_fd, ("gvmd-bind-files",))
    semaphore_fd = -1
    try:
        parent_stat = os.fstat(bind_parent_fd)
        if parent_stat.st_uid != os.getuid():
            raise OSError(errno.EPERM, "gvmd bind-file parent is not owned by the current user")
        os.fchmod(bind_parent_fd, 0o700)
        if stat.S_IMODE(os.fstat(bind_parent_fd).st_mode) & 0o077:
            raise OSError(errno.EPERM, "gvmd bind-file parent is not private")
        semaphore_fd = open_or_create_regular_file_at(bind_parent_fd, "gvmd.sem")
        os.fsync(semaphore_fd)
        os.fsync(bind_parent_fd)
    finally:
        if semaphore_fd >= 0:
            os.close(semaphore_fd)
        os.close(bind_parent_fd)
    return bind_parent / "gvmd.sem"


def seed_gvmd_runtime_state(repo_root: Path) -> dict[str, Any]:
    destination = runtime_path(repo_root, "state", "gvmd")
    repo_fd = runtime_fd = state_fd = source_fd = temporary_fd = -1
    temporary_name: str | None = None
    try:
        repo_fd, canonical_repo = open_absolute_directory_nofollow(repo_root)
        runtime_fd, canonical_runtime = open_absolute_directory_nofollow(runtime_dir(repo_root))
        if path_is_within(canonical_runtime, canonical_repo):
            raise OSError(errno.EINVAL, "runtime directory must be outside the repository")
        state_fd = open_directory_beneath(runtime_fd, ("state",))
        state_stat = os.fstat(state_fd)
        if state_stat.st_uid != os.getuid():
            raise OSError(errno.EPERM, "runtime state directory is not owned by the current user")
        os.fchmod(state_fd, 0o700)
        if stat.S_IMODE(os.fstat(state_fd).st_mode) & 0o077:
            raise OSError(errno.EPERM, "runtime state directory is not private")
        semaphore_path = ensure_gvmd_semaphore_bind_file(repo_root, state_fd, canonical_repo, canonical_runtime)

        try:
            destination_stat = os.stat("gvmd", dir_fd=state_fd, follow_symlinks=False)
        except FileNotFoundError:
            destination_stat = None
        if destination_stat is not None:
            if stat.S_ISLNK(destination_stat.st_mode) or not stat.S_ISDIR(destination_stat.st_mode):
                raise OSError(errno.EINVAL, "gvmd runtime-state destination is a symlink or special file")
            return finding("pass", "runtime.gvmd-state-seed", "Existing gvmd runtime state was left unchanged.", str(destination))

        try:
            source_fd = open_directory_beneath(repo_fd, ("build", "var", "lib", "gvm", "gvmd"))
        except FileNotFoundError:
            return finding(
                "pass",
                "runtime.gvmd-state-seed",
                "Built gvmd state is not available yet; no runtime-state seed was needed.",
                str(destination),
            )
        if container_running(repo_root, "gvmd"):
            raise OSError(errno.EBUSY, "gvmd must be stopped before initial runtime-state seeding")

        temporary_name = f".gvmd-seed-{os.getpid()}-{secrets.token_hex(8)}"
        os.mkdir(temporary_name, mode=0o700, dir_fd=state_fd)
        temporary_fd = open_directory_beneath(state_fd, (temporary_name,))
        copied, skipped = copy_gvmd_state_tree(source_fd, temporary_fd)
        os.fsync(temporary_fd)
        os.close(temporary_fd)
        temporary_fd = -1
        try:
            renameat2_noreplace(state_fd, temporary_name, state_fd, "gvmd")
        except FileExistsError:
            destination_stat = os.stat("gvmd", dir_fd=state_fd, follow_symlinks=False)
            if stat.S_ISLNK(destination_stat.st_mode) or not stat.S_ISDIR(destination_stat.st_mode):
                raise OSError(errno.EINVAL, "concurrent gvmd runtime-state destination is unsafe")
            remove_tree_at(state_fd, temporary_name)
            temporary_name = None
            return finding("pass", "runtime.gvmd-state-seed", "Existing gvmd runtime state was left unchanged.", str(destination))
        temporary_name = None
        os.fsync(state_fd)
        return finding(
            "pass",
            "runtime.gvmd-state-seed",
            "gvmd persistent state was installed atomically outside the build tree.",
            str(destination),
            {"copied": copied, "skipped_transient": skipped, "semaphore_bind_file": str(semaphore_path)},
        )
    except OSError as error:
        return finding("fail", "runtime.gvmd-state-seed", f"gvmd runtime state could not be prepared: {error}", str(destination))
    finally:
        if temporary_fd >= 0:
            os.close(temporary_fd)
        if temporary_name is not None and state_fd >= 0:
            try:
                remove_tree_at(state_fd, temporary_name)
            except OSError:
                pass
        for descriptor in (source_fd, state_fd, runtime_fd, repo_fd):
            if descriptor >= 0:
                os.close(descriptor)


def ensure_runtime_dirs(repo_root: Path) -> list[dict[str, Any]]:
    findings: list[dict[str, Any]] = []
    root = runtime_dir(repo_root)
    for dirname in RUNTIME_DIRS:
        path = root / dirname
        try:
            path.mkdir(parents=True, exist_ok=True)
            if dirname in PRIVATE_RUNTIME_DIRS:
                private_fd = open_private_directory(path)
                os.close(private_fd)
            probe = path / ".yafvs-write-test"
            probe.write_text("ok\n", encoding="utf-8")
            probe.unlink()
            status = "pass"
            message = f"Runtime directory is writable: {path}"
        except OSError as error:
            status = "fail"
            message = f"Runtime directory is not writable: {path}: {error}"
        findings.append(finding(status, "runtime.dir", message, str(path)))
    findings.append(seed_gvmd_runtime_state(repo_root))
    for lock_rel in ("run/feed-update.lock", "run/ospd/feed-update.lock"):
        path = root / lock_rel
        try:
            path.parent.mkdir(parents=True, exist_ok=True)
            path.touch(exist_ok=True)
            findings.append(finding("pass", "runtime.feed-lock", f"Runtime feed lock file exists: {path}", str(path)))
        except OSError as error:
            findings.append(finding("fail", "runtime.feed-lock", f"Runtime feed lock file is not usable: {path}: {error}", str(path)))
    return findings



