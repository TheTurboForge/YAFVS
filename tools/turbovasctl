def latest_completed_full_test_report_id(repo_root: Path) -> tuple[str | None, str | None, subprocess.CompletedProcess[str] | None]:
    if not container_running(repo_root, "postgres"):
        return None, "Postgres is not running; start the app profile before selecting the latest full-test report.", None
    query = (
        "SELECT r.uuid FROM reports r "
        "JOIN tasks t ON t.id = r.task "
        f"WHERE t.name = {sql_literal(FULL_TEST_TASK_NAME)} "
        f"AND coalesce(r.scan_run_status, 0) = {COMPLETED_SCAN_RUN_STATUS} "
        "AND coalesce(r.start_time, 0) > 0 "
        "ORDER BY coalesce(r.end_time, 0) DESC, coalesce(r.start_time, 0) DESC, r.id DESC "
        "LIMIT 1;"
    )
    result = psql(repo_root, query)
    if result.returncode != 0:
        return None, "Latest full-test report selection query failed.", result
    report_id = psql_value(result).strip()
    if not report_id:
        return None, "No completed full-test raw report exists; pass --report-id to inspect a specific report.", result
    return report_id, None, result


def command_runtime_report_metrics_native(repo_root: Path, report_id: str | None = None) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    artifact_dir = metrics_artifact_dir(repo_root)
    try:
        artifact_dir.mkdir(parents=True, exist_ok=True)
        findings.append(finding("pass", "runtime-metrics.artifact-dir", "Runtime metrics artifact directory is ready.", str(artifact_dir)))
    except OSError as error:
        findings.append(finding("fail", "runtime-metrics.artifact-dir", f"Runtime metrics artifact directory is not usable: {error}", str(artifact_dir)))
    findings.append(finding("pass" if container_running(repo_root, "turbovas-api") else "fail", "native-api.container", "turbovas-api container is running." if container_running(repo_root, "turbovas-api") else "turbovas-api container is not running; start the app profile before reading native raw-report metrics."))
    selected_report_id = report_id
    select_result = None
    if selected_report_id is None:
        selected_report_id, select_error, select_result = latest_completed_full_test_report_id(repo_root)
        if select_error:
            findings.append(finding("fail", "runtime-metrics.report-select", select_error, details={"output_tail": output_tail(select_result.stdout, 80) if select_result else []}))
        else:
            findings.append(finding("pass", "runtime-metrics.report-select", "Selected latest completed full-test raw report from PostgreSQL.", details={"report_id": selected_report_id}))
    else:
        findings.append(finding("pass", "runtime-metrics.report-select", "Using explicit raw report id.", details={"report_id": selected_report_id}))
    if aggregate_status(findings) == "fail" or not selected_report_id:
        payload = {
            "status": "fail",
            "summary": "Runtime report metrics stopped at native API prerequisites.",
            "generated_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat(),
            "details": {"source": "turbovas-api", "report_id": selected_report_id},
        }
        payload["artifacts"] = [write_json_artifact(artifact_dir, "report-metrics-failed.json", payload)]
        return make_result("runtime-report-metrics", repo_root, payload["summary"], findings, payload["artifacts"])

    metrics_path = f"/api/v1/reports/{urllib.parse.quote(selected_report_id)}/metrics"
    metrics = native_api_curl(repo_root, metrics_path)
    metrics_json = parse_json_output(metrics)
    metrics_ok = metrics.returncode == 0 and isinstance(metrics_json, dict) and isinstance(metrics_json.get("summary"), dict)
    payload = {
        "status": "pass" if metrics_ok else "fail",
        "summary": "Runtime report metrics read through the native API." if metrics_ok else "Runtime report metrics response did not include report metrics.",
        "generated_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat(),
        "details": {
            "source": "turbovas-api",
            "report_id": selected_report_id,
            "metrics": metrics_json,
        },
    }
    payload["artifacts"] = [write_json_artifact(artifact_dir, "report-metrics.json" if metrics_ok else "report-metrics-failed.json", payload)]
    findings.append(process_step_finding("pass" if metrics_ok else "fail", "runtime-metrics.report-native", payload["summary"], metrics, compose_command(repo_root, "exec", "-T", "turbovas-api", "curl", "-fsS", "http://127.0.0.1:9080/api/v1/reports/.../metrics")))
    return make_result("runtime-report-metrics", repo_root, payload["summary"], findings, payload["artifacts"])


