def normalize_native_api_endpoint_template(endpoint: str) -> str:
    return NATIVE_API_TEMPLATE_PLACEHOLDER.sub("{}", endpoint)


def normalize_native_api_operation_template(operation: str) -> str:
    method, _, endpoint = operation.partition(" ")
    return f"{method.upper()} {normalize_native_api_endpoint_template(endpoint)}" if endpoint else operation.upper()


def native_api_direct_access(endpoint: str) -> str:
    normalized = normalize_native_api_endpoint_template(endpoint)
    if normalized in DIRECT_API_SCRIPTABLE_ENDPOINTS:
        return "scriptable_read"
    if endpoint.startswith("/api/v1/") or endpoint == "/api/v1":
        return "internal_only"
    return "not_native_api"


def openapi_direct_operation_templates(repo_root: Path | None) -> list[dict[str, str]]:
    templates: list[dict[str, str]] = []
    for operation in openapi_contract_operations(repo_root):
        fields = set(operation.get("x_yafvs_fields", [])) if isinstance(operation.get("x_yafvs_fields"), list) else set()
        values = operation.get("x_yafvs_values", {}) if isinstance(operation.get("x_yafvs_values"), dict) else {}
        exposure = values.get("x-yafvs-exposure")
        if "x-yafvs-direct" not in fields and exposure not in OPENAPI_DIRECT_EXPOSURE_VALUES:
            continue
        method = str(operation.get("method", ""))
        path = str(operation.get("path", ""))
        if not method or not path:
            continue
        templates.append({"method": method, "endpoint": f"/api/v1{path}", "exposure": str(exposure or "")})
    return sorted(templates, key=lambda item: (item["method"], item["endpoint"]))


def openapi_direct_endpoint_templates(repo_root: Path | None) -> list[str]:
    direct_read_endpoints = [
        item["endpoint"]
        for item in openapi_direct_operation_templates(repo_root)
        if item["method"] == "get" and item["exposure"] == "direct-read"
    ]
    if direct_read_endpoints:
        return sorted(direct_read_endpoints)
    if repo_root is None:
        return []
    path = repo_root / "api" / "openapi" / "yafvs-v1.yaml"
    try:
        lines = path.read_text(encoding="utf-8").splitlines()
    except OSError:
        return []

    current_path: str | None = None
    in_get = False
    templates: list[str] = []
    for line in lines:
        path_match = re.match(r"^  (/[^:]+):$", line)
        if path_match:
            current_path = f"/api/v1{path_match.group(1)}"
            in_get = False
            continue
        if line.startswith("  ") and not line.startswith("    "):
            in_get = False
        if line == "    get:":
            in_get = True
            continue
        if in_get and line.strip() == "x-yafvs-direct: true" and current_path:
            templates.append(current_path)
    return sorted(templates)


def openapi_contract_lines(repo_root: Path | None) -> list[str]:
    if repo_root is None:
        return []
    path = repo_root / "api" / "openapi" / "yafvs-v1.yaml"
    try:
        return path.read_text(encoding="utf-8").splitlines()
    except OSError:
        return []


def openapi_info_version(repo_root: Path | None) -> str | None:
    in_info = False
    for line in openapi_contract_lines(repo_root):
        if line.strip() == "info:":
            in_info = True
            continue
        if in_info and line and not line.startswith("  "):
            return None
        if in_info:
            match = re.match(r"^  version:\s*([^#\s]+)\s*(?:#.*)?$", line)
            if match:
                return match.group(1)
    return None


def openapi_server_urls(repo_root: Path | None) -> list[str]:
    lines = openapi_contract_lines(repo_root)
    urls: list[str] = []
    in_servers = False
    for line in lines:
        if line == "servers:":
            in_servers = True
            continue
        if in_servers and line and not line.startswith(" "):
            break
        if in_servers:
            match = re.match(r"^  - url:\s*([^#]+?)\s*(?:#.*)?$", line)
            if match:
                urls.append(match.group(1).strip().strip("'\""))
    return urls


def openapi_top_level_security_requirements(repo_root: Path | None) -> list[str]:
    lines = openapi_contract_lines(repo_root)
    requirements: list[str] = []
    in_security = False
    for line in lines:
        if line == "security:":
            in_security = True
            continue
        if in_security and line and not line.startswith(" "):
            break
        if in_security:
            match = re.match(r"^  - ([A-Za-z0-9_]+):\s*\[\]\s*(?:#.*)?$", line)
            if match:
                requirements.append(match.group(1))
    return requirements


def openapi_security_schemes(repo_root: Path | None) -> dict[str, dict[str, str]]:
    lines = openapi_contract_lines(repo_root)
    schemes: dict[str, dict[str, str]] = {}
    in_components = False
    in_security_schemes = False
    current: str | None = None
    for line in lines:
        if line == "components:":
            in_components = True
            continue
        if in_components and line and not line.startswith(" "):
            break
        if not in_components:
            continue
        if line == "  securitySchemes:":
            in_security_schemes = True
            current = None
            continue
        if in_security_schemes and line.startswith("  ") and not line.startswith("    "):
            break
        if not in_security_schemes:
            continue
        scheme_match = re.match(r"^    ([A-Za-z0-9_]+):\s*$", line)
        if scheme_match:
            current = scheme_match.group(1)
            schemes[current] = {}
            continue
        field_match = re.match(r"^      (type|in|name|scheme):\s*([^#]+?)\s*(?:#.*)?$", line)
        if current and field_match:
            schemes[current][field_match.group(1)] = field_match.group(2).strip().strip("'\"")
    return schemes


def openapi_auth_contract_summary(repo_root: Path | None) -> dict[str, Any]:
    servers = openapi_server_urls(repo_root)
    security_requirements = openapi_top_level_security_requirements(repo_root)
    security_schemes = openapi_security_schemes(repo_root)
    missing_servers = sorted(OPENAPI_EXPECTED_SERVER_URLS - set(servers))
    unexpected_servers = sorted(set(servers) - OPENAPI_EXPECTED_SERVER_URLS)
    missing_security_requirements = sorted(OPENAPI_EXPECTED_SECURITY_REQUIREMENTS - set(security_requirements))
    unexpected_security_requirements = sorted(set(security_requirements) - OPENAPI_EXPECTED_SECURITY_REQUIREMENTS)
    missing_security_schemes = sorted(set(OPENAPI_EXPECTED_SECURITY_SCHEMES) - set(security_schemes))
    unexpected_security_schemes = sorted(set(security_schemes) - set(OPENAPI_EXPECTED_SECURITY_SCHEMES))
    security_scheme_mismatches: list[dict[str, str | None]] = []
    for name, expected_fields in sorted(OPENAPI_EXPECTED_SECURITY_SCHEMES.items()):
        actual_fields = security_schemes.get(name, {})
        for field, expected in sorted(expected_fields.items()):
            actual = actual_fields.get(field)
            if actual != expected:
                security_scheme_mismatches.append({"scheme": name, "field": field, "actual": actual, "expected": expected})
    drift = missing_servers or unexpected_servers or missing_security_requirements or unexpected_security_requirements or missing_security_schemes or unexpected_security_schemes or security_scheme_mismatches
    return {
        "alignment_status": "pass" if not drift else "warn",
        "servers": servers,
        "security_requirements": security_requirements,
        "security_schemes": security_schemes,
        "missing_servers": missing_servers,
        "unexpected_servers": unexpected_servers,
        "missing_security_requirements": missing_security_requirements,
        "unexpected_security_requirements": unexpected_security_requirements,
        "missing_security_schemes": missing_security_schemes,
        "unexpected_security_schemes": unexpected_security_schemes,
        "security_scheme_mismatches": security_scheme_mismatches,
    }


def openapi_identifier_words(value: str) -> list[str]:
    return [part.lower() for part in re.split(r"[^A-Za-z0-9]+", value) if part]


def openapi_camel_piece(value: str) -> str:
    return value[:1].upper() + value[1:]


def openapi_contract_operation_id(method: str, path: str) -> str:
    parts = [method.lower()]
    for segment in path.strip("/").split("/"):
        if segment.startswith("{") and segment.endswith("}"):
            parts.append("by")
            parts.extend(openapi_identifier_words(segment[1:-1]))
        else:
            parts.extend(openapi_identifier_words(segment))
    return parts[0] + "".join(openapi_camel_piece(part) for part in parts[1:])


def openapi_operation_label(operation: dict[str, Any]) -> str:
    return f"{str(operation.get('method', '')).upper()} {operation.get('path', '')}"


def openapi_contract_operations(repo_root: Path | None) -> list[dict[str, Any]]:
    lines = openapi_contract_lines(repo_root)
    operations: list[dict[str, Any]] = []
    current_path: str | None = None
    current: dict[str, Any] | None = None
    in_responses = False
    in_parameters = False
    in_request_body = False
    current_status: str | None = None

    def finish_current() -> None:
        nonlocal current, in_responses, in_parameters, in_request_body, current_status
        if current is not None:
            operations.append(current)
        current = None
        in_responses = False
        in_parameters = False
        in_request_body = False
        current_status = None

    for line in lines:
        path_match = re.match(r"^  (/[^:]+):$", line)
        if path_match:
            finish_current()
            current_path = path_match.group(1)
            continue
        if line == "components:" or (line and not line.startswith(" ")):
            finish_current()
            current_path = None
            continue
        method_match = re.match(r"^    ([a-z]+):$", line)
        if current_path and method_match and method_match.group(1) in OPENAPI_HTTP_METHODS:
            finish_current()
            current = {
                "method": method_match.group(1),
                "path": current_path,
                "operation_id": None,
                "summary": None,
                "x_yafvs_fields": [],
                "x_yafvs_values": {},
                "parameters": [],
                "responses": {},
                "request_body": False,
                "request_body_schema_ref": None,
            }
            continue
        if current is None:
            continue

        summary_match = re.match(r"^      summary:\s*([^#].*?)\s*(?:#.*)?$", line)
        if summary_match:
            current["summary"] = summary_match.group(1).strip()
            continue
        operation_id_match = re.match(r"^      operationId:\s*([^#\s]+)\s*$", line)
        if operation_id_match:
            current["operation_id"] = operation_id_match.group(1)
            continue
        yafvs_field_match = re.match(r"^      (x-yafvs-[A-Za-z0-9_-]+):(?:\s*([^#]+?))?\s*(?:#.*)?$", line)
        if yafvs_field_match:
            field = yafvs_field_match.group(1)
            value = yafvs_field_match.group(2)
            current["x_yafvs_fields"].append(field)
            if isinstance(current.get("x_yafvs_values"), dict):
                current["x_yafvs_values"][field] = openapi_scalar_value(value)
            continue
        if line == "      requestBody:":
            current["request_body"] = True
            in_request_body = True
            in_parameters = False
            in_responses = False
            current_status = None
            continue
        if line == "      parameters:":
            in_request_body = False
            in_parameters = True
            in_responses = False
            current_status = None
            continue
        if in_request_body and line.startswith("      ") and not line.startswith("        "):
            in_request_body = False
        if in_request_body:
            request_ref_match = re.match(r"^\s+\$ref: ['\"](#/components/schemas/[^'\"]+)['\"]$", line)
            if request_ref_match:
                current["request_body_schema_ref"] = request_ref_match.group(1)
            continue
        if in_parameters and line.startswith("      ") and not line.startswith("        "):
            in_parameters = False
        if in_parameters:
            parameter_ref_match = re.match(r"^        - \$ref: ['\"]#/components/parameters/([^'\"]+)['\"]$", line)
            if parameter_ref_match:
                current["parameters"].append(parameter_ref_match.group(1))
            continue
        if line == "      responses:":
            in_responses = True
            in_parameters = False
            in_request_body = False
            current_status = None
            continue
        if in_responses and line.startswith("      ") and not line.startswith("        "):
            in_responses = False
            current_status = None
        if not in_responses:
            continue
        status_match = re.match(r"^        '?([0-9A-Za-z]+)'?:$", line)
        if status_match:
            current_status = status_match.group(1)
            current["responses"].setdefault(current_status, None)
            continue
        response_ref_match = re.match(r"^          \$ref: ['\"]([^'\"]+)['\"]$", line)
        if response_ref_match and current_status:
            current["responses"][current_status] = response_ref_match.group(1)

    finish_current()
    return operations


def openapi_parameter_components(repo_root: Path | None) -> dict[str, dict[str, str]]:
    lines = openapi_contract_lines(repo_root)
    parameters: dict[str, dict[str, str]] = {}
    in_parameters = False
    current_name: str | None = None

    for line in lines:
        if line == "  parameters:":
            in_parameters = True
            current_name = None
            continue
        if not in_parameters:
            continue
        if line.startswith("  ") and not line.startswith("    "):
            break

        parameter_match = re.match(r"^    ([A-Za-z0-9]+):$", line)
        if parameter_match:
            current_name = parameter_match.group(1)
            parameters[current_name] = {}
            continue
        if current_name is None:
            continue
        for field, pattern in {
            "name": r"^      name:\s*([^#\s]+)",
            "in": r"^      in:\s*([^#\s]+)",
            "required": r"^      required:\s*([^#\s]+)",
            "type": r"^        type:\s*([^#\s]+)",
            "format": r"^        format:\s*([^#\s]+)",
        }.items():
            field_match = re.match(pattern, line)
            if field_match:
                parameters[current_name][field] = openapi_scalar_value(field_match.group(1)) or ""

    return parameters


def openapi_scalar_value(value: str | None) -> str | None:
    if value is None:
        return None
    value = value.strip()
    if len(value) >= 2 and value[0] == value[-1] and value[0] in {'"', "'"}:
        return value[1:-1]
    return value or None


def openapi_path_placeholders(path: str) -> list[str]:
    return re.findall(r"\{([^{}]+)\}", path)


def openapi_parameter_ref_for_placeholder(placeholder: str) -> str:
    if placeholder == "family":
        return "ScanConfigFamilyName"
    return "".join(part[:1].upper() + part[1:] for part in placeholder.split("_") if part)


def openapi_write_control_contract_summary(
    operations: list[dict[str, Any]],
    parameter_components: dict[str, dict[str, str]] | None = None,
) -> dict[str, Any]:
    write_control_operations: list[str] = []
    direct_write_control_operations: list[str] = []
    request_body_operations: list[str] = []
    get_request_body_operations: list[str] = []
    missing_metadata: list[dict[str, Any]] = []
    invalid_metadata: list[dict[str, Any]] = []
    invalid_path_parameters: list[dict[str, Any]] = []
    parameter_components = parameter_components or {}

    for item in operations:
        method = str(item.get("method", ""))
        label = openapi_operation_label(item)
        fields = set(item.get("x_yafvs_fields", [])) if isinstance(item.get("x_yafvs_fields"), list) else set()
        values = item.get("x_yafvs_values", {}) if isinstance(item.get("x_yafvs_values"), dict) else {}
        exposure = values.get("x-yafvs-exposure")
        maturity = values.get("x-yafvs-maturity")
        has_direct_marker = "x-yafvs-direct" in fields
        has_request_body = bool(item.get("request_body"))
        has_write_control_metadata = bool(fields & {"x-yafvs-safety-contract", "x-yafvs-side-effect"})
        looks_write_control = (
            method in OPENAPI_WRITE_CONTROL_METHODS
            or has_request_body
            or has_write_control_metadata
            or exposure == "direct-write"
            or maturity in {"live-write", "preview-write", "live-control", "preview-control"}
        )

        if has_request_body:
            request_body_operations.append(label)
            if method == "get":
                get_request_body_operations.append(label)
        if not looks_write_control:
            continue

        write_control_operations.append(label)
        if has_direct_marker:
            direct_write_control_operations.append(label)
            for placeholder in openapi_path_placeholders(str(item.get("path", ""))):
                expected_ref = openapi_parameter_ref_for_placeholder(placeholder)
                parameters = item.get("parameters", [])
                component = parameter_components.get(expected_ref, {})
                if expected_ref not in parameters:
                    invalid_path_parameters.append(
                        {
                            "operation": label,
                            "field": "parameters",
                            "placeholder": placeholder,
                            "actual": sorted(parameters) if isinstance(parameters, list) else parameters,
                            "expected": expected_ref,
                        }
                    )
                    continue
                expected_fields = {
                    "name": placeholder,
                    "in": "path",
                    "required": "true",
                    "type": "string",
                }
                if placeholder.endswith("_id"):
                    expected_fields["format"] = "uuid"
                for field, expected in expected_fields.items():
                    actual = component.get(field)
                    if actual != expected:
                        invalid_path_parameters.append(
                            {
                                "operation": label,
                                "field": f"components.parameters.{expected_ref}.{field}",
                                "actual": actual,
                                "expected": expected,
                            }
                        )
        for field in sorted(OPENAPI_WRITE_CONTROL_REQUIRED_FIELDS - fields):
            missing_metadata.append({"operation": label, "field": field})
        for field, allowed in {
            "x-yafvs-operator-identity": OPENAPI_ALLOWED_OPERATOR_IDENTITY_VALUES,
            "x-yafvs-owner-semantics": OPENAPI_ALLOWED_OWNER_SEMANTICS_VALUES,
            "x-yafvs-safety-contract": OPENAPI_ALLOWED_SAFETY_CONTRACT_VALUES,
            "x-yafvs-side-effect": OPENAPI_ALLOWED_SIDE_EFFECT_VALUES,
        }.items():
            if field in values and values.get(field) not in allowed:
                invalid_metadata.append(
                    {
                        "operation": label,
                        "field": field,
                        "actual": values.get(field),
                        "allowed": sorted(allowed),
                    }
                )
        if method == "get":
            invalid_metadata.append(
                {
                    "operation": label,
                    "field": "method",
                    "actual": method,
                    "expected": sorted(OPENAPI_WRITE_CONTROL_METHODS),
                }
            )
        if method != "get" and exposure == "direct-read":
            invalid_metadata.append(
                {
                    "operation": label,
                    "field": "x-yafvs-exposure",
                    "actual": exposure,
                    "expected": "direct-write or internal-only",
                }
            )
        if method == "get" and exposure == "direct-write":
            invalid_metadata.append(
                {
                    "operation": label,
                    "field": "x-yafvs-exposure",
                    "actual": exposure,
                    "expected": "direct-read or internal-only",
                }
            )

    drift = missing_metadata or invalid_metadata or invalid_path_parameters or get_request_body_operations
    return {
        "alignment_status": "pass" if not drift else "warn",
        "write_control_operations": write_control_operations,
        "direct_write_control_operations": direct_write_control_operations,
        "request_body_operations": request_body_operations,
        "get_request_body_operations": get_request_body_operations,
        "missing_write_control_metadata": missing_metadata,
        "invalid_write_control_metadata": invalid_metadata,
        "invalid_write_control_path_parameters": invalid_path_parameters,
        "allowed_safety_contract_values": sorted(OPENAPI_ALLOWED_SAFETY_CONTRACT_VALUES),
        "allowed_operator_identity_values": sorted(OPENAPI_ALLOWED_OPERATOR_IDENTITY_VALUES),
        "allowed_owner_semantics_values": sorted(OPENAPI_ALLOWED_OWNER_SEMANTICS_VALUES),
        "allowed_side_effect_values": sorted(OPENAPI_ALLOWED_SIDE_EFFECT_VALUES),
        "required_write_control_fields": sorted(OPENAPI_WRITE_CONTROL_REQUIRED_FIELDS),
    }


