def latest_completed_full_test_report_id(repo_root: Path) -> tuple[str | None, str | None, subprocess.CompletedProcess[str] | None]:
    if not container_running(repo_root, "postgres"):
        return None, "Postgres is not running; start the app profile before selecting the latest full-test report.", None
    query = (
        "SELECT r.uuid FROM reports r "
        "JOIN tasks t ON t.id = r.task "
        f"WHERE t.name = {sql_literal(FULL_TEST_TASK_NAME)} "
        f"AND coalesce(r.scan_run_status, 0) = {COMPLETED_SCAN_RUN_STATUS} "
        "AND coalesce(r.start_time, 0) > 0 "
        "ORDER BY coalesce(r.end_time, 0) DESC, coalesce(r.start_time, 0) DESC, r.id DESC "
        "LIMIT 1;"
    )
    result = psql(repo_root, query)
    if result.returncode != 0:
        return None, "Latest full-test report selection query failed.", result
    report_id = psql_value(result).strip()
    if not report_id:
        return None, "No completed full-test raw report exists; pass --report-id to inspect a specific report.", result
    return report_id, None, result


