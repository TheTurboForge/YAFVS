def native_api_module_ownership_summary(repo_root: Path) -> dict[str, Any]:
    missing_owner_symbols: list[dict[str, str]] = []
    misplaced_symbols: list[dict[str, str]] = []
    checked_symbol_count = 0
    for contract in NATIVE_API_MODULE_OWNERSHIP_CONTRACTS:
        owner = str(contract["owner"])
        owner_path = repo_root / owner
        owner_source = owner_path.read_text(encoding="utf-8", errors="ignore") if owner_path.is_file() else ""
        forbidden_sources = []
        for forbidden in contract.get("forbidden", ()):
            forbidden_path = repo_root / str(forbidden)
            source = forbidden_path.read_text(encoding="utf-8", errors="ignore") if forbidden_path.is_file() else ""
            forbidden_sources.append((str(forbidden), source))
        for symbol in contract.get("symbols", ()):
            checked_symbol_count += 1
            symbol_text = str(symbol)
            if symbol_text not in owner_source:
                missing_owner_symbols.append({"owner": owner, "symbol": symbol_text})
            for forbidden, source in forbidden_sources:
                if symbol_text in source:
                    misplaced_symbols.append({"path": forbidden, "owner": owner, "symbol": symbol_text})
    return {
        "alignment_status": "pass" if not missing_owner_symbols and not misplaced_symbols else "warn",
        "checked_symbol_count": checked_symbol_count,
        "contract_count": len(NATIVE_API_MODULE_OWNERSHIP_CONTRACTS),
        "missing_owner_symbols": missing_owner_symbols,
        "misplaced_symbols": misplaced_symbols,
    }


def native_api_browser_access_from_status(status: str | None) -> str:
    if status == "planned_internal_and_browser_proxied":
        return "planned_browser_proxied"
    if status == "partial_internal_browser_proxy_mismatch":
        return "partial_browser_proxy_mismatch"
    if status in {"implemented_internal_and_browser_proxied", "implemented_internal_browser_proxied_and_scriptable_read"}:
        return "browser_proxied"
    if status == "implemented_internal":
        return "internal_only"
    if status == "implemented_internal_and_scriptable_read":
        return "not_browser_proxied"
    if status == "implemented_direct_write_control":
        return "not_browser_proxied"
    return "unknown"


def compact_doctor_finding(item: dict[str, Any]) -> dict[str, Any]:
    compact = {
        key: item[key]
        for key in ("status", "check", "message", "path")
        if key in item and item[key] not in (None, "")
    }
    details = item.get("details")
    if isinstance(details, dict):
        compact_details: dict[str, Any] = {}
        for key, value in details.items():
            if isinstance(value, (str, int, float, bool)) or value is None:
                compact_details[key] = value
            elif isinstance(value, list):
                compact_details[key] = {"type": "list", "count": len(value)}
            elif isinstance(value, dict):
                compact_details[key] = {"type": "object", "key_count": len(value)}
        if compact_details:
            compact["details"] = compact_details
    return compact


def native_api_migration_matrix_rows(repo_root: Path) -> list[dict[str, Any]]:
    items = native_tooling_inventory(repo_root)
    summary = summarize_native_tooling(items, repo_root)
    annotate_native_tooling_direct_api(summary, repo_root)

    inventory_by_key: dict[tuple[str, str], dict[str, Any]] = {}
    for item in summary.get("implemented_native_endpoints", []):
        if not isinstance(item, dict) or not isinstance(item.get("endpoint"), str):
            continue
        method = str(item.get("method", "get"))
        key = (method, normalize_native_api_endpoint_template(item["endpoint"]))
        inventory_by_key.setdefault(key, item)

    openapi_by_key: dict[tuple[str, str], dict[str, Any]] = {}
    for operation in openapi_contract_operations(repo_root):
        method = str(operation.get("method", ""))
        path = operation.get("path")
        if not method or not isinstance(path, str):
            continue
        endpoint = f"/api/v1{path}"
        key = (method, normalize_native_api_endpoint_template(endpoint))
        openapi_by_key.setdefault(key, operation)

    def row_endpoint(key: tuple[str, str]) -> str:
        operation = openapi_by_key.get(key)
        if operation and isinstance(operation.get("path"), str):
            return f"/api/v1{operation['path']}"
        inventory = inventory_by_key.get(key, {})
        endpoint = inventory.get("endpoint")
        return endpoint if isinstance(endpoint, str) else key[1]

    rows: list[dict[str, Any]] = []
    for key in sorted(set(inventory_by_key) | set(openapi_by_key), key=row_endpoint):
        method, _normalized = key
        inventory = inventory_by_key.get(key)
        operation = openapi_by_key.get(key)
        endpoint = row_endpoint(key)
        fields = set(operation.get("x_yafvs_fields", [])) if isinstance(operation, dict) else set()
        values = operation.get("x_yafvs_values", {}) if isinstance(operation, dict) and isinstance(operation.get("x_yafvs_values"), dict) else {}
        status = inventory.get("status") if isinstance(inventory, dict) and isinstance(inventory.get("status"), str) else "unknown"
        if status == "unknown" and openapi_operation_is_pending_write_control(operation):
            status = "openapi_preview_write_control"
        if method != "get" and status != "openapi_preview_write_control":
            operation_status = (
                native_api_effective_browser_proxy_status(repo_root, inventory)
                if isinstance(inventory, dict)
                else native_browser_proxy_operation_status(repo_root, method, endpoint)
            )
            if operation_status != "planned_internal_and_browser_proxied":
                status = operation_status
        if isinstance(inventory, dict) and isinstance(inventory.get("direct_access"), str):
            direct_access = inventory["direct_access"]
        elif status == "openapi_preview_write_control":
            direct_access = "internal_only"
        else:
            direct_access = native_api_direct_access(endpoint)
        replacement_candidates = inventory.get("replacement_candidates", []) if isinstance(inventory, dict) else []
        if not isinstance(replacement_candidates, list):
            replacement_candidates = []
        rows.append(
            {
                "endpoint": endpoint,
                "method": method,
                "status": status,
                "browser_access": native_api_browser_access_from_status(status),
                "direct_access": direct_access,
                "operation_id": operation.get("operation_id") if isinstance(operation, dict) else None,
                "openapi_path": operation.get("path") if isinstance(operation, dict) else None,
                "inventory_endpoint": inventory.get("endpoint") if isinstance(inventory, dict) else None,
                "openapi_direct_marker": "x-yafvs-direct" in fields if isinstance(operation, dict) else None,
                "x_yafvs_exposure": values.get("x-yafvs-exposure"),
                "x_yafvs_maturity": values.get("x-yafvs-maturity"),
                "x_yafvs_operator_identity": values.get("x-yafvs-operator-identity"),
                "x_yafvs_owner_semantics": values.get("x-yafvs-owner-semantics"),
                "x_yafvs_replaces": values.get("x-yafvs-replaces"),
                "x_yafvs_inherited_still_owns": values.get("x-yafvs-inherited-still-owns"),
                "x_yafvs_safety_contract": values.get("x-yafvs-safety-contract"),
                "x_yafvs_side_effect": values.get("x-yafvs-side-effect"),
                "replacement_candidates": replacement_candidates,
            }
        )
    return rows


def native_api_migration_matrix_summary(rows: list[dict[str, Any]]) -> dict[str, Any]:
    def counts(field: str) -> dict[str, int]:
        result: dict[str, int] = {}
        for row in rows:
            value = row.get(field)
            key = str(value) if value is not None else "null"
            result[key] = result.get(key, 0) + 1
        return dict(sorted(result.items()))

    def percentage(count: int, total: int) -> float:
        return round((100.0 * count / total), 1) if total else 0.0

    contract = native_api_migration_matrix_contract_summary(rows)
    total_rows = len(rows)
    openapi_rows = sum(1 for row in rows if row.get("openapi_path") is not None)
    inventory_rows = sum(1 for row in rows if row.get("inventory_endpoint") is not None)
    replacement_candidate_rows = sum(1 for row in rows if row.get("replacement_candidates"))
    metadata_rows = sum(1 for row in rows if any(row.get(field) is not None for field in NATIVE_API_MIGRATION_MATRIX_METADATA_FIELDS))
    browser_access_counts = counts("browser_access")
    direct_access_counts = counts("direct_access")
    return {
        "total_rows": total_rows,
        "openapi_operation_rows": openapi_rows,
        "inventory_rows": inventory_rows,
        "rows_with_replacement_candidates": replacement_candidate_rows,
        "rows_with_checked_migration_metadata": metadata_rows,
        "checked_migration_field_counts": {field: sum(1 for row in rows if row.get(field) is not None) for field in NATIVE_API_MIGRATION_MATRIX_METADATA_FIELDS},
        "rows_missing_openapi_count": len(contract["rows_missing_openapi"]),
        "rows_missing_inventory_count": len(contract["rows_missing_inventory"]),
        "rows_missing_migration_metadata_count": len(contract["rows_missing_migration_metadata"]),
        "direct_exposure_mismatch_count": len(contract["direct_exposure_mismatches"]),
        "direct_marker_mismatch_count": len(contract["direct_marker_mismatches"]),
        "progress_percentages": {
            "openapi_operation_rows_percent": percentage(openapi_rows, total_rows),
            "inventory_rows_percent": percentage(inventory_rows, total_rows),
            "rows_with_replacement_candidates_percent": percentage(replacement_candidate_rows, total_rows),
            "rows_with_checked_migration_metadata_percent": percentage(metadata_rows, total_rows),
            "browser_proxied_percent": percentage(browser_access_counts.get("browser_proxied", 0), total_rows),
            "scriptable_read_percent": percentage(direct_access_counts.get("scriptable_read", 0), total_rows),
            "internal_only_percent": percentage(direct_access_counts.get("internal_only", 0), total_rows),
        },
        "by_status": counts("status"),
        "by_browser_access": browser_access_counts,
        "by_direct_access": direct_access_counts,
    }


def native_api_migration_matrix_contract_summary(rows: list[dict[str, Any]]) -> dict[str, list[dict[str, Any]]]:
    rows_missing_openapi = [
        {"endpoint": row.get("endpoint"), "method": row.get("method"), "inventory_endpoint": row.get("inventory_endpoint")}
        for row in rows
        if row.get("openapi_path") is None
    ]
    rows_missing_inventory = [
        {"endpoint": row.get("endpoint"), "method": row.get("method"), "openapi_path": row.get("openapi_path")}
        for row in rows
        if row.get("inventory_endpoint") is None and row.get("status") != "openapi_preview_write_control"
    ]
    rows_missing_migration_metadata = []
    direct_exposure_mismatches = []
    direct_marker_mismatches = []
    for row in rows:
        missing_fields = [field for field in NATIVE_API_MIGRATION_MATRIX_METADATA_FIELDS if row.get(field) is None]
        if missing_fields:
            rows_missing_migration_metadata.append(
                {"endpoint": row.get("endpoint"), "method": row.get("method"), "missing_fields": missing_fields}
            )

        direct_access = row.get("direct_access")
        expected_exposure = None
        expected_marker = None
        if direct_access == "scriptable_read":
            expected_exposure = "direct-read"
            expected_marker = True
        elif direct_access == "browser_write":
            expected_exposure = "browser-write"
            expected_marker = False
        elif direct_access == "internal_only":
            expected_exposure = "internal-only"
            expected_marker = False
        elif direct_access == "direct_write_control":
            expected_exposure = "direct-write"
            expected_marker = True

        if expected_exposure is not None and row.get("x_yafvs_exposure") != expected_exposure:
            direct_exposure_mismatches.append(
                {
                    "endpoint": row.get("endpoint"),
                    "method": row.get("method"),
                    "direct_access": direct_access,
                    "actual": row.get("x_yafvs_exposure"),
                    "expected": expected_exposure,
                }
            )
        if expected_marker is not None and row.get("openapi_direct_marker") is not expected_marker:
            direct_marker_mismatches.append(
                {
                    "endpoint": row.get("endpoint"),
                    "method": row.get("method"),
                    "direct_access": direct_access,
                    "actual": row.get("openapi_direct_marker"),
                    "expected": expected_marker,
                }
            )

    return {
        "rows_missing_openapi": rows_missing_openapi,
        "rows_missing_inventory": rows_missing_inventory,
        "rows_missing_migration_metadata": rows_missing_migration_metadata,
        "direct_exposure_mismatches": direct_exposure_mismatches,
        "direct_marker_mismatches": direct_marker_mismatches,
    }


def native_api_migration_matrix_focus_values(focus: str | Iterable[str] | None = None) -> list[str]:
    if not focus:
        return []
    if isinstance(focus, str):
        return [focus]
    return [value for value in focus if value]


def native_api_migration_matrix_focus_label(focus: str | Iterable[str] | None = None) -> str | None:
    values = native_api_migration_matrix_focus_values(focus)
    if not values:
        return None
    return ", ".join(values)


def native_api_migration_matrix_focus_terms(focus: str | Iterable[str] | None = None) -> list[str]:
    terms: list[str] = []
    for value in native_api_migration_matrix_focus_values(focus):
        terms.extend(term.strip().lower() for term in value.split(",") if term.strip())
    return terms


NATIVE_API_MIGRATION_RESIDUAL_BUCKET_TOKENS = {
    "write_or_mutation": ("write", "writes", "mutation", "mutations", "create", "creation", "delete", "deletes", "import"),
    "control_or_operation": ("control", "actions", "feed-sync", "scan-control", "delivery"),
    "export_or_download": ("export", "exports", "download", "downloads"),
    "credential_or_secret": ("credential", "credentials", "secret", "secrets"),
    "rich_context_or_history": ("rich", "history", "raw", "xml", "row-data"),
    "report_generation_or_retention": ("generation", "report-generation", "retention"),
}


def native_api_migration_matrix_residual_buckets(row: dict[str, Any]) -> list[str]:
    residue = row.get("x_yafvs_inherited_still_owns")
    if not isinstance(residue, str) or not residue:
        return []
    residue_words = residue.lower()
    return [
        bucket
        for bucket, tokens in NATIVE_API_MIGRATION_RESIDUAL_BUCKET_TOKENS.items()
        if any(token in residue_words for token in tokens)
    ]


def native_api_migration_matrix_filter_rows(rows: list[dict[str, Any]], focus: str | Iterable[str] | None = None) -> list[dict[str, Any]]:
    terms = native_api_migration_matrix_focus_terms(focus)
    if not terms:
        return rows

    def searchable_text(row: dict[str, Any]) -> str:
        values: list[str] = []
        for key in (
            "endpoint",
            "method",
            "status",
            "browser_access",
            "direct_access",
            "operation_id",
            "openapi_path",
            "x_yafvs_exposure",
            "x_yafvs_maturity",
            "x_yafvs_operator_identity",
            "x_yafvs_owner_semantics",
            "x_yafvs_replaces",
            "x_yafvs_inherited_still_owns",
            "x_yafvs_safety_contract",
            "x_yafvs_side_effect",
        ):
            value = row.get(key)
            if value is not None:
                values.append(str(value))
        candidates = row.get("replacement_candidates")
        if isinstance(candidates, list):
            values.extend(str(candidate) for candidate in candidates)
        values.extend(native_api_migration_matrix_residual_buckets(row))
        return "\n".join(values).lower()

    return [row for row in rows if any(term in searchable_text(row) for term in terms)]


def openapi_operation_is_pending_write_control(operation: dict[str, Any] | None) -> bool:
    if not isinstance(operation, dict):
        return False
    values = operation.get("x_yafvs_values", {}) if isinstance(operation.get("x_yafvs_values"), dict) else {}
    maturity = values.get("x-yafvs-maturity")
    exposure = values.get("x-yafvs-exposure")
    return exposure == "internal-only" and maturity in {"preview-write", "preview-control"}


def native_api_migration_matrix_remaining_surface(rows: list[dict[str, Any]]) -> dict[str, Any]:
    bucket_counts = {bucket: 0 for bucket in NATIVE_API_MIGRATION_RESIDUAL_BUCKET_TOKENS}
    residue_counts: dict[str, int] = {}
    examples: dict[str, str] = {}
    for row in rows:
        residue = row.get("x_yafvs_inherited_still_owns")
        if not isinstance(residue, str) or not residue:
            continue
        residue_counts[residue] = residue_counts.get(residue, 0) + 1
        endpoint = row.get("endpoint")
        if isinstance(endpoint, str):
            examples.setdefault(residue, endpoint)
        for bucket in native_api_migration_matrix_residual_buckets(row):
            bucket_counts[bucket] += 1

    top_residuals = [
        {"residue": residue, "count": count, "example_endpoint": examples.get(residue)}
        for residue, count in sorted(residue_counts.items(), key=lambda item: (-item[1], item[0]))[:8]
    ]
    return {
        "rows_with_inherited_owner_tail": sum(residue_counts.values()),
        "distinct_owner_tails": len(residue_counts),
        "bucket_counts": bucket_counts,
        "top_residuals": top_residuals,
        "planning_hint": (
            "Current native rows are metadata-complete; remaining inherited tails are mostly "
            "writes, control, exports, rich context, credentials, report generation, or retention. "
            "Skip candidates that cross those boundaries unless a dedicated design packet authorizes them."
        ),
    }


def native_api_migration_matrix_compact_focus_row(row: dict[str, Any]) -> dict[str, Any]:
    keys = (
        "method",
        "endpoint",
        "status",
        "direct_access",
        "browser_access",
        "x_yafvs_replaces",
        "x_yafvs_inherited_still_owns",
        "x_yafvs_operator_identity",
        "x_yafvs_owner_semantics",
        "x_yafvs_side_effect",
        "x_yafvs_safety_contract",
    )
    return {key: row[key] for key in keys if row.get(key) is not None}


def native_api_migration_matrix_status_only_result(result: dict[str, Any]) -> dict[str, Any]:
    details = result.get("details") if isinstance(result.get("details"), dict) else {}
    rows = details.get("items") if isinstance(details.get("items"), list) else []
    findings = result.get("findings", [])
    non_pass = [item for item in findings if item.get("status") != "pass"]
    compact = dict(result)
    compact["details"] = {
        "summary": details.get("summary", {}),
        "contract": details.get("contract", {}),
        "remaining_inherited_surface": native_api_migration_matrix_remaining_surface(rows),
    }
    if details.get("focus"):
        compact["details"]["focus"] = details["focus"]
    if details.get("focus_terms") is not None:
        compact["details"]["focus_terms"] = details["focus_terms"]
        compact["details"]["focus_match_count"] = details.get("focus_match_count", 0)
        focus_row_limit = 20
        compact["details"]["focus_rows"] = [
            native_api_migration_matrix_compact_focus_row(row)
            for row in rows[:focus_row_limit]
            if isinstance(row, dict)
        ]
        compact["details"]["focus_rows_truncated"] = len(rows) > focus_row_limit
    compact["findings"] = non_pass or [
        finding(
            "pass",
            "native-api-migration-matrix.status-only",
            "Native API migration matrix passed; no non-pass findings.",
        )
    ]
    return compact


def command_native_api_migration_matrix(repo_root: Path, status_only: bool = False, focus: str | Iterable[str] | None = None) -> dict[str, Any]:
    focus_terms = native_api_migration_matrix_focus_terms(focus)
    focus_label = native_api_migration_matrix_focus_label(focus)
    rows = native_api_migration_matrix_filter_rows(native_api_migration_matrix_rows(repo_root), focus)
    contract = native_api_migration_matrix_contract_summary(rows)
    summary = native_api_migration_matrix_summary(rows)
    details = {"summary": summary, "contract": contract, "items": rows}
    if focus_label:
        details["focus"] = focus_label
    if focus_terms:
        details["focus_terms"] = focus_terms
        details["focus_match_count"] = len(rows)
    row_drift = contract["rows_missing_openapi"] or contract["rows_missing_inventory"]
    metadata_drift = (
        contract["rows_missing_migration_metadata"]
        or contract["direct_exposure_mismatches"]
        or contract["direct_marker_mismatches"]
    )
    findings = [
        finding(
            "pass" if rows else "warn",
            "native-api-migration-matrix.rows",
            f"Collected {len(rows)} native API migration matrix row(s) from endpoint inventory and OpenAPI metadata.",
            details=details["summary"],
        ),
        finding(
            "fail" if row_drift else "pass",
            "native-api-migration-matrix.coverage",
            "Native API migration matrix rows are present in both endpoint inventory and OpenAPI."
            if not row_drift
            else "Native API migration matrix has endpoint inventory/OpenAPI row gaps.",
            details={
                "rows_missing_openapi_count": summary["rows_missing_openapi_count"],
                "rows_missing_inventory_count": summary["rows_missing_inventory_count"],
                "rows_missing_openapi": contract["rows_missing_openapi"],
                "rows_missing_inventory": contract["rows_missing_inventory"],
            },
        ),
        finding(
            "fail" if metadata_drift else "pass",
            "native-api-migration-matrix.metadata",
            "Native API migration matrix rows have complete migration metadata and direct exposure markers."
            if not metadata_drift
            else "Native API migration matrix rows have missing migration metadata or direct exposure marker drift.",
            details={
                "rows_missing_migration_metadata_count": summary["rows_missing_migration_metadata_count"],
                "direct_exposure_mismatch_count": summary["direct_exposure_mismatch_count"],
                "direct_marker_mismatch_count": summary["direct_marker_mismatch_count"],
                "rows_missing_migration_metadata": contract["rows_missing_migration_metadata"],
                "direct_exposure_mismatches": contract["direct_exposure_mismatches"],
                "direct_marker_mismatches": contract["direct_marker_mismatches"],
            },
        ),
    ]
    if focus_terms and not rows:
        findings.append(
            finding(
                "warn",
                "native-api-migration-matrix.focus",
                "Native API migration matrix focus terms matched zero rows.",
                details={"focus": focus_label, "focus_terms": focus_terms},
            )
        )
    result = make_result("native-api-migration-matrix", repo_root, "Native API migration matrix collected.", findings)
    result["details"] = details
    if status_only:
        result = native_api_migration_matrix_status_only_result(result)
    return result


def bounded_percent(value: float) -> float:
    return round(max(0.0, min(100.0, value)), 1)


def legacy_component_source_teardown(repo_root: Path) -> dict[str, Any]:
    component_states = {
        name: "present" if (repo_root / "components" / name).exists() else "absent"
        for name in ("python-gvm", "gvm-tools")
    }
    absent_count = sum(state == "absent" for state in component_states.values())
    percent = bounded_percent(100.0 * absent_count / len(component_states))
    return {
        "percent": percent,
        "status": "complete" if absent_count == len(component_states) else "in_progress",
        "components": component_states,
    }


def native_api_replacement_dashboard_status_only_result(result: dict[str, Any]) -> dict[str, Any]:
