def quality_gate_doctor_status(doctor_result: dict[str, Any]) -> tuple[str, str]:
    allowed_warnings = {"git.worktree", "surface.deferred"}
    non_pass = [item for item in doctor_result.get("findings", []) if item.get("status") != "pass"]
    if doctor_result.get("status") == "warn" and non_pass and all(item.get("status") == "warn" and item.get("check") in allowed_warnings for item in non_pass):
        return "pass", "Doctor completed with only worktree/deferred-surface notes."
    return doctor_result.get("status", "fail"), doctor_result.get("summary", "Doctor status unavailable.")


def command_quality_gate(repo_root: Path, include_runtime: bool = False) -> dict[str, Any]:
    artifact_dir = quality_gate_artifact_dir(repo_root)
    artifact_dir.mkdir(parents=True, exist_ok=True)
    findings: list[dict[str, Any]] = []
    details: dict[str, Any] = {"steps": {}}

    license_result = command_license_report(repo_root)
    details["steps"]["license-report"] = {"status": license_result["status"], "summary": license_result["summary"]}
    findings.append(finding(license_result["status"], "quality.license-report", license_result["summary"], details={"status": license_result["status"]}))

    doctor_result = command_doctor(repo_root)
    doctor_status, doctor_summary = quality_gate_doctor_status(doctor_result)
    doctor_non_pass = [item for item in doctor_result.get("findings", []) if item.get("status") != "pass"]
    details["steps"]["doctor"] = {
        "status": doctor_result["status"],
        "quality_status": doctor_status,
        "summary": doctor_result["summary"],
        "non_pass_findings": doctor_non_pass,
    }
    findings.append(finding(doctor_status, "quality.doctor", doctor_summary, details={"status": doctor_result["status"], "quality_status": doctor_status}))

    unit_command = [sys.executable, "-m", "unittest", "tools.tests.test_turbovasctl"]
    unit = run_command(unit_command, repo_root, env=quality_gate_unit_env(repo_root), timeout=300)
    details["steps"]["python-unit"] = {"exit_code": unit.returncode, "output_tail": output_tail(unit.stdout, 120)}
    findings.append(process_step_finding("pass" if unit.returncode == 0 else "fail", "quality.python-unit", f"Python tool unit tests exit code {unit.returncode}.", unit, unit_command))

    py_files = [repo_root / "tools" / "turbovasctl", *sorted((repo_root / "tools").glob("runtime_*.py"))]
    py_compile_command = [sys.executable, "-m", "py_compile", *[str(path.relative_to(repo_root)) for path in py_files]]
    py_compile = run_command(py_compile_command, repo_root, env=build_env(repo_root), timeout=120)
    details["steps"]["py_compile"] = {"exit_code": py_compile.returncode, "files": [str(path.relative_to(repo_root)) for path in py_files], "output_tail": output_tail(py_compile.stdout, 120)}
    findings.append(process_step_finding("pass" if py_compile.returncode == 0 else "fail", "quality.py-compile", f"Python compile check exit code {py_compile.returncode}.", py_compile, py_compile_command))

    compose_command_line = compose_command(repo_root, "--profile", "app", "config", "--quiet")
    compose = run_command(compose_command_line, repo_root, env=runtime_env(repo_root), timeout=120)
    details["steps"]["compose-config"] = {"exit_code": compose.returncode, "output_tail": output_tail(compose.stdout, 120)}
    findings.append(process_step_finding("pass" if compose.returncode == 0 else "fail", "quality.compose-config", f"Compose config validation exit code {compose.returncode}.", compose, compose_command_line))

    api_manifest = repo_root / "services" / "turbovas-api" / "Cargo.toml"
    if api_manifest.is_file():
        cargo_fmt_command = ["bash", "-lc", "cd services/turbovas-api && cargo fmt --check"]
        cargo_fmt = run_command(cargo_fmt_command, repo_root, env=build_env(repo_root), timeout=120)
        details["steps"]["turbovas-api-fmt"] = {"exit_code": cargo_fmt.returncode, "output_tail": output_tail(cargo_fmt.stdout, 120)}
        findings.append(process_step_finding("pass" if cargo_fmt.returncode == 0 else "fail", "quality.turbovas-api-fmt", f"turbovas-api cargo fmt exit code {cargo_fmt.returncode}.", cargo_fmt, cargo_fmt_command))

        cargo_test_command = ["bash", "-lc", "cd services/turbovas-api && cargo test --locked"]
        cargo_test = run_command(cargo_test_command, repo_root, env=build_env(repo_root), timeout=600)
        details["steps"]["turbovas-api-test"] = {"exit_code": cargo_test.returncode, "output_tail": output_tail(cargo_test.stdout, 160)}
        findings.append(process_step_finding("pass" if cargo_test.returncode == 0 else "fail", "quality.turbovas-api-test", f"turbovas-api cargo test exit code {cargo_test.returncode}.", cargo_test, cargo_test_command))

    try:
        with acquire_runtime_lock(repo_root, GSA_OPERATION_LOCK, "quality-gate GSA checks"):
            gsa_type = run_command(["bash", "-lc", "cd components/gsa && npm run type-check"], repo_root, env=gsa_quality_env(repo_root), timeout=600)
            details["steps"]["gsa-type-check"] = {"exit_code": gsa_type.returncode, "output_tail": output_tail(gsa_type.stdout, 120)}
            findings.append(process_step_finding("pass" if gsa_type.returncode == 0 else "fail", "quality.gsa-type-check", f"GSA type-check exit code {gsa_type.returncode}.", gsa_type, ["bash", "-lc", "cd components/gsa && npm run type-check"]))

            gsa_fast = run_command(["bash", "-lc", "cd components/gsa && npm run test:web-fast"], repo_root, env=gsa_quality_env(repo_root), timeout=900)
            details["steps"]["gsa-test-web-fast"] = {"exit_code": gsa_fast.returncode, "output_tail": output_tail(gsa_fast.stdout, 160)}
            findings.append(process_step_finding("pass" if gsa_fast.returncode == 0 else "fail", "quality.gsa-test-web-fast", f"GSA web-fast test exit code {gsa_fast.returncode}.", gsa_fast, ["bash", "-lc", "cd components/gsa && npm run test:web-fast"]))
    except RuntimeLockTimeout as exc:
        details["steps"]["gsa-lock"] = {"status": "fail", "holder": exc.metadata}
        findings.append(runtime_lock_timeout_finding(exc, "quality.gsa-lock"))

    if include_runtime:
        for name, command_result in (
            ("runtime-status", command_runtime_status(repo_root)),
            ("runtime-log-review", command_runtime_log_review(repo_root)),
            ("runtime-data-state", command_runtime_data_state(repo_root)),
        ):
            details["steps"][name] = {"status": command_result["status"], "summary": command_result["summary"], "artifacts": command_result.get("artifacts", [])}
            findings.append(finding(command_result["status"], f"quality.{name}", command_result["summary"], details={"status": command_result["status"], "artifacts": command_result.get("artifacts", [])}))

    latest_path, timestamped_path = retained_json_artifact_paths(artifact_dir, "quality-gate", "quality-gate.json")
    result = make_result("quality-gate", repo_root, "Local quality gate completed.", findings, [str(latest_path), str(timestamped_path)])
    result["details"] = details
    write_retained_json_artifact(latest_path, timestamped_path, result, "quality-gate", RETAINED_QUALITY_GATE_ARTIFACTS)
    return result


def command_quality_gate_state(repo_root: Path) -> dict[str, Any]:
    artifact_dir = quality_gate_artifact_dir(repo_root)
    latest_path = artifact_dir / "quality-gate.json"
    latest = read_json_artifact(latest_path)
    history = json_artifact_history(artifact_dir, "quality-gate") if artifact_dir.exists() else []
    recent_failures = [entry for entry in history if entry.get("status") == "fail"][:5]
    details: dict[str, Any] = {
        "artifact_dir": str(artifact_dir),
        "latest_artifact_path": str(latest_path),
        "history_count": len(history),
        "history": history[:10],
        "recent_failures": recent_failures,
    }
    findings: list[dict[str, Any]] = []
    if latest is None:
        findings.append(finding("warn", "quality-gate-state.latest", "No quality gate artifact has been written yet.", str(latest_path)))
        summary = "No quality gate history found."
    else:
        latest_status = latest.get("status", "unknown")
        details["latest"] = {
            "status": latest_status,
            "summary": latest.get("summary", ""),
            "generated_at": latest.get("metadata", {}).get("generated_at"),
            "artifact_path": str(latest_path),
        }
        findings.append(finding(latest_status if latest_status in STATUSES else "warn", "quality-gate-state.latest", f"Latest quality gate status is {latest_status}.", str(latest_path), {"latest": details["latest"]}))
        summary = f"Latest quality gate status is {latest_status}."
    findings.append(finding("pass", "quality-gate-state.history", f"Quality gate history contains {len(history)} retained timestamped artifacts.", details={"history_count": len(history), "recent_failure_count": len(recent_failures)}))
    result = make_result("quality-gate-state", repo_root, summary, findings, [str(latest_path)] if latest_path.exists() else [])
    result["details"] = details
    return result


def command_quality_gate_schedule(repo_root: Path, action: str) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    details: dict[str, Any] = {"action": action, "host": socket.gethostname(), "user": os.environ.get("USER") or Path.home().name}
    if action == "install":
        if socket.gethostname() != "turboforge-server":
            findings.append(finding("fail", "quality-gate-schedule.host", "Quality gate timer installation is allowed only on turboforge-server.", details={"host": socket.gethostname()}))
            return make_result("quality-gate-schedule", repo_root, "Quality gate schedule installation refused on the wrong host.", findings)
        if details["user"] != "turboforge":
            findings.append(finding("fail", "quality-gate-schedule.user", "Quality gate timer installation must run as the turboforge user.", details={"user": details["user"]}))
            return make_result("quality-gate-schedule", repo_root, "Quality gate schedule installation refused for the wrong user.", findings)
        systemd = systemctl_user(repo_root, "status", timeout=30)
        if systemd.returncode != 0:
            findings.append(process_step_finding("fail", "quality-gate-schedule.systemd-user", "User-level systemd is unavailable; refusing to fall back to cron.", systemd, ["systemctl", "--user", "status"]))
            result = make_result("quality-gate-schedule", repo_root, "Quality gate schedule installation blocked because user-level systemd is unavailable.", findings)
            result["details"] = details
            return result
        unit_dir = systemd_user_unit_dir()
        unit_dir.mkdir(parents=True, exist_ok=True)
        quality_gate_log_dir(repo_root).mkdir(parents=True, exist_ok=True)
        for unit in QUALITY_GATE_SYSTEMD_UNITS:
            target = unit_dir / unit
            target.write_text(render_quality_gate_systemd_unit(repo_root, unit), encoding="utf-8")
            findings.append(finding("pass", "quality-gate-schedule.unit-written", f"Wrote {unit} user unit.", str(target)))
        reload_result = systemctl_user(repo_root, "daemon-reload", timeout=60)
        findings.append(process_step_finding("pass" if reload_result.returncode == 0 else "fail", "quality-gate-schedule.daemon-reload", f"systemctl --user daemon-reload exit code {reload_result.returncode}.", reload_result, ["systemctl", "--user", "daemon-reload"]))
        enable = systemctl_user(repo_root, "enable", "--now", QUALITY_GATE_TIMER_NAME, timeout=60)
        findings.append(process_step_finding("pass" if enable.returncode == 0 else "fail", "quality-gate-schedule.enable", f"Enabled {QUALITY_GATE_TIMER_NAME} with exit code {enable.returncode}.", enable, ["systemctl", "--user", "enable", "--now", QUALITY_GATE_TIMER_NAME]))
    elif action == "disable":
        disable = systemctl_user(repo_root, "disable", "--now", QUALITY_GATE_TIMER_NAME, timeout=60)
        status = "pass" if disable.returncode == 0 else "warn"
        findings.append(process_step_finding(status, "quality-gate-schedule.disable", f"Disabled {QUALITY_GATE_TIMER_NAME} with exit code {disable.returncode}.", disable, ["systemctl", "--user", "disable", "--now", QUALITY_GATE_TIMER_NAME]))
    elif action != "status":
        findings.append(finding("fail", "quality-gate-schedule.action", f"Unknown schedule action {action}."))
        return make_result("quality-gate-schedule", repo_root, "Unknown quality gate schedule action.", findings)

    status_findings, status_details = quality_gate_schedule_status_details(repo_root)
    findings.extend(status_findings)
    details["status"] = status_details
    summary = "Quality gate schedule status collected." if action == "status" else f"Quality gate schedule {action} completed."
    result = make_result("quality-gate-schedule", repo_root, summary, findings, [str(systemd_user_unit_dir() / unit) for unit in QUALITY_GATE_SYSTEMD_UNITS])
    result["details"] = details
    return result


def print_human(result: dict[str, Any]) -> None:
    print(f"{result['status'].upper()}: {result['summary']}")
    for item in result["findings"]:
        line = f"[{item['status']}] {item['check']}: {item['message']}"
        if "path" in item:
            line += f" ({item['path']})"
        print(line)


def emit(result: dict[str, Any], as_json: bool) -> int:
    if as_json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        print_human(result)
    return 1 if result["status"] == "fail" else 0


