def command_runtime_report_export_native(repo_root: Path, report_id: str | None = None, max_results: int = 1000, top_results: int = 10) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    artifact_dir = report_artifact_dir(repo_root)
    try:
        artifact_dir.mkdir(parents=True, exist_ok=True)
        findings.append(finding("pass", "runtime-report.artifact-dir", "Runtime report artifact directory is ready.", str(artifact_dir)))
    except OSError as error:
        findings.append(finding("fail", "runtime-report.artifact-dir", f"Runtime report artifact directory is not usable: {error}", str(artifact_dir)))
    findings.append(finding("pass" if container_running(repo_root, "turbovas-api") else "fail", "native-api.container", "turbovas-api container is running." if container_running(repo_root, "turbovas-api") else "turbovas-api container is not running; start the app profile before exporting native raw-report data."))
    selected_report_id = report_id
    select_result = None
    if selected_report_id is None:
        selected_report_id, select_error, select_result = latest_completed_full_test_report_id(repo_root)
        if select_error:
            findings.append(finding("fail", "runtime-report.report-select", select_error, details={"output_tail": output_tail(select_result.stdout, 80) if select_result else []}))
        else:
            findings.append(finding("pass", "runtime-report.report-select", "Selected latest completed full-test raw report from PostgreSQL.", details={"report_id": selected_report_id}))
    else:
        findings.append(finding("pass", "runtime-report.report-select", "Using explicit raw report id.", details={"report_id": selected_report_id}))
    if aggregate_status(findings) == "fail" or not selected_report_id:
        payload = {
            "status": "fail",
            "summary": "Runtime report export stopped at native API prerequisites.",
            "generated_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat(),
            "details": {"source": "turbovas-api", "report_id": selected_report_id},
        }
        payload["artifacts"] = [write_json_artifact(artifact_dir, "export-failed.json", payload)]
        return make_result("runtime-report-export", repo_root, payload["summary"], findings, payload["artifacts"])

    detail_path = f"/api/v1/reports/{urllib.parse.quote(selected_report_id)}"
    detail = native_api_curl(repo_root, detail_path)
    detail_json = parse_json_output(detail)
    detail_ok = detail.returncode == 0 and isinstance(detail_json, dict) and detail_json.get("id") == selected_report_id
    findings.append(
        native_api_probe_finding(
            "pass" if detail_ok else "fail",
            "runtime-report.export-native-detail",
            "Native raw-report detail read." if detail_ok else "Native raw-report detail response was not usable.",
            detail,
            compose_command(repo_root, "exec", "-T", "turbovas-api", "curl", "-fsS", "http://127.0.0.1:9080/api/v1/reports/..."),
            detail_json if isinstance(detail_json, dict) else None,
        )
    )
    rows, total, rows_result, rows_json = native_report_results_pages(repo_root, selected_report_id, max_results)
    rows_ok = rows_result is not None and rows_result.returncode == 0 and total is not None
    findings.append(
        native_api_probe_finding(
            "pass" if rows_ok else "fail",
            "runtime-report.export-native-results",
            "Native raw-report result rows read." if rows_ok else "Native raw-report result response was not usable.",
            rows_result or detail,
            compose_command(repo_root, "exec", "-T", "turbovas-api", "curl", "-fsS", "http://127.0.0.1:9080/api/v1/reports/.../results?..."),
            rows_json if isinstance(rows_json, dict) else None,
        )
    )
    if not detail_ok or not rows_ok or not isinstance(detail_json, dict):
        payload = {
            "status": "fail",
            "summary": "Runtime report export failed while reading native report data.",
            "generated_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat(),
            "details": {"source": "turbovas-api", "report_id": selected_report_id, "detail": detail_json, "results": rows_json},
        }
        payload["artifacts"] = [write_json_artifact(artifact_dir, "export-failed.json", payload)]
        return make_result("runtime-report-export", repo_root, payload["summary"], findings, payload["artifacts"])

    task = detail_json.get("task") if isinstance(detail_json.get("task"), dict) else {}
    normalized_rows = [runtime_report_summary_row(row) for row in rows]
    export_complete = total is None or len(rows) >= total
    payload = {
        "status": "pass" if export_complete else "warn",
        "summary": "Runtime report export read through the native API.",
        "generated_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat(),
        "details": {"source": "turbovas-api", "report_id": selected_report_id},
        "report": {
            "id": detail_json.get("id"),
            "name": detail_json.get("name"),
            "task_id": task.get("id"),
            "task_name": task.get("name"),
            "scan_run_status": detail_json.get("status"),
            "scan_start": detail_json.get("scan_start"),
            "scan_end": detail_json.get("scan_end"),
            "counts": {
                "hosts": json_int(detail_json.get("host_count")),
                "results": json_int(detail_json.get("result_count")),
                "vulnerabilities": json_int(detail_json.get("vulnerability_count")),
                "cves": json_int(detail_json.get("cve_count")),
                "operating_systems": None,
            },
        },
        "result_filter": f"native:/api/v1/reports/{selected_report_id}/results?sort=-severity&max_results={max_results}",
        "parsed_result_count": len(rows),
        "export_complete": export_complete,
        "severity_counts": runtime_report_summary_severity_counts(rows),
        "affected_hosts": runtime_report_summary_affected_hosts(rows),
        "top_results": normalized_rows[:top_results],
        "results": normalized_rows,
    }
    csv_text = runtime_report_results_csv(normalized_rows)
    payload["artifacts"] = [
        write_json_artifact(artifact_dir, "export.json", payload),
        write_text_artifact(artifact_dir, "export-results.csv", csv_text),
    ]
    return make_result("runtime-report-export", repo_root, payload["summary"], findings, payload["artifacts"])


def json_int(value: Any) -> int:
    try:
        return int(value)
    except (TypeError, ValueError):
        return 0


def json_float(value: Any) -> float:
    try:
        return float(value)
    except (TypeError, ValueError):
        return 0.0


def native_result_threat(score: float) -> str:
    if score >= 9.0:
        return "Critical"
    if score >= 7.0:
        return "High"
    if score >= 4.0:
        return "Medium"
    if score > 0.0:
        return "Low"
    if score == 0.0:
        return "Log"
    if score == -1.0:
        return "False Positive"
    return "Unknown"


def runtime_report_summary_row(row: dict[str, Any]) -> dict[str, Any]:
    severity_score = json_float(row.get("severity"))
    return {
        "id": row.get("id"),
        "name": row.get("name"),
        "host": row.get("host"),
        "hostname": row.get("hostname"),
        "port": row.get("port"),
        "severity": str(row.get("severity", "")),
        "severity_score": severity_score,
        "threat": native_result_threat(severity_score),
        "qod": json_int(row.get("qod")),
        "nvt_oid": row.get("nvt_oid"),
        "nvt_name": row.get("name"),
        "nvt_family": row.get("nvt_family"),
        "description_excerpt": row.get("description_excerpt"),
    }


