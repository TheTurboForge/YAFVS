def runtime_gsa_freshness_findings(repo_root: Path) -> list[dict[str, Any]]:
    findings: list[dict[str, Any]] = []
    staged = gsad_static_dir(repo_root)
    staged_latest, staged_latest_path = paths_latest_mtime(repo_root, (str(staged.relative_to(repo_root)),)) if staged.exists() else (None, None)
    source_latest, source_latest_path = paths_latest_mtime(repo_root, GSA_FRESHNESS_SOURCE_PATHS, skip_dirs=GSA_FRESHNESS_SKIP_DIRS, skip_file=gsa_freshness_should_skip_source_file)
    if staged_latest is not None and source_latest is not None and source_latest > staged_latest:
        findings.append(
            finding(
                "warn",
                "gsa.static-freshness",
                "GSA source inputs are newer than staged gsad static assets; run just build-ui before browser validation.",
                str(staged),
                {
                    "latest_source_path": source_latest_path,
                    "latest_source_mtime": iso_mtime(source_latest),
                    "latest_staged_path": staged_latest_path,
                    "latest_staged_mtime": iso_mtime(staged_latest),
                },
            )
        )
    elif staged_latest is not None:
        findings.append(finding("pass", "gsa.static-freshness", "Staged GSA static assets are not older than tracked GSA source inputs.", str(staged), {"latest_staged_mtime": iso_mtime(staged_latest), "latest_source_mtime": iso_mtime(source_latest)}))

    gsad_state = docker_container_state(repo_root, "gsad")
    started_at = parse_container_started_at(gsad_state.get("StartedAt") if gsad_state else None)
    gsad_source_latest, gsad_source_latest_path = paths_latest_mtime(repo_root, GSAD_FRESHNESS_SOURCE_PATHS)
    gsad_build_latest, gsad_build_latest_path = paths_latest_mtime(repo_root, GSAD_FRESHNESS_BUILD_PATHS)
    compare_latest = max([value for value in (staged_latest, gsad_source_latest, gsad_build_latest) if value is not None], default=None)
    if started_at is not None and compare_latest is not None and compare_latest > started_at:
        findings.append(
            finding(
                "warn",
                "gsad.runtime-freshness",
                "Running gsad predates relevant static or native-proxy build inputs; run just build-c-services, just build-ui, then refresh runtime-app-up before browser validation.",
                details={
                    "container_id": gsad_state.get("container_id") if gsad_state else None,
                    "started_at": gsad_state.get("StartedAt") if gsad_state else None,
                    "latest_gsad_source_path": gsad_source_latest_path,
                    "latest_gsad_source_mtime": iso_mtime(gsad_source_latest),
                    "latest_gsad_build_path": gsad_build_latest_path,
                    "latest_gsad_build_mtime": iso_mtime(gsad_build_latest),
                    "latest_staged_mtime": iso_mtime(staged_latest),
                },
            )
        )
    elif started_at is not None:
        findings.append(finding("pass", "gsad.runtime-freshness", "Running gsad is not older than relevant static or native-proxy build inputs.", details={"started_at": gsad_state.get("StartedAt") if gsad_state else None}))
    return findings


def feed_path_summary(path: Path, markers: tuple[str, ...]) -> dict[str, Any]:
    file_count = 0
    byte_count = 0
    latest_mtime: float | None = None
    errors: list[str] = []
    if path.is_dir():
        for entry in path.rglob("*"):
            try:
                if entry.is_file():
                    stat = entry.stat()
                    file_count += 1
                    byte_count += stat.st_size
                    latest_mtime = stat.st_mtime if latest_mtime is None else max(latest_mtime, stat.st_mtime)
            except OSError as error:
                errors.append(f"{entry}: {error}")
    marker_rows = [{"path": marker, "exists": (path / marker).exists()} for marker in markers]
    latest = datetime.fromtimestamp(latest_mtime, timezone.utc).replace(microsecond=0).isoformat() if latest_mtime is not None else None
    return {
        "exists": path.is_dir(),
        "file_count": file_count,
        "byte_count": byte_count,
        "latest_mtime": latest,
        "markers": marker_rows,
        "errors": errors[:20],
    }


def feed_location_findings(repo_root: Path, location: str, root: Path, rel_attr: str) -> list[dict[str, Any]]:
    findings: list[dict[str, Any]] = []
    findings.append(finding("pass" if root.is_dir() else "warn", f"feed.{location}.root", f"{location} feed root {'exists' if root.is_dir() else 'is missing'}.", str(root)))
    for feed_class in FEED_CLASSES:
        rel = getattr(feed_class, rel_attr)
        path = root / rel
        summary = feed_path_summary(path, feed_class.markers)
        marker_missing = [row["path"] for row in summary["markers"] if not row["exists"]]
        status = "pass" if summary["exists"] and summary["file_count"] > 0 and not marker_missing and not summary["errors"] else "warn"
        if not summary["exists"]:
            message = f"{feed_class.label} directory is missing."
        elif summary["file_count"] == 0:
            message = f"{feed_class.label} directory exists but contains no files."
        elif marker_missing:
            message = f"{feed_class.label} has files but expected markers are missing."
        elif summary["errors"]:
            message = f"{feed_class.label} state has filesystem inspection errors."
        else:
            message = f"{feed_class.label} is present."
        findings.append(finding(status, f"feed.{location}.{feed_class.key}", message, str(path), {"summary": summary, "missing_markers": marker_missing}))
    return findings


