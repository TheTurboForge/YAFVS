# Non-secret local development defaults for Docker Compose.
#
# The default runtime directory is intentionally outside the repository when
# commands are run through tools/forkctl. If using docker compose directly,
# set this to the sibling runtime directory explicitly.
TURBOVAS_RUNTIME_DIR=../../TurboVAS-runtime
TURBOVAS_UID=1000
TURBOVAS_GID=1000
POSTGRES_USER=turbovas
POSTGRES_PASSWORD=turbovas-dev
POSTGRES_DB=turbovas
