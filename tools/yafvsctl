def compose_app_services_up_with_retry(
    repo_root: Path,
    check: str,
    message: str,
    timeout: int = 900,
    *,
    app_env: dict[str, str] | None = None,
    app_image_ids: dict[str, str],
) -> list[dict[str, Any]]:
    app_env = runtime_app_env(repo_root) if app_env is None else app_env
    validate_app_service_image_ids(app_image_ids)
    up_args = [
        "--profile",
        "app",
        "up",
        "-d",
        "--no-deps",
        "--no-build",
        "--pull",
        "never",
        "--force-recreate",
        *APP_SERVICES,
    ]
    command = compose_command_with_app_images(
        repo_root, app_image_ids, *up_args, env=app_env
    )
    result = run_command(command, repo_root, env=app_env, timeout=timeout)
    if result.returncode == 0:
        return [process_step_finding("pass", check, f"{message} exit code 0.", result, command)]

    if not compose_app_up_transient_error(result.stdout):
        return [process_step_finding("fail", check, f"{message} exit code {result.returncode}.", result, command)]

    findings = [
        process_step_finding(
            "warn",
            f"{check}.transient",
            f"{message} hit Docker container-removal race exit code {result.returncode}; retrying with already-built images.",
            result,
            command,
        )
    ]
    retry_args = [
        "--profile",
        "app",
        "up",
        "-d",
        "--no-deps",
        "--no-build",
        "--pull",
        "never",
        "--force-recreate",
        *APP_SERVICES,
    ]
    retry_command = compose_command_with_app_images(
        repo_root, app_image_ids, *retry_args, env=app_env
    )
    for attempt in range(1, 3):
        time.sleep(8 * attempt)
        retry = run_command(retry_command, repo_root, env=app_env, timeout=300)
        if retry.returncode == 0:
            findings.append(process_step_finding("pass", f"{check}.retry", f"{message} retry {attempt} exit code 0.", retry, retry_command))
            return findings
        if app_services_running(repo_root):
            findings.append(
                process_step_finding(
                    "warn",
                    f"{check}.retry",
                    f"{message} retry {attempt} reported exit code {retry.returncode}, but all app services are running after Docker settled.",
                    retry,
                    retry_command,
                )
            )
            return findings
        findings.append(
            process_step_finding(
                "warn" if attempt == 1 and compose_app_up_transient_error(retry.stdout) else "fail",
                f"{check}.retry-{attempt}",
                f"{message} retry {attempt} exit code {retry.returncode}.",
                retry,
                retry_command,
            )
        )
        if not compose_app_up_transient_error(retry.stdout):
            return findings
    return findings


