        "important_checks": important_checks,
    }
    metadata_block = result.get("metadata", {}) if isinstance(result.get("metadata"), dict) else {}
    command_name = str(metadata_block.get("command") or "runtime-native-api-direct-smoke")
    compact["findings"] = non_pass or [
        finding("pass", f"{command_name}.status-only", f"{command_name} passed; no non-pass findings.")
