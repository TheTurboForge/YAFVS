    host = native_api_direct_host(env)
    wildcard_host = host_is_wildcard(host)
    findings.append(
        finding(
            "fail" if wildcard_host else "pass",
            "native-api-direct.host-binding",
            "Direct native API host binding is explicit."
            if not wildcard_host
            else "Direct native API host binding must not use a wildcard host in this development helper.",
            details={
                "host": host,
                "host_port": native_api_direct_port(env),
                "container_bind": env.get(TURBOVAS_API_DIRECT_BIND_ENV),
                "token_source": "environment" if token_from_env else "runtime-secret",
            },
        )
    )
    config = run_command(compose_command(repo_root, "config", "--quiet", env=env), repo_root, env=env)
    findings.append(finding("pass" if config.returncode == 0 else "fail", "compose.config", f"Compose direct native API config validation exit code {config.returncode}.", str(compose_file(repo_root).relative_to(repo_root)), {"output_tail": output_tail(config.stdout, 40)}))
    if aggregate_status(findings) == "fail":
        result = make_result("runtime-native-api-direct-smoke", repo_root, "Direct native API smoke stopped at prerequisites.", findings, [str(artifact_dir)])
        result["details"] = {"base_url": native_api_direct_base_url(env)}
