def native_api_openapi_contract_summary(repo_root: Path | None) -> dict[str, Any]:
    operations = openapi_contract_operations(repo_root)
    operation_ids = [item["operation_id"] for item in operations if isinstance(item.get("operation_id"), str) and item["operation_id"]]
    duplicate_ids = sorted({operation_id for operation_id in operation_ids if operation_ids.count(operation_id) > 1})
    missing_operation_ids = [openapi_operation_label(item) for item in operations if not item.get("operation_id")]
    missing_operation_summaries = [openapi_operation_label(item) for item in operations if not item.get("summary")]
    write_control_contract = openapi_write_control_contract_summary(
        operations,
        openapi_parameter_components(repo_root),
    )
    operations_with_request_bodies = write_control_contract["request_body_operations"]
    nondeterministic_operation_ids = [
        {
            "operation": openapi_operation_label(item),
            "actual": item.get("operation_id"),
            "expected": openapi_contract_operation_id(str(item.get("method", "")), str(item.get("path", ""))),
        }
        for item in operations
        if item.get("operation_id") and item.get("operation_id") != openapi_contract_operation_id(str(item.get("method", "")), str(item.get("path", "")))
    ]
    unexpected_yafvs_fields = [
        {"operation": openapi_operation_label(item), "fields": sorted(set(item.get("x_yafvs_fields", [])) - OPENAPI_ALLOWED_YAFVS_OPERATION_FIELDS)}
        for item in operations
        if sorted(set(item.get("x_yafvs_fields", [])) - OPENAPI_ALLOWED_YAFVS_OPERATION_FIELDS)
    ]
    exposure_drift = openapi_exposure_contract_drift(operations)
    migration_metadata_drift = openapi_migration_metadata_contract_drift(operations)
    error_schema_drift = openapi_error_schema_contract_drift(repo_root)
    request_body_schema_drift = openapi_request_body_schema_contract_drift(repo_root, operations)
    schedule_create_schema_drift = openapi_schedule_create_schema_contract_drift(repo_root, operations)
    tag_write_schema_drift = openapi_tag_write_schema_contract_drift(repo_root)
    collection_query_contract = openapi_collection_query_contract_summary(repo_root, operations)
    auth_contract = openapi_auth_contract_summary(repo_root)

    shared_response_refs = openapi_components_response_refs(repo_root)
    missing_shared_responses = sorted(set(OPENAPI_SHARED_ERROR_RESPONSES) - set(shared_response_refs))
    invalid_shared_responses = [
        {"response": name, "actual": shared_response_refs.get(name), "expected": expected}
        for name, expected in sorted(OPENAPI_SHARED_ERROR_RESPONSES.items())
        if name in shared_response_refs and shared_response_refs.get(name) != expected
    ]
    operations_missing_error_responses = []
    for item in operations:
        responses = item.get("responses", {}) if isinstance(item.get("responses"), dict) else {}
        for status, response_name in sorted(openapi_required_error_response_refs(str(item.get("path", ""))).items()):
            expected_ref = f"#/components/responses/{response_name}"
            if responses.get(status) != expected_ref:
                operations_missing_error_responses.append(
                    {
                        "operation": openapi_operation_label(item),
                        "status": status,
                        "actual": responses.get(status),
                        "expected": expected_ref,
                    }
                )

    drift = (
        missing_operation_ids
        or missing_operation_summaries
        or duplicate_ids
        or nondeterministic_operation_ids
        or unexpected_yafvs_fields
        or exposure_drift["missing_exposure_operations"]
        or exposure_drift["invalid_exposure_operations"]
        or exposure_drift["exposure_mismatches"]
        or migration_metadata_drift["missing_migration_metadata_operations"]
        or migration_metadata_drift["invalid_migration_metadata_operations"]
        or migration_metadata_drift["migration_metadata_mismatches"]
        or missing_shared_responses
        or invalid_shared_responses
        or operations_missing_error_responses
        or error_schema_drift["missing_error_schema_fields"]
        or error_schema_drift["invalid_error_schema_fields"]
        or request_body_schema_drift["missing_request_body_schema_refs"]
        or request_body_schema_drift["invalid_request_body_schema_refs"]
        or schedule_create_schema_drift["schedule_create_schema_missing"]
        or schedule_create_schema_drift["schedule_create_schema_invalid"]
        or tag_write_schema_drift["tag_write_schema_missing"]
        or tag_write_schema_drift["tag_write_schema_invalid"]
        or collection_query_contract["alignment_status"] != "pass"
        or auth_contract["alignment_status"] != "pass"
        or write_control_contract["alignment_status"] != "pass"
    )
    return {
        "alignment_status": "pass" if not drift else "warn",
        "operation_count": len(operations),
        "operation_ids": sorted(operation_ids),
        "missing_operation_ids": missing_operation_ids,
        "missing_operation_summaries": missing_operation_summaries,
        "operations_with_request_bodies": operations_with_request_bodies,
        "get_operations_with_request_bodies": write_control_contract["get_request_body_operations"],
        "duplicate_operation_ids": duplicate_ids,
        "nondeterministic_operation_ids": nondeterministic_operation_ids,
        "allowed_yafvs_operation_fields": sorted(OPENAPI_ALLOWED_YAFVS_OPERATION_FIELDS),
        "unexpected_yafvs_operation_fields": unexpected_yafvs_fields,
        "allowed_exposure_values": sorted(OPENAPI_ALLOWED_EXPOSURE_VALUES),
        "allowed_maturity_values": sorted(OPENAPI_ALLOWED_MATURITY_VALUES),
        "allowed_replaces_values": sorted(OPENAPI_ALLOWED_REPLACES_VALUES),
        "allowed_inherited_still_owns_values": sorted(OPENAPI_ALLOWED_INHERITED_STILL_OWNS_VALUES),
        **exposure_drift,
        **migration_metadata_drift,
        "shared_error_responses": shared_response_refs,
        "missing_shared_error_responses": missing_shared_responses,
        "invalid_shared_error_responses": invalid_shared_responses,
        "operations_missing_error_responses": operations_missing_error_responses,
        **error_schema_drift,
        **request_body_schema_drift,
        **schedule_create_schema_drift,
        **tag_write_schema_drift,
        "collection_query_contract": collection_query_contract,
        "auth_contract": auth_contract,
        "write_control_contract": write_control_contract,
    }


def rust_source_function_body(source: str, name: str) -> str:
    match = re.search(rf"\bfn\s+{re.escape(name)}\s*\([^)]*\)\s*(?:->[^{{]+)?{{", source)
    if match is None:
        return ""
    start = source.find("{", match.start())
    depth = 0
    for index in range(start, len(source)):
        char = source[index]
        if char == "{":
            depth += 1
        elif char == "}":
            depth -= 1
            if depth == 0:
                return source[start + 1 : index]
    return ""


def rust_route_to_endpoint_template(route: str) -> str:
    parts = []
    for segment in route.split("/"):
        if segment.startswith(":") or segment.startswith("*"):
            name = segment[1:] or "id"
            parts.append(f"{{{name}}}")
        else:
            parts.append(segment)
    return "/".join(parts)


