def openapi_components_response_refs(repo_root: Path | None) -> dict[str, str | None]:
    lines = openapi_contract_lines(repo_root)
    in_components = False
    in_responses = False
    current_response: str | None = None
    refs: dict[str, str | None] = {}
    for line in lines:
        if line == "components:":
            in_components = True
            in_responses = False
            current_response = None
            continue
        if in_components and line and not line.startswith(" "):
            break
        if not in_components:
            continue
        top_key_match = re.match(r"^  ([A-Za-z][A-Za-z0-9_-]*):$", line)
        if top_key_match:
            in_responses = top_key_match.group(1) == "responses"
            current_response = None
            continue
        if not in_responses:
            continue
        response_match = re.match(r"^    ([A-Za-z][A-Za-z0-9]*):$", line)
        if response_match:
            current_response = response_match.group(1)
            refs.setdefault(current_response, None)
            continue
        ref_match = re.match(r"^\s+\$ref: ['\"]([^'\"]+)['\"]$", line)
        if ref_match and current_response:
            refs[current_response] = ref_match.group(1)
    return refs


def openapi_component_schema_block(repo_root: Path | None, schema_name: str) -> list[str]:
    lines = openapi_contract_lines(repo_root)
    in_components = False
    in_schemas = False
    in_schema = False
    block: list[str] = []
    for line in lines:
        if line == "components:":
            in_components = True
            in_schemas = False
            in_schema = False
            continue
        if in_components and line and not line.startswith(" "):
            break
        if not in_components:
            continue
        top_key_match = re.match(r"^  ([A-Za-z][A-Za-z0-9_-]*):$", line)
        if top_key_match:
            in_schemas = top_key_match.group(1) == "schemas"
            in_schema = False
            continue
        if not in_schemas:
            continue
        schema_match = re.match(r"^    ([A-Za-z][A-Za-z0-9_-]*):$", line)
        if schema_match:
            if in_schema:
                break
            in_schema = schema_match.group(1) == schema_name
            continue
        if in_schema:
            block.append(line)
    return block


def openapi_indented_scalar_fields(block: list[str]) -> dict[str, str]:
    stack: list[tuple[int, str]] = []
    values: dict[str, str] = {}
    for line in block:
        if not line.strip() or line.lstrip().startswith("#"):
            continue
        indent = len(line) - len(line.lstrip(" "))
        text = line.strip()
        if ":" not in text or text.startswith("-"):
            continue
        key, raw_value = text.split(":", 1)
        key = key.strip().strip("'\"")
        value = raw_value.strip().strip("'\"")
        while stack and indent <= stack[-1][0]:
            stack.pop()
        path = ".".join([item[1] for item in stack] + [key])
        if value:
            values[path] = value
        else:
            stack.append((indent, key))
    return values


def openapi_duplicate_field_paths(block: list[str]) -> list[str]:
    stack: list[tuple[int, str]] = []
    counts: dict[str, int] = {}
    for line in block:
        if not line.strip() or line.lstrip().startswith("#"):
            continue
        indent = len(line) - len(line.lstrip(" "))
        text = line.strip()
        if ":" not in text or text.startswith("-"):
            continue
        key, raw_value = text.split(":", 1)
        key = key.strip().strip("'\"")
        while stack and indent <= stack[-1][0]:
            stack.pop()
        path = ".".join([item[1] for item in stack] + [key])
        counts[path] = counts.get(path, 0) + 1
        if not raw_value.strip():
            stack.append((indent, key))
    duplicates = sorted(path for path, count in counts.items() if count > 1)
    return [
        path
        for path in duplicates
        if not any(path.startswith(f"{parent}.") for parent in duplicates if parent != path)
    ]


def openapi_error_schema_contract_drift(repo_root: Path | None) -> dict[str, Any]:
    block = openapi_component_schema_block(repo_root, "Error")
    values = openapi_indented_scalar_fields(block)
    missing = []
    invalid = []
    for field, expected in sorted(OPENAPI_ERROR_SCHEMA_EXPECTED_FIELDS.items()):
        if field not in values:
            missing.append({"field": field, "expected": expected})
            continue
        actual = values[field]
        if actual != expected:
            invalid.append({"field": field, "actual": actual, "expected": expected})
    return {
        "expected_error_schema_fields": dict(sorted(OPENAPI_ERROR_SCHEMA_EXPECTED_FIELDS.items())),
        "error_schema_fields": dict(sorted(values.items())),
        "missing_error_schema_fields": missing,
        "invalid_error_schema_fields": invalid,
    }


def openapi_schema_top_level_keys(block: list[str]) -> set[str]:
    keys: set[str] = set()
    for line in block:
        match = re.match(r"^      ([A-Za-z][A-Za-z0-9_-]*):", line)
        if match:
            keys.add(match.group(1))
    return keys


def openapi_request_body_schema_contract_drift(repo_root: Path | None, operations: list[dict[str, Any]]) -> dict[str, Any]:
    request_body_schema_refs = sorted(
        {
            str(operation.get("request_body_schema_ref"))
            for operation in operations
            if isinstance(operation.get("request_body_schema_ref"), str)
        }
    )
    missing: list[dict[str, Any]] = []
    invalid: list[dict[str, Any]] = []

    for operation in operations:
        if not operation.get("request_body"):
            continue
        ref = operation.get("request_body_schema_ref")
        label = openapi_operation_label(operation)
        if not isinstance(ref, str):
            missing.append({"operation": label, "field": "requestBody.schema.$ref", "expected": "#/components/schemas/..."})
            continue
        match = re.fullmatch(r"#/components/schemas/([A-Za-z][A-Za-z0-9_-]*)", ref)
        if not match:
            invalid.append({"operation": label, "field": "requestBody.schema.$ref", "actual": ref, "expected": "#/components/schemas/..."})
            continue
        schema_name = match.group(1)
        block = openapi_component_schema_block(repo_root, schema_name)
        if not block:
            missing.append({"operation": label, "field": f"components.schemas.{schema_name}", "expected": "top-level schema"})
            continue
        values = openapi_indented_scalar_fields(block)
        duplicate_paths = openapi_duplicate_field_paths(block)
        if duplicate_paths:
            invalid.append(
                {
                    "operation": label,
                    "field": f"components.schemas.{schema_name}",
                    "actual": duplicate_paths,
                    "expected": "unique YAML field paths",
                }
            )
        top_level_keys = openapi_schema_top_level_keys(block)
        block_text = "\n".join(block)
        one_of_refs = re.findall(
            r"^\s{8}-\s+\$ref:\s+['\"](#/components/schemas/[A-Za-z][A-Za-z0-9_-]*)['\"]\s*$",
            block_text,
            re.MULTILINE,
        )
        discriminator = re.search(r"^\s{6}discriminator:\s*$\n^\s{8}propertyName:\s+([^\s#]+)\s*$", block_text, re.MULTILINE)
        is_valid_discriminated_union = (
            "oneOf" in top_level_keys
            and discriminator is not None
            and len(one_of_refs) >= 2
            and all(openapi_component_schema_block(repo_root, item.rsplit("/", 1)[-1]) for item in one_of_refs)
        )
        if is_valid_discriminated_union:
            continue
        if "oneOf" in top_level_keys:
            invalid.append({"operation": label, "field": f"components.schemas.{schema_name}.oneOf", "actual": one_of_refs, "expected": "two or more component schema references with a discriminator propertyName"})
            continue
        if values.get("type") != "object":
            invalid.append({"operation": label, "field": f"components.schemas.{schema_name}.type", "actual": values.get("type"), "expected": "object"})
        is_closed_empty_object = (
            values.get("type") == "object"
            and values.get("maxProperties") == "0"
            and values.get("additionalProperties") == "false"
        )
        if "properties" not in top_level_keys and not is_closed_empty_object:
            invalid.append({"operation": label, "field": f"components.schemas.{schema_name}.properties", "actual": None, "expected": "top-level properties"})

    return {
        "request_body_schema_refs": request_body_schema_refs,
        "missing_request_body_schema_refs": missing,
        "invalid_request_body_schema_refs": invalid,
    }


