def command_runtime_performance_snapshot(repo_root: Path) -> dict[str, Any]:
    artifact_dir = performance_artifact_dir(repo_root)
    findings: list[dict[str, Any]] = []
    details: dict[str, Any] = {"docker_stats": [], "database": {}, "paths": {}}
    artifact_dir.mkdir(parents=True, exist_ok=True)

    stats = run_command(["docker", "stats", "--no-stream", "--format", "json"], repo_root, env=runtime_env(repo_root), timeout=120)
    if stats.returncode == 0:
        for line in stats.stdout.splitlines():
            try:
                details["docker_stats"].append(json.loads(line))
            except json.JSONDecodeError:
                continue
    details["docker_stats_numeric"] = [normalize_docker_stat(row) for row in details["docker_stats"]]
    details["docker_top"] = {
        "cpu_percent": top_numeric_rows(details["docker_stats_numeric"], "cpu_percent"),
        "memory_usage_bytes": top_numeric_rows(details["docker_stats_numeric"], "memory_usage_bytes"),
        "network_rx_bytes": top_numeric_rows(details["docker_stats_numeric"], "network_rx_bytes"),
        "network_tx_bytes": top_numeric_rows(details["docker_stats_numeric"], "network_tx_bytes"),
        "block_read_bytes": top_numeric_rows(details["docker_stats_numeric"], "block_read_bytes"),
        "block_write_bytes": top_numeric_rows(details["docker_stats_numeric"], "block_write_bytes"),
        "pids": top_numeric_rows(details["docker_stats_numeric"], "pids"),
    }
    findings.append(process_step_finding("pass" if stats.returncode == 0 else "warn", "performance.docker-stats", f"docker stats snapshot exit code {stats.returncode}.", stats, ["docker", "stats", "--no-stream", "--format", "json"]))
    if stats.returncode == 0:
        findings.append(finding("pass", "performance.docker-stats-numeric", "Docker stats numeric summary captured.", details={"container_count": len(details["docker_stats_numeric"]), "top": details["docker_top"]}))

    if container_running(repo_root, "postgres"):
        db_size = psql(repo_root, "SELECT pg_database_size(current_database());")
        details["database"]["byte_count"] = int(psql_value(db_size) or "0") if db_size.returncode == 0 and psql_value(db_size).isdigit() else None
        findings.append(finding("pass" if db_size.returncode == 0 else "warn", "performance.database-size", "Database size captured." if db_size.returncode == 0 else "Database size query failed.", details={"output_tail": output_tail(db_size.stdout, 40), "byte_count": details["database"].get("byte_count")}))
        table_query, presence = table_presence_rows(repo_root, (*DATABASE_CORE_TABLES, *DATABASE_SCOPE_TABLES))
        if table_query.returncode == 0:
            details["database"]["row_counts"] = {table: table_row_count(repo_root, table) for table, exists in presence.items() if exists}
            findings.append(finding("pass", "performance.table-row-counts", "Database row-count estimates captured for known tables.", details={"table_count": len(details["database"]["row_counts"])}))
        else:
            findings.append(finding("warn", "performance.table-row-counts", "Could not inspect database row counts.", details={"output_tail": output_tail(table_query.stdout, 80)}))
        largest_relations = psql(
            repo_root,
            "SELECT relname || '|' || pg_total_relation_size(c.oid) FROM pg_class c JOIN pg_namespace n ON n.oid = c.relnamespace WHERE n.nspname = 'public' AND c.relkind IN ('r','m','i','t') ORDER BY pg_total_relation_size(c.oid) DESC LIMIT 10;",
        )
        details["database"]["largest_relations"] = parse_relation_size_rows(largest_relations.stdout) if largest_relations.returncode == 0 else []
        findings.append(finding("pass" if largest_relations.returncode == 0 else "warn", "performance.database-largest-relations", "Largest database relations captured." if largest_relations.returncode == 0 else "Largest database relation query failed.", details={"relations": details["database"].get("largest_relations", []), "output_tail": output_tail(largest_relations.stdout, 80)}))
        report_workflow = psql(
            repo_root,
            "SELECT 'reports|' || count (*) FROM reports "
            "UNION ALL SELECT 'scope_reports|' || count (*) FROM scope_reports "
            "UNION ALL SELECT 'scope_report_sources|' || count (*) FROM scope_report_sources "
            "UNION ALL SELECT 'max_sources_per_scope_report|' || coalesce ((SELECT max (source_count) FROM (SELECT count (*) AS source_count FROM scope_report_sources GROUP BY scope_report) x), 0) "
            "UNION ALL SELECT 'max_results_per_report|' || coalesce ((SELECT max (result_count) FROM (SELECT count (*) AS result_count FROM results GROUP BY report) x), 0) "
            "UNION ALL SELECT 'max_scope_report_result_count|' || coalesce ((SELECT max (result_count) FROM scope_reports), 0) "
            "UNION ALL SELECT 'max_scope_report_source_host_count|' || coalesce ((SELECT max (evidence_host_count) FROM scope_reports), 0);",
        )
        details["report_workflow"] = parse_pipe_int_rows(report_workflow.stdout) if report_workflow.returncode == 0 else {}
        findings.append(finding("pass" if report_workflow.returncode == 0 else "warn", "performance.report-workflow", "Report workflow baseline captured." if report_workflow.returncode == 0 else "Report workflow baseline query failed.", details={"report_workflow": details.get("report_workflow", {}), "output_tail": output_tail(report_workflow.stdout, 80)}))
    else:
        findings.append(finding("warn", "performance.database", "Postgres is not running; database size and row counts are unavailable."))

    if container_running(repo_root, "redis-openvas"):
        scanner_redis = scanner_redis_metrics(repo_root)
        details["scanner_redis"] = scanner_redis
        metrics_ready = scanner_redis.get("dbsize_status") == "pass" and scanner_redis.get("info_status") == "pass"
        findings.append(
            finding(
                "pass" if metrics_ready else "warn",
                "performance.scanner-redis",
                "Scanner Redis performance counters captured without key names or values."
                if metrics_ready
                else "Scanner Redis performance counters could not be fully captured.",
                str(scanner_redis_socket_path(repo_root)),
                {"scanner_redis": scanner_redis},
            )
        )
    else:
        findings.append(finding("warn", "performance.scanner-redis", "Scanner Redis is not running; performance counters are unavailable.", str(scanner_redis_socket_path(repo_root))))

    for name, path, recursive in (
        ("runtime-artifacts", runtime_path(repo_root, "artifacts"), True),
        ("runtime-logs", runtime_path(repo_root, "logs"), True),
        ("gsa-static", gsad_static_dir(repo_root), True),
        ("build-prefix", repo_root / "build" / "prefix", False),
    ):
        summary = path_tree_summary(path, recursive=recursive)
        if name == "gsa-static":
            summary["largest_files"] = largest_files(path)
        details["paths"][name] = summary
        findings.append(finding("pass" if summary["exists"] else "warn", "performance.path", f"{name} size snapshot captured." if summary["exists"] else f"{name} path is missing.", summary["path"], {"summary": summary}))

    latest_path, timestamped_path = retained_json_artifact_paths(artifact_dir, "performance-snapshot", "performance-snapshot.json")
    result = make_result("runtime-performance-snapshot", repo_root, "Runtime performance snapshot completed.", findings, [str(latest_path), str(timestamped_path)])
    result["details"] = details
    write_retained_json_artifact(latest_path, timestamped_path, result, "performance-snapshot", RETAINED_PERFORMANCE_ARTIFACTS)
    return result


