    malformed_dynamic_ok = malformed_dynamic.returncode == 0 and malformed_dynamic_status == 404 and isinstance(malformed_dynamic_json, dict) and malformed_dynamic_json.get("error", {}).get("code") == "not_found"
    findings.append(native_api_probe_finding("pass" if malformed_dynamic_ok else "fail", "native-api-direct.empty-dynamic-segment", "Direct native API denies empty dynamic path segments with JSON 404." if malformed_dynamic_ok else "Direct native API did not deny an empty dynamic path segment correctly.", malformed_dynamic, direct_native_api_display_command("/api/v1/reports//results", token=token, env=env), malformed_dynamic_json, {"http_status": malformed_dynamic_status, **summarize_native_api_response(malformed_dynamic_json)}))

    scope_report_detail = direct_native_api_curl(
        repo_root,
