        "uses_default_body_limit": "DefaultBodyLimit::max(" in direct_router_body,
        "uses_shared_write_limit": "MAX_DIRECT_API_WRITE_BODY_BYTES as usize" in direct_router_body,
        "shared_write_limit_declared": "const MAX_DIRECT_API_WRITE_BODY_BYTES" in request_shape_source,
    }
    missing = [property_name for property_name, present in properties.items() if not present]
    return {
