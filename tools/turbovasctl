def xml_local_name(tag: str) -> str:
    return tag.rsplit("}", 1)[-1] if "}" in tag else tag


def parse_ospd_vts_version(output: str) -> str | None:
    try:
        root = ET.fromstring(output)
    except ET.ParseError:
        return None
    for element in root.iter():
        if xml_local_name(str(element.tag)) == "vts":
            version = element.get("vts_version")
            return version if version else None
    return None


def wait_for_ospd_vts_version(repo_root: Path, timeout_seconds: int = 180) -> tuple[str | None, list[str]]:
    deadline = time.monotonic() + timeout_seconds
    last_output: list[str] = []
    while time.monotonic() < deadline:
        result = run_command(ospd_vts_version_probe_command(repo_root), repo_root, env=build_env(repo_root), timeout=60)
        last_output = output_tail(result.stdout, 40)
        if result.returncode == 0:
            version = parse_ospd_vts_version(result.stdout)
            if version:
                return version, last_output
        if "OSPd OpenVAS is still starting" not in result.stdout and result.returncode != 0:
            break
        time.sleep(5)
    return None, last_output


