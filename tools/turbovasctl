def openvas_runtime_config_path(repo_root: Path) -> Path:
    return repo_root / "build" / "prefix" / "etc" / "openvas" / "openvas.conf"


def wait_for_socket(path: Path, timeout_seconds: int = 20) -> bool:
    deadline = time.monotonic() + timeout_seconds
    while time.monotonic() < deadline:
        if path.is_socket():
            return True
        time.sleep(1)
    return path.is_socket()


def runtime_env(repo_root: Path) -> dict[str, str]:
    env = build_env(repo_root)
    env.setdefault("COMPOSE_PROJECT_NAME", "turbovas")
    env.setdefault("TURBOVAS_RUNTIME_DIR", str(runtime_dir(repo_root)))
    env.setdefault("TURBOVAS_UID", str(os.getuid()))
    env.setdefault("TURBOVAS_GID", str(os.getgid()))
    env.setdefault("POSTGRES_USER", POSTGRES_DEFAULTS["user"])
    env.setdefault("POSTGRES_PASSWORD", POSTGRES_DEFAULTS["password"])
    env.setdefault("POSTGRES_DB", POSTGRES_DEFAULTS["database"])
    env.setdefault("OPENVAS_CONFIG", str(openvas_runtime_config_path(repo_root)))
    return env


def compose_file(repo_root: Path) -> Path:
    return repo_root / "compose" / "dev.yaml"


def compose_command(repo_root: Path, *args: str) -> list[str]:
    return ["docker", "compose", "-f", str(compose_file(repo_root)), *args]


def ensure_runtime_dirs(repo_root: Path) -> list[dict[str, Any]]:
    findings: list[dict[str, Any]] = []
    root = runtime_dir(repo_root)
    for dirname in RUNTIME_DIRS:
        path = root / dirname
        try:
            path.mkdir(parents=True, exist_ok=True)
            probe = path / ".turbovas-write-test"
            probe.write_text("ok\n", encoding="utf-8")
            probe.unlink()
            status = "pass"
            message = f"Runtime directory is writable: {path}"
        except OSError as error:
            status = "fail"
            message = f"Runtime directory is not writable: {path}: {error}"
        findings.append(finding(status, "runtime.dir", message, str(path)))
    return findings



def ensure_build_runtime_dirs(repo_root: Path) -> list[dict[str, Any]]:
    findings: list[dict[str, Any]] = []
    for dirname in ("build/var/lib/gvm", "build/run/gvmd", "build/run/gsad", "build/logs"):
        path = repo_root / dirname
