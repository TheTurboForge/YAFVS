def load_security_sensitive_paths(repo_root: Path) -> tuple[dict[str, Any] | None, str | None]:
    path = repo_root / SECURITY_SENSITIVE_PATHS_FILE
    try:
        with path.open("rb") as handle:
            return tomllib.load(handle), None
    except OSError as exc:
        return None, str(exc)
    except tomllib.TOMLDecodeError as exc:
        return None, str(exc)


def normalize_security_policy_area(area: dict[str, Any]) -> dict[str, Any]:
    paths = [path for path in area.get("paths", []) if isinstance(path, str) and path]
    checks = [check for check in area.get("required_checks", []) if isinstance(check, str) and check]
    return {
        "id": area.get("id") if isinstance(area.get("id"), str) else "",
        "title": area.get("title") if isinstance(area.get("title"), str) else "",
        "risk": area.get("risk") if isinstance(area.get("risk"), str) else "",
        "paths": paths,
        "required_checks": checks,
    }


def security_policy_area_findings(repo_root: Path, areas: list[dict[str, Any]]) -> list[dict[str, Any]]:
    findings: list[dict[str, Any]] = []
    seen_ids: set[str] = set()
    for raw_area in areas:
        area = normalize_security_policy_area(raw_area)
        area_id = area["id"] or "<missing-id>"
        missing_fields = [field for field in ("id", "title", "risk") if not area[field]]
        if not area["paths"]:
            missing_fields.append("paths")
        if not area["required_checks"]:
            missing_fields.append("required_checks")
        duplicate_id = area["id"] in seen_ids if area["id"] else False
        if area["id"]:
            seen_ids.add(area["id"])
        missing_paths = [path for path in area["paths"] if not (repo_root / path).exists()]
        status = "pass"
        if missing_fields or duplicate_id:
            status = "fail"
        elif missing_paths:
            status = "warn"
        message_state = "valid" if status == "pass" else "not fully valid"
        findings.append(
            finding(
                status,
                "security-policy.area",
                f"Security policy area {area_id} is {message_state}.",
                details={**area, "missing_fields": missing_fields, "duplicate_id": duplicate_id, "missing_paths": missing_paths},
            )
        )
    return findings


def command_security_policy_check(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    doc_path = repo_root / SECURITY_POLICY_DOC
    policy_path = repo_root / SECURITY_SENSITIVE_PATHS_FILE
    findings.append(finding("pass" if doc_path.is_file() else "fail", "security-policy.doc", "Security policy documentation exists." if doc_path.is_file() else "Security policy documentation is missing.", str(SECURITY_POLICY_DOC)))
    findings.append(finding("pass" if policy_path.is_file() else "fail", "security-policy.paths-file", "Security-sensitive path policy exists." if policy_path.is_file() else "Security-sensitive path policy is missing.", str(SECURITY_SENSITIVE_PATHS_FILE)))
    if not policy_path.is_file():
        return make_result("security-policy-check", repo_root, "Security-sensitive path policy check failed before parsing.", findings, [str(SECURITY_POLICY_DOC), str(SECURITY_SENSITIVE_PATHS_FILE)])
    parsed, error = load_security_sensitive_paths(repo_root)
    if parsed is None:
        findings.append(finding("fail", "security-policy.parse", "Security-sensitive path policy could not be parsed.", str(SECURITY_SENSITIVE_PATHS_FILE), {"error": error or "unknown"}))
        return make_result("security-policy-check", repo_root, "Security-sensitive path policy check failed while parsing.", findings, [str(SECURITY_POLICY_DOC), str(SECURITY_SENSITIVE_PATHS_FILE)])
    areas = parsed.get("areas", []) if isinstance(parsed, dict) else []
    if not isinstance(areas, list) or not areas:
        findings.append(finding("fail", "security-policy.areas", "Security-sensitive path policy does not define any areas.", str(SECURITY_SENSITIVE_PATHS_FILE)))
        return make_result("security-policy-check", repo_root, "Security-sensitive path policy has no areas.", findings, [str(SECURITY_POLICY_DOC), str(SECURITY_SENSITIVE_PATHS_FILE)])
    area_dicts = [area for area in areas if isinstance(area, dict)]
    findings.append(finding("pass", "security-policy.parse", "Security-sensitive path policy parsed successfully.", str(SECURITY_SENSITIVE_PATHS_FILE), {"area_count": len(area_dicts)}))
    findings.extend(security_policy_area_findings(repo_root, area_dicts))
    area_summaries = [normalize_security_policy_area(area) for area in area_dicts]
    result = make_result("security-policy-check", repo_root, "Security-sensitive path policy checked.", findings, [str(SECURITY_POLICY_DOC), str(SECURITY_SENSITIVE_PATHS_FILE)])
    result["details"] = {"areas": area_summaries, "area_count": len(area_summaries)}
    return result


def command_production_posture_check(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    details: dict[str, Any] = {}

    required_docs = (
        "docs/USER_MANUAL.md",
        "docs/CHANGES_FROM_UPSTREAM.md",
        "docs/PRODUCTION_POSTURE.md",
        "docs/PUBLIC_RELEASE_READINESS.md",
        "docs/VALIDATION_STANDARDS.md",
        "UPSTREAMS.md",
        "LICENSE_AUDIT.md",
    )
    for relative in required_docs:
        path = repo_root / relative
        findings.append(finding("pass" if path.is_file() else "fail", "production.docs", f"{relative} {'exists' if path.is_file() else 'is missing'}.", relative))

    license_gate = command_license_report(repo_root, public_release=True, mode="source-public")
    details["public_release_license_gate"] = {
        "status": license_gate["status"],
        "summary": license_gate["summary"],
    }
    findings.append(
        finding(
            "pass" if license_gate["status"] == "pass" else "fail",
            "production.public-release-license-gate",
            "Public-release license gate passes." if license_gate["status"] == "pass" else "Public-release license gate is not satisfied; do not publish or distribute.",
            details=details["public_release_license_gate"],
        )
    )

    secret_path = runtime_secret_path(repo_root, DEV_ADMIN_SECRET)
    secret_value = secret_path.read_text(encoding="utf-8").strip() if secret_path.is_file() else None
    if secret_value == DEV_ADMIN_PASSWORD:
        findings.append(finding("fail", "production.default-credentials", "Development admin password is still the default value; rotate before production exposure.", str(secret_path)))
    elif secret_value:
        findings.append(finding("pass", "production.default-credentials", "Development admin password is not the default value.", str(secret_path)))
    else:
        findings.append(finding("warn", "production.default-credentials", "Development admin password secret is not initialized; verify first-login/password-rotation workflow before production.", str(secret_path)))
    findings.append(finding("fail", "production.first-login-password-rotation", "Production first-login/password-rotation bootstrap is not implemented yet; do not deploy beyond private development."))

    hosts = gsad_hosts(repo_root)
    wildcard_hosts = [host for host in hosts if host in {"0.0.0.0", "::", "[::]"}]
    non_loopback_hosts = [host for host in hosts if host not in {"127.0.0.1", "localhost", "::1", "[::1]"}]
    if wildcard_hosts:
        port_status = "fail"
        port_message = "GSA is configured for broad wildcard host binding."
    elif non_loopback_hosts:
        port_status = "warn"
        port_message = "GSA is configured for explicit non-loopback development access; review network exposure before production."
    else:
        port_status = "pass"
        port_message = "GSA host binding is loopback-only by default."
    findings.append(finding(port_status, "production.gsad-binding", port_message, details={"hosts": list(hosts), "bindings": list(gsad_port_bindings(repo_root))}))

    findings.extend(direct_native_api_posture_findings(repo_root, runtime_env(repo_root)))

    compose = run_command(compose_command(repo_root, "config", "--quiet"), repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if compose.returncode == 0 else "fail", "production.compose-config", f"Compose config validation exit code {compose.returncode}.", str(compose_file(repo_root).relative_to(repo_root)), {"output_tail": compose.stdout.splitlines()[-40:]}))

    cert_findings = cert_file_findings(repo_root)
    if certs_complete(repo_root):
        findings.append(finding("warn", "production.tls", "Development TLS files exist, but trusted production certificates and hostname/SAN policy still need deployment review.", details={"cert_files": [item.get("path") for item in cert_findings]}))
    else:
        findings.append(finding("fail", "production.tls", "Runtime TLS files are incomplete; production exposure requires a complete trusted TLS setup.", details={"cert_files": [item.get("path") for item in cert_findings]}))

    findings.append(finding("warn", "production.runtime-model", "The current Docker runtime is documented as development-only; production deployment architecture remains a release blocker."))

    result = make_result("production-posture-check", repo_root, "Production posture checklist completed.", findings)
    result["details"] = details
    return result


