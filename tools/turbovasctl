def rust_direct_api_allowed_endpoint_templates(repo_root: Path | None) -> list[str]:
    source = rust_direct_api_source(repo_root)
    if not source:
        return []

    function_body = rust_source_function_body(source, "direct_api_v1_path_is_allowed")
    templates: set[str] = set()
    for match in re.finditer(r"\[([^\]]+)\]", function_body):
        pattern_source = match.group(1)
        if "section" in pattern_source:
            continue
        endpoint = rust_match_pattern_to_endpoint(pattern_source)
        if endpoint and endpoint.startswith("/api/v1"):
            templates.add(endpoint)
    templates.update(rust_direct_scope_report_section_templates(function_body))

    wildcard_body = rust_source_function_body(source, "direct_api_wildcard_detail_path_is_allowed")
    for prefix in re.findall(r'"(/api/v1/[^"]+/)"', wildcard_body):
        templates.add(f"{prefix.rstrip('/')}/{{}}")
    return sorted(templates)


