def copy_pg_gvm_extension(repo_root: Path) -> list[dict[str, Any]]:
    artifact_findings, artifacts = pg_gvm_artifacts(repo_root)
    if aggregate_status(artifact_findings) == "fail":
        return artifact_findings
    extension_dir = artifacts["extension_dir"]
    library = artifacts["library"]
    copy_sql = run_command(
        compose_command(repo_root, "cp", str(extension_dir) + "/.", f"postgres:/usr/share/postgresql/16/extension/"),
        repo_root,
        env=runtime_env(repo_root),
    )
    copy_library = run_command(
        compose_command(repo_root, "cp", str(library), f"postgres:/usr/lib/postgresql/16/lib/{PG_GVM_LIBRARY}"),
        repo_root,
        env=runtime_env(repo_root),
    )
    return [
        *artifact_findings,
        finding("pass" if copy_sql.returncode == 0 else "fail", "pg-gvm.copy.sql", f"Copy pg-gvm SQL/control files exit code {copy_sql.returncode}.", details={"output_tail": copy_sql.stdout.splitlines()[-40:]}),
        finding("pass" if copy_library.returncode == 0 else "fail", "pg-gvm.copy.library", f"Copy pg-gvm shared library exit code {copy_library.returncode}.", details={"output_tail": copy_library.stdout.splitlines()[-40:]}),
    ]


def pg_gvm_extension_status(repo_root: Path) -> dict[str, Any]:
    if not container_running(repo_root, "postgres"):
        return finding("warn", "postgres.pg-gvm", "Postgres is not running; pg-gvm extension status is unavailable.")
    result = psql(repo_root, f"SELECT COALESCE((SELECT extversion FROM pg_extension WHERE extname = '{PG_GVM_EXTENSION}'), 'missing');")
    if result.returncode != 0:
        return finding("fail", "postgres.pg-gvm", f"pg-gvm extension status query exit code {result.returncode}.", details={"output_tail": result.stdout.splitlines()[-40:]})
    version = psql_value(result)
    return finding("pass" if version and version != "missing" else "warn", "postgres.pg-gvm", f"pg-gvm extension is {version}.", details={"version": version})


