        sources.append("environment")
    if env.get(TURBOVAS_API_BEARER_TOKEN_FILE_ENV):
        sources.append("configured-token-file")
    secret_path = runtime_secret_path(repo_root, TURBOVAS_API_BEARER_TOKEN_SECRET)
    secret_present = False
    try:
        secret_present = secret_path.is_file() and bool(secret_path.read_text(encoding="utf-8").strip())
    except OSError:
        pass
    if running_service_env_value(repo_root, "turbovas-api", TURBOVAS_API_BEARER_TOKEN_ENV):
