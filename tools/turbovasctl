            findings.append(native_api_probe_finding("pass" if post_delete_ok else "fail", "native-api-direct.tag-write-post-delete", "Direct API confirms the temporary tag is gone after delete." if post_delete_ok else "Direct API did not confirm the temporary tag was deleted.", post_delete, direct_native_api_display_command(f"/api/v1/tags/{urllib.parse.quote(tag_id)}", token=token, env=env), post_delete_json, {"http_status": post_delete_status, "tag_id": tag_id, **summarize_native_api_response(post_delete_json)}))

    if started_write_control and aggregate_status(findings) == "fail":
        log_tail = service_log_tail(repo_root, "turbovas-api", lines=160)
        interesting_log_tail = [
