    up = run_command(compose_command(repo_root, "--profile", "app", "up", "-d", "--no-deps", "turbovas-api", env=env), repo_root, env=env, timeout=300)
    findings.append(process_step_finding("pass" if up.returncode == 0 else "fail", "compose.turbovas-api-direct-up", f"docker compose direct turbovas-api up exit code {up.returncode}.", up, compose_command(repo_root, "--profile", "app", "up", "-d", "--no-deps", "turbovas-api", env=env)))
    if up.returncode != 0:
        result = make_result("runtime-native-api-direct-smoke", repo_root, "Direct native API smoke stopped because turbovas-api restart failed.", findings, [str(artifact_dir)])
        result["details"] = {"base_url": native_api_direct_base_url(env)}
        write_json_artifact(artifact_dir, "native-api-direct-smoke-failed.json", result)
        return result

    health = direct_native_api_curl(repo_root, "/healthz", token=None, env=env)
    health_json, health_status = parse_json_output_with_http_status(health)
    health_ok = health.returncode == 0 and health_status == 200 and isinstance(health_json, dict) and health_json.get("status") == "ok"
    findings.append(native_api_probe_finding("pass" if health_ok else "fail", "native-api-direct.healthz", "Direct native API health endpoint is reachable without bearer auth." if health_ok else "Direct native API health endpoint failed.", health, direct_native_api_display_command("/healthz", token=None, env=env), health_json, {"http_status": health_status, **summarize_native_api_response(health_json)}))

    missing = direct_native_api_curl(repo_root, "/api/v1/reports?page_size=1", token=None, env=env)
    missing_json, missing_status = parse_json_output_with_http_status(missing)
    missing_ok = missing.returncode == 0 and missing_status == 401 and isinstance(missing_json, dict) and missing_json.get("error", {}).get("code") == "unauthorized"
    findings.append(native_api_probe_finding("pass" if missing_ok else "fail", "native-api-direct.missing-token", "Direct native API rejects missing bearer token with JSON 401." if missing_ok else "Direct native API did not reject a missing bearer token correctly.", missing, direct_native_api_display_command("/api/v1/reports?page_size=1", token=None, env=env), missing_json, {"http_status": missing_status, **summarize_native_api_response(missing_json)}))

    wrong = direct_native_api_curl(repo_root, "/api/v1/reports?page_size=1", token="wrong-token", env=env)
    wrong_json, wrong_status = parse_json_output_with_http_status(wrong)
    wrong_ok = wrong.returncode == 0 and wrong_status == 401 and isinstance(wrong_json, dict) and wrong_json.get("error", {}).get("code") == "unauthorized"
    findings.append(native_api_probe_finding("pass" if wrong_ok else "fail", "native-api-direct.wrong-token", "Direct native API rejects wrong bearer token with JSON 401." if wrong_ok else "Direct native API did not reject a wrong bearer token correctly.", wrong, direct_native_api_display_command("/api/v1/reports?page_size=1", token="wrong-token", env=env), wrong_json, {"http_status": wrong_status, **summarize_native_api_response(wrong_json)}))

    valid = direct_native_api_curl(repo_root, "/api/v1/reports?page_size=1", token=env[TURBOVAS_API_BEARER_TOKEN_ENV], env=env)
    valid_json, valid_status = parse_json_output_with_http_status(valid)
    valid_ok = valid.returncode == 0 and valid_status == 200 and isinstance(valid_json, dict) and isinstance(valid_json.get("items"), list)
    findings.append(native_api_probe_finding("pass" if valid_ok else "fail", "native-api-direct.valid-token", "Direct native API accepts the configured bearer token and returns JSON." if valid_ok else "Direct native API did not return JSON for the configured bearer token.", valid, direct_native_api_display_command("/api/v1/reports?page_size=1", token=env[TURBOVAS_API_BEARER_TOKEN_ENV], env=env), valid_json, {"http_status": valid_status, **summarize_native_api_response(valid_json)}))

    non_get = direct_native_api_curl(
        repo_root,
        "/api/v1/reports?page_size=1",
        token=env[TURBOVAS_API_BEARER_TOKEN_ENV],
        env=env,
        method="POST",
    )
    non_get_json, non_get_status = parse_json_output_with_http_status(non_get)
    non_get_ok = non_get.returncode == 0 and non_get_status == 405 and isinstance(non_get_json, dict) and non_get_json.get("error", {}).get("code") == "method_not_allowed"
    findings.append(native_api_probe_finding("pass" if non_get_ok else "fail", "native-api-direct.read-only-method-guard", "Direct native API rejects valid-token non-GET /api/v1 requests with JSON 405." if non_get_ok else "Direct native API did not reject a valid-token non-GET /api/v1 request correctly.", non_get, direct_native_api_display_command("/api/v1/reports?page_size=1", token=env[TURBOVAS_API_BEARER_TOKEN_ENV], env=env, method="POST"), non_get_json, {"http_status": non_get_status, **summarize_native_api_response(non_get_json)}))

    unclassified = direct_native_api_curl(
        repo_root,
        "/api/v1/__unclassified_probe__",
        token=env[TURBOVAS_API_BEARER_TOKEN_ENV],
        env=env,
    )
    unclassified_json, unclassified_status = parse_json_output_with_http_status(unclassified)
    unclassified_ok = unclassified.returncode == 0 and unclassified_status == 404 and isinstance(unclassified_json, dict) and unclassified_json.get("error", {}).get("code") == "not_found"
    findings.append(native_api_probe_finding("pass" if unclassified_ok else "fail", "native-api-direct.positive-allowlist", "Direct native API denies unclassified /api/v1 GET routes with JSON 404." if unclassified_ok else "Direct native API did not deny an unclassified /api/v1 GET route correctly.", unclassified, direct_native_api_display_command("/api/v1/__unclassified_probe__", token=env[TURBOVAS_API_BEARER_TOKEN_ENV], env=env), unclassified_json, {"http_status": unclassified_status, **summarize_native_api_response(unclassified_json)}))

    scope_reports = native_api_curl(repo_root, "/api/v1/scope-reports?page_size=1&sort=-creation_time")
    scope_reports_json = parse_json_output(scope_reports)
    scope_report_items = scope_reports_json.get("items", []) if isinstance(scope_reports_json, dict) else []
    selected_scope_report = scope_report_items[0] if scope_report_items else None
    selected_scope = selected_scope_report.get("scope") if isinstance(selected_scope_report, dict) else None
    if (
        isinstance(selected_scope_report, dict)
        and isinstance(selected_scope, dict)
        and selected_scope_report.get("id")
        and selected_scope.get("id")
    ):
        retention_path = f"/api/v1/scopes/{urllib.parse.quote(str(selected_scope['id']))}/reports/{urllib.parse.quote(str(selected_scope_report['id']))}/retention-plan"
        retention_direct = direct_native_api_curl(
            repo_root,
            retention_path,
            token=env[TURBOVAS_API_BEARER_TOKEN_ENV],
            env=env,
        )
        retention_direct_json, retention_direct_status = parse_json_output_with_http_status(retention_direct)
        retention_direct_ok = (
            retention_direct.returncode == 0
            and retention_direct_status == 404
            and isinstance(retention_direct_json, dict)
            and retention_direct_json.get("error", {}).get("code") == "not_found"
        )
        findings.append(
            native_api_probe_finding(
                "pass" if retention_direct_ok else "fail",
                "native-api-direct.internal-only-retention-plan",
                "Direct native API denies the internal-only retention preview with JSON 404."
                if retention_direct_ok
                else "Direct native API did not deny the internal-only retention preview correctly.",
                retention_direct,
                direct_native_api_display_command(retention_path, token=env[TURBOVAS_API_BEARER_TOKEN_ENV], env=env),
                retention_direct_json,
                {"http_status": retention_direct_status, **summarize_native_api_response(retention_direct_json)},
            )
        )
    else:
        findings.append(finding("warn", "native-api-direct.internal-only-retention-plan", "No scope report exists yet, so the direct internal-only retention preview denial probe was skipped."))

    internal = command_runtime_native_api_smoke(repo_root)
    findings.append(finding(internal["status"], "native-api.internal-smoke", internal["summary"], details={"status": internal["status"], "artifacts": internal.get("artifacts", [])}))
    result = make_result("runtime-native-api-direct-smoke", repo_root, "Direct native API smoke checks completed.", findings, [str(artifact_dir), *internal.get("artifacts", [])])
    result["details"] = {
        "base_url": native_api_direct_base_url(env),
        "container_bind": env.get(TURBOVAS_API_DIRECT_BIND_ENV),
        "token_source": "environment" if token_from_env else "runtime-secret",
        "direct_request_example": f"tools/turbovasctl native-api-request --direct --json --path '/api/v1/reports?page_size=1'",
    }
    write_json_artifact(artifact_dir, "native-api-direct-smoke.json" if result["status"] != "fail" else "native-api-direct-smoke-failed.json", result)
    return result


