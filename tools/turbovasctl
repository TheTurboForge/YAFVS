def rust_migration_tool_state(repo_root: Path) -> list[dict[str, Any]]:
    states: list[dict[str, Any]] = []
    env = build_env(repo_root)
    for name, command in RUST_MIGRATION_TOOL_COMMANDS:
        executable = shutil.which(command[0])
        state: dict[str, Any] = {"name": name, "command": list(command), "path": executable}
        if executable:
            probe = run_command(list(command), repo_root, env=env, timeout=30)
            state["status"] = "pass" if probe.returncode == 0 else "warn"
            state["version"] = probe.stdout.strip().splitlines()[0] if probe.stdout.strip() else None
            state["exit_code"] = probe.returncode
        else:
            state["status"] = "fail"
            state["version"] = None
            state["exit_code"] = None
        states.append(state)
    return states


def rust_toolchain_state(repo_root: Path) -> dict[str, Any]:
    env = build_env(repo_root)
    probes = {
        "rustc": ["rustc", "--version"],
        "cargo": ["cargo", "--version"],
        "clang": ["clang", "--version"],
        "llvm-config": ["llvm-config", "--version"],
    }
    state: dict[str, Any] = {}
    for name, command in probes.items():
        path = shutil.which(command[0])
        item: dict[str, Any] = {"path": path}
        if path:
            probe = run_command(command, repo_root, env=env, timeout=30)
            item["status"] = "pass" if probe.returncode == 0 else "warn"
            item["version"] = probe.stdout.strip().splitlines()[0] if probe.stdout.strip() else None
            item["exit_code"] = probe.returncode
        else:
            item["status"] = "fail"
            item["version"] = None
            item["exit_code"] = None
        state[name] = item
    return state


def rust_migration_candidate_state(repo_root: Path) -> dict[str, Any]:
