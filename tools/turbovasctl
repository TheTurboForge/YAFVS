def command_logs(repo_root: Path, service: str | None = None, lines: int = 120) -> dict[str, Any]:
    if lines < 1:
        findings = [finding("fail", "compose.logs.invalid_lines", "--lines must be 1 or greater.", details={"service": service, "lines": lines})]
        return make_result("logs", repo_root, "Runtime logs were not collected.", findings)
    command = compose_command(repo_root, "logs", "--tail", str(lines))
    if service:
        command.append(service)
    result = run_command(command, repo_root, env=runtime_env(repo_root))
    output_tail = result.stdout.splitlines()[-lines:]
    message = f"docker compose logs exit code {result.returncode}."
    if output_tail:
        message += "\n" + "\n".join(output_tail)
    findings = [finding("pass" if result.returncode == 0 else "fail", "compose.logs", message, details={"service": service, "lines": lines, "output_tail": output_tail})]
    return make_result("logs", repo_root, "Runtime logs collected.", findings)


def command_runtime_log_review(repo_root: Path) -> dict[str, Any]:
    artifact_dir = log_review_artifact_dir(repo_root)
    secrets_to_redact = runtime_secret_redactions(repo_root)
    findings: list[dict[str, Any]] = []
    artifact_dir.mkdir(parents=True, exist_ok=True)
    review_details: dict[str, Any] = {"services": {}}

    for service in (*RUNTIME_SERVICES, *APP_SERVICES):
        service_details: dict[str, Any] = {}
        state = docker_container_state(repo_root, service)
        service_details["state"] = state
        if state is None:
            findings.append(finding("warn", "log-review.container", f"{service} container does not exist; logs may be unavailable.", details={"service": service}))
        elif state.get("Running") is not True:
            status = "fail" if service in RUNTIME_SERVICES else "warn"
            findings.append(finding(status, "log-review.container", f"{service} container is not running.", details={"service": service, "state": state}))
        else:
            findings.append(finding("pass", "log-review.container", f"{service} container is running.", details={"service": service, "state": {"Status": state.get("Status"), "Running": state.get("Running")}}))

        command = compose_command(repo_root, "logs", "--no-color", "--tail", str(LOG_REVIEW_TAIL_LINES), service)
        logs = run_command(command, repo_root, env=runtime_env(repo_root), timeout=120)
        redacted = redact_text(logs.stdout, secrets_to_redact)
        log_path = artifact_dir / f"{service}.log"
        log_path.write_text(redacted, encoding="utf-8")
        service_details["artifact"] = str(log_path)
        service_details["line_count"] = len(redacted.splitlines())
        redacted_logs = subprocess.CompletedProcess(logs.args, logs.returncode, redacted)
        findings.append(process_step_finding("pass" if logs.returncode == 0 else "warn", "log-review.logs", f"Collected recent {service} Docker logs with exit code {logs.returncode}.", redacted_logs, command))

        matches = log_review_matches(redacted.splitlines(), service=service)
        service_details["matches"] = matches
        if matches:
            for match in matches:
                findings.append(finding(match["status"], f"log-review.{match['key']}", f"{service}: {match['message']}", details={"service": service, "matches": match["matches"]}))
        else:
            findings.append(finding("pass", "log-review.patterns", f"{service} log tail contains no high-signal runtime patterns.", details={"service": service}))
        review_details["services"][service] = service_details

    result = make_result("runtime-log-review", repo_root, "Runtime log review completed.", findings, [str(artifact_dir / "log-review.json")])
    result["details"] = review_details
    write_json_artifact(artifact_dir, "log-review.json", result)
    return result


def command_runtime_data_state(repo_root: Path) -> dict[str, Any]:
    artifact_dir = data_state_artifact_dir(repo_root)
    findings: list[dict[str, Any]] = []
    details: dict[str, Any] = {
        "database": {"classification": "system_of_record"},
        "paths": {},
    }
    artifact_dir.mkdir(parents=True, exist_ok=True)

    manager_lock = runtime_lock_status(repo_root, RUNTIME_MANAGER_LOCK)
    details["runtime_manager_lock"] = manager_lock
    if manager_lock["active"]:
        findings.append(finding("warn", "data-state.runtime-manager-lock", "runtime-manager-init or another manager operation is currently active; data-state may be transient.", details={"lock": manager_lock}))

    if not container_running(repo_root, "postgres"):
        findings.append(finding("warn", "data-state.postgres", "Postgres is not running; database state is unavailable."))
    else:
        version = psql(repo_root, "SELECT COALESCE((SELECT value FROM meta WHERE name = 'database_version'), 'missing');")
        db_version = psql_value(version) if version.returncode == 0 else ""
        details["database"]["database_version"] = db_version
        findings.append(finding("pass" if version.returncode == 0 and db_version else "fail", "data-state.database-version", f"Manager database version is {db_version or 'unknown'}.", details={"output_tail": output_tail(version.stdout, 40)}))

        for label, tables, expected_present in (
            ("core", DATABASE_CORE_TABLES, True),
            ("scope", DATABASE_SCOPE_TABLES, True),
            ("removed", DATABASE_REMOVED_TABLES, False),
        ):
            table_query, presence = table_presence_rows(repo_root, tables)
            details["database"][f"{label}_tables"] = {table: {"exists": presence.get(table, False)} for table in tables}
            if table_query.returncode != 0:
                findings.append(finding("fail", f"data-state.{label}-tables", f"Could not inspect {label} table presence.", details={"output_tail": output_tail(table_query.stdout, 80)}))
                continue
            bad = [table for table in tables if presence.get(table, False) is not expected_present]
            status = "fail" if bad else "pass"
            message = f"{label} table presence matches expectation." if not bad else f"{label} table presence mismatch: {', '.join(bad)}."
            findings.append(finding(status, f"data-state.{label}-tables", message, details={"mismatches": bad, "expected_present": expected_present}))
            for table in tables:
                if presence.get(table, False):
                    details["database"][f"{label}_tables"][table]["row_count"] = table_row_count(repo_root, table)

    for name, classification, parts, recursive in DATA_STATE_ARTIFACT_PATHS:
        summary = path_tree_summary(runtime_path(repo_root, *parts), recursive=recursive)
        summary["classification"] = classification
        details["paths"][name] = summary
        findings.append(finding("pass" if summary["exists"] else "warn", "data-state.path", f"{name} classified as {classification}.", summary["path"], {"summary": summary}))
    details["data_outside_db"] = summarize_data_outside_db(details["paths"])
    findings.append(finding("pass", "data-state.outside-db", "Non-database runtime state summary captured.", details={"summary": details["data_outside_db"]}))
    details["product_data_audit"] = product_data_audit(details)
    audit_status = details["product_data_audit"].get("status", "warn")
    audit_message = "Product data exports have database sources of record."
    if audit_status != "pass":
        audit_message = "Product data exports are missing expected database sources of record."
    findings.append(finding(audit_status, "data-state.product-data-audit", audit_message, details={"audit": details["product_data_audit"]}))

    result = make_result("runtime-data-state", repo_root, "Runtime data-state diagnostic completed.", findings, [str(artifact_dir / "data-state.json")])
    result["details"] = details
    write_json_artifact(artifact_dir, "data-state.json", result)
    return result


def runtime_db_introspect_status_only_result(result: dict[str, Any]) -> dict[str, Any]:
    compact = dict(result)
    findings = result.get("findings", [])
    non_pass = [compact_doctor_finding(item) for item in findings if item.get("status") != "pass"]
    details = result.get("details", {}) if isinstance(result.get("details"), dict) else {}
    database = details.get("database", {}) if isinstance(details.get("database"), dict) else {}
    schemas = details.get("schemas", {}) if isinstance(details.get("schemas"), dict) else {}
    tables = details.get("tables", {}) if isinstance(details.get("tables"), dict) else {}
    columns = details.get("columns", {}) if isinstance(details.get("columns"), dict) else {}
    requested_columns = details.get("requested_columns", []) if isinstance(details.get("requested_columns"), list) else []
    compact["details"] = {
        "database_name": database.get("name"),
        "manager_database_version": database.get("manager_database_version"),
        "schema_count": len(schemas),
        "missing_schema_count": sum(1 for item in schemas.values() if isinstance(item, dict) and not item.get("exists")),
        "table_count": len(tables),
        "existing_table_count": sum(1 for item in tables.values() if isinstance(item, dict) and item.get("exists")),
        "column_count": len(columns),
        "existing_column_count": sum(1 for item in columns.values() if isinstance(item, dict) and item.get("exists")),
        "requested_column_table_count": len(requested_columns),
        "finding_count": len(findings),
        "non_pass_count": len(non_pass),
    }
    compact["findings"] = non_pass or [
        finding(
            "pass",
            "runtime-db-introspect.status-only",
            "Runtime database introspection passed; no non-pass findings.",
        )
    ]
    return compact


def command_runtime_db_introspect(repo_root: Path, status_only: bool = False, columns_for: Sequence[str] = ()) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    details: dict[str, Any] = {"database": {}, "schemas": {}, "tables": {}, "columns": {}, "requested_columns": []}
    requested_column_tables: list[tuple[str, str]] = []
    for request in columns_for:
        try:
            parsed = parse_safe_schema_table(request)
        except ValueError as error:
            findings.append(finding("fail", "db-introspect.columns-for-shape", str(error), details={"input": request}))
            continue
        if parsed not in requested_column_tables:
            requested_column_tables.append(parsed)
    if not container_running(repo_root, "postgres"):
        findings.append(finding("warn", "db-introspect.postgres", "Postgres is not running; database introspection is unavailable."))
        result = make_result("runtime-db-introspect", repo_root, "Runtime database introspection could not inspect Postgres.", findings)
        result["details"] = details
        if status_only:
            result = runtime_db_introspect_status_only_result(result)
        return result

    identity = psql(repo_root, "SELECT current_database() || '|' || current_user || '|' || session_user;")
    if identity.returncode == 0 and "|" in psql_value(identity):
        database, current_user, session_user = psql_value(identity).split("|", 2)
        details["database"].update({"name": database, "current_user": current_user, "session_user": session_user})
        findings.append(finding("pass", "db-introspect.identity", "Database identity captured.", details={"database": details["database"]}))
    else:
        findings.append(finding("fail", "db-introspect.identity", "Database identity query failed.", details={"output_tail": output_tail(identity.stdout, 80)}))

    version = psql(repo_root, "SELECT COALESCE((SELECT value FROM meta WHERE name = 'database_version'), 'missing');")
    db_version = psql_value(version) if version.returncode == 0 else ""
    details["database"]["manager_database_version"] = db_version
    findings.append(finding("pass" if version.returncode == 0 and db_version else "fail", "db-introspect.database-version", f"Manager database version is {db_version or 'unknown'}.", details={"output_tail": output_tail(version.stdout, 40)}))

    schemas = psql(repo_root, "SELECT schema_name FROM information_schema.schemata WHERE schema_name IN ('public', 'cert') ORDER BY schema_name;")
    schema_names = {line.strip() for line in schemas.stdout.splitlines() if line.strip()} if schemas.returncode == 0 else set()
    details["schemas"] = {schema: {"exists": schema in schema_names} for schema in ("public", "cert")}
    missing_schemas = [schema for schema, info in details["schemas"].items() if not info["exists"]]
    findings.append(finding("pass" if schemas.returncode == 0 and not missing_schemas else "warn", "db-introspect.schemas", "Expected database schemas are present." if not missing_schemas else f"Missing expected schemas: {', '.join(missing_schemas)}.", details={"schemas": details["schemas"], "output_tail": output_tail(schemas.stdout, 40)}))

    table_query, table_presence = introspection_table_presence(repo_root)
    if table_query.returncode == 0:
        for schema, table in DB_INTROSPECT_TABLES:
            key = f"{schema}.{table}"
            exists = table_presence.get(key, False)
            details["tables"][key] = {"exists": exists}
            if exists:
                details["tables"][key]["row_count"] = qualified_table_row_count(repo_root, schema, table)
        findings.append(finding("pass", "db-introspect.tables", "Fixed database table catalog captured.", details={"table_count": len(details["tables"])}))
    else:
        findings.append(finding("fail", "db-introspect.tables", "Fixed database table catalog query failed.", details={"output_tail": output_tail(table_query.stdout, 80)}))

    column_query, column_presence = introspection_column_presence(repo_root)
    if column_query.returncode == 0:
        details["columns"] = {key: {"exists": exists} for key, exists in column_presence.items()}
        findings.append(finding("pass", "db-introspect.columns", "Fixed database column catalog captured.", details={"column_count": len(details["columns"])}))
    else:
        findings.append(finding("fail", "db-introspect.columns", "Fixed database column catalog query failed.", details={"output_tail": output_tail(column_query.stdout, 80)}))

    if requested_column_tables:
        requested_columns, requested_findings = introspection_table_columns(repo_root, requested_column_tables)
        details["requested_columns"] = requested_columns
        findings.extend(requested_findings)

    result = make_result("runtime-db-introspect", repo_root, "Runtime database introspection completed.", findings)
