def ospd_vt_load_status_from_logs(lines: Iterable[str]) -> tuple[str, list[str]]:
    relevant: list[str] = []
    for line in lines:
        if "Finished loading VTs" in line or "VTs were up to date" in line:
            relevant.append(line)
            return "pass", relevant
        if "Updating VTs failed" in line or "failed to load VTs" in line or "OpenVAS Scanner failed to load VTs" in line:
            relevant.append(line)
            return "fail", relevant
        if "Loading VTs" in line:
            relevant.append(line)
    return "wait", relevant


def wait_for_ospd_vt_load(repo_root: Path, timeout_seconds: int = 300) -> tuple[str, list[str]]:
    deadline = time.monotonic() + timeout_seconds
    last_lines: list[str] = []
    while time.monotonic() < deadline:
        status, lines = ospd_vt_load_status_from_logs(service_log_tail(repo_root, "ospd-openvas", lines=200))
        if lines:
            last_lines = lines
        if status in ("pass", "fail"):
            return status, last_lines
        time.sleep(5)
    return "wait", last_lines


