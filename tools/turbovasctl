                templates.add(f"{scope_prefix.rstrip('/')}/{{}}/reports/{{}}{suffix}")

    post_function_body = c_source_function_body(source, "native_api_post_path_is_allowed")
    if post_function_body:
        post_constants = c_string_constants(post_function_body)
        for match in re.finditer(
            r"if\s*\(\s*g_strcmp0\s*\(\s*path\s*,\s*(\w+)\s*\)\s*==\s*0\s*\)\s*return\s+TRUE\s*;",
            post_function_body,
            re.DOTALL,
        ):
            variable = match.group(1)
            value = post_constants.get(variable)
            if value and value.startswith("/api/v1"):
                templates.add(value)
            else:
                errors.append(f"unresolved_post_exact_path:{variable}")

        clone_suffix = post_constants.get("clone_suffix")
        restore_suffix = post_constants.get("restore_suffix")
        resources_suffix = post_constants.get("resources_suffix")
        for prefix_variable in ("filter_prefix", "port_list_prefix", "report_config_prefix", "scan_config_prefix", "schedule_prefix", "tag_prefix", "target_prefix"):
            prefix = post_constants.get(prefix_variable)
            if prefix and clone_suffix and f"g_str_has_prefix (path, {prefix_variable})" in post_function_body:
                templates.add(f"{prefix.rstrip('/')}/{{}}{clone_suffix}")
            if prefix and restore_suffix and f"g_str_has_prefix (path, {prefix_variable})" in post_function_body:
                templates.add(f"{prefix.rstrip('/')}/{{}}{restore_suffix}")
        tag_prefix = post_constants.get("tag_prefix")
        if (
            tag_prefix
            and resources_suffix
            and "g_str_has_prefix (path, tag_prefix)" in post_function_body
            and "g_str_has_suffix (id, resources_suffix)" in post_function_body
        ):
            templates.add(f"{tag_prefix.rstrip('/')}/{{}}{resources_suffix}")

    patch_function_body = c_source_function_body(source, "native_api_patch_path_is_allowed")
    if patch_function_body:
        patch_constants = c_string_constants(patch_function_body)
        for prefix_variable in ("filter_prefix", "port_list_prefix", "report_config_prefix", "scan_config_prefix", "scanner_prefix", "schedule_prefix", "tag_prefix", "target_prefix"):
            prefix = patch_constants.get(prefix_variable)
            if prefix and f"g_str_has_prefix (path, {prefix_variable})" in patch_function_body:
                templates.add(f"{prefix.rstrip('/')}/{{}}")

    delete_function_body = c_source_function_body(source, "native_api_delete_path_is_allowed")
    if delete_function_body:
        delete_constants = c_string_constants(delete_function_body)
        trash_suffix = delete_constants.get("trash_suffix")
        for prefix_variable in (
            "filter_prefix",
            "port_list_prefix",
            "report_config_prefix",
            "scan_config_prefix",
            "schedule_prefix",
            "scope_prefix",
            "tag_prefix",
            "target_prefix",
        ):
