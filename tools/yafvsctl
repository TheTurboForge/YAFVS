def validate_native_api_direct_host_value(value: str, *, env_name: str) -> str:
    host = value.strip()
    if not host:
        raise ValueError(f"{env_name} must not be empty")
    if any(ord(char) < 33 or char.isspace() for char in host):
        raise ValueError(f"{env_name} must not contain whitespace or control characters")
    if any(char in host for char in "/\\?#@,"):
        raise ValueError(f"{env_name} must be a host name or address, not a URL or host list")
    if host.startswith("["):
        if not re.fullmatch(r"\[[0-9A-Fa-f:.]+\]", host):
            raise ValueError(f"{env_name} must contain a bracketed IPv6 address like [::1]")
    elif ":" in host:
        raise ValueError(f"{env_name} must bracket IPv6 addresses, for example [::1]")
    elif not re.fullmatch(r"[A-Za-z0-9][A-Za-z0-9.-]*", host):
        raise ValueError(f"{env_name} must contain only host-safe ASCII characters")
    return host


def validate_native_api_direct_port_value(value: str, *, env_name: str) -> str:
    port = value.strip()
    if not port:
        raise ValueError(f"{env_name} must not be empty")
    if not port.isdigit():
        raise ValueError(f"{env_name} must be a decimal TCP port")
    number = int(port)
    if not 1 <= number <= 65535:
        raise ValueError(f"{env_name} must be between 1 and 65535")
    return str(number)


def validate_native_api_direct_bind_value(value: str, *, env_name: str) -> str:
    bind = value.strip()
    if not bind:
        raise ValueError(f"{env_name} must not be empty")
    if bind.startswith("["):
        host_end = bind.find("]")
        if host_end == -1 or len(bind) <= host_end + 2 or bind[host_end + 1] != ":":
            raise ValueError(f"{env_name} must be host:port or [ipv6]:port")
        host = bind[: host_end + 1]
        port = bind[host_end + 2 :]
    else:
        if bind.count(":") != 1:
            raise ValueError(f"{env_name} must be host:port or [ipv6]:port")
        host, port = bind.rsplit(":", 1)
    normalized_port = validate_native_api_direct_port_value(port, env_name=env_name)
    if normalized_port != YAFVS_API_DIRECT_CONTAINER_PORT:
        raise ValueError(
            f"{env_name} must use container port {YAFVS_API_DIRECT_CONTAINER_PORT} "
            "when managed by yafvsctl"
        )
    return f"{validate_native_api_direct_host_value(host, env_name=env_name)}:{normalized_port}"


def validate_native_api_operator_uuid_value(value: str, *, env_name: str) -> str:
    if not UUID_VALUE_RE.fullmatch(value):
        raise ValueError(f"{env_name} must be a UUID")
    return value.lower()


def validate_native_api_operator_name_value(value: str, *, env_name: str) -> str:
    if not value.strip() or len(value.strip()) > 256 or any(ord(ch) < 32 for ch in value):
        raise ValueError(f"{env_name} must be a non-empty printable operator name up to 256 characters")
    return value.strip()


def validate_native_api_direct_write_control_value(value: str, *, env_name: str) -> str:
    normalized = value.strip().lower()
    if normalized in {"1", "true", "yes", "on", "0", "false", "no", "off"}:
        return normalized
    raise ValueError(f"{env_name} must be a boolean value such as 1/0 or true/false")


def native_api_direct_config_errors(env: dict[str, str]) -> tuple[str, ...]:
    errors: list[str] = []
    for value, env_name, validator in (
        (native_api_direct_host(env), YAFVS_API_DIRECT_HOST_ENV, validate_native_api_direct_host_value),
        (native_api_direct_port(env), YAFVS_API_DIRECT_PORT_ENV, validate_native_api_direct_port_value),
    ):
        try:
            validator(value, env_name=env_name)
        except ValueError as exc:
            errors.append(str(exc))
    direct_bind = env.get(YAFVS_API_DIRECT_BIND_ENV)
    if direct_bind:
        try:
            validate_native_api_direct_bind_value(direct_bind, env_name=YAFVS_API_DIRECT_BIND_ENV)
        except ValueError as exc:
            errors.append(str(exc))
    operator_uuid = env.get(YAFVS_API_OPERATOR_UUID_ENV, "").strip()
    operator_name = env.get(YAFVS_API_OPERATOR_NAME_ENV, "")
    if operator_uuid:
        try:
            validate_native_api_operator_uuid_value(operator_uuid, env_name=YAFVS_API_OPERATOR_UUID_ENV)
        except ValueError as exc:
            errors.append(str(exc))
    elif operator_name.strip():
        errors.append(f"{YAFVS_API_OPERATOR_NAME_ENV} requires {YAFVS_API_OPERATOR_UUID_ENV}")
    if operator_name.strip():
        try:
            validate_native_api_operator_name_value(operator_name, env_name=YAFVS_API_OPERATOR_NAME_ENV)
        except ValueError as exc:
            errors.append(str(exc))
    write_control = env.get(YAFVS_API_DIRECT_WRITE_CONTROL_ENV, "")
    if write_control.strip():
        try:
            normalized_write_control = validate_native_api_direct_write_control_value(
                write_control,
                env_name=YAFVS_API_DIRECT_WRITE_CONTROL_ENV,
            )
            if normalized_write_control in {"1", "true", "yes", "on"} and not operator_uuid:
                errors.append(f"{YAFVS_API_DIRECT_WRITE_CONTROL_ENV} requires {YAFVS_API_OPERATOR_UUID_ENV}")
        except ValueError as exc:
            errors.append(str(exc))
    return tuple(errors)


def native_api_direct_config_shape_finding(env: dict[str, str], *, check: str) -> dict[str, Any]:
    errors = native_api_direct_config_errors(env)
    return finding(
        "fail" if errors else "pass",
        check,
        "Direct native API host, port, and bind settings have a valid local shape."
        if not errors
        else "Direct native API host, port, or bind settings are malformed.",
        details={
            "host_env": YAFVS_API_DIRECT_HOST_ENV,
            "host": native_api_direct_host(env),
            "port_env": YAFVS_API_DIRECT_PORT_ENV,
            "port": native_api_direct_port(env),
            "bind_env": YAFVS_API_DIRECT_BIND_ENV,
            "bind": env.get(YAFVS_API_DIRECT_BIND_ENV),
            "write_control_env": YAFVS_API_DIRECT_WRITE_CONTROL_ENV,
            "write_control": env.get(YAFVS_API_DIRECT_WRITE_CONTROL_ENV),
