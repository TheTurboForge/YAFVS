def compact_native_tooling_summary(summary: dict[str, Any]) -> dict[str, Any]:
    endpoint_statuses: dict[str, int] = {}
    for endpoint in summary.get("implemented_native_endpoints", []):
        status = str(endpoint.get("status", "unknown")) if isinstance(endpoint, dict) else "unknown"
        endpoint_statuses[status] = endpoint_statuses.get(status, 0) + 1
    by_category = {
        category: {"count": category_summary.get("count", 0)}
        for category, category_summary in summary.get("by_category", {}).items()
        if isinstance(category_summary, dict)
    }
    return {
        "total_items": summary.get("total_items", 0),
        "by_category": by_category,
        "candidate_for_removal_paths": summary.get("by_category", {}).get("candidate_for_removal", {}).get("paths", []),
        "unknown_paths": summary.get("by_category", {}).get("unknown", {}).get("paths", []),
        "implemented_native_endpoint_count": len(summary.get("implemented_native_endpoints", [])),
        "implemented_native_endpoints_by_status": endpoint_statuses,
        "next_replacement_candidates": summary.get("next_replacement_candidates", []),
    }


def compact_native_tooling_finding_details(summary: dict[str, Any]) -> dict[str, Any]:
    compact = compact_native_tooling_summary(summary)
    return {
        "total_items": compact["total_items"],
        "by_category": compact["by_category"],
        "implemented_native_endpoint_count": compact["implemented_native_endpoint_count"],
        "implemented_native_endpoints_by_status": compact["implemented_native_endpoints_by_status"],
    }


def command_native_tooling_state(repo_root: Path, compact: bool = False) -> dict[str, Any]:
    items = native_tooling_inventory(repo_root)
    summary = summarize_native_tooling(items, repo_root)
    unknown_count = summary["by_category"]["unknown"]["count"]
    finding_details = compact_native_tooling_finding_details(summary) if compact else summary
    findings = [
        finding("pass", "native-tooling.inventory", f"Classified {len(items)} inherited tooling dependency surface(s).", details=finding_details),
        finding("warn" if unknown_count else "pass", "native-tooling.unknown", f"{unknown_count} inherited tooling surface(s) are outside the current classification map." if unknown_count else "No inherited tooling surfaces were left unclassified.", details={"paths": summary["by_category"]["unknown"]["paths"]}),
        finding("pass", "native-tooling.end-state", "End-state remains full removal of required python-gvm and gvm-tools dependence after native API replacements land."),
    ]
    result = make_result("native-tooling-state", repo_root, "Inherited GMP/python-gvm/gvm-tools dependency state collected.", findings)
    result["details"] = compact_native_tooling_summary(summary) if compact else {"items": items, **summary}
    return result


def rust_migration_tool_state(repo_root: Path) -> list[dict[str, Any]]:
    states: list[dict[str, Any]] = []
    env = build_env(repo_root)
    for name, command in RUST_MIGRATION_TOOL_COMMANDS:
        executable = shutil.which(command[0])
        state: dict[str, Any] = {"name": name, "command": list(command), "path": executable}
        if executable:
            probe = run_command(list(command), repo_root, env=env, timeout=30)
            state["status"] = "pass" if probe.returncode == 0 else "warn"
            state["version"] = probe.stdout.strip().splitlines()[0] if probe.stdout.strip() else None
            state["exit_code"] = probe.returncode
        else:
            state["status"] = "fail"
            state["version"] = None
            state["exit_code"] = None
        states.append(state)
    return states


def rust_toolchain_state(repo_root: Path) -> dict[str, Any]:
    env = build_env(repo_root)
    probes = {
        "rustc": ["rustc", "--version"],
        "cargo": ["cargo", "--version"],
        "clang": ["clang", "--version"],
        "llvm-config": ["llvm-config", "--version"],
    }
    state: dict[str, Any] = {}
    for name, command in probes.items():
        path = shutil.which(command[0])
        item: dict[str, Any] = {"path": path}
        if path:
            probe = run_command(command, repo_root, env=env, timeout=30)
            item["status"] = "pass" if probe.returncode == 0 else "warn"
            item["version"] = probe.stdout.strip().splitlines()[0] if probe.stdout.strip() else None
            item["exit_code"] = probe.returncode
        else:
            item["status"] = "fail"
            item["version"] = None
            item["exit_code"] = None
        state[name] = item
    return state


def rust_migration_candidate_state(repo_root: Path) -> dict[str, Any]:
    candidate = dict(RUST_MIGRATION_FIRST_CANDIDATE)
    for key in ("c_file", "header", "test_file"):
        path = repo_root / candidate[key]
        candidate[f"{key}_exists"] = path.is_file()
    candidate["production_replacement_allowed_in_current_slice"] = False
    candidate["production_replacement_requirements"] = [
        "CMake/Rust integration for the owning C library",
        "exported C ABI if retained C callers continue to call the symbol",
        "version-string injection equivalent to current GVM_LIBS_VERSION handling",
        "preserved upstream license notices plus TurboVAS modification notice where required",
        "existing C test parity and Rust-side tests before deleting the C implementation",
    ]
    return candidate


def command_rust_migration_state(repo_root: Path) -> dict[str, Any]:
    tools = rust_migration_tool_state(repo_root)
    toolchain = rust_toolchain_state(repo_root)
    candidate = rust_migration_candidate_state(repo_root)
    scanner_workspace = repo_root / "components" / "openvas-scanner" / "rust" / "Cargo.toml"
    artifact_dir = rust_migration_artifact_dir(repo_root)
    findings: list[dict[str, Any]] = []
    missing_tools = [item["name"] for item in tools if item["status"] == "fail"]
    warning_tools = [item["name"] for item in tools if item["status"] == "warn"]
    findings.append(finding("fail" if missing_tools else "pass", "rust-migration.tools", "All Rust migration tools are available." if not missing_tools else "Some Rust migration tools are missing.", details={"missing": missing_tools, "warnings": warning_tools, "tools": tools}))
    failed_toolchain = [name for name, item in toolchain.items() if item["status"] == "fail"]
    findings.append(finding("fail" if failed_toolchain else "pass", "rust-migration.toolchain", "Rust, Cargo, Clang, and LLVM config are available." if not failed_toolchain else "Rust/LLVM toolchain prerequisite is missing.", details={"missing": failed_toolchain, "toolchain": toolchain}))
    findings.append(finding("pass" if scanner_workspace.is_file() else "warn", "rust-migration.scanner-workspace", "Inherited scanner Rust workspace exists." if scanner_workspace.is_file() else "Inherited scanner Rust workspace was not found.", str(scanner_workspace)))
    candidate_ready = bool(candidate.get("c_file_exists") and candidate.get("header_exists") and candidate.get("test_file_exists"))
    findings.append(finding("pass" if candidate_ready else "fail", "rust-migration.first-candidate", "First dry-run C-to-Rust candidate exists and has tests." if candidate_ready else "First dry-run C-to-Rust candidate is incomplete.", details=candidate))
    try:
        artifact_dir.mkdir(parents=True, exist_ok=True)
        findings.append(finding("pass", "rust-migration.artifact-dir", "Rust migration artifact directory is ready.", str(artifact_dir)))
    except OSError as error:
        findings.append(finding("fail", "rust-migration.artifact-dir", f"Rust migration artifact directory is not usable: {error}", str(artifact_dir)))
    result = make_result("rust-migration-state", repo_root, "Rust migration tooling and first dry-run candidate state collected.", findings, [str(artifact_dir)])
    result["details"] = {"tools": tools, "toolchain": toolchain, "scanner_workspace": str(scanner_workspace), "first_candidate": candidate, "artifact_dir": str(artifact_dir)}
    return result


def redis_reference_candidate(relative_path: str) -> bool:
    return relative_path in REDIS_REFERENCE_FILES or any(relative_path.startswith(prefix) for prefix in REDIS_REFERENCE_ROOTS)


def redis_reference_category(relative_path: str, text: str) -> str:
    lower = text.lower()
    if "redis-openvas" in lower or "scanner_redis" in lower or "scanner redis" in lower or "/run/redis-openvas" in lower:
        return "scanner_kb"
    if "hiredis" in lower or "redis-tools" in lower or "redis-server" in lower or "redis:" in lower:
        return "dependency_build"
    if relative_path.startswith("tools/"):
        return "diagnostic_tooling"
    if relative_path.startswith("docs/") or relative_path == "README.md":
        return "documentation"
    return "generic_runtime"


def redis_source_references(repo_root: Path) -> list[dict[str, Any]]:
    tracked = git_tracked_files(repo_root) or []
    references: list[dict[str, Any]] = []
    for relative_path in tracked:
        if not redis_reference_candidate(relative_path):
            continue
        path = repo_root / relative_path
        if not path.is_file():
            continue
        try:
            text = path.read_text(encoding="utf-8", errors="ignore")
        except OSError:
            continue
        matches = sorted({match.group(0) for match in REDIS_REFERENCE_PATTERN.finditer(text)})
        if not matches:
            continue
        references.append({"path": relative_path, "category": redis_reference_category(relative_path, text), "markers": matches})
    return sorted(references, key=lambda item: (item["category"], item["path"]))


def summarize_redis_references(references: list[dict[str, Any]]) -> dict[str, Any]:
    categories = ("scanner_kb", "generic_runtime", "dependency_build", "diagnostic_tooling", "documentation")
    by_category: dict[str, dict[str, Any]] = {}
    for category in categories:
        rows = [item for item in references if item["category"] == category]
        by_category[category] = {"count": len(rows), "paths": [item["path"] for item in rows]}
    return {"total_items": len(references), "by_category": by_category}


def path_coupling_category(relative_path: str) -> str:
    if relative_path.startswith("docs/") or relative_path.endswith((".md", ".rst", ".txt")) or relative_path in {"README.md", "BUILDING.md"}:
        return "documentation"
    if relative_path.startswith(("compose/", "docker/", "ops/")) or relative_path in {"justfile", "tools/turbovasctl"}:
        return "runtime_tooling"
    if relative_path.startswith("tools/"):
        return "diagnostic_tooling"
    if relative_path.startswith("components/"):
        return "component_source"
    return "other_tracked_source"


def path_coupling_markers(text: str) -> list[str]:
    return sorted(marker for marker, needle in PATH_COUPLING_MARKERS.items() if needle in text)


def path_coupling_references(repo_root: Path) -> list[dict[str, Any]]:
    references: list[dict[str, Any]] = []
    for relative_path in git_tracked_files(repo_root) or []:
        path = repo_root / relative_path
        if not path.is_file():
            continue
        try:
            text = path.read_text(encoding="utf-8", errors="ignore")
        except OSError:
            continue
        markers = path_coupling_markers(text)
        if not markers:
            continue
        references.append({"path": relative_path, "category": path_coupling_category(relative_path), "markers": markers})
    return sorted(references, key=lambda item: (item["category"], item["path"]))


def summarize_path_coupling(references: list[dict[str, Any]]) -> dict[str, Any]:
    by_category: dict[str, list[str]] = {}
    by_marker: dict[str, list[str]] = {}
    warning_paths: list[str] = []
    for reference in references:
        path = reference["path"]
        category = reference["category"]
        by_category.setdefault(category, []).append(path)
        for marker in reference["markers"]:
            by_marker.setdefault(marker, []).append(path)
        if category != "documentation" and "dev_checkout_path" in reference["markers"]:
            warning_paths.append(path)
    return {
        "total_references": len(references),
        "by_category": {category: {"count": len(paths), "paths": paths[:50]} for category, paths in sorted(by_category.items())},
        "by_marker": {marker: {"count": len(paths), "paths": paths[:50]} for marker, paths in sorted(by_marker.items())},
        "non_documentation_dev_checkout_paths": sorted(set(warning_paths))[:100],
    }


def redis_compose_boundaries(repo_root: Path) -> dict[str, Any]:
    path = compose_file(repo_root)
    try:
        text = path.read_text(encoding="utf-8")
    except OSError:
        text = ""
    generic_redis_present = re.search(r"(?m)^  redis:\s*$", text) is not None
    return {
        "compose_file": str(path.relative_to(repo_root)) if path.exists() else str(path),
        "generic_redis_service_present": generic_redis_present,
        "generic_redis_loopback_tcp": '"127.0.0.1:16379:6379"' in text,
        "scanner_redis_no_tcp_port": "--port 0" in text,
        "scanner_redis_unix_socket": "/run/redis-openvas/redis.sock" in text,
        "gvmd_depends_on_generic_redis": "gvmd:" in text and re.search(r"(?m)^\s{6}redis:\s*$", text) is not None,
        "ospd_depends_on_scanner_redis": "ospd-openvas:" in text and "redis-openvas:" in text,
    }


def scanner_redis_cli(repo_root: Path, args: list[str]) -> subprocess.CompletedProcess[str]:
    return exec_in_service(repo_root, "redis-openvas", ["redis-cli", "-s", "/run/redis-openvas/redis.sock", *args])


def parse_redis_info(stdout: str) -> dict[str, int]:
    keys = {
        "used_memory",
        "used_memory_peak",
        "connected_clients",
        "blocked_clients",
        "total_commands_processed",
        "instantaneous_ops_per_sec",
        "keyspace_hits",
        "keyspace_misses",
    }
    metrics: dict[str, int] = {}
    db_key_total = 0
    for raw_line in stdout.splitlines():
        line = raw_line.strip()
        if not line or line.startswith("#") or ":" not in line:
            continue
        key, value = line.split(":", 1)
        if key in keys:
            try:
                metrics[key] = int(value)
            except ValueError:
                continue
        elif key.startswith("db"):
            for part in value.split(","):
                if part.startswith("keys="):
                    try:
                        db_key_total += int(part.split("=", 1)[1])
                    except ValueError:
                        pass
    if db_key_total:
        metrics["keyspace_keys"] = db_key_total
    return metrics


def parse_redis_dbsize(stdout: str) -> int | None:
    for line in stdout.splitlines():
        try:
            return int(line.strip())
        except ValueError:
            continue
    return None


def scanner_redis_metrics(repo_root: Path) -> dict[str, Any]:
    metrics: dict[str, Any] = {}
    dbsize = scanner_redis_cli(repo_root, ["DBSIZE"])
    metrics["dbsize_status"] = "pass" if dbsize.returncode == 0 else "fail"
    metrics["dbsize"] = parse_redis_dbsize(dbsize.stdout) if dbsize.returncode == 0 else None
    if dbsize.returncode != 0:
        metrics["dbsize_output_tail"] = output_tail(dbsize.stdout + dbsize.stderr, 20)

    info = scanner_redis_cli(repo_root, ["INFO"])
    metrics["info_status"] = "pass" if info.returncode == 0 else "fail"
    if info.returncode == 0:
        metrics.update(parse_redis_info(info.stdout))
    else:
        metrics["info_output_tail"] = output_tail(info.stdout + info.stderr, 20)
    return metrics


def redis_runtime_probe(repo_root: Path) -> dict[str, Any]:
    details: dict[str, Any] = {
        "redis": {"running": container_running(repo_root, "redis")},
        "redis-openvas": {"running": container_running(repo_root, "redis-openvas"), "socket": str(scanner_redis_socket_path(repo_root))},
    }
    if details["redis"]["running"]:
        ping = exec_in_service(repo_root, "redis", ["redis-cli", "ping"])
        details["redis"].update({"ping_status": "pass" if ping.returncode == 0 and "PONG" in ping.stdout else "fail", "output_tail": output_tail(ping.stdout, 20)})
    if details["redis-openvas"]["running"]:
        ping = scanner_redis_ping(repo_root)
        details["redis-openvas"].update({"ping_status": "pass" if ping.returncode == 0 and "PONG" in ping.stdout else "fail", "output_tail": output_tail(ping.stdout, 20), "socket_exists": scanner_redis_socket_path(repo_root).is_socket()})
        if ping.returncode == 0 and "PONG" in ping.stdout:
            details["redis-openvas"]["metrics"] = scanner_redis_metrics(repo_root)
    return details


def command_runtime_redis_state(repo_root: Path) -> dict[str, Any]:
    references = redis_source_references(repo_root)
    reference_summary = summarize_redis_references(references)
    boundaries = redis_compose_boundaries(repo_root)
    runtime = redis_runtime_probe(repo_root)
    findings = [
        finding("pass", "redis.source-map", f"Classified {len(references)} Redis reference surface(s).", details=reference_summary),
        finding("warn" if boundaries["generic_redis_service_present"] else "pass", "redis.generic-boundary", "Generic Redis is still present in the development Compose file." if boundaries["generic_redis_service_present"] else "Generic Redis is absent from the development Compose file; scanner Redis remains the retained Redis boundary.", boundaries["compose_file"], boundaries),
        finding("pass" if boundaries["scanner_redis_no_tcp_port"] and boundaries["scanner_redis_unix_socket"] else "fail", "redis.scanner-boundary", "Scanner Redis is configured with no TCP port and a runtime Unix socket." if boundaries["scanner_redis_no_tcp_port"] and boundaries["scanner_redis_unix_socket"] else "Scanner Redis network/socket boundary is not as expected.", boundaries["compose_file"], boundaries),
    ]
    if runtime["redis"].get("running"):
        findings.append(finding("warn", "redis.runtime-ping", "Generic Redis container is still running as stale runtime state; remove the orphan container after Compose reconciliation.", details=runtime["redis"]))
    else:
        findings.append(finding("pass", "redis.runtime-ping", "Generic Redis container is not running, as expected.", details=runtime["redis"]))
    if runtime["redis-openvas"].get("running"):
        scanner_ready = runtime["redis-openvas"].get("ping_status") == "pass" and runtime["redis-openvas"].get("socket_exists") is True
        findings.append(finding("pass" if scanner_ready else "fail", "redis-openvas.runtime-ping", "Scanner Redis Unix socket responded to ping." if scanner_ready else "Scanner Redis Unix socket ping failed.", str(scanner_redis_socket_path(repo_root)), runtime["redis-openvas"]))
        scanner_metrics = runtime["redis-openvas"].get("metrics", {})
        metrics_ready = scanner_metrics.get("dbsize_status") == "pass" and scanner_metrics.get("info_status") == "pass"
        findings.append(finding("pass" if metrics_ready else "warn", "redis-openvas.runtime-metrics", "Scanner Redis metrics were collected without exposing key names or values." if metrics_ready else "Scanner Redis metrics could not be fully collected.", str(scanner_redis_socket_path(repo_root)), scanner_metrics))
    else:
        findings.append(finding("warn", "redis-openvas.runtime-ping", "Scanner Redis container is not running; runtime ping skipped.", str(scanner_redis_socket_path(repo_root)), runtime["redis-openvas"]))
    result = make_result("runtime-redis-state", repo_root, "Redis dependency and runtime boundary state collected.", findings)
    result["details"] = {"references": references, "reference_summary": reference_summary, "boundaries": boundaries, "runtime": runtime}
    return result


def command_path_coupling_state(repo_root: Path) -> dict[str, Any]:
    references = path_coupling_references(repo_root)
    summary = summarize_path_coupling(references)
    warning_paths = summary["non_documentation_dev_checkout_paths"]
