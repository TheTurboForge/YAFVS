def current_gsad_published_hosts(repo_root: Path) -> tuple[str, ...]:
    cid = container_id(repo_root, "gsad")
    if not cid:
        return ()
    result = run_command(["docker", "inspect", "-f", "{{json .NetworkSettings.Ports}}", cid], repo_root, env=runtime_env(repo_root))
    if result.returncode != 0 or not result.stdout.strip():
        return ()
    try:
        ports = json.loads(result.stdout)
    except json.JSONDecodeError:
        return ()
    bindings = ports.get(f"{GSAD_CONTAINER_PORT}/tcp") or []
    hosts: list[str] = []
    seen: set[str] = set()
    for binding in bindings:
        if not isinstance(binding, dict):
            continue
        host = str(binding.get("HostIp") or "").strip()
        port = str(binding.get("HostPort") or "").strip()
        if not host or port != GSAD_PORT or host in seen:
            continue
        hosts.append(host)
        seen.add(host)
    return tuple(hosts)


def current_native_api_direct_published_bindings(repo_root: Path) -> tuple[dict[str, str], ...]:
    cid = container_id(repo_root, "turbovas-api")
