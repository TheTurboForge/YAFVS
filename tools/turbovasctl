def json_int(value: Any) -> int:
    try:
        return int(value)
    except (TypeError, ValueError):
        return 0


def json_float(value: Any) -> float:
    try:
        return float(value)
    except (TypeError, ValueError):
        return 0.0


def native_result_threat(score: float) -> str:
    if score >= 9.0:
        return "Critical"
    if score >= 7.0:
        return "High"
    if score >= 4.0:
        return "Medium"
    if score > 0.0:
        return "Low"
    if score == 0.0:
        return "Log"
    if score == -1.0:
        return "False Positive"
    return "Unknown"


def runtime_report_summary_row(row: dict[str, Any]) -> dict[str, Any]:
    severity_score = json_float(row.get("severity"))
    return {
        "id": row.get("id"),
        "name": row.get("name"),
        "host": row.get("host"),
        "hostname": row.get("hostname"),
        "port": row.get("port"),
        "severity": str(row.get("severity", "")),
        "severity_score": severity_score,
        "threat": native_result_threat(severity_score),
        "qod": json_int(row.get("qod")),
        "nvt_oid": row.get("nvt_oid"),
        "nvt_name": row.get("name"),
        "nvt_family": row.get("nvt_family"),
        "description_excerpt": row.get("description_excerpt"),
    }


def runtime_report_summary_severity_counts(rows: list[dict[str, Any]]) -> dict[str, int]:
    counts = {bucket: 0 for bucket in ("Critical", "High", "Medium", "Low", "Log", "False Positive", "Unknown")}
    for row in rows:
        counts[native_result_threat(json_float(row.get("severity")))] += 1
    return counts


def runtime_report_summary_affected_hosts(rows: list[dict[str, Any]]) -> list[dict[str, Any]]:
    hosts: dict[str, dict[str, Any]] = {}
    for row in rows:
        host = str(row.get("host") or "unknown")
        current = hosts.setdefault(
            host,
            {
                "host": host,
                "hostnames": set(),
                "result_count": 0,
                "vulnerability_count": 0,
                "max_severity": 0.0,
                "threats": set(),
            },
        )
        current["result_count"] += 1
        severity_score = json_float(row.get("severity"))
        current["max_severity"] = max(current["max_severity"], severity_score)
        if severity_score > 0:
            current["vulnerability_count"] += 1
        hostname = row.get("hostname")
        if hostname:
            current["hostnames"].add(str(hostname))
        current["threats"].add(native_result_threat(severity_score))
    return sorted(
        [
            {
                "host": host["host"],
                "hostnames": sorted(host["hostnames"]),
                "result_count": host["result_count"],
                "vulnerability_count": host["vulnerability_count"],
                "max_severity": host["max_severity"],
                "threats": sorted(host["threats"]),
            }
            for host in hosts.values()
        ],
        key=lambda item: (-item["max_severity"], item["host"]),
    )


def native_report_results_pages(repo_root: Path, report_id: str, max_results: int) -> tuple[list[dict[str, Any]], int | None, subprocess.CompletedProcess[str] | None, dict[str, Any] | None]:
    rows: list[dict[str, Any]] = []
    total: int | None = None
    first_result: subprocess.CompletedProcess[str] | None = None
    first_parsed: dict[str, Any] | None = None
    page = 1
    while len(rows) < max_results:
        page_size = min(500, max_results - len(rows))
        if page_size <= 0:
            break
        path = f"/api/v1/reports/{urllib.parse.quote(report_id)}/results?page={page}&page_size={page_size}&sort=-severity"
        result = native_api_curl(repo_root, path)
        parsed = parse_json_output(result)
        if first_result is None:
            first_result = result
            first_parsed = parsed
        if result.returncode != 0 or not isinstance(parsed, dict):
            return rows, total, result, parsed
        items = parsed.get("items", [])
        page_info = parsed.get("page", {})
        if not isinstance(items, list) or not isinstance(page_info, dict):
            return rows, total, result, parsed
        total = json_int(page_info.get("total"))
        rows.extend(item for item in items if isinstance(item, dict))
        if len(rows) >= total or not items:
            break
        page += 1
    return rows, total, first_result, first_parsed


