def summarize_native_tooling(items: list[dict[str, Any]], repo_root: Path | None = None) -> dict[str, Any]:
    by_category: dict[str, dict[str, Any]] = {}
    for category in NATIVE_TOOLING_CATEGORIES:
        category_items = [item for item in items if item["category"] == category]
        by_category[category] = {"count": len(category_items), "paths": [item["path"] for item in category_items]}
    product_residue: dict[str, dict[str, Any]] = {}
    for kind in NATIVE_TOOLING_RESIDUE_KINDS:
        residue_items = [item for item in items if item.get("residue_kind") == kind]
        if residue_items:
            product_residue[kind] = {
                "count": len(residue_items),
                "paths": [item["path"] for item in residue_items],
                "reason": residue_items[0].get("residue_reason"),
            }
    removal_candidate_paths = sorted(
        {
            *by_category["candidate_for_removal"]["paths"],
            *(
                item["path"]
                for item in items
                if item["category"] == "product_workflow"
                and item["path"].startswith("components/gvm-tools/scripts/")
            ),
        }
    )
    return {
        "total_items": len(items),
        "by_category": by_category,
        "product_workflow_residue": product_residue,
        "candidate_for_removal_review": native_tooling_removal_review(removal_candidate_paths),
        "implemented_native_endpoints": [
