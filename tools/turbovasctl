def ensure_gsad_ports_override(repo_root: Path, env: dict[str, str] | None = None) -> Path | None:
    env = runtime_env(repo_root) if env is None else env
    hosts = gsad_hosts_from_env(env)
    if len(hosts) <= 1 and not env.get(GSAD_HOSTS_ENV):
        return None
    path = gsad_ports_override_file(repo_root)
    path.parent.mkdir(parents=True, exist_ok=True)
