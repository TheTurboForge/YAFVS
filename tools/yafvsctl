def artifact_slug(value: str, *, fallback: str = "run", max_length: int = 80) -> str:
    slug = re.sub(r"[^A-Za-z0-9_.-]+", "-", value.strip()).strip(".-").lower()
    return (slug[:max_length].strip(".-") or fallback)


def route_artifact_slug(routes: Iterable[str] | None) -> str:
    route_values = [route for route in routes or [] if str(route).strip()]
    if not route_values:
        return "all-routes"
    slugs = [artifact_slug(str(route), fallback="route", max_length=36) for route in route_values[:4]]
    if len(route_values) > len(slugs):
        slugs.append(f"plus-{len(route_values) - len(slugs)}")
    return "routes-" + "-".join(slugs)


