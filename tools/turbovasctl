                    "actual": values.get("x-turbovas-exposure"),
                    "allowed": sorted(OPENAPI_ALLOWED_EXPOSURE_VALUES),
                }
            )
        turbovas_contract_fields = fields & OPENAPI_ALLOWED_TURBOVAS_OPERATION_FIELDS
        if turbovas_contract_fields and "x-turbovas-exposure" not in fields:
            missing.append(
                {
                    "operation": openapi_operation_label(item),
                    "expected": sorted(OPENAPI_ALLOWED_EXPOSURE_VALUES),
                    "reason": "field_missing_for_turbovas_contract",
                }
            )
        if "x-turbovas-exposure" in fields:
            actual = values.get("x-turbovas-exposure")
            has_direct_marker = "x-turbovas-direct" in fields
            if actual in OPENAPI_DIRECT_EXPOSURE_VALUES and not has_direct_marker:
                mismatches.append(
                    {
                        "operation": openapi_operation_label(item),
                        "field": "x-turbovas-direct",
                        "actual": False,
                        "expected": True,
                    }
                )
            if actual == "internal-only" and has_direct_marker:
                mismatches.append(
                    {
                        "operation": openapi_operation_label(item),
                        "field": "x-turbovas-direct",
                        "actual": True,
                        "expected": False,
                    }
                )

    for key, expected in sorted(OPENAPI_REQUIRED_EXPOSURE.items()):
        item = by_key.get(key)
        operation = f"{key[0].upper()} {key[1]}"
        if item is None:
            missing.append({"operation": operation, "expected": expected, "reason": "operation_missing"})
            continue
        fields = set(item.get("x_turbovas_fields", [])) if isinstance(item.get("x_turbovas_fields"), list) else set()
        values = item.get("x_turbovas_values", {}) if isinstance(item.get("x_turbovas_values"), dict) else {}
        if "x-turbovas-exposure" not in fields:
            missing.append({"operation": operation, "expected": expected, "reason": "field_missing"})
            continue
        actual = values.get("x-turbovas-exposure")
        if actual != expected:
            mismatches.append(
                {
                    "operation": operation,
                    "field": "x-turbovas-exposure",
                    "actual": actual,
                    "expected": expected,
                }
            )
    return {
        "missing_exposure_operations": missing,
        "invalid_exposure_operations": invalid,
        "exposure_mismatches": mismatches,
    }


