def path_latest_mtime(path: Path, *, skip_dirs: frozenset[str] = frozenset(), skip_file: Callable[[Path], bool] | None = None) -> float | None:
    try:
        if path.is_file():
            if skip_file and skip_file(path):
                return None
            return path.stat().st_mtime
        if not path.is_dir():
            return None
    except OSError:
        return None
    latest: float | None = None
    for root, dirs, files in os.walk(path):
        dirs[:] = [dirname for dirname in dirs if dirname not in skip_dirs]
        root_path = Path(root)
        for filename in files:
            candidate = root_path / filename
            if skip_file and skip_file(candidate):
                continue
            try:
                mtime = candidate.stat().st_mtime
            except OSError:
                continue
            latest = mtime if latest is None else max(latest, mtime)
    return latest


def paths_latest_mtime(repo_root: Path, rel_paths: Iterable[str], *, skip_dirs: frozenset[str] = frozenset(), skip_file: Callable[[Path], bool] | None = None) -> tuple[float | None, str | None]:
    latest: float | None = None
    latest_path: str | None = None
    for rel_path in rel_paths:
        mtime = path_latest_mtime(repo_root / rel_path, skip_dirs=skip_dirs, skip_file=skip_file)
        if mtime is None:
            continue
        if latest is None or mtime > latest:
            latest = mtime
            latest_path = rel_path
    return latest, latest_path


def iso_mtime(mtime: float | None) -> str | None:
    return datetime.fromtimestamp(mtime, timezone.utc).replace(microsecond=0).isoformat() if mtime is not None else None


def parse_container_started_at(value: Any) -> float | None:
    if not isinstance(value, str) or not value:
        return None
    try:
        parsed = datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        return None
    return parsed.timestamp()


def qualified_table_name(schema: str, table: str) -> str:
    return f"{sql_identifier(schema)}.{sql_identifier(table)}"


def qualified_table_row_count(repo_root: Path, schema: str, table: str) -> int | None:
    result = psql(repo_root, f"SELECT count(*) FROM {qualified_table_name(schema, table)};")
    if result.returncode != 0:
        return None
    value = psql_value(result)
    try:
        return int(value)
    except ValueError:
        return None


def introspection_table_presence(repo_root: Path) -> tuple[subprocess.CompletedProcess[str], dict[str, bool]]:
    values = ",".join(f"({sql_literal(schema)}, {sql_literal(table)})" for schema, table in DB_INTROSPECT_TABLES)
    query = (
        f"WITH wanted(schema_name, table_name) AS (VALUES {values}) "
        "SELECT wanted.schema_name || '.' || wanted.table_name || '|' || (tables.table_name IS NOT NULL) "
        "FROM wanted LEFT JOIN information_schema.tables tables "
        "ON tables.table_schema = wanted.schema_name AND tables.table_name = wanted.table_name "
        "ORDER BY wanted.schema_name, wanted.table_name;"
    )
    result = psql(repo_root, query)
    rows: dict[str, bool] = {}
    if result.returncode == 0:
        for line in result.stdout.splitlines():
            if "|" not in line:
                continue
            name, value = line.strip().split("|", 1)
            rows[name] = value.strip().lower() in ("t", "true", "1")
    return result, rows


def introspection_table_columns(repo_root: Path, requests: Iterable[tuple[str, str]]) -> tuple[list[dict[str, Any]], list[dict[str, Any]]]:
    results: list[dict[str, Any]] = []
    findings: list[dict[str, Any]] = []
    for schema, table in requests:
        query = (
            "SELECT column_name || '|' || data_type || '|' || is_nullable "
            "FROM information_schema.columns "
            f"WHERE table_schema = {sql_literal(schema)} AND table_name = {sql_literal(table)} "
            "ORDER BY ordinal_position;"
        )
        result = psql(repo_root, query)
        key = f"{schema}.{table}"
        columns: list[dict[str, str]] = []
        if result.returncode == 0:
            for line in result.stdout.splitlines():
                parts = line.split("|", 2)
                if len(parts) != 3:
                    continue
                columns.append({"name": parts[0], "data_type": parts[1], "is_nullable": parts[2]})
            results.append({"table": key, "exists": bool(columns), "columns": columns})
            findings.append(finding("pass" if columns else "warn", "db-introspect.requested-columns", f"Column catalog captured for {key}." if columns else f"No columns found for {key}.", details={"table": key, "column_count": len(columns)}))
        else:
            results.append({"table": key, "exists": False, "columns": []})
            findings.append(finding("fail", "db-introspect.requested-columns", f"Column catalog query failed for {key}.", details={"table": key, "output_tail": output_tail(result.stdout, 80)}))
    return results, findings


