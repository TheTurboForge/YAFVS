    subparsers.add_parser("runtime-full-test-scan-preflight", parents=[common], help="preflight the fixed authorized full test scan")
    full_test_start = subparsers.add_parser("runtime-full-test-scan-start", parents=[common], help="start the fixed authorized full test scan")
    full_test_start.add_argument("--confirm-authorized-lan", action="store_true", help="confirm authorization for 192.168.178.0/24")
    subparsers.add_parser("runtime-full-test-scan-status", parents=[common], help="show the fixed authorized full test scan status")
