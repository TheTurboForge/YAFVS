def command_runtime_native_api_direct_write_smoke(repo_root: Path, status_only: bool = False) -> dict[str, Any]:
    try:
        with acquire_runtime_lock(repo_root, FEED_ACTIVATION_LOCK, "runtime-native-api-direct-write-smoke"):
            return _command_runtime_native_api_direct_write_smoke_unlocked(repo_root, status_only=status_only)
    except RuntimeLockTimeout as error:
        result = make_result(
            "runtime-native-api-direct-write-smoke",
            repo_root,
            "Direct write-control smoke stopped while waiting for the feed lifecycle lock.",
            [runtime_lock_timeout_finding(error, "feed-generation.activation-lock")],
            [str(runtime_lock_dir(repo_root))],
        )
        return direct_smoke_status_only_result(result) if status_only else result


