def rust_direct_api_segment_guard_summary(repo_root: Path | None) -> dict[str, Any]:
    source = rust_direct_api_source(repo_root)

    def guard_summary(name: str) -> dict[str, Any]:
        body = rust_source_function_body(source, name)
        return {
            "name": name,
            "present": bool(body),
            "rejects_empty": any(
                marker in body
                for marker in ("!part.is_empty()", "!segment.is_empty()", "!tail.is_empty()")
            ),
            "rejects_dot": '!= "."' in body,
            "rejects_dotdot": '!= ".."' in body,
        }

    guards = [
        guard_summary("direct_api_segments_are_nonempty"),
        guard_summary("direct_api_wildcard_tail_is_allowed"),
    ]
    missing = [
        {"guard": guard["name"], "property": property_name}
        for guard in guards
        for property_name in ("present", "rejects_empty", "rejects_dot", "rejects_dotdot")
        if not guard.get(property_name)
    ]
    return {
        "alignment_status": "pass" if not missing else "warn",
        "guards": guards,
        "missing_guard_properties": missing,
    }


