def ensure_postgres_collation(repo_root: Path, refresh_empty: bool = True) -> dict[str, Any]:
    result = psql(repo_root, "SELECT datcollversion || '|' || pg_database_collation_actual_version(oid) FROM pg_database WHERE datname = current_database();")
    if result.returncode != 0:
        return finding("fail", "postgres.collation", f"Collation version check exit code {result.returncode}.", details={"output_tail": result.stdout.splitlines()[-40:]})
    value = psql_value(result)
    if "|" not in value:
        return finding("warn", "postgres.collation", "Could not parse database collation version check.", details={"output_tail": result.stdout.splitlines()[-40:]})
    recorded, actual = value.split("|", 1)
    if recorded == actual:
        return finding("pass", "postgres.collation", f"Database collation version is current: {actual}.", details={"recorded": recorded, "actual": actual})

    count_result = psql(repo_root, "SELECT count(*) FROM pg_class WHERE relkind IN ('r','i','S','v','m') AND relnamespace NOT IN (SELECT oid FROM pg_namespace WHERE nspname LIKE 'pg_%' OR nspname = 'information_schema');")
    if count_result.returncode != 0:
        return finding("fail", "postgres.collation", f"Collation mismatch {recorded} != {actual}; relation-count check failed.", details={"output_tail": count_result.stdout.splitlines()[-40:]})
    relation_count = psql_value(count_result)
    if relation_count == "0" and refresh_empty:
        refresh = psql(repo_root, f"ALTER DATABASE {sql_identifier(postgres_database(repo_root))} REFRESH COLLATION VERSION;")
        return finding("pass" if refresh.returncode == 0 else "fail", "postgres.collation", f"Refreshed empty development database collation version from {recorded} to {actual}.", details={"recorded": recorded, "actual": actual, "relation_count": relation_count, "output_tail": refresh.stdout.splitlines()[-40:]})
    if relation_count == "0":
        return finding("warn", "postgres.collation", f"Database collation version mismatch {recorded} != {actual}; runtime-init can refresh this empty development database.", details={"recorded": recorded, "actual": actual, "relation_count": relation_count})
    return finding("warn", "postgres.collation", f"Database collation version mismatch {recorded} != {actual}; manual review required before refreshing a database with objects.", details={"recorded": recorded, "actual": actual, "relation_count": relation_count})


