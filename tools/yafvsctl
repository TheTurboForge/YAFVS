def _command_runtime_native_api_rebuild_unlocked(repo_root: Path) -> dict[str, Any]:
    findings = ensure_runtime_dirs(repo_root)
    findings.extend(ensure_build_runtime_dirs(repo_root))
    findings.append(active_feed_generation_finding(repo_root))
    app_env = runtime_native_api_rebuild_env(repo_root)
    config_command = compose_command(repo_root, "config", "--quiet", env=app_env)
    config = run_command(config_command, repo_root, env=app_env)
    findings.append(finding("pass" if config.returncode == 0 else "fail", "compose.config", f"Compose config validation exit code {config.returncode}.", str(compose_file(repo_root).relative_to(repo_root)), {"output_tail": output_tail(config.stdout, 40)}))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-native-api-rebuild", repo_root, "Native API rebuild stopped at prerequisites.", findings, [str(runtime_dir(repo_root))])
    receipt, receipt_error = require_app_deployment_receipt(
        repo_root, app_env=app_env
    )
    findings.append(
        finding(
            "pass" if receipt_error is None else "fail",
            "runtime.app-deployment-receipt",
            "Prepared application deployment receipt is valid before the API-only rebuild."
            if receipt_error is None
            else receipt_error,
            str(app_deployment_receipt_path(repo_root)),
        )
    )
    if receipt_error is not None or receipt is None:
        return make_result("runtime-native-api-rebuild", repo_root, "Native API rebuild stopped because no verified application deployment was prepared.", findings, [str(runtime_dir(repo_root))])

    build_command = compose_command(repo_root, "build", "yafvs-api", env=app_env)
    build = run_command(build_command, repo_root, env=app_env, timeout=1200)
    findings.append(process_step_finding("pass" if build.returncode == 0 else "fail", "compose.yafvs-api-build", f"docker compose build yafvs-api exit code {build.returncode}.", build, build_command))
    if build.returncode != 0:
        return make_result("runtime-native-api-rebuild", repo_root, "Native API rebuild stopped because image build failed.", findings, [str(runtime_dir(repo_root))])
    receipt, receipt_error = refresh_app_deployment_receipt_after_image_build(
        repo_root, receipt, ("yafvs-api",), app_env=app_env
    )
    findings.append(
        finding(
            "pass" if receipt_error is None else "fail",
            "runtime.app-deployment-receipt-refresh",
            "Prepared application deployment receipt now identifies the rebuilt native API image."
            if receipt_error is None
            else receipt_error,
            str(app_deployment_receipt_path(repo_root)),
        )
    )
    if receipt_error is not None or receipt is None:
        return make_result("runtime-native-api-rebuild", repo_root, "Native API rebuild stopped because the deployment receipt could not be refreshed.", findings, [str(runtime_dir(repo_root))])
    app_image_ids = receipt["image_ids"]

    up_command = compose_command_with_app_images(repo_root, app_image_ids, "--profile", "app", "up", "-d", "--no-deps", "--force-recreate", "--no-build", "--pull", "never", "yafvs-api", env=app_env)
    up = run_command(up_command, repo_root, env=app_env, timeout=300)
    findings.append(process_step_finding("pass" if up.returncode == 0 else "fail", "compose.yafvs-api-up", f"docker compose up --no-deps yafvs-api exit code {up.returncode}.", up, up_command))
    if up.returncode != 0:
        return make_result("runtime-native-api-rebuild", repo_root, "Native API rebuild stopped because yafvs-api restart failed.", findings, [str(runtime_dir(repo_root))])

    smoke = command_runtime_native_api_smoke(repo_root)
    findings.append(finding(smoke["status"], "native-api.smoke", smoke["summary"], details={"status": smoke["status"], "artifacts": smoke.get("artifacts", [])}))
    artifacts = sorted(set([str(runtime_dir(repo_root)), *smoke.get("artifacts", [])]))
    return make_result("runtime-native-api-rebuild", repo_root, "Native API sidecar rebuild attempted.", findings, artifacts)


