def parse_process_table(output: str) -> list[dict[str, str]]:
    processes: list[dict[str, str]] = []
    for line in output.splitlines()[1:]:
        stripped = line.strip()
        if not stripped:
            continue
        parts = stripped.split(None, 4)
        if len(parts) < 4:
            continue
        pid, ppid, stat, comm = parts[:4]
        args = parts[4] if len(parts) > 4 else comm
        processes.append({"pid": pid, "ppid": ppid, "stat": stat, "comm": comm, "args": args})
    return processes


def process_is_zombie(process: dict[str, str]) -> bool:
    return "Z" in process.get("stat", "")


def process_is_active_scanner_child(process: dict[str, str]) -> bool:
    if process_is_zombie(process):
        return False
    comm = process.get("comm", "")
    return comm in {"openvas", "nmap"}


def summarize_scanner_processes(output: str) -> dict[str, Any]:
    processes = parse_process_table(output)
    zombies = [process for process in processes if process_is_zombie(process)]
    active_children = [process for process in processes if process_is_active_scanner_child(process)]
    return {
        "process_count": len(processes),
        "zombie_count": len(zombies),
        "active_scanner_child_count": len(active_children),
        "zombies": zombies[:50],
        "active_scanner_children": active_children[:50],
    }


def output_tail(output: str, lines: int = 80, secrets_to_redact: Iterable[str] = ()) -> list[str]:
