            <modification_time>2013-01-11T16:03:24+01:00</modification_time>
            <writable>1</writable>
            <in_use>0</in_use>
            <owner>
              <name>admin</name>
            </owner>
            <alterable>0</alterable>
            <config id="daba56c8-73ec-11df-a475-002264764cea">
              <name>Full and fast</name>
            </config>
            <target id="1f28d970-17ef-4c69-ba8a-13827059f2b9">
