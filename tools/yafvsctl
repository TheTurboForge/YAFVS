def parse_json_output(result: subprocess.CompletedProcess[str]) -> dict[str, Any] | None:
    try:
        parsed = json.loads(result.stdout)
    except json.JSONDecodeError:
        return None
    return parsed if isinstance(parsed, dict) else None


def summarize_native_item(item: Any) -> dict[str, Any]:
    if not isinstance(item, dict):
        return {"type": type(item).__name__}
    keys = (
        "id",
        "name",
        "type",
        "version",
        "status",
        "sync_status",
        "host",
        "port",
        "nvt_oid",
        "severity",
        "max_severity",
        "result_count",
        "vulnerability_count",
        "affected_system_count",
        "source_report_count",
        "created_at",
        "creation_time",
    )
    summary = {key: item[key] for key in keys if key in item}
    scope = item.get("scope")
    if isinstance(scope, dict):
        summary["scope"] = {key: scope[key] for key in ("id", "name") if key in scope}
    return summary


def alert_type_value(item: dict[str, Any], flat_key: str, nested_key: str) -> str | None:
    value = item.get(flat_key)
    if isinstance(value, str):
        return value
    nested = item.get(nested_key)
    if isinstance(nested, dict) and isinstance(nested.get("type"), str):
        return nested["type"]
    return None


def summarize_native_alert_item(item: Any) -> dict[str, Any]:
    if not isinstance(item, dict):
        return {"type": type(item).__name__}
    summary = {key: item[key] for key in ("id", "name") if key in item}
    for flat_key, nested_key in (
        ("event_type", "event"),
        ("condition_type", "condition"),
        ("method_type", "method"),
    ):
        value = alert_type_value(item, flat_key, nested_key)
        if value is not None:
            summary[flat_key] = value
    return summary


def summarize_native_alerts_response(parsed: dict[str, Any] | None) -> dict[str, Any]:
    if not isinstance(parsed, dict):
        return {"parsed": False}
    summary: dict[str, Any] = {"parsed": True}
    if isinstance(parsed.get("page"), dict):
        summary["page"] = parsed["page"]
    items = parsed.get("items")
    if isinstance(items, list):
        summary["item_count_in_response"] = len(items)
        summary["items_sample"] = [summarize_native_alert_item(item) for item in items[:3]]
    return summary


def summarize_native_alert_detail_response(parsed: dict[str, Any] | None) -> dict[str, Any]:
    if not isinstance(parsed, dict):
        return {"parsed": False}
    summary = summarize_native_alert_item(parsed)
    summary["parsed"] = True
    error = parsed.get("error")
    if isinstance(error, dict) and isinstance(error.get("code"), str):
        summary["error_code"] = error["code"]
    tasks = parsed.get("tasks")
    if isinstance(tasks, list):
        summary["task_count_in_response"] = len(tasks)
    return summary


def forbidden_alert_payload_keys(value: Any) -> list[str]:
    found: list[str] = []
    if isinstance(value, dict):
        for key, nested in value.items():
            if key in ALERT_FORBIDDEN_PAYLOAD_KEYS:
                found.append(key)
            found.extend(forbidden_alert_payload_keys(nested))
    elif isinstance(value, list):
        for item in value:
            found.extend(forbidden_alert_payload_keys(item))
    return found


def alert_metadata_item_ok(item: Any) -> bool:
    if not isinstance(item, dict):
        return False
    if set(item) - ALERT_ALLOWED_PAYLOAD_KEYS:
        return False
    if forbidden_alert_payload_keys(item):
        return False
    if item.get("method_data_redacted") is not True:
        return False
    owner_id = item.get("owner_id")
    if owner_id is not None and not (
        isinstance(owner_id, str) and UUID_VALUE_RE.fullmatch(owner_id)
    ):
        return False
    owner = item.get("owner")
    if owner is not None and not (isinstance(owner, str) or (isinstance(owner, dict) and set(owner) <= {"name"})):
        return False
    alert_filter = item.get("filter")
    if alert_filter is not None and not (isinstance(alert_filter, dict) and set(alert_filter) <= {"id", "name"}):
        return False
    tasks = item.get("tasks")
    if tasks is not None and not (
        isinstance(tasks, list)
        and all(isinstance(task, dict) and set(task) <= {"id", "name"} for task in tasks)
    ):
        return False
    for nested_key in ("event", "condition", "method"):
        nested = item.get(nested_key)
        if nested is not None and not (isinstance(nested, dict) and set(nested) <= {"type"}):
            return False
    return True


def summarize_native_api_response(parsed: dict[str, Any] | None) -> dict[str, Any]:
    if not isinstance(parsed, dict):
        return {"parsed": False}
    summary: dict[str, Any] = {"parsed": True}
    for key in ("status", "database", "id"):
        if key in parsed:
            summary[key] = parsed[key]
    if isinstance(parsed.get("page"), dict):
        summary["page"] = parsed["page"]
    if isinstance(parsed.get("summary"), dict):
        summary["summary"] = parsed["summary"]
    if isinstance(parsed.get("policy"), dict):
        summary["policy"] = parsed["policy"]
    error = parsed.get("error")
    if isinstance(error, dict):
        summary["error"] = {key: error[key] for key in ("code", "message") if isinstance(error.get(key), str)}
    items = parsed.get("items")
    if isinstance(items, list):
        summary["item_count_in_response"] = len(items)
        summary["items_sample"] = [summarize_native_item(item) for item in items[:3]]
    sources = parsed.get("sources")
    if isinstance(sources, list):
        summary["source_count"] = len(sources)
        summary["sources_sample"] = [summarize_native_item(item) for item in sources[:3]]
    for key in ("systems", "vulnerabilities"):
        values = parsed.get(key)
        if isinstance(values, list):
            summary[f"{key}_count"] = len(values)
            summary[f"{key}_sample"] = [summarize_native_item(item) for item in values[:3]]
    return summary


def compact_text_tail(output: str, max_chars: int = 1200) -> str:
    stripped = output.strip()
    if len(stripped) <= max_chars:
        return stripped
    return f"{stripped[:max_chars]}...<truncated {len(stripped) - max_chars} chars>"


def native_api_probe_finding(
    status: str,
    check: str,
    message: str,
    result: subprocess.CompletedProcess[str],
    command: list[str],
    parsed: dict[str, Any] | None,
    response_summary: dict[str, Any] | None = None,
) -> dict[str, Any]:
    details: dict[str, Any] = {
        "exit_code": result.returncode,
        "command": " ".join(shlex.quote(part) for part in command),
        "response_summary": response_summary if response_summary is not None else summarize_native_api_response(parsed),
    }
    if parsed is None and result.stdout:
        details["stdout_tail"] = compact_text_tail(result.stdout)
    if result.stderr:
        details["stderr_tail"] = compact_text_tail(result.stderr)
    return finding(status, check, message, details=details)


def native_api_oversized_filter_path(repo_root: Path, base_path: str) -> tuple[str, int]:
    max_filter_length = rust_collection_contract_constants(repo_root).get("max_filter_length")
    if not isinstance(max_filter_length, int) or max_filter_length < 0:
        max_filter_length = 4096
    oversized_filter = "x" * (max_filter_length + 1)
    separator = "&" if "?" in base_path else "?"
    return f"{base_path}{separator}filter={urllib.parse.quote(oversized_filter, safe='')}", len(
        oversized_filter
    )


def native_api_expected_bad_request_finding(
    repo_root: Path,
    check: str,
    path: str,
    expected_code: str,
    display_path: str | None = None,
    extra_summary: dict[str, Any] | None = None,
) -> dict[str, Any]:
    result = native_api_curl_with_http_status(repo_root, path)
    parsed, http_status = parse_json_output_with_http_status(result)
    actual_code = parsed.get("error", {}).get("code") if isinstance(parsed, dict) else None
    ok = result.returncode == 0 and http_status == 400 and actual_code == expected_code
    display_path = display_path or path
    summary = {"http_status": http_status, "error_code": actual_code, **summarize_native_api_response(parsed)}
    if extra_summary:
        summary.update(extra_summary)
    return native_api_probe_finding(
        "pass" if ok else "fail",
        check,
        f"Native API rejected {display_path} with JSON 400 {expected_code}."
        if ok
        else f"Native API did not reject {display_path} with JSON 400 {expected_code}.",
        result,
        compose_command(
            repo_root,
            "exec",
            "-T",
            "yafvs-api",
            "curl",
            "-sS",
            "--max-time",
            "10",
            "-w",
            "\\n%{http_code}",
            f"http://127.0.0.1:{YAFVS_API_CONTAINER_PORT}{display_path}",
        ),
        parsed,
        summary,
    )


def native_api_smoke_status_only_result(result: dict[str, Any]) -> dict[str, Any]:
    compact = dict(result)
    findings = result.get("findings", [])
    non_pass = [compact_doctor_finding(item) for item in findings if item.get("status") != "pass"]
    details = result.get("details", {}) if isinstance(result.get("details"), dict) else {}
    checks = {
        item.get("check"): item.get("status")
        for item in findings
        if isinstance(item, dict) and item.get("check")
    }
    important_checks = {
        check: status
        for check, status in checks.items()
        if status != "pass" or check in {"native-api.running", "native-api.healthz"}
    }
    compact["details"] = {
        "service": details.get("service"),
        "finding_count": len(findings),
        "non_pass_count": len(non_pass),
        "artifact_count": len(result.get("artifacts", [])) if isinstance(result.get("artifacts"), list) else 0,
        "important_checks": important_checks,
    }
    compact["findings"] = non_pass or [
        finding("pass", "runtime-native-api-smoke.status-only", "runtime-native-api-smoke passed; no non-pass findings.")
    ]
    return compact


