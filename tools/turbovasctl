    state["container_id"] = cid
    return state


def table_presence_rows(repo_root: Path, tables: tuple[str, ...]) -> tuple[subprocess.CompletedProcess[str], dict[str, bool]]:
    values = ",".join(f"({sql_literal(table)})" for table in tables)
    query = f"WITH wanted(name) AS (VALUES {values}) SELECT name || '|' || (to_regclass('public.' || quote_ident(name)) IS NOT NULL) FROM wanted ORDER BY name;"
    result = psql(repo_root, query)
    rows: dict[str, bool] = {}
    if result.returncode == 0:
        for line in result.stdout.splitlines():
            if "|" not in line:
