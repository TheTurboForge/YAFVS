    )


def command_feed_cache_sync(repo_root: Path) -> dict[str, Any]:
    findings = ensure_runtime_dirs(repo_root)
    binary = feed_sync_binary(repo_root)
    findings.append(finding("pass" if binary.is_file() else "fail", "feed-sync.available", "greenbone-feed-sync venv command is available." if binary.is_file() else "greenbone-feed-sync venv command is missing; run just build-python or just build-baseline.", str(binary)))
    findings.append(finding("pass" if shutil.which("rsync") else "fail", "rsync.available", "rsync is available." if shutil.which("rsync") else "rsync is missing."))
    findings.append(finding("pass" if shutil.which("tmux") else "fail", "tmux.available", "tmux is available." if shutil.which("tmux") else "tmux is missing."))
    if aggregate_status(findings) == "fail":
        return make_result("feed-cache-sync", repo_root, "Feed cache sync stopped at prerequisites.", findings, [str(feed_cache_var_lib(repo_root))])

    selftest = run_command(feed_sync_command(repo_root, selftest=True), repo_root, env=build_env(repo_root), timeout=120)
    findings.append(finding("pass" if selftest.returncode == 0 else "fail", "feed-sync.selftest", f"greenbone-feed-sync selftest exit code {selftest.returncode}.", details={"output_tail": output_tail(selftest.stdout, 80)}))
    if selftest.returncode != 0:
        return make_result("feed-cache-sync", repo_root, "Feed cache sync stopped at greenbone-feed-sync selftest.", findings, [str(feed_cache_var_lib(repo_root))])

    session_check = run_command(["tmux", "has-session", "-t", FEED_SYNC_SESSION], repo_root)
    if session_check.returncode == 0:
        findings.append(finding("warn", "feed-sync.session", f"tmux session {FEED_SYNC_SESSION} is already running; not starting another sync.", details={"session": FEED_SYNC_SESSION}))
        return make_result("feed-cache-sync", repo_root, "Feed cache sync is already running.", findings, [str(feed_cache_var_lib(repo_root))])

    feed_sync_log_dir(repo_root).mkdir(parents=True, exist_ok=True)
    timestamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    log_path = feed_sync_log_dir(repo_root) / f"community-{FEED_RELEASE}-{timestamp}.log"
    sync_command = feed_sync_command(repo_root)
    sync_line = " ".join(shlex.quote(part) for part in sync_command)
    inner_command = (
        f"cd {shlex.quote(str(repo_root))} && "
        "set -o pipefail && "
        f"{{ printf '%s\\n' 'TurboVAS feed cache sync started at {timestamp}'; "
        f"{sync_line}; "
        "status=$?; "
        "printf '%s\\n' \"TurboVAS feed cache sync exited with status $status\"; "
        "exit $status; "
        f"}} 2>&1 | tee -a {shlex.quote(str(log_path))}"
    )
    shell_command = f"bash -lc {shlex.quote(inner_command)}"
    start = run_command(["tmux", "new-session", "-d", "-s", FEED_SYNC_SESSION, shell_command], repo_root)
    findings.append(finding("pass" if start.returncode == 0 else "fail", "feed-sync.session-start", f"Start tmux feed sync session exit code {start.returncode}.", details={"session": FEED_SYNC_SESSION, "log_path": str(log_path), "output_tail": output_tail(start.stdout, 80)}))
    return make_result("feed-cache-sync", repo_root, "Feed cache sync session start attempted.", findings, [str(feed_cache_var_lib(repo_root)), str(log_path)])


def command_feed_copy_to_runtime(repo_root: Path) -> dict[str, Any]:
    findings = ensure_runtime_dirs(repo_root)
    findings.append(finding("pass" if shutil.which("rsync") else "fail", "rsync.available", "rsync is available." if shutil.which("rsync") else "rsync is missing."))
    if aggregate_status(findings) == "fail":
        return make_result("feed-copy-to-runtime", repo_root, "Feed copy stopped at prerequisites.", findings, [str(feed_runtime_root(repo_root))])

    for feed_class, source, _destination in feed_copy_pairs(repo_root):
        summary = feed_path_summary(source, feed_class.markers)
        marker_missing = [row["path"] for row in summary["markers"] if not row["exists"]]
        if not summary["exists"] or summary["file_count"] == 0:
            findings.append(finding("fail", f"feed.cache.{feed_class.key}", f"{feed_class.label} cache is missing or empty; refusing to copy an incomplete feed cache.", str(source), {"summary": summary}))
        elif marker_missing:
            findings.append(finding("warn", f"feed.cache.{feed_class.key}", f"{feed_class.label} cache has files but expected markers are missing.", str(source), {"summary": summary, "missing_markers": marker_missing}))
        else:
            findings.append(finding("pass", f"feed.cache.{feed_class.key}", f"{feed_class.label} cache is ready to copy.", str(source), {"summary": summary}))
    if aggregate_status(findings) == "fail":
        return make_result("feed-copy-to-runtime", repo_root, "Feed copy stopped because the cache is incomplete.", findings, [str(feed_cache_var_lib(repo_root)), str(feed_runtime_root(repo_root))])

    for feed_class, source, destination in feed_copy_pairs(repo_root):
        destination.parent.mkdir(parents=True, exist_ok=True)
        copy = run_command(["rsync", "-a", "--delete", f"{source}/", f"{destination}/"], repo_root, timeout=3600)
        findings.append(finding("pass" if copy.returncode == 0 else "fail", f"feed.copy.{feed_class.key}", f"Copy {feed_class.label} to runtime exit code {copy.returncode}.", details={"source": str(source), "destination": str(destination), "output_tail": output_tail(copy.stdout, 80)}))
        if copy.returncode != 0:
            break
    findings.extend(feed_location_findings(repo_root, "runtime", feed_runtime_root(repo_root), "runtime_rel"))
    return make_result("feed-copy-to-runtime", repo_root, "Feed cache copy to runtime attempted.", findings, [str(feed_cache_var_lib(repo_root)), str(feed_runtime_root(repo_root))])


def command_runtime_app_up(repo_root: Path) -> dict[str, Any]:
    findings = ensure_runtime_dirs(repo_root)
    findings.extend(ensure_build_runtime_dirs(repo_root))
    config = run_command(compose_command(repo_root, "config", "--quiet"), repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if config.returncode == 0 else "fail", "compose.config", f"Compose config validation exit code {config.returncode}.", str(compose_file(repo_root).relative_to(repo_root)), {"output_tail": output_tail(config.stdout, 40)}))
    infra = command_up(repo_root)
    findings.append(finding(infra["status"], "runtime.infrastructure", infra["summary"], details={"status": infra["status"]}))
    db_init = command_runtime_init(repo_root)
    findings.append(finding(db_init["status"], "runtime.database-init", db_init["summary"], details={"status": db_init["status"]}))
    scanner_redis = command_runtime_scanner_redis_init(repo_root, probe_openvas=False)
    findings.append(finding(scanner_redis["status"], "runtime.scanner-redis", scanner_redis["summary"], details={"status": scanner_redis["status"]}))
    keyring = command_runtime_feed_keyring_init(repo_root)
    findings.append(finding(keyring["status"], "runtime.feed-keyring", keyring["summary"], details={"status": keyring["status"]}))
    cert_findings = cert_file_findings(repo_root)
    if not certs_complete(repo_root):
        cert_findings = [dict(item, status="fail") for item in cert_findings]
    findings.extend(cert_findings)
    findings.extend(stage_gsa_static(repo_root))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-app-up", repo_root, "Application runtime startup stopped at prerequisites.", findings, [str(runtime_dir(repo_root))])

    result = run_command(compose_command(repo_root, "--profile", "app", "up", "-d", "--no-deps", "--build", *APP_SERVICES), repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if result.returncode == 0 else "fail", "compose.app-up", f"docker compose app up exit code {result.returncode}.", details={"output_tail": output_tail(result.stdout, 120)}))
    for service in APP_SERVICES:
        running = container_running(repo_root, service)
        findings.append(finding("pass" if running else "warn", "runtime.app.running", f"{service} container is {'running' if running else 'not running'}.", details={"service": service, "logs_tail": [] if running else service_log_tail(repo_root, service)}))
    return make_result("runtime-app-up", repo_root, "Application runtime startup attempted.", findings, [str(runtime_dir(repo_root))])


def command_runtime_app_down(repo_root: Path) -> dict[str, Any]:
    stop = run_command(compose_command(repo_root, "--profile", "app", "stop", *APP_SERVICES), repo_root, env=runtime_env(repo_root))
    remove = run_command(compose_command(repo_root, "--profile", "app", "rm", "-f", *APP_SERVICES), repo_root, env=runtime_env(repo_root))
    findings = [
        finding("pass" if stop.returncode == 0 else "fail", "compose.app-stop", f"docker compose app stop exit code {stop.returncode}.", details={"output_tail": output_tail(stop.stdout, 80)}),
        finding("pass" if remove.returncode == 0 else "fail", "compose.app-rm", f"docker compose app rm exit code {remove.returncode}.", details={"output_tail": output_tail(remove.stdout, 80)}),
    ]
    return make_result("runtime-app-down", repo_root, "Application runtime shutdown attempted.", findings, [str(runtime_dir(repo_root))])


def command_runtime_app_smoke(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    findings.extend(command_feed_state(repo_root)["findings"])
    findings.extend(cert_file_findings(repo_root))
    if not certs_complete(repo_root):
        findings.append(finding("fail", "runtime.cert.complete", "Runtime certificates are incomplete; run just runtime-certs-init."))
    findings.append(pg_gvm_extension_status(repo_root))
    secret_path = runtime_secret_path(repo_root, DEV_ADMIN_SECRET)
    findings.append(finding("pass" if secret_path.is_file() else "warn", "runtime.admin-secret", "Development admin secret exists." if secret_path.is_file() else "Development admin secret is missing; run just runtime-manager-init.", str(secret_path)))

    password = secret_path.read_text(encoding="utf-8").strip() if secret_path.is_file() else ""
    if feed_gnupg_home(repo_root).is_dir() and shutil.which("gpg"):
        fingerprint = run_command(gpg_command(repo_root, "--with-colons", "--fingerprint", GREENBONE_COMMUNITY_KEY_FPR), repo_root, timeout=60)
        fingerprint_ok = fingerprint.returncode == 0 and GREENBONE_COMMUNITY_KEY_FPR in fingerprint.stdout.replace(" ", "").upper()
        findings.append(finding("pass" if fingerprint_ok else "fail", "feed-keyring.fingerprint", "Shared feed signature keyring contains the Greenbone Community signing key." if fingerprint_ok else "Shared feed signature keyring is missing the Greenbone Community signing key.", str(feed_gnupg_home(repo_root)), {"fingerprint": GREENBONE_COMMUNITY_KEY_FPR, "output_tail": output_tail(fingerprint.stdout, 60)}))
    else:
        findings.append(finding("fail", "feed-keyring.fingerprint", "Shared feed signature keyring is not initialized; run just runtime-feed-keyring-init.", str(feed_gnupg_home(repo_root))))
    for service in APP_SERVICES:
        running = container_running(repo_root, service)
        findings.append(finding("pass" if running else "warn", "runtime.app.running", f"{service} container is {'running' if running else 'not running'}.", details={"service": service, "logs_tail": [] if running else service_log_tail(repo_root, service)}))

    gvmd_socket = gvmd_socket_path(repo_root)
    gvmd_ready = wait_for_socket(gvmd_socket)
    findings.append(finding("pass" if gvmd_ready else "warn", "gvmd.socket", f"gvmd socket {'is ready' if gvmd_ready else 'is not ready'}.", str(gvmd_socket)))
    if gvmd_ready and password:
        gmp = command_runtime_gmp_smoke(repo_root)
        findings.append(finding(gmp["status"], "gvmd.gmp", gmp["summary"], details={"status": gmp["status"]}))

    ospd_socket = ospd_socket_path(repo_root)
    ospd_ready = wait_for_socket(ospd_socket, timeout_seconds=5)
    findings.append(finding("pass" if ospd_ready else "warn", "ospd.socket", f"ospd-openvas socket {'is ready' if ospd_ready else 'is not ready'}.", str(ospd_socket)))
    if container_running(repo_root, "ospd-openvas"):
        capability = command_runtime_scanner_capability_check(repo_root)
        findings.append(finding(capability["status"], "ospd.capability-check", capability["summary"], details={"status": capability["status"], "findings": capability["findings"]}))
        process_check = command_runtime_scanner_process_check(repo_root)
        findings.append(finding(process_check["status"], "ospd.process-check", process_check["summary"], details={"status": process_check["status"], "findings": process_check["findings"]}))
        nmap_capability = command_runtime_nmap_capability_check(repo_root)
        findings.append(finding(nmap_capability["status"], "nmap.capability-check", nmap_capability["summary"], details={"status": nmap_capability["status"], "findings": nmap_capability["findings"]}))
        ospd_logs = service_log_tail(repo_root, "ospd-openvas", lines=120)
        ospd_errors = [line for line in ospd_logs if "ERROR" in line]
        ospd_feed_errors = feed_signature_log_errors(ospd_logs)
        known_feed_gap = any("failed to load VTs" in line or "Updating VTs failed" in line for line in ospd_errors)
        if ospd_errors:
            message = "ospd-openvas logs contain errors; current known blocker is missing feed/plugin cache." if known_feed_gap else "ospd-openvas logs contain errors that require investigation."
            findings.append(finding("warn", "ospd.logs", message, details={"known_deferred_feed_state": known_feed_gap, "error_tail": ospd_errors[-20:]}))
        else:
            findings.append(finding("pass", "ospd.logs", "ospd-openvas logs contain no ERROR lines in the inspected tail."))
        findings.append(finding("fail" if ospd_feed_errors else "pass", "ospd.feed-signature-logs", "ospd-openvas logs contain feed signature or Notus advisory load errors." if ospd_feed_errors else "ospd-openvas logs contain no feed signature or Notus advisory load errors in the inspected tail.", details={"error_tail": ospd_feed_errors[-20:]}))
        vt_status, vt_lines = ospd_vt_load_status_from_logs(ospd_logs)
        findings.append(
            finding(
                {"pass": "pass", "fail": "fail", "wait": "warn"}[vt_status],
                "ospd.vt-load",
                "ospd-openvas reports VTs are loaded." if vt_status == "pass" else "ospd-openvas VT loading failed." if vt_status == "fail" else "ospd-openvas is still loading VTs.",
                details={"status": vt_status, "log_lines": vt_lines[-20:]},
            )
        )
    if container_running(repo_root, "notus-scanner"):
        notus_logs = service_log_tail(repo_root, "notus-scanner", lines=120)
        notus_file_logs = runtime_file_tail(runtime_path(repo_root, "logs", "notus", "notus-scanner.log"), lines=120)
        notus_errors = [line for line in [*notus_logs, *notus_file_logs] if "ERROR" in line or "CRITICAL" in line]
        notus_feed_errors = feed_signature_log_errors([*notus_logs, *notus_file_logs])
        findings.append(finding("fail" if notus_errors else "pass", "notus.logs", "notus-scanner logs contain ERROR/CRITICAL lines." if notus_errors else "notus-scanner logs contain no ERROR/CRITICAL lines in the inspected tail.", details={"error_tail": notus_errors[-20:]}))
        findings.append(finding("fail" if notus_feed_errors else "pass", "notus.feed-signature-logs", "notus-scanner logs contain GPG, signature, or advisory-load errors." if notus_feed_errors else "notus-scanner logs contain no GPG, signature, or advisory-load errors in the inspected tail.", details={"error_tail": notus_feed_errors[-20:]}))
    if ospd_ready:
        scanners = run_gvmd_oneoff(repo_root, ["--get-scanners"], no_deps=False)
        findings.append(finding("pass" if scanners.returncode == 0 else "warn", "gvmd.scanners", f"gvmd --get-scanners exit code {scanners.returncode}.", details={"output_tail": output_tail(scanners.stdout, 80, [password])}))
        findings.append(scanner_registration_status(repo_root))

    for base_url in gsad_base_urls(repo_root):
        gsad_http = run_command(["curl", "-kIsS", "--max-time", "10", f"{base_url}/"], repo_root, env=runtime_env(repo_root))
        findings.append(finding("pass" if gsad_http.returncode == 0 else "warn", "gsad.https", f"Configured HTTPS header probe exit code {gsad_http.returncode}.", details={"url": f"{base_url}/", "output_tail": output_tail(gsad_http.stdout, 80, [password])}))
    return make_result("runtime-app-smoke", repo_root, "Application runtime smoke checks completed.", findings, [str(runtime_dir(repo_root))])


def command_runtime_webui_smoke(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    static_dir = gsad_static_dir(repo_root)
    index_path = static_dir / "index.html"
    config_path = static_dir / "config.js"
    findings.append(finding("pass" if index_path.is_file() else "fail", "webui.static-index", "Staged GSA index.html exists." if index_path.is_file() else "Staged GSA index.html is missing; run just build-ui.", str(index_path)))
    findings.append(finding("pass" if config_path.is_file() else "fail", "webui.static-config", "Staged GSA config.js exists." if config_path.is_file() else "Staged GSA config.js is missing; run just build-ui.", str(config_path)))

    index_text = index_path.read_text(encoding="utf-8") if index_path.is_file() else ""
    asset_rel = first_gsa_asset_rel(index_text)
    findings.append(finding("pass" if asset_rel else "fail", "webui.static-asset-ref", f"Found GSA asset reference {asset_rel}." if asset_rel else "No GSA asset reference found in index.html.", str(index_path)))

    for base_url in gsad_base_urls(repo_root):
        index_http = run_command(["curl", "-kfsS", "--max-time", "10", f"{base_url}/"], repo_root, env=runtime_env(repo_root))
        findings.append(finding("pass" if index_http.returncode == 0 and '<div id="app">' in index_http.stdout else "fail", "webui.http-index", f"GSA index HTTP probe exit code {index_http.returncode}.", details={"url": f"{base_url}/", "output_tail": output_tail(index_http.stdout, 40)}))

        config_http = run_command(["curl", "-kfsS", "--max-time", "10", f"{base_url}/config.js"], repo_root, env=runtime_env(repo_root))
        expected_api_server = "apiServer: window.location.host"
        findings.append(finding("pass" if config_http.returncode == 0 and expected_api_server in config_http.stdout else "fail", "webui.http-config", f"GSA config.js HTTP probe exit code {config_http.returncode}.", details={"url": f"{base_url}/config.js", "expected": expected_api_server, "output_tail": output_tail(config_http.stdout, 40)}))

        if asset_rel:
            asset_http = run_command(["curl", "-kfsS", "--max-time", "10", "-o", "/dev/null", f"{base_url}/{asset_rel}"], repo_root, env=runtime_env(repo_root))
            findings.append(finding("pass" if asset_http.returncode == 0 else "fail", "webui.http-asset", f"GSA asset HTTP probe exit code {asset_http.returncode}.", details={"url": f"{base_url}/{asset_rel}", "output_tail": output_tail(asset_http.stdout, 40)}))

    return make_result("runtime-webui-smoke", repo_root, "Runtime web UI smoke checks completed.", findings, [str(static_dir), *gsad_base_urls(repo_root)])


def command_runtime_browser_smoke(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    secret_path = runtime_secret_path(repo_root, DEV_ADMIN_SECRET)
    probe = runtime_browser_smoke_probe_path(repo_root)
    artifact_dir = browser_smoke_artifact_dir(repo_root)
    findings.append(finding("pass" if secret_path.is_file() else "fail", "runtime.admin-secret", "Development admin secret exists." if secret_path.is_file() else "Development admin secret is missing.", str(secret_path)))
    findings.append(finding("pass" if probe.is_file() else "fail", "browser-smoke.probe", "Browser smoke helper exists." if probe.is_file() else "Browser smoke helper is missing.", str(probe.relative_to(repo_root)) if probe.exists() else str(probe)))
    findings.append(finding("pass" if shutil.which("node") else "fail", "node.available", "node is available for Playwright browser smoke." if shutil.which("node") else "node is not available on PATH."))
    try:
        artifact_dir.mkdir(parents=True, exist_ok=True)
        probe_file = artifact_dir / ".turbovas-write-test"
        probe_file.write_text("ok\n", encoding="utf-8")
        probe_file.unlink()
        findings.append(finding("pass", "browser-smoke.artifact-dir", "Browser smoke artifact directory is ready.", str(artifact_dir)))
    except OSError as error:
        findings.append(finding("fail", "browser-smoke.artifact-dir", f"Browser smoke artifact directory is not usable: {error}", str(artifact_dir)))

    base_urls = gsad_base_urls(repo_root)
    findings.append(finding("pass" if base_urls else "fail", "gsad.urls", "Configured gsad base URLs are available." if base_urls else "No gsad base URLs are configured.", details={"base_urls": list(base_urls)}))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-browser-smoke", repo_root, "Runtime browser smoke stopped at prerequisites.", findings, [str(artifact_dir)])

    scope_report_path: str | None = None
    expect_result_row = False
    scope_probe = runtime_scope_probe_path(repo_root)
    scope_python = venv_python(repo_root, "python-gvm")
    if gvmd_socket_path(repo_root).is_socket() and scope_probe.is_file() and scope_python.is_file():
        scope_args = [
            str(scope_python),
            str(scope_probe),
            "summary",
            "--socket",
            str(gvmd_socket_path(repo_root)),
            "--username",
            DEV_ADMIN_USER,
            "--password-file",
            str(secret_path),
            "--artifact-dir",
            str(scope_report_artifact_dir(repo_root)),
        ]
        scope_summary = run_command(scope_args, repo_root, env=build_env(repo_root), timeout=180)
        try:
            scope_payload = json.loads(scope_summary.stdout)
        except (IndexError, json.JSONDecodeError):
            scope_payload = None
        scope_status = scope_payload.get("status") if scope_payload else None
        scope_details = scope_payload.get("details", {}) if scope_payload else {}
        scope = scope_details.get("scope", {}) if isinstance(scope_details, dict) else {}
        scope_report = scope_details.get("scope_report", {}) if isinstance(scope_details, dict) else {}
        scope_id = scope.get("id") if isinstance(scope, dict) else None
        scope_report_id = scope_report.get("id") if isinstance(scope_report, dict) else None
        if scope_summary.returncode == 0 and scope_status == "pass" and scope_id and scope_report_id:
            scope_report_path = f"/scopes/{scope_id}/reports/{scope_report_id}"
            expect_result_row = int(scope_report.get("results_total") or 0) > 0
            findings.append(
                finding(
                    "pass",
                    "browser-smoke.scope-report-target",
                    "Latest Organization scope-report route selected for browser smoke.",
                    details={"path": scope_report_path, "results_total": scope_report.get("results_total")},
                )
            )
        else:
            findings.append(
                finding(
                    "warn",
                    "browser-smoke.scope-report-target",
                    "Latest Organization scope-report route could not be resolved; browser smoke will use the first visible link.",
                    details={"exit_code": scope_summary.returncode, "output_tail": output_tail(scope_summary.stdout, 80)},
                )
            )

    args = [
        sys.executable,
        str(probe),
        "--username",
        DEV_ADMIN_USER,
        "--password-file",
        str(secret_path),
        "--artifact-dir",
        str(artifact_dir),
    ]
    if scope_report_path:
        args.extend(["--scope-report-path", scope_report_path])
    if expect_result_row:
        args.append("--expect-result-row")
    for base_url in base_urls:
        args.extend(["--base-url", base_url])
    result = run_command(args, repo_root, env=runtime_env(repo_root), timeout=420)
    try:
        parsed = json.loads(result.stdout.strip().splitlines()[-1])
    except (IndexError, json.JSONDecodeError):
        parsed = None
    helper_status = parsed.get("status") if parsed else None
    finding_status = helper_status if result.returncode == 0 and helper_status in {"pass", "warn"} else "fail"
