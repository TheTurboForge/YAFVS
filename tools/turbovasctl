def rust_native_api_route_sources(repo_root: Path | None) -> list[str]:
    if repo_root is None:
        return []
    sources: list[str] = []
    for relative_path in RUST_NATIVE_API_ROUTE_SOURCE_PATHS:
        try:
            sources.append((repo_root / relative_path).read_text(encoding="utf-8"))
        except OSError:
            continue
    return sources


def rust_native_api_route_source(repo_root: Path | None, function_name: str | None = None) -> str:
    if repo_root is None:
        return ""
    if function_name:
        preferred_path = RUST_NATIVE_API_ROUTE_FUNCTION_SOURCES.get(function_name)
        if preferred_path:
            source = rust_repo_file_source(repo_root, preferred_path)
            if rust_source_function_body(source, function_name):
                return source
        for source in rust_native_api_route_sources(repo_root):
            if rust_source_function_body(source, function_name):
                return source
        return ""
    return "\n".join(rust_native_api_route_sources(repo_root))


def rust_native_api_route_templates(repo_root: Path | None) -> list[str]:
    source = rust_native_api_route_source(repo_root)
    routes = {
        rust_route_to_endpoint_template(match.group(1))
        for match in re.finditer(r'\.route\(\s*"(/api/v1[^"]*)"', source)
    }
    return sorted(routes)


def rust_native_api_route_operations(
    repo_root: Path | None,
    function_name: str | None = None,
) -> set[tuple[str, str]]:
    source = rust_native_api_route_source(repo_root, function_name)
    route_source = rust_source_function_body(source, function_name) if function_name else source
    if function_name and not route_source:
        return set()
    return {
        (match.group(2).lower(), rust_route_to_endpoint_template(match.group(1)))
        for match in re.finditer(
            r'\.route\(\s*"(/api/v1[^"]*)"\s*,\s*([a-z]+)\s*\(',
            route_source,
        )
    }


def rust_native_api_route_operation_declared(
    repo_root: Path | None,
