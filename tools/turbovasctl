    return make_result("runtime-native-api-rebuild", repo_root, "Native API sidecar rebuild attempted.", findings, artifacts)


def command_runtime_native_api_direct_token(repo_root: Path, *, rotate: bool) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    secret_path = runtime_secret_path(repo_root, TURBOVAS_API_BEARER_TOKEN_SECRET)
    if rotate:
        rotate_runtime_secret(repo_root, TURBOVAS_API_BEARER_TOKEN_SECRET)
        findings.append(
            finding(
                "pass",
                "native-api-direct-token.rotate",
                "Direct native API runtime bearer token was rotated without printing the secret value.",
                str(secret_path),
            )
        )
    try:
        token = secret_path.read_text(encoding="utf-8").strip() if secret_path.is_file() else ""
    except OSError:
        token = ""
    token_exists = bool(token)
    token_ok = direct_api_bearer_token_is_acceptable(token) if token_exists else False
    secret_metadata = runtime_secret_file_metadata(secret_path)
    token_status = "pass" if token_exists and token_ok and secret_metadata["permission_ok"] else "warn"
    if token_exists and token_ok and not secret_metadata["permission_ok"]:
        token_status = "fail"
    findings.append(
        finding(
            token_status,
            "native-api-direct-token.runtime-secret",
            "Direct native API runtime bearer token file exists, satisfies the local strength contract, and is not group/world accessible."
            if token_status == "pass"
            else "Direct native API runtime bearer token file is missing, weak, or group/world accessible.",
            str(secret_path),
            {
                "exists": token_exists,
                "acceptable": token_ok,
                "secret_path": str(secret_path),
                "mode": secret_metadata["mode"],
                "permission_ok": secret_metadata["permission_ok"],
                "group_or_world_accessible": secret_metadata["group_or_world_accessible"],
                "token_value_reported": False,
            },
        )
    )
    if rotate:
        running_bindings = current_native_api_direct_published_bindings(repo_root)
        findings.append(
            finding(
                "warn" if running_bindings else "pass",
                "native-api-direct-token.running-listener-reload",
                "A running direct native API listener is currently published and may still require turbovas-api restart or runtime-native-api-direct-smoke before it accepts the rotated token."
                if running_bindings
                else "No running direct native API listener publication was detected; no live direct listener needs token reload.",
                details={
                    "published_bindings": list(running_bindings),
                    "token_value_reported": False,
                },
            )
        )
        findings.append(
            finding(
                "pass",
                "native-api-direct-token.reload-required",
                "Restart turbovas-api or rerun runtime-native-api-direct-smoke before expecting any running direct listener to accept the rotated token.",
            )
        )
    summary = "Direct native API runtime bearer token rotated." if rotate else "Direct native API runtime bearer token inspected."
    return make_result("runtime-native-api-direct-token", repo_root, summary, findings)


