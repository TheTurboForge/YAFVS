    findings = [
        finding("pass", "native-tooling.inventory", f"Classified {len(items)} inherited tooling dependency surface(s).", details=summary),
        finding("warn" if unknown_count else "pass", "native-tooling.unknown", f"{unknown_count} inherited tooling surface(s) are outside the current classification map." if unknown_count else "No inherited tooling surfaces were left unclassified.", details={"paths": summary["by_category"]["unknown"]["paths"]}),
        finding("pass", "native-tooling.end-state", "End-state remains full removal of required python-gvm and gvm-tools dependence after native API replacements land."),
    ]
    result = make_result("native-tooling-state", repo_root, "Inherited GMP/python-gvm/gvm-tools dependency state collected.", findings)
    result["details"] = {"items": items, **summary}
    return result


def redis_reference_candidate(relative_path: str) -> bool:
    return relative_path in REDIS_REFERENCE_FILES or any(relative_path.startswith(prefix) for prefix in REDIS_REFERENCE_ROOTS)


def redis_reference_category(relative_path: str, text: str) -> str:
    lower = text.lower()
    if "redis-openvas" in lower or "scanner_redis" in lower or "scanner redis" in lower or "/run/redis-openvas" in lower:
        return "scanner_kb"
    if "hiredis" in lower or "redis-tools" in lower or "redis-server" in lower or "redis:" in lower:
        return "dependency_build"
    if relative_path.startswith("tools/"):
        return "diagnostic_tooling"
    if relative_path.startswith("docs/") or relative_path == "README.md":
        return "documentation"
    return "generic_runtime"


def redis_source_references(repo_root: Path) -> list[dict[str, Any]]:
    tracked = git_tracked_files(repo_root) or []
    references: list[dict[str, Any]] = []
    for relative_path in tracked:
        if not redis_reference_candidate(relative_path):
            continue
        path = repo_root / relative_path
        if not path.is_file():
            continue
        try:
            text = path.read_text(encoding="utf-8", errors="ignore")
        except OSError:
            continue
        matches = sorted({match.group(0) for match in REDIS_REFERENCE_PATTERN.finditer(text)})
        if not matches:
            continue
        references.append({"path": relative_path, "category": redis_reference_category(relative_path, text), "markers": matches})
    return sorted(references, key=lambda item: (item["category"], item["path"]))


def summarize_redis_references(references: list[dict[str, Any]]) -> dict[str, Any]:
    categories = ("scanner_kb", "generic_runtime", "dependency_build", "diagnostic_tooling", "documentation")
    by_category: dict[str, dict[str, Any]] = {}
    for category in categories:
        rows = [item for item in references if item["category"] == category]
        by_category[category] = {"count": len(rows), "paths": [item["path"] for item in rows]}
    return {"total_items": len(references), "by_category": by_category}


def redis_compose_boundaries(repo_root: Path) -> dict[str, Any]:
    path = compose_file(repo_root)
    try:
        text = path.read_text(encoding="utf-8")
    except OSError:
        text = ""
    return {
        "compose_file": str(path.relative_to(repo_root)) if path.exists() else str(path),
        "generic_redis_loopback_tcp": '"127.0.0.1:16379:6379"' in text,
        "scanner_redis_no_tcp_port": "--port 0" in text,
        "scanner_redis_unix_socket": "/run/redis-openvas/redis.sock" in text,
        "gvmd_depends_on_generic_redis": "gvmd:" in text and "redis:" in text,
        "ospd_depends_on_scanner_redis": "ospd-openvas:" in text and "redis-openvas:" in text,
    }


def redis_runtime_probe(repo_root: Path) -> dict[str, Any]:
    details: dict[str, Any] = {
        "redis": {"running": container_running(repo_root, "redis")},
        "redis-openvas": {"running": container_running(repo_root, "redis-openvas"), "socket": str(scanner_redis_socket_path(repo_root))},
    }
    if details["redis"]["running"]:
        ping = exec_in_service(repo_root, "redis", ["redis-cli", "ping"])
        details["redis"].update({"ping_status": "pass" if ping.returncode == 0 and "PONG" in ping.stdout else "fail", "output_tail": output_tail(ping.stdout, 20)})
    if details["redis-openvas"]["running"]:
        ping = scanner_redis_ping(repo_root)
        details["redis-openvas"].update({"ping_status": "pass" if ping.returncode == 0 and "PONG" in ping.stdout else "fail", "output_tail": output_tail(ping.stdout, 20), "socket_exists": scanner_redis_socket_path(repo_root).is_socket()})
    return details


def command_runtime_redis_state(repo_root: Path) -> dict[str, Any]:
    references = redis_source_references(repo_root)
    reference_summary = summarize_redis_references(references)
    boundaries = redis_compose_boundaries(repo_root)
    runtime = redis_runtime_probe(repo_root)
    findings = [
        finding("pass", "redis.source-map", f"Classified {len(references)} Redis reference surface(s).", details=reference_summary),
        finding("pass" if boundaries["generic_redis_loopback_tcp"] else "warn", "redis.generic-boundary", "Generic Redis is bound to loopback TCP in the development Compose file." if boundaries["generic_redis_loopback_tcp"] else "Generic Redis loopback binding was not recognized in Compose.", boundaries["compose_file"], boundaries),
        finding("pass" if boundaries["scanner_redis_no_tcp_port"] and boundaries["scanner_redis_unix_socket"] else "fail", "redis.scanner-boundary", "Scanner Redis is configured with no TCP port and a runtime Unix socket." if boundaries["scanner_redis_no_tcp_port"] and boundaries["scanner_redis_unix_socket"] else "Scanner Redis network/socket boundary is not as expected.", boundaries["compose_file"], boundaries),
    ]
    if runtime["redis"].get("running"):
        findings.append(finding(runtime["redis"].get("ping_status", "fail"), "redis.runtime-ping", "Generic Redis responded to ping." if runtime["redis"].get("ping_status") == "pass" else "Generic Redis ping failed.", details=runtime["redis"]))
    else:
        findings.append(finding("warn", "redis.runtime-ping", "Generic Redis container is not running; runtime ping skipped.", details=runtime["redis"]))
    if runtime["redis-openvas"].get("running"):
        scanner_ready = runtime["redis-openvas"].get("ping_status") == "pass" and runtime["redis-openvas"].get("socket_exists") is True
        findings.append(finding("pass" if scanner_ready else "fail", "redis-openvas.runtime-ping", "Scanner Redis Unix socket responded to ping." if scanner_ready else "Scanner Redis Unix socket ping failed.", str(scanner_redis_socket_path(repo_root)), runtime["redis-openvas"]))
    else:
        findings.append(finding("warn", "redis-openvas.runtime-ping", "Scanner Redis container is not running; runtime ping skipped.", str(scanner_redis_socket_path(repo_root)), runtime["redis-openvas"]))
    result = make_result("runtime-redis-state", repo_root, "Redis dependency and runtime boundary state collected.", findings)
    result["details"] = {"references": references, "reference_summary": reference_summary, "boundaries": boundaries, "runtime": runtime}
    return result


def comment_notice_supported(relative_path: str) -> bool:
    path = Path(relative_path)
    return path.name in COMMENT_NOTICE_NAMES or path.suffix in COMMENT_NOTICE_SUFFIXES


def file_head(path: Path, limit: int = 5000) -> str:
    try:
        return path.read_text(encoding="utf-8", errors="ignore")[:limit]
    except OSError:
        return ""


def has_spdx_header(path: Path) -> bool:
    head = file_head(path, 2000)
    return "SPDX-FileCopyrightText:" in head and "SPDX-License-Identifier:" in head


def has_turbovas_modification_notice(path: Path) -> bool:
    return TURBOVAS_MODIFICATION_NOTICE in file_head(path)


def imported_added_path(relative_path: str) -> bool:
    return any(relative_path.startswith(prefix) for prefix in IMPORTED_ADDED_PREFIXES)


def modified_imported_notice_gaps(repo_root: Path, rows: list[tuple[str, str]]) -> tuple[list[str], list[str]]:
    missing: list[str] = []
    review: list[str] = []
    for status, relative_path in rows:
        if status != "M":
            continue
        path = repo_root / relative_path
        if not path.is_file():
            continue
        if has_turbovas_modification_notice(path):
            continue
        if comment_notice_supported(relative_path):
            missing.append(relative_path)
        else:
            review.append(relative_path)
    return missing, review


def modified_imported_no_comment_manifest_gaps(review_notices: list[str], manifest: dict[str, str] | None = None) -> tuple[list[str], list[str], list[str]]:
    manifest_paths = set((manifest or MODIFIED_IMPORTED_NO_COMMENT_FILES).keys())
    review_paths = set(review_notices)
    documented = sorted(review_paths & manifest_paths)
    undocumented = sorted(review_paths - manifest_paths)
    stale = sorted(manifest_paths - review_paths)
    return documented, undocumented, stale


def added_turbovas_spdx_gaps(repo_root: Path, rows: list[tuple[str, str]]) -> list[str]:
    missing: list[str] = []
    for status, relative_path in rows:
        if not status.startswith("A") or imported_added_path(relative_path):
            continue
        path = repo_root / relative_path
        if path.is_file() and not has_spdx_header(path):
            missing.append(relative_path)
    return missing


def tracked_feed_content_paths(repo_root: Path) -> list[str] | None:
    tracked = git_tracked_files(repo_root)
    if tracked is None:
        return None
    return [path for path in tracked if any(path.startswith(prefix) for prefix in FEED_CONTENT_TRACKED_PREFIXES)]


def public_readiness_finding(public_release: bool = False) -> dict[str, Any]:
    return finding(
        "fail" if public_release else "pass",
        "license.public-readiness",
        "Public-release license review items are still open; do not publish or distribute release artifacts until they are resolved." if public_release else "Public-release license review items are tracked separately; run with --public-release to enforce the release gate.",
        details={"review_items": list(PUBLIC_READINESS_LICENSE_ITEMS), "release_gate": public_release},
    )


def command_license_report(repo_root: Path, public_release: bool = False) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    for component in COMPONENTS:
        component_path = repo_root / component.path
        for license_file in component.licenses:
            relative = f"{component.path}/{license_file}"
            findings.append(finding("pass" if (component_path / license_file).is_file() else "fail", "license.file", f"{component.name}: expected {license_file}", relative))

    all_rows = git_name_status(repo_root, IMPORT_BASELINE_COMMIT)
    rows = git_name_status(repo_root, IMPORT_BASELINE_COMMIT, ("components",))
    if rows is None:
        findings.append(finding("fail", "license.git-history", f"Could not compare against import baseline {IMPORT_BASELINE_COMMIT}."))
    else:
        missing_notices, review_notices = modified_imported_notice_gaps(repo_root, rows)
        findings.append(
            finding(
                "pass" if not missing_notices else "fail",
                "license.modified-imported-notices",
                "Modified imported files have TurboVAS modification notices." if not missing_notices else "Modified imported files are missing TurboVAS modification notices.",
                details={"baseline": IMPORT_BASELINE_COMMIT, "missing": missing_notices},
            )
        )
        documented_review, undocumented_review, stale_review = modified_imported_no_comment_manifest_gaps(review_notices)
        findings.append(
            finding(
                "pass" if not undocumented_review and not stale_review else "fail",
                "license.modified-imported-no-comment-manifest",
                "Modified imported no-comment files are explicitly recorded in the license manifest." if not undocumented_review and not stale_review else "Modified imported no-comment manifest is incomplete or stale.",
                details={"documented": documented_review, "undocumented": undocumented_review, "stale": stale_review, "manifest": MODIFIED_IMPORTED_NO_COMMENT_FILES},
            )
        )

    if all_rows is None:
        findings.append(finding("fail", "license.new-file-spdx", f"Could not compare new files against import baseline {IMPORT_BASELINE_COMMIT}."))
    else:
        missing_spdx = added_turbovas_spdx_gaps(repo_root, all_rows)
        findings.append(
            finding(
                "pass" if not missing_spdx else "fail",
                "license.new-file-spdx",
                "New TurboVAS-created files have SPDX copyright and license headers." if not missing_spdx else "New TurboVAS-created files are missing SPDX copyright or license headers.",
                details={"missing": missing_spdx},
            )
        )

    tracked_feed = tracked_feed_content_paths(repo_root)
    if tracked_feed is None:
        findings.append(finding("fail", "license.feed-content-tracking", "Could not list tracked files to verify feed content is untracked."))
    else:
        findings.append(
            finding(
                "pass" if not tracked_feed else "fail",
                "license.feed-content-tracking",
                "No runtime feed/cache content is tracked in Git." if not tracked_feed else "Runtime feed/cache content appears to be tracked in Git.",
                details={"tracked_paths": tracked_feed},
            )
        )

    findings.append(public_readiness_finding(public_release))
    return make_result("license-report", repo_root, "License/provenance checks completed.", findings)


def command_deps(repo_root: Path, component: str | None = None) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    env = build_env(repo_root)
    try:
        metas = selected_build_metas(component)
    except KeyError:
        return make_result("deps", repo_root, f"Unknown component {component}.", [finding("fail", "component.known", f"Unknown component {component}.")])
    for meta in metas:
        component_path = COMPONENT_BY_NAME[meta.name].path
        findings.append(finding("pass", "build.metadata", f"{meta.name}: {meta.build_system}", component_path, {"order": meta.order, "package_hints": list(meta.package_hints)}))
        for program in meta.programs:
            found = shutil.which(program)
            findings.append(finding("pass" if found else "fail", "program.available", f"{meta.name}: {program}" + (f" at {found}" if found else " not found"), details={"component": meta.name, "program": program}))
            version = tool_version(program)
            if version:
                findings.append(finding("pass", "program.version", f"{meta.name}: {program} {version}", details={"component": meta.name, "program": program, "version": version}))
        for module in meta.pkg_config:
            version = pkg_config_version(module, env)
            findings.append(finding("pass" if version else "fail", "pkg-config.module", f"{meta.name}: {module}" + (f" {version}" if version else " not found"), details={"component": meta.name, "module": module}))
        if meta.build_system == "node-npm":
            node_version = tool_version("node")
            npm_version = tool_version("npm")
            findings.append(finding("pass" if node_version and version_tuple(node_version) >= (22, 0) else "fail", "node.version", f"{meta.name}: node {node_version or 'not found'}; required >=22.0", details={"component": meta.name, "required": ">=22.0", "actual": node_version}))
            findings.append(finding("pass" if npm_version and version_tuple(npm_version) >= (11, 0) else "fail", "npm.version", f"{meta.name}: npm {npm_version or 'not found'}; required >=11.0", details={"component": meta.name, "required": ">=11.0", "actual": npm_version}))
    return make_result("deps", repo_root, "Dependency readiness checked.", findings)


def cmake_paths(repo_root: Path, component: str) -> tuple[Path, Path, Path]:
    source = repo_root / COMPONENT_BY_NAME[component].path
    build = repo_root / "build" / component
    prefix = repo_root / "build" / "prefix"
    return source, build, prefix


def cmake_configure(repo_root: Path, meta: BuildMeta) -> subprocess.CompletedProcess[str]:
    source, build, prefix = cmake_paths(repo_root, meta.name)
    build.mkdir(parents=True, exist_ok=True)
    prefix.mkdir(parents=True, exist_ok=True)
    run_dir = repo_root / "build" / "run" / "gvm"
    gvmd_run_dir = repo_root / "build" / "run" / "gvmd"
    gsad_run_dir = repo_root / "build" / "run" / "gsad"
    state_dir = repo_root / "build" / "var"
    log_dir = repo_root / "build" / "logs"
    sysconf_dir = prefix / "etc"
    command = [
        "cmake",
        "-S",
        str(source),
        "-B",
        str(build),
        "-G",
        "Ninja",
        f"-DCMAKE_INSTALL_PREFIX={prefix}",
        f"-DCMAKE_PREFIX_PATH={prefix}",
        f"-DSYSCONFDIR={sysconf_dir}",
        f"-DLOCALSTATEDIR={state_dir}",
        f"-DGVM_RUN_DIR={run_dir}",
        f"-DGVMD_RUN_DIR={gvmd_run_dir}",
        f"-DGSAD_RUN_DIR={gsad_run_dir}",
        f"-DGVM_STATE_DIR={state_dir / 'lib' / 'gvm'}",
        f"-DGVMD_STATE_DIR={state_dir / 'lib' / 'gvm' / 'gvmd'}",
        f"-DGVM_LOG_DIR={log_dir}",
        *meta.cmake_args,
    ]
    if meta.name == "pg-gvm":
        command.append(f"-DCMAKE_INSTALL_DEV_PREFIX={prefix}")
    return run_command(command, repo_root, env=build_env(repo_root))


def command_configure(repo_root: Path, component: str) -> dict[str, Any]:
    meta = BUILD_META.get(component)
    if not meta:
        return make_result("configure", repo_root, f"Unknown component {component}.", [finding("fail", "component.known", f"Unknown component {component}.")])
    if meta.build_system != "cmake":
        return make_result("configure", repo_root, f"{component} is not a CMake component.", [finding("warn", "build.unsupported", f"{component} uses {meta.build_system}, not cmake.")])
    result = cmake_configure(repo_root, meta)
    _, build, _ = cmake_paths(repo_root, component)
    status = "pass" if result.returncode == 0 else "fail"
    return make_result("configure", repo_root, f"Configure {component} completed with exit code {result.returncode}.", [finding(status, "cmake.configure", f"{component} configure {'succeeded' if status == 'pass' else 'failed'}.", str(build.relative_to(repo_root)), {"output_tail": result.stdout.splitlines()[-80:]})], [str(build.relative_to(repo_root))])


def command_build(repo_root: Path, component: str, install: bool = False, configure_first: bool = True) -> dict[str, Any]:
    meta = BUILD_META.get(component)
    if not meta:
        return make_result("build", repo_root, f"Unknown component {component}.", [finding("fail", "component.known", f"Unknown component {component}.")])
    if meta.build_system == "node-npm":
        return command_build_node(repo_root, meta)
    if meta.build_system in ("python-uv", "python-poetry-core"):
        return command_build_python(repo_root, meta)
    if meta.build_system != "cmake":
        return make_result("build", repo_root, f"{component} is not a CMake component.", [finding("warn", "build.unsupported", f"{component} uses {meta.build_system}, not cmake.")])
    findings: list[dict[str, Any]] = []
    _, build, prefix = cmake_paths(repo_root, component)
    if configure_first:
        configure = cmake_configure(repo_root, meta)
        findings.append(finding("pass" if configure.returncode == 0 else "fail", "cmake.configure", f"{component} configure exit code {configure.returncode}.", str(build.relative_to(repo_root)), {"output_tail": configure.stdout.splitlines()[-60:]}))
        if configure.returncode != 0:
            return make_result("build", repo_root, f"Build {component} stopped at configure.", findings, [str(build.relative_to(repo_root))])
    build_result = run_command(["cmake", "--build", str(build), "--parallel"], repo_root, env=build_env(repo_root))
    findings.append(finding("pass" if build_result.returncode == 0 else "fail", "cmake.build", f"{component} build exit code {build_result.returncode}.", str(build.relative_to(repo_root)), {"output_tail": build_result.stdout.splitlines()[-80:]}))
    if build_result.returncode == 0 and (install or meta.install_for_dependents):
        install_result = run_command(["cmake", "--install", str(build)], repo_root, env=build_env(repo_root))
        findings.append(finding("pass" if install_result.returncode == 0 else "fail", "cmake.install", f"{component} install exit code {install_result.returncode}.", str(prefix.relative_to(repo_root)), {"output_tail": install_result.stdout.splitlines()[-60:]}))
    return make_result("build", repo_root, f"Build {component} completed.", findings, [str(build.relative_to(repo_root)), str(prefix.relative_to(repo_root))])


def command_build_node(repo_root: Path, meta: BuildMeta) -> dict[str, Any]:
    component = COMPONENT_BY_NAME[meta.name]
    component_path = repo_root / component.path
    findings: list[dict[str, Any]] = []
    npm_ci = run_command(["npm", "ci"], component_path, env=build_env(repo_root))
    findings.append(finding("pass" if npm_ci.returncode == 0 else "fail", "npm.ci", f"{meta.name} npm ci exit code {npm_ci.returncode}.", component.path, {"output_tail": npm_ci.stdout.splitlines()[-80:]}))
    if npm_ci.returncode != 0:
        return make_result("build", repo_root, f"Build {meta.name} stopped at npm ci.", findings, [f"{component.path}/node_modules"])
    for script in meta.node_scripts:
        result = run_command(["npm", "run", script], component_path, env=build_env(repo_root))
        findings.append(finding("pass" if result.returncode == 0 else "fail", "npm.script", f"{meta.name} npm run {script} exit code {result.returncode}.", component.path, {"script": script, "output_tail": result.stdout.splitlines()[-80:]}))
        if result.returncode != 0:
            break
    return make_result("build", repo_root, f"Build {meta.name} completed.", findings, [f"{component.path}/node_modules", f"{component.path}/build"])


def venv_python(repo_root: Path, component: str) -> Path:
    return repo_root / "build" / "venvs" / component / "bin" / "python"


def command_build_python(repo_root: Path, meta: BuildMeta) -> dict[str, Any]:
    component = COMPONENT_BY_NAME[meta.name]
    component_path = repo_root / component.path
    venv = repo_root / "build" / "venvs" / meta.name
    findings: list[dict[str, Any]] = []
    create = run_command(["uv", "venv", "--clear", str(venv)], repo_root, env=build_env(repo_root))
    findings.append(finding("pass" if create.returncode == 0 else "fail", "python.venv", f"{meta.name} uv venv exit code {create.returncode}.", str(venv.relative_to(repo_root)), {"output_tail": create.stdout.splitlines()[-40:]}))
    if create.returncode != 0:
        return make_result("build", repo_root, f"Build {meta.name} stopped at venv creation.", findings, [str(venv.relative_to(repo_root))])
    python = venv_python(repo_root, meta.name)
    for local_dep in meta.python_local_deps:
        dep_path = repo_root / COMPONENT_BY_NAME[local_dep].path
        install_dep = run_command(["uv", "pip", "install", "--python", str(python), "-e", str(dep_path)], repo_root, env=build_env(repo_root))
        findings.append(finding("pass" if install_dep.returncode == 0 else "fail", "python.local-dep", f"{meta.name} install local dependency {local_dep} exit code {install_dep.returncode}.", COMPONENT_BY_NAME[local_dep].path, {"dependency": local_dep, "output_tail": install_dep.stdout.splitlines()[-60:]}))
        if install_dep.returncode != 0:
            return make_result("build", repo_root, f"Build {meta.name} stopped at local dependency {local_dep}.", findings, [str(venv.relative_to(repo_root))])
    install = run_command(["uv", "pip", "install", "--python", str(python), "-e", str(component_path)], repo_root, env=build_env(repo_root))
    findings.append(finding("pass" if install.returncode == 0 else "fail", "python.install", f"{meta.name} editable install exit code {install.returncode}.", component.path, {"output_tail": install.stdout.splitlines()[-80:]}))
    if install.returncode != 0:
        return make_result("build", repo_root, f"Build {meta.name} stopped at install.", findings, [str(venv.relative_to(repo_root))])
    for import_name in meta.python_imports:
        result = run_command([str(python), "-c", f"import {import_name}"], repo_root, env=build_env(repo_root))
        findings.append(finding("pass" if result.returncode == 0 else "fail", "python.import", f"{meta.name} import {import_name} exit code {result.returncode}.", component.path, {"import": import_name, "output_tail": result.stdout.splitlines()[-40:]}))
        if result.returncode != 0:
            break
    return make_result("build", repo_root, f"Build {meta.name} completed.", findings, [str(venv.relative_to(repo_root))])


def command_build_chain(repo_root: Path, command: str, chain: tuple[str, ...]) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    artifacts: list[str] = []
    for component in chain:
        result = command_build(repo_root, component, install=BUILD_META[component].install_for_dependents)
        artifacts.extend(result["artifacts"])
        findings.append(finding(result["status"], f"{command}.component", f"{component}: {result['summary']}", details={"component": component}))
        for item in result["findings"]:
            item = dict(item)
            item["check"] = f"{component}.{item['check']}"
            findings.append(item)
        if result["status"] == "fail":
            break
