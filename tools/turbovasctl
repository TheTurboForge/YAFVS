    vulnerability_prefix = constants.get("vulnerability_prefix")
    vulnerability_export_suffix = constants.get("vulnerability_export_suffix")
    if (
        vulnerability_prefix
        and vulnerability_export_suffix
        and "g_str_has_prefix (path, vulnerability_prefix)" in function_body
        and "g_str_has_suffix (id, vulnerability_export_suffix)" in function_body
    ):
        templates.add(f"{vulnerability_prefix.rstrip('/')}/{{}}")
        templates.add(f"{vulnerability_prefix.rstrip('/')}/{{}}{vulnerability_export_suffix}")

    single_segment_prefixes = (
        "cpe_prefix",
        "cve_prefix",
        "cert_bund_advisory_prefix",
        "dfn_cert_advisory_prefix",
        "nvt_prefix",
        "operating_system_prefix",
        "host_prefix",
        "tls_certificate_prefix",
        "scanner_prefix",
        "credential_prefix",
        "user_prefix",
        "filter_prefix",
        "alert_prefix",
        "tag_resource_names_prefix",
        "override_prefix",
        "port_list_prefix",
        "schedule_prefix",
        "report_config_prefix",
