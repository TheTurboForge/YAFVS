def largest_files(path: Path, limit: int = 10) -> list[dict[str, Any]]:
    if not path.exists():
        return []
    files: list[dict[str, Any]] = []
    if path.is_file():
        try:
            return [{"path": str(path), "byte_count": path.stat().st_size}]
        except OSError:
            return []
    for root, _, filenames in os.walk(path):
        for filename in filenames:
            candidate = Path(root) / filename
            try:
                size = candidate.stat().st_size
            except OSError:
                continue
            try:
                display_path = str(candidate.relative_to(path))
            except ValueError:
                display_path = str(candidate)
            files.append({"path": display_path, "byte_count": size})
    return sorted(files, key=lambda item: item["byte_count"], reverse=True)[:limit]


