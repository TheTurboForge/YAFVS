def path_tree_summary(path: Path, recursive: bool = True) -> dict[str, Any]:
    summary: dict[str, Any] = {
        "path": str(path),
        "exists": path.exists(),
        "kind": "missing",
        "file_count": 0,
        "directory_count": 0,
        "byte_count": 0,
        "latest_mtime": None,
    }
    if not path.exists():
        return summary
    latest = 0.0
    if path.is_file():
        stat = path.stat()
        latest = stat.st_mtime
        summary.update({"kind": "file", "file_count": 1, "byte_count": stat.st_size})
    elif path.is_dir():
        summary["kind"] = "directory"
        if recursive:
            for root, dirs, files in os.walk(path):
                summary["directory_count"] += len(dirs)
                for filename in files:
                    candidate = Path(root) / filename
                    try:
                        stat = candidate.stat()
                    except OSError:
                        continue
                    summary["file_count"] += 1
                    summary["byte_count"] += stat.st_size
                    latest = max(latest, stat.st_mtime)
        else:
            try:
                children = list(path.iterdir())
            except OSError:
                children = []
            summary["file_count"] = sum(1 for child in children if child.is_file())
            summary["directory_count"] = sum(1 for child in children if child.is_dir())
            try:
                latest = max((child.stat().st_mtime for child in children), default=path.stat().st_mtime)
            except OSError:
                latest = path.stat().st_mtime
    if latest:
        summary["latest_mtime"] = datetime.fromtimestamp(latest, timezone.utc).replace(microsecond=0).isoformat()
    return summary


def parse_percent(value: str | None) -> float | None:
    if value is None:
        return None
    value = value.strip()
    if not value.endswith("%"):
        return None
    try:
        return float(value[:-1])
    except ValueError:
        return None


def parse_byte_quantity(value: str | None) -> int | None:
    if value is None:
        return None
    value = value.strip()
    match = re.fullmatch(r"([0-9]+(?:\.[0-9]+)?)\s*([A-Za-z]+)", value)
    if not match:
        return None
    number, unit = match.groups()
    multiplier = BYTE_UNITS.get(unit)
    if multiplier is None:
        return None
    return int(float(number) * multiplier)


def parse_byte_pair(value: str | None, first_key: str, second_key: str) -> dict[str, int | None]:
    if value is None or "/" not in value:
        return {first_key: None, second_key: None}
    first, second = value.split("/", 1)
    return {first_key: parse_byte_quantity(first), second_key: parse_byte_quantity(second)}


def normalize_docker_stat(row: dict[str, str]) -> dict[str, Any]:
    normalized: dict[str, Any] = {
        "name": row.get("Name"),
        "id": row.get("ID"),
        "cpu_percent": parse_percent(row.get("CPUPerc")),
        "memory_percent": parse_percent(row.get("MemPerc")),
        "pids": None,
    }
    try:
        normalized["pids"] = int(row.get("PIDs", ""))
    except ValueError:
        normalized["pids"] = None
    normalized.update(parse_byte_pair(row.get("MemUsage"), "memory_usage_bytes", "memory_limit_bytes"))
    normalized.update(parse_byte_pair(row.get("NetIO"), "network_rx_bytes", "network_tx_bytes"))
    normalized.update(parse_byte_pair(row.get("BlockIO"), "block_read_bytes", "block_write_bytes"))
    return normalized


