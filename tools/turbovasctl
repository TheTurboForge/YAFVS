def split_gsad_hosts(value: str | None) -> tuple[str, ...]:
    if not value:
        return ()
    hosts: list[str] = []
    seen: set[str] = set()
    for raw_host in value.split(","):
        host = raw_host.strip()
        if not host or host in seen:
            continue
        hosts.append(host)
        seen.add(host)
    return tuple(hosts)


def gsad_hosts(repo_root: Path) -> tuple[str, ...]:
    env = runtime_env(repo_root)
    hosts = split_gsad_hosts(env.get(GSAD_HOSTS_ENV))
    if hosts:
        return hosts
    return split_gsad_hosts(env.get(GSAD_HOST_ENV)) or (DEFAULT_GSAD_HOST,)


def gsad_host(repo_root: Path) -> str:
    return gsad_hosts(repo_root)[0]


def gsad_base_url(repo_root: Path) -> str:
    return f"https://{gsad_host(repo_root)}:{GSAD_PORT}"


def gsad_base_urls(repo_root: Path) -> tuple[str, ...]:
    return tuple(f"https://{host}:{GSAD_PORT}" for host in gsad_hosts(repo_root))


def gsad_port_bindings(repo_root: Path) -> tuple[str, ...]:
    return tuple(f"{host}:{GSAD_PORT}:{GSAD_CONTAINER_PORT}" for host in gsad_hosts(repo_root))


def gsad_ports_override_file(repo_root: Path) -> Path:
    return repo_root / "build" / "compose" / "gsad-ports.override.yaml"


def ensure_gsad_ports_override(repo_root: Path) -> Path | None:
    hosts = gsad_hosts(repo_root)
    if len(hosts) <= 1 and not runtime_env(repo_root).get(GSAD_HOSTS_ENV):
        return None
    path = gsad_ports_override_file(repo_root)
    path.parent.mkdir(parents=True, exist_ok=True)
    bindings = "\n".join(f"      - {json.dumps(binding)}" for binding in gsad_port_bindings(repo_root))
    path.write_text(
        "services:\n"
        "  gsad:\n"
        "    ports: !override\n"
        f"{bindings}\n",
        encoding="utf-8",
    )
    return path


def stage_gsa_static(repo_root: Path) -> list[dict[str, Any]]:
    findings: list[dict[str, Any]] = []
    source = gsa_build_dir(repo_root)
    destination = gsad_static_dir(repo_root)
    index = source / "index.html"
    findings.append(finding("pass" if index.is_file() else "fail", "gsa.build.index", "GSA production build index.html exists." if index.is_file() else "GSA production build is missing index.html; run just build-ui.", str(index)))
    if aggregate_status(findings) == "fail":
        return findings
    if destination.exists():
        shutil.rmtree(destination)
    destination.parent.mkdir(parents=True, exist_ok=True)
    shutil.copytree(source, destination)
    config_js = destination / "config.js"
    fallback_api_server = f"{gsad_host(repo_root)}:{GSAD_PORT}"
    config_js.write_text(
        "config = {\n"
        "  apiProtocol: (window.location.protocol || 'https:').replace(':', ''),\n"
        f"  apiServer: window.location.host || '{fallback_api_server}',\n"
        "};\n",
        encoding="utf-8",
    )
    findings.append(finding("pass", "gsa.static-stage", "GSA production build is staged for gsad.", str(destination)))
    findings.append(finding("pass", "gsa.config-js", "GSA config.js uses the browser host with a fallback gsad endpoint.", str(config_js), {"api_protocol": "browser", "api_server_fallback": fallback_api_server, "hosts": list(gsad_hosts(repo_root))}))
    return findings


