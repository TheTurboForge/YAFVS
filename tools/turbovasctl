def production_posture_status_only_result(result: dict[str, Any]) -> dict[str, Any]:
    sensitive_parts = ("secret", "token", "password", "credential", "bearer")

    def sensitive(value: object) -> bool:
        return any(part in str(value).lower() for part in sensitive_parts)

    compact = dict(result)
    findings = result.get("findings", [])
    non_pass = []
    for item in findings:
        if item.get("status") == "pass":
            continue
        compact_item = compact_doctor_finding(item)
        path = compact_item.get("path")
        if isinstance(path, str) and (path.startswith("/") or sensitive(path)):
            compact_item["path"] = "[redacted]"
        details = compact_item.get("details")
        if isinstance(details, dict):
            compact_item["details"] = {
                key: "[redacted]" if sensitive(key) or sensitive(value) else value
                for key, value in details.items()
            }
        non_pass.append(compact_item)
    details = result.get("details", {}) if isinstance(result.get("details"), dict) else {}
    compact["details"] = {
        "finding_count": len(findings),
        "non_pass_count": len(non_pass),
        "public_release_license_status": details.get("public_release_license_gate", {}).get("status", "unknown")
        if isinstance(details.get("public_release_license_gate"), dict)
        else "unknown",
    }
    compact["findings"] = non_pass or [
        finding("pass", "production-posture.status-only", "Production posture check passed; no non-pass findings.")
    ]
    return compact


