        "--scanner-name=OpenVAS Default",
        "--scanner-type=OpenVAS",
        "--scanner-host=/runtime/run/ospd/ospd-openvas.sock",
        "--scanner-port=0",
        "--no-default-certs",
    ]
    if scanner_uuid:
        change = run_gvmd_oneoff(repo_root, [f"--modify-scanner={scanner_uuid}", *scanner_args], no_deps=False)
        findings.append(finding("pass" if change.returncode == 0 else "fail", "gvmd.modify-scanner", f"Modify OpenVAS Default scanner exit code {change.returncode}.", details={"scanner_uuid": scanner_uuid, "output_tail": output_tail(change.stdout, 80)}))
    else:
        change = run_gvmd_oneoff(repo_root, ["--create-scanner=OpenVAS Default", *scanner_args[1:]], no_deps=False)
        scanner_uuid = parse_named_uuid(change.stdout, "OpenVAS Default") or parse_named_uuid(change.stdout, "Scanner")
        findings.append(finding("pass" if change.returncode == 0 else "fail", "gvmd.create-scanner", f"Create OpenVAS Default scanner exit code {change.returncode}.", details={"scanner_uuid": scanner_uuid, "output_tail": output_tail(change.stdout, 80)}))

    scanners_after = run_gvmd_oneoff(repo_root, ["--get-scanners"], no_deps=False)
    scanner_uuid = parse_named_uuid(scanners_after.stdout, "OpenVAS Default") if scanners_after.returncode == 0 else scanner_uuid
    findings.append(finding("pass" if scanner_uuid else "fail", "gvmd.scanner.openvas-default", "OpenVAS Default scanner is registered." if scanner_uuid else "OpenVAS Default scanner registration could not be confirmed.", details={"scanner_uuid": scanner_uuid, "output_tail": output_tail(scanners_after.stdout, 80)}))
    if scanner_uuid:
        verify = run_gvmd_oneoff(repo_root, [f"--verify-scanner={scanner_uuid}"], no_deps=False)
        findings.append(finding("pass" if verify.returncode == 0 else "warn", "gvmd.verify-scanner", f"Verify OpenVAS Default scanner exit code {verify.returncode}.", details={"scanner_uuid": scanner_uuid, "output_tail": output_tail(verify.stdout, 100)}))
    return make_result("runtime-scanner-register", repo_root, "Runtime scanner registration completed.", findings, [str(runtime_dir(repo_root))])


def command_runtime_feed_keyring_init(repo_root: Path) -> dict[str, Any]:
    findings = ensure_runtime_dirs(repo_root)
    home = feed_gnupg_home(repo_root)
    key_path = feed_community_key_path(repo_root)
    try:
        home.mkdir(parents=True, exist_ok=True)
        home.chmod(0o700)
        key_path.parent.mkdir(parents=True, exist_ok=True)
        findings.append(finding("pass", "feed-keyring.dir", "Shared feed signature keyring directory is ready.", str(home)))
    except OSError as error:
        findings.append(finding("fail", "feed-keyring.dir", f"Shared feed signature keyring directory is not usable: {error}", str(home)))

    findings.append(finding("pass" if shutil.which("gpg") else "fail", "gpg.available", "gpg is available." if shutil.which("gpg") else "gpg is missing."))
    findings.append(finding("pass" if shutil.which("curl") else "fail", "curl.available", "curl is available." if shutil.which("curl") else "curl is missing."))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-feed-keyring-init", repo_root, "Feed keyring initialization stopped at prerequisites.", findings, [str(home)])

    if key_path.is_file() and key_path.stat().st_size > 0:
        findings.append(finding("pass", "feed-keyring.community-key", "Greenbone Community signing key artifact already exists.", str(key_path)))
    else:
        download = run_command(feed_community_key_download_command(repo_root), repo_root, timeout=120)
        findings.append(finding("pass" if download.returncode == 0 else "fail", "feed-keyring.community-key", f"Download Greenbone Community signing key exit code {download.returncode}.", str(key_path), {"url": GREENBONE_COMMUNITY_KEY_URL, "output_tail": output_tail(download.stdout, 80)}))
        if download.returncode != 0:
            return make_result("runtime-feed-keyring-init", repo_root, "Feed keyring initialization stopped while downloading the signing key.", findings, [str(home), str(key_path)])

    imported = run_command(gpg_command(repo_root, "--import", str(key_path)), repo_root, timeout=120)
    findings.append(finding("pass" if imported.returncode == 0 else "fail", "feed-keyring.import", f"Import Greenbone Community signing key exit code {imported.returncode}.", details={"output_tail": output_tail(imported.stdout, 80)}))
    if imported.returncode != 0:
        return make_result("runtime-feed-keyring-init", repo_root, "Feed keyring initialization stopped while importing the signing key.", findings, [str(home), str(key_path)])

    ownertrust = run_command(gpg_command(repo_root, "--import-ownertrust"), repo_root, timeout=60, input_text=f"{GREENBONE_COMMUNITY_KEY_FPR}:6:\n")
    findings.append(finding("pass" if ownertrust.returncode == 0 else "fail", "feed-keyring.ownertrust", f"Set Greenbone Community signing key ownertrust exit code {ownertrust.returncode}.", details={"fingerprint": GREENBONE_COMMUNITY_KEY_FPR, "output_tail": output_tail(ownertrust.stdout, 80)}))

    fingerprint = run_command(gpg_command(repo_root, "--with-colons", "--fingerprint", GREENBONE_COMMUNITY_KEY_FPR), repo_root, timeout=60)
    fingerprint_ok = fingerprint.returncode == 0 and GREENBONE_COMMUNITY_KEY_FPR in fingerprint.stdout.replace(" ", "").upper()
    findings.append(finding("pass" if fingerprint_ok else "fail", "feed-keyring.fingerprint", "Greenbone Community signing key fingerprint is present." if fingerprint_ok else "Greenbone Community signing key fingerprint was not found after import.", details={"fingerprint": GREENBONE_COMMUNITY_KEY_FPR, "output_tail": output_tail(fingerprint.stdout, 80)}))

    for subtree, checksums, signature in notus_signature_files(repo_root):
        paths_ok = checksums.is_file() and signature.is_file()
        findings.append(finding("pass" if paths_ok else "fail", f"feed-keyring.notus-{subtree}-files", f"Notus {subtree} signature files are present." if paths_ok else f"Notus {subtree} signature files are missing.", details={"checksums": str(checksums), "signature": str(signature)}))
        if paths_ok:
            verify = run_command(gpg_command(repo_root, "--verify", str(signature), str(checksums)), repo_root, timeout=120)
            findings.append(finding("pass" if verify.returncode == 0 else "fail", f"feed-keyring.notus-{subtree}-signature", f"Verify Notus {subtree} sha256sums signature exit code {verify.returncode}.", details={"output_tail": output_tail(verify.stdout, 80)}))

    return make_result("runtime-feed-keyring-init", repo_root, "Shared feed signature keyring initialization completed.", findings, [str(home), str(key_path)])


