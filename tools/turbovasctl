        ");"
    )


def ensure_postgres_database_collation(repo_root: Path, database: str, refresh_empty: bool = True) -> dict[str, Any]:
    result = psql(repo_root, "SELECT datcollversion || '|' || pg_database_collation_actual_version(oid) FROM pg_database WHERE datname = current_database();", database=database)
    if result.returncode != 0:
        return finding("fail", "postgres.collation", f"{database}: collation version check exit code {result.returncode}.", details={"database": database, "output_tail": result.stdout.splitlines()[-40:]})
    value = psql_value(result)
    if "|" not in value:
        return finding("warn", "postgres.collation", f"{database}: could not parse database collation version check.", details={"database": database, "output_tail": result.stdout.splitlines()[-40:]})
    recorded, actual = value.split("|", 1)
    if recorded == actual:
        return finding("pass", "postgres.collation", f"{database}: database collation version is current: {actual}.", details={"database": database, "recorded": recorded, "actual": actual})

    count_result = psql(repo_root, postgres_user_relation_count_query(), database=database)
    if count_result.returncode != 0:
        return finding("fail", "postgres.collation", f"{database}: collation mismatch {recorded} != {actual}; relation-count check failed.", details={"database": database, "recorded": recorded, "actual": actual, "output_tail": count_result.stdout.splitlines()[-40:]})
    relation_count = psql_value(count_result)
    if relation_count == "0" and refresh_empty:
        refresh = psql(
            repo_root,
            f"ALTER DATABASE {sql_identifier(database)} REFRESH COLLATION VERSION;",
            database=postgres_collation_connection_database(repo_root, database),
        )
        return finding("pass" if refresh.returncode == 0 else "fail", "postgres.collation", f"{database}: refreshed empty development database collation version from {recorded} to {actual}.", details={"database": database, "recorded": recorded, "actual": actual, "relation_count": relation_count, "output_tail": refresh.stdout.splitlines()[-40:]})
    if relation_count == "0":
        return finding("warn", "postgres.collation", f"{database}: database collation version mismatch {recorded} != {actual}; runtime-init can refresh this empty development database.", details={"database": database, "recorded": recorded, "actual": actual, "relation_count": relation_count})
    return finding("warn", "postgres.collation", f"{database}: database collation version mismatch {recorded} != {actual}; manual review required before refreshing a database with objects.", details={"database": database, "recorded": recorded, "actual": actual, "relation_count": relation_count})


def ensure_postgres_collation(repo_root: Path, refresh_empty: bool = True) -> list[dict[str, Any]]:
    return [
        ensure_postgres_database_collation(repo_root, database, refresh_empty=refresh_empty)
        for database in postgres_collation_databases(repo_root)
    ]

def pg_gvm_artifacts(repo_root: Path) -> tuple[list[dict[str, Any]], dict[str, Path]]:
    prefix = repo_root / "build" / "prefix"
    extension_dir = prefix / "share" / "postgresql" / "extension"
    library = prefix / "lib" / "postgresql" / PG_GVM_LIBRARY
    sql_files = sorted(extension_dir.glob("pg-gvm--*.sql"))
    artifacts = {
        "extension_dir": extension_dir,
        "control": extension_dir / PG_GVM_CONTROL,
        "library": library,
    }
    findings = [
        finding("pass" if artifacts["control"].is_file() else "fail", "pg-gvm.control", f"{PG_GVM_CONTROL} is available in build/prefix.", str(artifacts["control"].relative_to(repo_root)) if artifacts["control"].exists() else str(artifacts["control"])),
        finding("pass" if library.is_file() else "fail", "pg-gvm.library", f"{PG_GVM_LIBRARY} is available in build/prefix.", str(library.relative_to(repo_root)) if library.exists() else str(library)),
        finding("pass" if sql_files else "fail", "pg-gvm.sql", "pg-gvm extension SQL files are available in build/prefix.", details={"files": [str(path.relative_to(repo_root)) for path in sql_files]}),
    ]
    return findings, artifacts


def copy_pg_gvm_extension(repo_root: Path) -> list[dict[str, Any]]:
    artifact_findings, artifacts = pg_gvm_artifacts(repo_root)
    if aggregate_status(artifact_findings) == "fail":
        return artifact_findings
    extension_dir = artifacts["extension_dir"]
    library = artifacts["library"]
    copy_sql = run_command(
        compose_command(repo_root, "cp", str(extension_dir) + "/.", f"postgres:/usr/share/postgresql/16/extension/"),
        repo_root,
        env=runtime_env(repo_root),
    )
    copy_library = run_command(
        compose_command(repo_root, "cp", str(library), f"postgres:/usr/lib/postgresql/16/lib/{PG_GVM_LIBRARY}"),
        repo_root,
        env=runtime_env(repo_root),
    )
    return [
        *artifact_findings,
        finding("pass" if copy_sql.returncode == 0 else "fail", "pg-gvm.copy.sql", f"Copy pg-gvm SQL/control files exit code {copy_sql.returncode}.", details={"output_tail": copy_sql.stdout.splitlines()[-40:]}),
        finding("pass" if copy_library.returncode == 0 else "fail", "pg-gvm.copy.library", f"Copy pg-gvm shared library exit code {copy_library.returncode}.", details={"output_tail": copy_library.stdout.splitlines()[-40:]}),
    ]


def pg_gvm_extension_status(repo_root: Path) -> dict[str, Any]:
