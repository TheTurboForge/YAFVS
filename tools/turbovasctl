def unix_socket_status(path: Path, *, timeout_seconds: float = 1.0) -> dict[str, Any]:
    details: dict[str, Any] = {"path": str(path)}
    if not path.exists():
        details["state"] = "missing"
        return details
    if not path.is_socket():
        details["state"] = "not-socket"
        return details
    client = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    client.settimeout(timeout_seconds)
    try:
        client.connect(str(path))
    except ConnectionRefusedError as exc:
        details.update({"state": "stale", "error": str(exc), "errno": exc.errno})
    except socket.timeout as exc:
        details.update({"state": "timeout", "error": str(exc)})
    except OSError as exc:
        details.update({"state": "error", "error": str(exc), "errno": exc.errno})
    else:
        details["state"] = "ready"
    finally:
        client.close()
    return details


def socket_ready(path: Path) -> bool:
    return unix_socket_status(path).get("state") == "ready"


def socket_readiness_finding(check: str, label: str, path: Path, *, missing_status: str = "warn") -> dict[str, Any]:
    status = unix_socket_status(path)
    state = status.get("state")
    if state == "ready":
        return finding("pass", check, f"{label} socket accepts connections.", str(path), {"socket": status})
    severity = missing_status if state == "missing" else "fail"
    message = {
        "missing": f"{label} socket is missing.",
        "not-socket": f"{label} path exists but is not a socket.",
        "stale": f"{label} socket path exists but no process is listening.",
        "timeout": f"{label} socket connection timed out.",
        "error": f"{label} socket connection failed.",
    }.get(str(state), f"{label} socket state is {state or 'unknown'}.")
    return finding(severity, check, message, str(path), {"socket": status})


def wait_for_socket(path: Path, timeout_seconds: int = 20) -> bool:
    deadline = time.monotonic() + timeout_seconds
    while time.monotonic() < deadline:
        if socket_ready(path):
            return True
        time.sleep(1)
    return socket_ready(path)


