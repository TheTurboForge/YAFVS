            findings.append(native_api_probe_finding("pass" if query_patch_ok else "fail", "native-api-direct.tag-write-query-denied", "Direct write-control rejects non-GET query strings before tag mutation." if query_patch_ok else "Direct write-control did not reject a non-GET query string before tag mutation.", query_patch, direct_native_api_display_command(f"/api/v1/tags/{urllib.parse.quote(tag_id)}?unexpected=1", token=token, env=env, method="PATCH", body=query_patch_body, extra_headers=content_type), query_patch_json, {"http_status": query_patch_status, "tag_id": tag_id, **summarize_native_api_response(query_patch_json)}))

            delete_body = direct_native_api_curl(repo_root, f"/api/v1/tags/{urllib.parse.quote(tag_id)}", token=token, env=env, method="DELETE", body="probe-body", extra_headers=content_type)
