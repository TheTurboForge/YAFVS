    expected_feed_types = {"NVT", "SCAP", "CERT", "GVMD_DATA"}
    feed_item_types = {
        item.get("type")
        for item in feed_items
        if isinstance(item, dict) and isinstance(item.get("type"), str)
    }
    feeds_ok = (
        feeds.returncode == 0
        and isinstance(feed_items, list)
        and feed_item_types == expected_feed_types
        and all(
            isinstance(item, dict)
            and isinstance(item.get("name"), str)
            and isinstance(item.get("version"), str)
            and item.get("status") in {"Up-to-date...", "Update in progress...", "Unknown"}
            and item.get("sync_status") in {"up_to_date", "syncing", "unknown"}
            and item.get("metadata_source") == "runtime_feed_copy"
            and item.get("status_source") in {"runtime_feed_lock", "unavailable"}
            for item in feed_items
        )
