def command_build_ui(repo_root: Path) -> dict[str, Any]:
    return command_build(repo_root, "gsa")


def command_build_python_chain(repo_root: Path) -> dict[str, Any]:
    return command_build_chain(repo_root, "build-python", PYTHON_CHAIN)


def command_build_baseline(repo_root: Path) -> dict[str, Any]:
