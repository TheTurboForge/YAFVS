                "direct_marker_mismatches": contract["direct_marker_mismatches"],
            },
        ),
    ]
    if focus_terms and not rows:
        findings.append(
            finding(
                "warn",
                "native-api-migration-matrix.focus",
                "Native API migration matrix focus terms matched zero rows.",
                details={"focus": focus_label, "focus_terms": focus_terms},
            )
        )
    result = make_result("native-api-migration-matrix", repo_root, "Native API migration matrix collected.", findings)
    result["details"] = details
    if status_only:
        result = native_api_migration_matrix_status_only_result(result)
    return result


