def command_runtime_init(repo_root: Path) -> dict[str, Any]:
    findings = ensure_runtime_dirs(repo_root)
    config = run_command(compose_command(repo_root, "config", "--quiet"), repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if config.returncode == 0 else "fail", "compose.config", f"Compose config validation exit code {config.returncode}.", str(compose_file(repo_root).relative_to(repo_root)), {"output_tail": config.stdout.splitlines()[-40:]}))
    findings.extend(pg_gvm_artifacts(repo_root)[0])
    if aggregate_status(findings) == "fail":
        return make_result("runtime-init", repo_root, "Runtime initialization stopped before Postgres changes.", findings)

    result = run_command(compose_command(repo_root, "up", "-d", "--build", "postgres"), repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if result.returncode == 0 else "fail", "postgres.up", f"docker compose up postgres exit code {result.returncode}.", details={"output_tail": result.stdout.splitlines()[-80:]}))
    if result.returncode != 0:
        return make_result("runtime-init", repo_root, "Runtime initialization stopped at Postgres startup.", findings)

    ready_result: subprocess.CompletedProcess[str] | None = None
    for _ in range(30):
        ready_result = postgres_ready(repo_root)
        if ready_result.returncode == 0:
            break
        import time

        time.sleep(2)
    findings.append(finding("pass" if ready_result and ready_result.returncode == 0 else "fail", "postgres.ready", f"pg_isready exit code {ready_result.returncode if ready_result else 'unavailable'}.", details={"output_tail": ready_result.stdout.splitlines()[-20:] if ready_result else []}))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-init", repo_root, "Runtime initialization stopped before database setup.", findings)

    findings.extend(ensure_postgres_collation(repo_root))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-init", repo_root, "Runtime initialization stopped at Postgres collation check.", findings)

    findings.extend(copy_pg_gvm_extension(repo_root))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-init", repo_root, "Runtime initialization stopped while installing pg-gvm files.", findings)

    create_dba = psql(repo_root, "DO $$ BEGIN CREATE ROLE dba WITH SUPERUSER NOINHERIT; EXCEPTION WHEN duplicate_object THEN NULL; END $$;")
    findings.append(finding("pass" if create_dba.returncode == 0 else "fail", "postgres.role.dba", f"Create/verify dba role exit code {create_dba.returncode}.", details={"output_tail": create_dba.stdout.splitlines()[-40:]}))
    grant_dba = psql(repo_root, f"GRANT dba TO {sql_identifier(postgres_user(repo_root))};")
    findings.append(finding("pass" if grant_dba.returncode == 0 else "fail", "postgres.role.grant", f"Grant dba to {postgres_user(repo_root)} exit code {grant_dba.returncode}.", details={"output_tail": grant_dba.stdout.splitlines()[-40:]}))
    create_extension = psql(repo_root, f'CREATE EXTENSION IF NOT EXISTS "{PG_GVM_EXTENSION}";')
    findings.append(finding("pass" if create_extension.returncode == 0 else "fail", "postgres.extension.pg-gvm", f"Create/verify pg-gvm extension exit code {create_extension.returncode}.", details={"output_tail": create_extension.stdout.splitlines()[-80:]}))
    findings.append(pg_gvm_extension_status(repo_root))
    return make_result("runtime-init", repo_root, "Runtime database initialization completed.", findings, [str(runtime_dir(repo_root)), "build/prefix"])


def command_runtime_certs_init(repo_root: Path) -> dict[str, Any]:
    findings = ensure_runtime_dirs(repo_root)
    cert_private_dir(repo_root).mkdir(parents=True, exist_ok=True)
    cert_public_dir(repo_root).mkdir(parents=True, exist_ok=True)
    try:
        cert_private_dir(repo_root).chmod(0o700)
        cert_public_dir(repo_root).chmod(0o755)
    except OSError as error:
        findings.append(finding("warn", "runtime.cert.permissions", f"Could not adjust certificate directory permissions: {error}."))

    script = repo_root / "build" / "prefix" / "bin" / "gvm-manage-certs"
    findings.append(finding("pass" if shutil.which("certtool") else "fail", "certtool.available", "certtool is available." if shutil.which("certtool") else "certtool is missing; install gnutls-bin."))
    findings.append(finding("pass" if script.is_file() else "fail", "gvm-manage-certs.available", "gvm-manage-certs is available in build/prefix." if script.is_file() else "gvm-manage-certs is missing; build/install gvmd first.", str(script)))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-certs-init", repo_root, "Certificate initialization stopped before generation.", findings, [str(runtime_dir(repo_root))])

    if certs_partial(repo_root):
        findings.extend(cert_file_findings(repo_root))
        findings.append(finding("fail", "runtime.cert.partial", "Partial certificate infrastructure exists; refusing to overwrite or rotate automatically."))
        return make_result("runtime-certs-init", repo_root, "Certificate initialization stopped at partial existing state.", findings, [str(runtime_dir(repo_root))])

    if not certs_complete(repo_root):
        create = run_command([str(script), "-a"], repo_root, env=gvm_cert_env(repo_root))
        findings.append(finding("pass" if create.returncode == 0 else "fail", "runtime.cert.create", f"gvm-manage-certs -a exit code {create.returncode}.", details={"output_tail": output_tail(create.stdout, 80)}))
        if create.returncode != 0:
            return make_result("runtime-certs-init", repo_root, "Certificate generation failed.", findings, [str(runtime_dir(repo_root))])
    else:
        findings.append(finding("pass", "runtime.cert.exists", "Complete certificate infrastructure already exists; not regenerating."))

    verify = run_command([str(script), "-V"], repo_root, env=gvm_cert_env(repo_root))
    findings.append(finding("pass" if verify.returncode == 0 else "fail", "runtime.cert.verify", f"gvm-manage-certs -V exit code {verify.returncode}.", details={"output_tail": output_tail(verify.stdout, 80)}))
    findings.extend(cert_file_findings(repo_root))
    return make_result("runtime-certs-init", repo_root, "Runtime certificate initialization completed.", findings, [str(cert_public_dir(repo_root)), str(cert_private_dir(repo_root))])


def command_runtime_scanner_redis_init(repo_root: Path, probe_openvas: bool = True) -> dict[str, Any]:
