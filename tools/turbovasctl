def compact_candidate_for_removal_review(review: dict[str, Any]) -> dict[str, Any]:
    compact_buckets: dict[str, Any] = {}
    for bucket, data in review.get("buckets", {}).items():
        if not isinstance(data, dict):
            continue
        compact_bucket: dict[str, Any] = {
            "count": data.get("count", 0),
            "path_count": len(data.get("paths", [])) if isinstance(data.get("paths"), list) else 0,
        }
        if data.get("reason"):
            compact_bucket["reason"] = data["reason"]
        compact_buckets[bucket] = compact_bucket
    return {
        "total": review.get("total", 0),
        "safe_removal_count": review.get("safe_removal_count", 0),
        "blocked_or_review_count": review.get("blocked_or_review_count", 0),
        "buckets": compact_buckets,
    }


