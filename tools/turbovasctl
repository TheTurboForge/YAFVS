    findings.append(finding("pass" if config.returncode == 0 else "fail", "compose.config", f"Compose config validation exit code {config.returncode}.", str(compose_file(repo_root).relative_to(repo_root)), {"output_tail": output_tail(config.stdout, 40)}))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-native-api-rebuild", repo_root, "Native API rebuild stopped at prerequisites.", findings, [str(runtime_dir(repo_root))])

    build = run_command(compose_command(repo_root, "build", "turbovas-api"), repo_root, env=runtime_env(repo_root), timeout=1200)
    findings.append(process_step_finding("pass" if build.returncode == 0 else "fail", "compose.turbovas-api-build", f"docker compose build turbovas-api exit code {build.returncode}.", build, compose_command(repo_root, "build", "turbovas-api")))
    if build.returncode != 0:
        return make_result("runtime-native-api-rebuild", repo_root, "Native API rebuild stopped because image build failed.", findings, [str(runtime_dir(repo_root))])

    up = run_command(compose_command(repo_root, "--profile", "app", "up", "-d", "--no-deps", "turbovas-api"), repo_root, env=runtime_env(repo_root), timeout=300)
    findings.append(process_step_finding("pass" if up.returncode == 0 else "fail", "compose.turbovas-api-up", f"docker compose up --no-deps turbovas-api exit code {up.returncode}.", up, compose_command(repo_root, "--profile", "app", "up", "-d", "--no-deps", "turbovas-api")))
    if up.returncode != 0:
        return make_result("runtime-native-api-rebuild", repo_root, "Native API rebuild stopped because turbovas-api restart failed.", findings, [str(runtime_dir(repo_root))])

    smoke = command_runtime_native_api_smoke(repo_root)
    findings.append(finding(smoke["status"], "native-api.smoke", smoke["summary"], details={"status": smoke["status"], "artifacts": smoke.get("artifacts", [])}))
    artifacts = sorted(set([str(runtime_dir(repo_root)), *smoke.get("artifacts", [])]))
    return make_result("runtime-native-api-rebuild", repo_root, "Native API sidecar rebuild attempted.", findings, artifacts)


def command_runtime_native_api_direct_smoke(repo_root: Path) -> dict[str, Any]:
