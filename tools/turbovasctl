def artifact_timestamp() -> str:
    return datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%S%fZ")


def retained_json_artifact_paths(artifact_dir: Path, stem: str, latest_name: str) -> tuple[Path, Path]:
    artifact_dir.mkdir(parents=True, exist_ok=True)
    timestamp = artifact_timestamp()
    path = artifact_dir / f"{stem}-{timestamp}.json"
    counter = 1
    while path.exists():
        path = artifact_dir / f"{stem}-{timestamp}-{counter}.json"
        counter += 1
    return artifact_dir / latest_name, path


def prune_retained_json_artifacts(artifact_dir: Path, stem: str, keep: int) -> None:
    if keep <= 0:
        return
    candidates = sorted(artifact_dir.glob(f"{stem}-*.json"), key=lambda path: path.name)
    for path in candidates[:-keep]:
        path.unlink(missing_ok=True)


def write_retained_json_artifact(latest_path: Path, timestamped_path: Path, payload: dict[str, Any], stem: str, keep: int) -> tuple[str, str]:
    latest_path.parent.mkdir(parents=True, exist_ok=True)
    text = json.dumps(payload, indent=2, sort_keys=True) + "\n"
    latest_path.write_text(text, encoding="utf-8")
    timestamped_path.write_text(text, encoding="utf-8")
    prune_retained_json_artifacts(latest_path.parent, stem, keep)
    return str(latest_path), str(timestamped_path)


def read_json_artifact(path: Path) -> dict[str, Any] | None:
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError):
        return None
    return data if isinstance(data, dict) else None


def json_artifact_history(artifact_dir: Path, stem: str) -> list[dict[str, Any]]:
    history: list[dict[str, Any]] = []
    for path in sorted(artifact_dir.glob(f"{stem}-*.json"), key=lambda candidate: candidate.name, reverse=True):
        payload = read_json_artifact(path) or {}
        try:
            mtime = datetime.fromtimestamp(path.stat().st_mtime, timezone.utc).replace(microsecond=0).isoformat()
        except OSError:
            mtime = None
        history.append(
            {
                "path": str(path),
                "name": path.name,
                "mtime": mtime,
                "generated_at": payload.get("metadata", {}).get("generated_at"),
                "status": payload.get("status", "unknown"),
                "summary": payload.get("summary", ""),
            }
        )
    return history


def gvm_cli_path(repo_root: Path) -> Path:
