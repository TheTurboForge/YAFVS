    for schema_name, (expected_values, expected_required, expected_properties) in contracts.items():
        block = openapi_component_schema_block(repo_root, schema_name)
        values = openapi_indented_scalar_fields(block)
        required = values.get("required")
        properties = {
            match.group(1)
            for line in block
            if (match := re.match(r"^        ([A-Za-z][A-Za-z0-9_-]*):$", line))
        }
        duplicates = openapi_duplicate_field_paths(block)
        observed[schema_name] = {
            "required": required,
            "properties": sorted(properties),
            "duplicate_field_paths": duplicates,
            "values": values,
        }
        if not block:
            missing.append({"field": f"components.schemas.{schema_name}", "expected": "schema"})
            continue
        if required != expected_required:
            invalid.append({"field": f"components.schemas.{schema_name}.required", "actual": required, "expected": expected_required})
        if properties != expected_properties:
            invalid.append({"field": f"components.schemas.{schema_name}.properties", "actual": sorted(properties), "expected": sorted(expected_properties)})
        if duplicates:
            invalid.append({"field": f"components.schemas.{schema_name}", "actual": duplicates, "expected": "unique YAML field paths"})
        for field, expected in sorted(expected_values.items()):
            if field not in values:
                missing.append({"field": f"components.schemas.{schema_name}.{field}", "expected": expected})
            elif values[field] != expected:
                invalid.append({"field": f"components.schemas.{schema_name}.{field}", "actual": values[field], "expected": expected})
    return {
        "tag_write_schema_missing": missing,
        "tag_write_schema_invalid": invalid,
        "tag_write_schema_observed": observed,
    }


def openapi_schedule_create_schema_contract_drift(repo_root: Path | None, operations: list[dict[str, Any]]) -> dict[str, Any]:
    candidates = [operation for operation in operations if operation.get("method") == "post" and operation.get("path") == "/schedules"]
    missing: list[dict[str, Any]] = []
    invalid: list[dict[str, Any]] = []
    observed: dict[str, Any] = {"schema_ref": None, "required": [], "values": {}}
    if len(candidates) != 1:
        missing.append({"field": "POST /schedules", "expected": "exactly one operation"})
        return {
            "schedule_create_schema_missing": missing,
            "schedule_create_schema_invalid": invalid,
            "schedule_create_schema_observed": observed,
        }
    operation = candidates[0]
    ref = operation.get("request_body_schema_ref")
    observed["schema_ref"] = ref
    if ref != "#/components/schemas/ScheduleCreateRequest":
        invalid.append(
            {
                "field": "POST /schedules.requestBody.schema.$ref",
                "actual": ref,
                "expected": "#/components/schemas/ScheduleCreateRequest",
            }
        )
        return {
            "schedule_create_schema_missing": missing,
            "schedule_create_schema_invalid": invalid,
            "schedule_create_schema_observed": observed,
        }
    block = openapi_component_schema_block(repo_root, "ScheduleCreateRequest")
    values = openapi_indented_scalar_fields(block)
    required = tuple(line.strip()[2:] for line in block if line.startswith("        - "))
    observed["required"] = list(required)
    observed["values"] = values
    if not block:
        missing.append({"field": "components.schemas.ScheduleCreateRequest", "expected": "schema"})
    if required != OPENAPI_SCHEDULE_CREATE_SCHEMA_EXPECTED_REQUIRED:
        invalid.append(
            {
                "field": "components.schemas.ScheduleCreateRequest.required",
                "actual": list(required),
                "expected": list(OPENAPI_SCHEDULE_CREATE_SCHEMA_EXPECTED_REQUIRED),
            }
        )
    for field, expected in sorted(OPENAPI_SCHEDULE_CREATE_SCHEMA_EXPECTED_VALUES.items()):
        if field not in values:
            missing.append({"field": f"components.schemas.ScheduleCreateRequest.{field}", "expected": expected})
        elif values[field] != expected:
            invalid.append(
                {
                    "field": f"components.schemas.ScheduleCreateRequest.{field}",
                    "actual": values[field],
                    "expected": expected,
                }
            )
    return {
        "schedule_create_schema_missing": missing,
        "schedule_create_schema_invalid": invalid,
        "schedule_create_schema_observed": observed,
    }


def rust_collection_contract_constants(repo_root: Path | None) -> dict[str, int | None]:
    if repo_root is None:
        return {"default_page_size": None, "max_page_size": None, "max_filter_length": None}
    path = repo_root / "services" / "yafvs-api" / "src" / "collections.rs"
    try:
        source = path.read_text(encoding="utf-8")
    except OSError:
        source = ""

    def const_int(name: str) -> int | None:
        match = re.search(rf"pub\(crate\)\s+const\s+{re.escape(name)}\s*:\s*(?:i64|usize)\s*=\s*([0-9]+)\s*;", source)
        return int(match.group(1)) if match else None

    return {
        "default_page_size": const_int("DEFAULT_COLLECTION_PAGE_SIZE"),
        "max_page_size": const_int("MAX_COLLECTION_PAGE_SIZE"),
        "max_filter_length": const_int("MAX_COLLECTION_FILTER_LENGTH"),
    }


def rust_collection_contract_paths(repo_root: Path | None) -> list[str]:
    if repo_root is None:
        return []
    source = ""
    for relative_path in (
        "services/yafvs-api/src/collection_contract_tests.rs",
        "services/yafvs-api/src/main.rs",
    ):
        try:
            source += "\n" + (repo_root / relative_path).read_text(encoding="utf-8")
        except OSError:
            continue
    return sorted(
        {
            path
            for path in re.findall(r'path:\s*"(/api/v1[^"]+)"', source)
            if ":" not in path
        }
    )


def openapi_component_parameter_block(repo_root: Path | None, parameter_name: str) -> list[str]:
    lines = openapi_contract_lines(repo_root)
    in_components = False
    in_parameters = False
    in_parameter = False
    block: list[str] = []
    for line in lines:
        if line == "components:":
            in_components = True
            in_parameters = False
            in_parameter = False
            continue
        if in_components and line and not line.startswith(" "):
            break
        if not in_components:
            continue
        top_key_match = re.match(r"^  ([A-Za-z][A-Za-z0-9_-]*):$", line)
        if top_key_match:
            in_parameters = top_key_match.group(1) == "parameters"
            in_parameter = False
            continue
        if not in_parameters:
            continue
        parameter_match = re.match(r"^    ([A-Za-z][A-Za-z0-9_-]*):$", line)
        if parameter_match:
            if in_parameter:
                break
            in_parameter = parameter_match.group(1) == parameter_name
            continue
        if in_parameter:
            block.append(line)
    return block


def openapi_collection_query_contract_summary(repo_root: Path | None, operations: list[dict[str, Any]]) -> dict[str, Any]:
    rust_constants = rust_collection_contract_constants(repo_root)
    rust_contract_paths = rust_collection_contract_paths(repo_root)
    page_size_fields = openapi_indented_scalar_fields(openapi_component_parameter_block(repo_root, "PageSize"))
    filter_fields = openapi_indented_scalar_fields(openapi_component_parameter_block(repo_root, "Filter"))

    def int_value(value: str | None) -> int | None:
        return int(value) if isinstance(value, str) and re.fullmatch(r"[0-9]+", value) else None

    openapi_values = {
        "default_page_size": int_value(page_size_fields.get("schema.default")),
        "max_page_size": int_value(page_size_fields.get("schema.maximum")),
        "max_filter_length": int_value(filter_fields.get("schema.maxLength")),
    }
    mismatches = [
        {"field": field, "openapi": openapi_values.get(field), "rust": rust_constants.get(field)}
        for field in sorted(openapi_values)
        if openapi_values.get(field) != rust_constants.get(field)
    ]

    required = set(OPENAPI_COLLECTION_PARAMETER_REFS)
    incomplete_collection_parameters = []
    openapi_collection_paths = []
    for operation in operations:
        if operation.get("method") != "get":
            continue
        parameters = set(operation.get("parameters", [])) if isinstance(operation.get("parameters"), list) else set()
        present = parameters & required
        if present == required and isinstance(operation.get("path"), str):
            openapi_collection_paths.append(f"/api/v1{operation['path']}")
        if present and present != required:
            incomplete_collection_parameters.append(
                {
                    "operation": openapi_operation_label(operation),
                    "present": sorted(present),
                    "missing": sorted(required - present),
                }
            )
    openapi_collection_paths = sorted(set(openapi_collection_paths))
    missing_openapi_collection_parameters = sorted(set(rust_contract_paths) - set(openapi_collection_paths))
    missing_rust_collection_contracts = sorted(set(openapi_collection_paths) - set(rust_contract_paths))
    return {
        "alignment_status": "pass" if not mismatches and not incomplete_collection_parameters and not missing_openapi_collection_parameters and not missing_rust_collection_contracts else "warn",
        "rust_collection_constants": rust_constants,
        "openapi_collection_values": openapi_values,
        "rust_collection_contract_count": len(rust_contract_paths),
        "openapi_collection_operation_count": len(openapi_collection_paths),
        "rust_collection_contract_paths": rust_contract_paths,
        "openapi_collection_paths": openapi_collection_paths,
        "collection_limit_mismatches": mismatches,
        "incomplete_collection_parameters": incomplete_collection_parameters,
        "missing_openapi_collection_parameters": missing_openapi_collection_parameters,
        "missing_rust_collection_contracts": missing_rust_collection_contracts,
    }


