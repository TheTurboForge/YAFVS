def validate_native_api_direct_host_value(value: str, *, env_name: str) -> str:
    host = value.strip()
    if not host:
        raise ValueError(f"{env_name} must not be empty")
    if any(ord(char) < 33 or char.isspace() for char in host):
        raise ValueError(f"{env_name} must not contain whitespace or control characters")
    if any(char in host for char in "/\\?#@,"):
        raise ValueError(f"{env_name} must be a host name or address, not a URL or host list")
    if host.startswith("["):
        if not re.fullmatch(r"\[[0-9A-Fa-f:.]+\]", host):
            raise ValueError(f"{env_name} must contain a bracketed IPv6 address like [::1]")
    elif ":" in host:
        raise ValueError(f"{env_name} must bracket IPv6 addresses, for example [::1]")
    elif not re.fullmatch(r"[A-Za-z0-9][A-Za-z0-9.-]*", host):
        raise ValueError(f"{env_name} must contain only host-safe ASCII characters")
    return host


def validate_native_api_direct_port_value(value: str, *, env_name: str) -> str:
    port = value.strip()
    if not port:
        raise ValueError(f"{env_name} must not be empty")
    if not port.isdigit():
        raise ValueError(f"{env_name} must be a decimal TCP port")
    number = int(port)
    if not 1 <= number <= 65535:
        raise ValueError(f"{env_name} must be between 1 and 65535")
    return str(number)


def validate_native_api_direct_bind_value(value: str, *, env_name: str) -> str:
    bind = value.strip()
    if not bind:
        raise ValueError(f"{env_name} must not be empty")
    if bind.startswith("["):
        host_end = bind.find("]")
        if host_end == -1 or len(bind) <= host_end + 2 or bind[host_end + 1] != ":":
            raise ValueError(f"{env_name} must be host:port or [ipv6]:port")
        host = bind[: host_end + 1]
        port = bind[host_end + 2 :]
    else:
        if bind.count(":") != 1:
            raise ValueError(f"{env_name} must be host:port or [ipv6]:port")
        host, port = bind.rsplit(":", 1)
    normalized_port = validate_native_api_direct_port_value(port, env_name=env_name)
    if normalized_port != TURBOVAS_API_DIRECT_CONTAINER_PORT:
        raise ValueError(
            f"{env_name} must use container port {TURBOVAS_API_DIRECT_CONTAINER_PORT} "
            "when managed by turbovasctl"
        )
    return f"{validate_native_api_direct_host_value(host, env_name=env_name)}:{normalized_port}"


