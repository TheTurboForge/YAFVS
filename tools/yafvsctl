                "direct_segment_guard_missing_property_count": details["direct_segment_guard_missing_property_count"],
                "direct_body_limit_alignment_status": details["direct_body_limit_alignment_status"],
                "direct_body_limit_missing_property_count": details["direct_body_limit_missing_property_count"],
            },
        ),
    ]
    result = make_result("native-api-client-contract", repo_root, "Native API generated-client contract checked.", findings)
    result["details"] = details
    if status_only:
        result = native_api_client_contract_status_only_result(result)
    return result


def command_native_tooling_state(repo_root: Path, compact: bool = False, summary_only: bool = False, status_only: bool = False) -> dict[str, Any]:
    items = native_tooling_inventory(repo_root)
    summary = summarize_native_tooling(items, repo_root)
    annotate_native_tooling_direct_api(summary, repo_root)
    summary["openapi_contract"] = native_api_openapi_contract_summary(repo_root)
    summary["module_ownership"] = native_api_module_ownership_summary(repo_root)
    endpoints = summary.get("implemented_native_endpoints", [])
    summary["browser_proxy_contract"] = native_api_browser_proxy_contract_summary(repo_root, [item for item in endpoints if isinstance(item, dict)])
    unknown_count = summary["by_category"]["unknown"]["count"]
    direct_contract = summary.get("direct_api_contract", {})
    direct_alignment_status = direct_contract.get("alignment_status", "warn") if isinstance(direct_contract, dict) else "warn"
    browser_proxy_contract = summary.get("browser_proxy_contract", {})
    browser_proxy_alignment_status = browser_proxy_contract.get("alignment_status", "warn") if isinstance(browser_proxy_contract, dict) else "warn"
    openapi_contract = summary.get("openapi_contract", {})
    openapi_alignment_status = openapi_contract.get("alignment_status", "warn") if isinstance(openapi_contract, dict) else "warn"
    module_ownership = summary.get("module_ownership", {})
    module_ownership_alignment_status = module_ownership.get("alignment_status", "warn") if isinstance(module_ownership, dict) else "warn"
    summary_details = compact_native_tooling_finding_details(summary)
    low_noise = compact or summary_only or status_only
    finding_details = summary_details if compact or low_noise else summary
    direct_finding_details = summary_details["direct_api_contract"] if low_noise else direct_contract
    browser_proxy_finding_details = summary_details["browser_proxy_contract"] if low_noise else browser_proxy_contract
    openapi_finding_details = summary_details["openapi_contract"] if low_noise else openapi_contract
    module_ownership_finding_details = summary_details["module_ownership"] if low_noise else module_ownership
    unknown_finding_details = {"count": unknown_count} if low_noise else {"paths": summary["by_category"]["unknown"]["paths"]}
    findings = [
        finding("pass", "native-tooling.inventory", f"Classified {len(items)} inherited tooling dependency surface(s).", details=finding_details),
        finding(
            contract_drift_status(direct_alignment_status),
            "native-tooling.direct-api-contract",
            "Native API endpoint inventory is aligned with Rust routes, Rust direct allowlist, and OpenAPI direct markers."
            if direct_alignment_status == "pass"
            else "Native API endpoint inventory, Rust routes, Rust direct allowlist, or OpenAPI direct markers differ.",
            details=direct_finding_details,
        ),
        finding(
            contract_drift_status(browser_proxy_alignment_status),
            "native-tooling.browser-proxy-contract",
            "Native API browser-proxied endpoint inventory is aligned with the gsad same-origin proxy allowlist."
            if browser_proxy_alignment_status == "pass"
            else "Native API browser-proxied endpoint inventory or internal-only exposure metadata differs from the gsad proxy allowlist.",
            details=browser_proxy_finding_details,
        ),
        finding(
            contract_drift_status(openapi_alignment_status),
            "native-tooling.openapi-contract",
            "Native API OpenAPI operations have deterministic operation IDs, exposure/migration metadata, shared Error responses, and collection query contracts."
            if openapi_alignment_status == "pass"
            else "Native API OpenAPI operation IDs, x-yafvs exposure/migration fields, shared Error responses, or collection query contracts need attention.",
            details=openapi_finding_details,
        ),
        finding(
            contract_drift_status(module_ownership_alignment_status),
            "native-tooling.module-ownership",
            "Native API moved module symbols remain in their owner modules."
            if module_ownership_alignment_status == "pass"
            else "Native API moved module symbols drifted out of their owner modules.",
            details=module_ownership_finding_details,
        ),
        finding("warn" if unknown_count else "pass", "native-tooling.unknown", f"{unknown_count} inherited tooling surface(s) are outside the current classification map." if unknown_count else "No inherited tooling surfaces were left unclassified.", details=unknown_finding_details),
        finding("pass", "native-tooling.end-state", "End-state remains full removal of required python-gvm and gvm-tools dependence after native API replacements land."),
    ]
    result = make_result("native-tooling-state", repo_root, "Inherited GMP/python-gvm/gvm-tools dependency state collected.", findings)
    if status_only or compact:
        result["details"] = native_tooling_status_only_details(summary)
        result["findings"] = native_tooling_status_only_findings(findings)
    elif summary_only:
        result["details"] = summary_details
    else:
        result["details"] = {"items": items, **summary}
    return result


def cmake_paths(repo_root: Path, component: str, profile: str | None = None) -> tuple[Path, Path, Path]:
    source = repo_root / COMPONENT_BY_NAME[component].path
    build_root = repo_root / "build" if profile is None else repo_root / "build" / profile
    build = build_root / component
    prefix = build_root / "prefix"
    return source, build, prefix


def hardened_flag_probe(repo_root: Path, flags: Sequence[str], *, link: bool = False) -> bool:
    compiler = shlex.split(os.environ.get("CC", "cc"))
    if not compiler or not shutil.which(compiler[0]):
        return False
    probe_root = repo_root / "build" / "hardened" / ".feature-probes"
    probe_root.mkdir(parents=True, exist_ok=True)
    with tempfile.TemporaryDirectory(dir=probe_root) as temporary:
        output = Path(temporary) / "probe"
        command = [*compiler, "-Werror", *flags, "-x", "c", "-"]
        if link:
            command.extend(["-o", str(output)])
        else:
            command.extend(["-c", "-o", str(output)])
        result = run_command(command, repo_root, env=build_env(repo_root, "hardened"), input_text="int main(void) { return 0; }\n")
    return result.returncode == 0


def cmake_fresh_support(repo_root: Path) -> tuple[bool, str]:
    cmake = shutil.which("cmake")
    if not cmake:
        return False, "cmake is unavailable; hardened profiles require cmake with --fresh support"
    result = run_command([cmake, "--help"], repo_root)
    if result.returncode != 0 or "--fresh" not in result.stdout:
        return False, "installed cmake does not advertise --fresh; cmake >= 3.24 is required for hardened profiles"
    return True, ""


def hardened_control_flow_required(machine: str | None = None) -> bool:
    return (machine or os.uname().machine).lower() in HARDENED_CONTROL_FLOW_ARCHITECTURES


def hardened_required_features(machine: str | None = None) -> tuple[str, ...]:
    required = list(HARDENED_REQUIRED_FEATURES)
    if hardened_control_flow_required(machine):
        required.append("control_flow_protection")
    return tuple(required)


def hardened_profile_configuration(repo_root: Path) -> tuple[list[str], dict[str, dict[str, Any]]]:
    compiler_flags = ["-O2", "-g", "-DNDEBUG", "-Wall", "-Wextra", "-Wformat", "-Wformat=2"]
    linker_flags: list[str] = []
    evidence: dict[str, dict[str, Any]] = {}

    def compiler_feature(name: str, flags: list[str]) -> None:
        supported = hardened_flag_probe(repo_root, flags)
        evidence[name] = {"status": "present" if supported else "unsupported", "flags": flags}
        if supported:
            compiler_flags.extend(flags)

    def linker_feature(name: str, flags: list[str]) -> None:
        supported = hardened_flag_probe(repo_root, flags, link=True)
        evidence[name] = {"status": "present" if supported else "unsupported", "flags": flags}
        if supported:
            linker_flags.extend(flags)

    compiler_feature("format_security", ["-Werror=format-security"])
    compiler_feature("format_nonliteral_compat", ["-Wno-error=format-nonliteral"])
    fortify_level_three_supported = hardened_flag_probe(
        repo_root, ["-O2", "-U_FORTIFY_SOURCE", "-D_FORTIFY_SOURCE=3"]
    )
    # Retained CMake roots append their inherited Fortify level after user C flags.
    # Level 2 is the highest effective cross-component contract without editing them.
    fortify_level = 3 if fortify_level_three_supported else 2
    fortify_flags = ["-U_FORTIFY_SOURCE", f"-D_FORTIFY_SOURCE={fortify_level}"]
    compiler_feature("fortify", fortify_flags)
    evidence["fortify"]["level_three_supported"] = fortify_level_three_supported
    evidence["fortify"]["selected_level"] = fortify_level
    compiler_feature("stack_protector", ["-fstack-protector-strong"])
    compiler_feature("stack_clash", ["-fstack-clash-protection"])
    machine = os.uname().machine.lower()
    if machine in {"x86_64", "amd64"}:
        compiler_feature("control_flow_protection", ["-fcf-protection=full"])
    elif machine in {"aarch64", "arm64"}:
        compiler_feature("control_flow_protection", ["-mbranch-protection=standard"])
    else:
        evidence["control_flow_protection"] = {"status": "unsupported", "flags": [], "reason": f"no profile flag for {machine}"}

    linker_feature("relro", ["-Wl,-z,relro"])
    linker_feature("now", ["-Wl,-z,now"])
    linker_feature("noexecstack", ["-Wl,-z,noexecstack"])
    pie_supported = hardened_flag_probe(repo_root, ["-fPIE", "-pie"], link=True)
    evidence["pie"] = {
        "status": "present" if pie_supported else "unsupported",
        "flags": ["CMAKE_POSITION_INDEPENDENT_CODE=ON", "-pie"],
    }

    injection_path = repo_root / HARDENED_CMAKE_INJECTION
    injection_path.parent.mkdir(parents=True, exist_ok=True)
    injection_path.write_text(
        "# Generated by tools/yafvsctl; do not edit.\n"
        "if(NOT YAFVS_HARDENING_OPTIONS_APPLIED)\n"
        "  set(YAFVS_HARDENING_OPTIONS_APPLIED TRUE)\n"
        "  add_compile_options(\n"
        + "".join(f"    {flag}\n" for flag in compiler_flags)
        + "  )\n"
        "endif()\n",
        encoding="utf-8",
    )
    configuration = {
        "schema_version": 1,
        "architecture": os.uname().machine,
        "compile_options": compiler_flags,
        "linker_options": linker_flags,
        "features": evidence,
        "cmake_injection": str(HARDENED_CMAKE_INJECTION),
    }
    write_json_artifact((repo_root / HARDENED_CONFIGURATION).parent, HARDENED_CONFIGURATION.name, configuration)

    cmake_args = [
        "-DCMAKE_BUILD_TYPE=Release",
        "-DCMAKE_EXPORT_COMPILE_COMMANDS=ON",
        "-DCMAKE_POSITION_INDEPENDENT_CODE=ON",
        f"-DCMAKE_PROJECT_INCLUDE={injection_path}",
        "-DCMAKE_SHARED_LINKER_FLAGS=" + " ".join(linker_flags),
        "-DCMAKE_MODULE_LINKER_FLAGS=" + " ".join(linker_flags),
    ]
    executable_linker_flags = [*linker_flags, "-pie"] if pie_supported else linker_flags
    cmake_args.append("-DCMAKE_EXE_LINKER_FLAGS=" + " ".join(executable_linker_flags))
    return cmake_args, evidence


def cmake_configure(repo_root: Path, meta: BuildMeta, profile: str | None = None) -> subprocess.CompletedProcess[str]:
    if profile == "hardened":
        fresh_supported, fresh_error = cmake_fresh_support(repo_root)
        if not fresh_supported:
            return subprocess.CompletedProcess(["cmake", "--fresh"], 2, fresh_error)
    source, build, prefix = cmake_paths(repo_root, meta.name, profile)
    build.mkdir(parents=True, exist_ok=True)
    prefix.mkdir(parents=True, exist_ok=True)
    run_dir = repo_root / "build" / "run" / "gvm"
    gvmd_run_dir = repo_root / "build" / "run" / "gvmd"
    gsad_run_dir = repo_root / "build" / "run" / "gsad"
    state_dir = repo_root / "build" / "var"
    log_dir = repo_root / "build" / "logs"
    sysconf_dir = prefix / "etc"
    command = [
        "cmake",
        *(["--fresh"] if profile == "hardened" else []),
        "-S",
        str(source),
        "-B",
        str(build),
        "-G",
        "Ninja",
        f"-DCMAKE_INSTALL_PREFIX={prefix}",
        f"-DCMAKE_PREFIX_PATH={prefix}",
        f"-DSYSCONFDIR={sysconf_dir}",
        f"-DLOCALSTATEDIR={state_dir}",
        f"-DGVM_RUN_DIR={run_dir}",
        f"-DGVMD_RUN_DIR={gvmd_run_dir}",
        f"-DGSAD_RUN_DIR={gsad_run_dir}",
        f"-DGVM_STATE_DIR={state_dir / 'lib' / 'gvm'}",
        f"-DGVMD_STATE_DIR={state_dir / 'lib' / 'gvm' / 'gvmd'}",
        f"-DGVM_LOG_DIR={log_dir}",
        *meta.cmake_args,
    ]
    if profile == "hardened":
        profile_args, evidence = hardened_profile_configuration(repo_root)
        failed_features = [
            name
            for name in hardened_required_features()
            if evidence.get(name, {}).get("status") != "present"
        ]
        if failed_features:
            return subprocess.CompletedProcess(
                ["cmake", "hardened-profile-probes"],
                2,
                "Required hardened profile feature probe(s) failed: " + ", ".join(failed_features),
            )
        command.extend(profile_args)
    if meta.name == "pg-gvm":
        command.append(f"-DCMAKE_INSTALL_DEV_PREFIX={prefix}")
    return run_command(command, repo_root, env=build_env(repo_root, profile))


def command_configure(repo_root: Path, component: str, profile: str | None = None) -> dict[str, Any]:
    meta = BUILD_META.get(component)
    if not meta:
        return make_result("configure", repo_root, f"Unknown component {component}.", [finding("fail", "component.known", f"Unknown component {component}.")])
    if meta.build_system != "cmake":
        if profile is not None:
            return make_result("configure", repo_root, f"Configure profile {profile} only supports CMake components.", [finding("fail", "build.profile-unsupported", f"{component} uses {meta.build_system}, not cmake.")])
        return make_result("configure", repo_root, f"{component} is not a CMake component.", [finding("warn", "build.unsupported", f"{component} uses {meta.build_system}, not cmake.")])
    if profile is None:
        guard = live_app_build_guard(repo_root, "configure")
        if guard is not None:
            return guard
    result = cmake_configure(repo_root, meta, profile)
    _, build, _ = cmake_paths(repo_root, component, profile)
    status = "pass" if result.returncode == 0 else "fail"
    return make_result("configure", repo_root, f"Configure {component} completed with exit code {result.returncode}.", [finding(status, "cmake.configure", f"{component} configure {'succeeded' if status == 'pass' else 'failed'}.", str(build.relative_to(repo_root)), {"output_tail": result.stdout.splitlines()[-80:]})], [str(build.relative_to(repo_root))])


def command_build(
    repo_root: Path,
    component: str,
    install: bool = False,
    configure_first: bool = True,
    profile: str | None = None,
    *,
    lifecycle_managed: bool = False,
) -> dict[str, Any]:
    if not lifecycle_managed:
        try:
            with acquire_runtime_lock(
                repo_root, FEED_ACTIVATION_LOCK, f"build {component}"
            ):
                return command_build(
                    repo_root,
                    component,
                    install=install,
                    configure_first=configure_first,
                    profile=profile,
                    lifecycle_managed=True,
                )
        except RuntimeLockTimeout as error:
            return make_result(
                "build",
                repo_root,
                f"Build {component} stopped while waiting for the feed lifecycle lock.",
                [runtime_lock_timeout_finding(error, "feed-generation.activation-lock")],
            )
    meta = BUILD_META.get(component)
    if not meta:
        return make_result("build", repo_root, f"Unknown component {component}.", [finding("fail", "component.known", f"Unknown component {component}.")])
    if profile is not None and meta.build_system != "cmake":
        return make_result("build", repo_root, f"Build profile {profile} only supports CMake components.", [finding("fail", "build.profile-unsupported", f"{component} uses {meta.build_system}, not cmake.")])
    if profile is None and meta.name != "gsa":
        guard = live_app_build_guard(repo_root, "build")
        if guard is not None:
            return guard
    if meta.build_system == "node-npm":
        return command_build_node(repo_root, meta)
    if meta.build_system in ("python-uv", "python-poetry-core"):
        return command_build_python(repo_root, meta)
    if meta.build_system != "cmake":
        return make_result("build", repo_root, f"{component} is not a CMake component.", [finding("warn", "build.unsupported", f"{component} uses {meta.build_system}, not cmake.")])
    findings: list[dict[str, Any]] = []
    _, build, prefix = cmake_paths(repo_root, component, profile)
    if configure_first:
        configure = cmake_configure(repo_root, meta, profile)
        findings.append(finding("pass" if configure.returncode == 0 else "fail", "cmake.configure", f"{component} configure exit code {configure.returncode}.", str(build.relative_to(repo_root)), {"output_tail": configure.stdout.splitlines()[-60:]}))
        if configure.returncode != 0:
            return make_result("build", repo_root, f"Build {component} stopped at configure.", findings, [str(build.relative_to(repo_root))])
    build_result = run_command(["cmake", "--build", str(build), "--parallel"], repo_root, env=build_env(repo_root, profile))
    findings.append(finding("pass" if build_result.returncode == 0 else "fail", "cmake.build", f"{component} build exit code {build_result.returncode}.", str(build.relative_to(repo_root)), {"output_tail": build_result.stdout.splitlines()[-80:]}))
    if build_result.returncode == 0 and (install or meta.install_for_dependents):
        install_result = run_command(["cmake", "--install", str(build)], repo_root, env=build_env(repo_root, profile))
        findings.append(finding("pass" if install_result.returncode == 0 else "fail", "cmake.install", f"{component} install exit code {install_result.returncode}.", str(prefix.relative_to(repo_root)), {"output_tail": install_result.stdout.splitlines()[-60:]}))
    return make_result("build", repo_root, f"Build {component} completed.", findings, [str(build.relative_to(repo_root)), str(prefix.relative_to(repo_root))])


def command_build_node(repo_root: Path, meta: BuildMeta) -> dict[str, Any]:
    if meta.name == "gsa":
        try:
            with acquire_runtime_lock(repo_root, GSA_OPERATION_LOCK, f"build {meta.name}"):
                return command_build_node_unlocked(repo_root, meta)
        except RuntimeLockTimeout as exc:
            return make_result("build", repo_root, f"Build {meta.name} stopped while waiting for the GSA operation lock.", [runtime_lock_timeout_finding(exc, "gsa.lock")], [f"{COMPONENT_BY_NAME[meta.name].path}/node_modules"])
    return command_build_node_unlocked(repo_root, meta)


def command_build_node_unlocked(repo_root: Path, meta: BuildMeta) -> dict[str, Any]:
    component = COMPONENT_BY_NAME[meta.name]
    component_path = repo_root / component.path
    findings: list[dict[str, Any]] = []
    npm_ci = run_command(["npm", "ci"], component_path, env=build_env(repo_root))
    findings.append(finding("pass" if npm_ci.returncode == 0 else "fail", "npm.ci", f"{meta.name} npm ci exit code {npm_ci.returncode}.", component.path, {"output_tail": npm_ci.stdout.splitlines()[-80:]}))
    if npm_ci.returncode != 0:
        return make_result("build", repo_root, f"Build {meta.name} stopped at npm ci.", findings, [f"{component.path}/node_modules"])
    for script in meta.node_scripts:
        result = run_command(["npm", "run", script], component_path, env=build_env(repo_root))
        findings.append(finding("pass" if result.returncode == 0 else "fail", "npm.script", f"{meta.name} npm run {script} exit code {result.returncode}.", component.path, {"script": script, "output_tail": result.stdout.splitlines()[-80:]}))
        if result.returncode != 0:
            break
    return make_result("build", repo_root, f"Build {meta.name} completed.", findings, [f"{component.path}/node_modules", f"{component.path}/build"])


def venv_python(repo_root: Path, component: str) -> Path:
    return repo_root / "build" / "venvs" / component / "bin" / "python"


def command_build_python(repo_root: Path, meta: BuildMeta) -> dict[str, Any]:
    component = COMPONENT_BY_NAME[meta.name]
    component_path = repo_root / component.path
    venv = repo_root / "build" / "venvs" / meta.name
    findings: list[dict[str, Any]] = []
    create = run_command(["uv", "venv", "--clear", str(venv)], repo_root, env=build_env(repo_root))
    findings.append(finding("pass" if create.returncode == 0 else "fail", "python.venv", f"{meta.name} uv venv exit code {create.returncode}.", str(venv.relative_to(repo_root)), {"output_tail": create.stdout.splitlines()[-40:]}))
    if create.returncode != 0:
        return make_result("build", repo_root, f"Build {meta.name} stopped at venv creation.", findings, [str(venv.relative_to(repo_root))])
    python = venv_python(repo_root, meta.name)
    for local_dep in meta.python_local_deps:
        dep_path = repo_root / COMPONENT_BY_NAME[local_dep].path
        install_dep = run_command(["uv", "pip", "install", "--python", str(python), "-e", str(dep_path)], repo_root, env=build_env(repo_root))
        findings.append(finding("pass" if install_dep.returncode == 0 else "fail", "python.local-dep", f"{meta.name} install local dependency {local_dep} exit code {install_dep.returncode}.", COMPONENT_BY_NAME[local_dep].path, {"dependency": local_dep, "output_tail": install_dep.stdout.splitlines()[-60:]}))
        if install_dep.returncode != 0:
            return make_result("build", repo_root, f"Build {meta.name} stopped at local dependency {local_dep}.", findings, [str(venv.relative_to(repo_root))])
    install = run_command(["uv", "pip", "install", "--python", str(python), "-e", str(component_path)], repo_root, env=build_env(repo_root))
    findings.append(finding("pass" if install.returncode == 0 else "fail", "python.install", f"{meta.name} editable install exit code {install.returncode}.", component.path, {"output_tail": install.stdout.splitlines()[-80:]}))
    if install.returncode != 0:
        return make_result("build", repo_root, f"Build {meta.name} stopped at install.", findings, [str(venv.relative_to(repo_root))])
    for import_name in meta.python_imports:
        result = run_command([str(python), "-c", f"import {import_name}"], repo_root, env=build_env(repo_root))
        findings.append(finding("pass" if result.returncode == 0 else "fail", "python.import", f"{meta.name} import {import_name} exit code {result.returncode}.", component.path, {"import": import_name, "output_tail": result.stdout.splitlines()[-40:]}))
        if result.returncode != 0:
            break
    return make_result("build", repo_root, f"Build {meta.name} completed.", findings, [str(venv.relative_to(repo_root))])


def command_build_chain(
    repo_root: Path,
    command: str,
    chain: tuple[str, ...],
    profile: str | None = None,
    *,
    lifecycle_managed: bool = False,
) -> dict[str, Any]:
    if not lifecycle_managed:
        try:
            with acquire_runtime_lock(repo_root, FEED_ACTIVATION_LOCK, command):
                return command_build_chain(
                    repo_root,
                    command,
                    chain,
                    profile,
                    lifecycle_managed=True,
                )
        except RuntimeLockTimeout as error:
            return make_result(
                command,
                repo_root,
                f"{command} stopped while waiting for the feed lifecycle lock.",
                [runtime_lock_timeout_finding(error, "feed-generation.activation-lock")],
            )
    findings: list[dict[str, Any]] = []
    artifacts: list[str] = []
    for component in chain:
        result = command_build(repo_root, component, install=BUILD_META[component].install_for_dependents, profile=profile, lifecycle_managed=True)
        artifacts.extend(result["artifacts"])
        findings.append(finding(result["status"], f"{command}.component", f"{component}: {result['summary']}", details={"component": component}))
        for item in result["findings"]:
            item = dict(item)
            item["check"] = f"{component}.{item['check']}"
            findings.append(item)
        if result["status"] == "fail":
            break
    return make_result(command, repo_root, f"{command} attempted.", findings, sorted(set(artifacts)))


def command_build_core_c(repo_root: Path, profile: str | None = None) -> dict[str, Any]:
    return command_build_chain(repo_root, "build-core-c", CORE_C_CHAIN, profile)


def hardened_build_preflight_cleanup(repo_root: Path) -> dict[str, Any]:
    build_root = repo_root / "build" / "hardened"
    paths = [*(build_root / component for component in C_SERVICES_CHAIN), build_root / "prefix"]
    removed: list[str] = []
    errors: list[dict[str, str]] = []
    unsafe_parent = next(
        (path for path in (repo_root / "build", build_root) if path.is_symlink()),
        None,
    )
    if unsafe_parent is not None:
        return finding(
            "fail",
            "build-c-services.hardened-preflight",
            "Hardened generated-tree cleanup refused a symlinked build parent.",
            str(unsafe_parent.relative_to(repo_root)),
            {
                "requested_paths": [str(path.relative_to(repo_root)) for path in paths],
                "removed_paths": removed,
                "errors": [{"path": str(unsafe_parent.relative_to(repo_root)), "error": "symlinked build parent"}],
            },
        )
    for path in paths:
        relative_path = str(path.relative_to(repo_root))
        try:
            if path.is_symlink() or path.is_file():
                path.unlink()
                removed.append(relative_path)
            elif path.is_dir():
                shutil.rmtree(path)
                removed.append(relative_path)
        except OSError as exc:
            errors.append({"path": relative_path, "error": str(exc)})
    return finding(
        "fail" if errors else "pass",
        "build-c-services.hardened-preflight",
        "Hardened generated component trees and dependency prefix could not be fully reset."
        if errors
        else "Hardened generated component trees and dependency prefix were reset before the build chain.",
        "build/hardened",
        {
            "requested_paths": [str(path.relative_to(repo_root)) for path in paths],
            "removed_paths": removed,
            "errors": errors,
        },
    )


def command_build_c_services(repo_root: Path, profile: str | None = None) -> dict[str, Any]:
    manifest_path = repo_root / HARDENED_BUILD_MANIFEST
    if profile == "hardened":
        cleanup_finding = hardened_build_preflight_cleanup(repo_root)
        if cleanup_finding["status"] == "fail":
            return make_result("build-c-services", repo_root, "Hardened build stopped during generated-tree cleanup.", [cleanup_finding])
        try:
            manifest_path.unlink(missing_ok=True)
        except OSError as exc:
            return make_result(
                "build-c-services",
                repo_root,
                "Hardened build stopped while invalidating prior evidence.",
                [finding("fail", "build-c-services.hardening-manifest", f"Prior hardened manifest could not be removed: {exc}.", str(HARDENED_BUILD_MANIFEST))],
            )
    result = command_build_chain(repo_root, "build-c-services", C_SERVICES_CHAIN, profile)
    if profile == "hardened":
        result["findings"].insert(0, cleanup_finding)
        result["status"] = aggregate_status(result["findings"])
    if profile == "hardened" and result["status"] == "pass":
        manifest_finding = rust_c_hardening_manifest_finding(repo_root)
        result["findings"].append(manifest_finding)
        result["artifacts"] = sorted(set([*result["artifacts"], str(HARDENED_BUILD_MANIFEST)]))
        result["status"] = aggregate_status(result["findings"])
    return result


def rust_c_hardening_manifest_finding(repo_root: Path) -> dict[str, Any]:
    expected_check = "build-c-services.hardening-manifest"
    expected_path = str(HARDENED_BUILD_MANIFEST)
    command = [
        "cargo",
        "run",
        "--quiet",
        "--locked",
        "--target-dir",
        str(repo_root / "build" / "yafvsctl-rs"),
        "--manifest-path",
        str(repo_root / YAFVSCTL_RUST_CRATE / "Cargo.toml"),
        "--",
        "c-hardening-manifest-write",
        "--json",
    ]
    try:
        completed = run_command(command, repo_root, timeout=300)
    except OSError:
        completed = None
    stdout = completed.stdout if completed is not None else None
    if not isinstance(stdout, str) or len(stdout.encode("utf-8")) > YAFVSCTL_RUST_BRIDGE_MAX_OUTPUT_BYTES:
        payload = None
    else:
        try:
            payload = json.loads(stdout, object_pairs_hook=reject_duplicate_json_object_keys)
        except (json.JSONDecodeError, ValueError):
            payload = None

    findings = payload.get("findings") if isinstance(payload, dict) else None
    metadata_block = payload.get("metadata") if isinstance(payload, dict) else None
    item = findings[0] if isinstance(findings, list) and len(findings) == 1 else None
    status = item.get("status") if isinstance(item, dict) else None
    valid = (
        completed is not None
        and completed.returncode == (1 if status == "fail" else 0)
        and status in {"pass", "fail"}
        and isinstance(item.get("message"), str)
        and item.get("check") == expected_check
        and item.get("path") == expected_path
        and payload.get("status") == status
        and isinstance(payload.get("summary"), str)
        and isinstance(metadata_block, dict)
        and metadata_block.get("command") == "c-hardening-manifest-write"
    )
    if valid:
        return dict(item)
    return finding(
        "fail",
        expected_check,
        "Rust hardened build manifest writer failed closed because its result was unavailable or invalid.",
        expected_path,
    )


