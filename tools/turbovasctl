def native_tooling_gvm_tools_removal_bucket(relative_path: str) -> str:
    name = Path(relative_path).name
    for bucket, names in NATIVE_TOOLING_GVM_TOOLS_REMOVAL_BUCKETS.items():
        if name in names:
            return bucket
    return "needs_review"


def native_tooling_removal_review(paths: list[str]) -> dict[str, Any]:
    buckets = {
        bucket: {"count": 0, "paths": [], "reason": reason}
        for bucket, reason in NATIVE_TOOLING_GVM_TOOLS_REMOVAL_BUCKET_REASONS.items()
    }
    for path in sorted(paths):
        bucket = native_tooling_gvm_tools_removal_bucket(path)
        buckets[bucket]["count"] += 1
        buckets[bucket]["paths"].append(path)
    return {
        "total": len(paths),
        "safe_removal_count": buckets["native_read_replaced"]["count"],
        "blocked_or_review_count": len(paths) - buckets["native_read_replaced"]["count"],
        "buckets": {bucket: data for bucket, data in buckets.items() if data["count"] > 0},
    }


