def native_tooling_gvm_tools_removal_bucket(relative_path: str) -> str:
    name = Path(relative_path).name
    for bucket, names in NATIVE_TOOLING_GVM_TOOLS_REMOVAL_BUCKETS.items():
        if name in names:
            return bucket
    return "needs_review"


def native_tooling_removal_review(paths: list[str]) -> dict[str, Any]:
    buckets = {
        bucket: {"count": 0, "paths": [], "reason": reason}
        for bucket, reason in NATIVE_TOOLING_GVM_TOOLS_REMOVAL_BUCKET_REASONS.items()
    }
    for path in sorted(paths):
        bucket = native_tooling_gvm_tools_removal_bucket(path)
        buckets[bucket]["count"] += 1
        buckets[bucket]["paths"].append(path)
        path_blocker = NATIVE_TOOLING_GVM_TOOLS_PATH_BLOCKERS.get(Path(path).name)
        if path_blocker:
            buckets[bucket].setdefault("path_blockers", {})[path] = path_blocker
    return {
        "total": len(paths),
        "safe_removal_count": buckets["native_read_replaced"]["count"],
        "blocked_or_review_count": len(paths) - buckets["native_read_replaced"]["count"],
        "buckets": {bucket: data for bucket, data in buckets.items() if data["count"] > 0},
    }


def native_api_direct_token_sources(repo_root: Path, env: dict[str, str]) -> tuple[tuple[str, ...], Path, bool]:
    sources: list[str] = []
    if env.get(TURBOVAS_API_BEARER_TOKEN_ENV):
        sources.append("environment")
    if env.get(TURBOVAS_API_BEARER_TOKEN_FILE_ENV):
        sources.append("configured-token-file")
    secret_path = runtime_secret_path(repo_root, TURBOVAS_API_BEARER_TOKEN_SECRET)
    secret_present = False
    try:
        secret_present = secret_path.is_file() and bool(secret_path.read_text(encoding="utf-8").strip())
    except OSError:
        pass
    if running_service_env_value(repo_root, "turbovas-api", TURBOVAS_API_BEARER_TOKEN_ENV):
        sources.append("running-container-env")
    running_token_file = running_service_env_value(repo_root, "turbovas-api", TURBOVAS_API_BEARER_TOKEN_FILE_ENV)
    if running_token_file:
        sources.append("running-container-token-file")
    return tuple(sources), secret_path, secret_present


def native_api_direct_host_token_file_path(repo_root: Path, token_file: str) -> Path:
    if token_file == TURBOVAS_API_BEARER_TOKEN_CONTAINER_FILE:
        return runtime_secret_path(repo_root, TURBOVAS_API_BEARER_TOKEN_SECRET)
    return Path(token_file).expanduser()


def native_api_direct_token_file_metadata(repo_root: Path, env: dict[str, str]) -> dict[str, Any]:
    configured_token_file = env.get(TURBOVAS_API_BEARER_TOKEN_FILE_ENV, "").strip()
    if configured_token_file:
        host_path = native_api_direct_host_token_file_path(repo_root, configured_token_file)
        metadata = runtime_secret_file_metadata(host_path)
        source = "runtime-secret-file" if configured_token_file == TURBOVAS_API_BEARER_TOKEN_CONTAINER_FILE else "configured-token-file"
        return {
            **metadata,
            "source": source,
            "configured_value": configured_token_file,
            "host_path": str(host_path),
            "host_metadata_available": True,
        }

    running_token_file = running_service_env_value(repo_root, "turbovas-api", TURBOVAS_API_BEARER_TOKEN_FILE_ENV)
    if running_token_file:
        if running_token_file == TURBOVAS_API_BEARER_TOKEN_CONTAINER_FILE:
            host_path = runtime_secret_path(repo_root, TURBOVAS_API_BEARER_TOKEN_SECRET)
            metadata = runtime_secret_file_metadata(host_path)
            return {
                **metadata,
                "source": "running-container-token-file",
                "configured_value": running_token_file,
                "host_path": str(host_path),
                "host_metadata_available": True,
            }
        return {
            "exists": None,
            "mode": None,
            "permission_ok": None,
            "group_or_world_accessible": None,
            "source": "running-container-token-file",
            "configured_value": running_token_file,
            "host_path": None,
            "host_metadata_available": False,
        }

    host_path = runtime_secret_path(repo_root, TURBOVAS_API_BEARER_TOKEN_SECRET)
    metadata = runtime_secret_file_metadata(host_path)
    return {
        **metadata,
        "source": "runtime-secret-default",
        "configured_value": None,
        "host_path": str(host_path),
        "host_metadata_available": True,
    }


def direct_native_api_posture_findings(repo_root: Path, env: dict[str, str] | None = None) -> list[dict[str, Any]]:
    env = runtime_env(repo_root) if env is None else env
    findings: list[dict[str, Any]] = []
    configured = native_api_direct_requested(env)
    direct_env_names = (
        TURBOVAS_API_DIRECT_ENV,
        TURBOVAS_API_DIRECT_HOST_ENV,
        TURBOVAS_API_DIRECT_PORT_ENV,
        TURBOVAS_API_DIRECT_BIND_ENV,
        TURBOVAS_API_OPERATOR_UUID_ENV,
        TURBOVAS_API_OPERATOR_NAME_ENV,
        TURBOVAS_API_DIRECT_WRITE_CONTROL_ENV,
    )
    configured_env = [name for name in direct_env_names if env.get(name)]
    running_bindings = current_native_api_direct_published_bindings(repo_root)

    if configured:
        findings.append(native_api_direct_config_shape_finding(env, check="production.native-api-direct.config-shape"))

    if configured:
        config_errors = native_api_direct_config_errors(env)
        configured_host = native_api_direct_host(env)
        if config_errors:
            configured_status = "fail"
            configured_message = "Direct native API host publication has malformed host, port, or bind settings."
        elif host_is_wildcard(configured_host):
            configured_status = "fail"
            configured_message = "Direct native API host publication is configured for a broad wildcard binding."
        elif not host_is_loopback(configured_host):
            configured_status = "fail"
            configured_message = "Direct native API host publication is configured for explicit non-loopback access before production TLS/bootstrap/host-binding hardening is complete."
        else:
            configured_status = "pass"
            configured_message = "Direct native API host publication is configured for loopback access."
        findings.append(
            finding(
                configured_status,
                "production.native-api-direct.configured-binding",
                configured_message,
                details={
                    "enabled": True,
                    "host": configured_host,
                    "host_port": native_api_direct_port(env),
                    "host_binding": native_api_direct_port_binding(env),
                    "container_bind": env.get(TURBOVAS_API_DIRECT_BIND_ENV),
                    "configured_env": configured_env,
                },
            )
        )
    else:
        findings.append(
            finding(
                "pass",
                "production.native-api-direct.configured-binding",
                "Direct native API host publication is not configured; internal-only native API remains the default.",
                details={"enabled": False, "configured_env": configured_env},
            )
        )

    broad_running = [binding for binding in running_bindings if host_is_wildcard(binding.get("host", ""))]
    external_running = [binding for binding in running_bindings if not host_is_wildcard(binding.get("host", "")) and not host_is_loopback(binding.get("host", ""))]
    if broad_running:
        running_status = "fail"
        running_message = "A running direct native API listener is published on a broad wildcard host binding."
    elif external_running:
        running_status = "fail"
        running_message = "A running direct native API listener is published on explicit non-loopback host binding before production TLS/bootstrap/host-binding hardening is complete."
    elif running_bindings:
        running_status = "pass"
        running_message = "Any running direct native API listener is published only on loopback host binding."
    else:
        running_status = "pass"
        running_message = "No running direct native API host publication was detected."
    findings.append(
        finding(
            running_status,
            "production.native-api-direct.running-binding",
            running_message,
            details={"published_bindings": list(running_bindings)},
        )
    )

    token_sources, secret_path, secret_present = native_api_direct_token_sources(repo_root, env)
    configured_token = env.get(TURBOVAS_API_BEARER_TOKEN_ENV, "")
    configured_token_ok = direct_api_bearer_token_is_acceptable(configured_token) if configured_token else None
    secret_metadata = native_api_direct_token_file_metadata(repo_root, env)
    secret_file_used = "configured-token-file" in token_sources or "running-container-token-file" in token_sources
    environment_token_used = "environment" in token_sources or "running-container-env" in token_sources
    exposure_enabled = configured or bool(running_bindings)
    auth_details = {
        "exposure_enabled": exposure_enabled,
        "token_sources": list(token_sources),
        "environment_token_used": environment_token_used,
        "secret_file_used": secret_file_used,
        "bearer_token_env": TURBOVAS_API_BEARER_TOKEN_ENV,
        "bearer_token_file_env": TURBOVAS_API_BEARER_TOKEN_FILE_ENV,
        "minimum_token_length": TURBOVAS_API_BEARER_TOKEN_MIN_LENGTH,
        "maximum_token_length": TURBOVAS_API_BEARER_TOKEN_MAX_LENGTH,
        "configured_environment_token_ok": configured_token_ok,
        "runtime_secret": str(secret_path),
        "runtime_secret_present": secret_present,
        "token_file_source": secret_metadata["source"],
        "token_file_configured_value": secret_metadata["configured_value"],
        "token_file_host_path": secret_metadata["host_path"],
        "token_file_host_metadata_available": secret_metadata["host_metadata_available"],
        "runtime_secret_mode": secret_metadata["mode"],
        "runtime_secret_permission_ok": secret_metadata["permission_ok"],
        "runtime_secret_group_or_world_accessible": secret_metadata["group_or_world_accessible"],
    }
    if not exposure_enabled:
        findings.append(
            finding(
                "pass",
                "production.native-api-direct.auth-boundary",
                "Direct native API host exposure is disabled; no direct bearer boundary is needed for the internal-only default.",
                details=auth_details,
            )
        )
    elif configured_token_ok is False:
        findings.append(
            finding(
                "fail",
                "production.native-api-direct.auth-boundary",
                "Direct native API exposure is configured with a bearer token that is too short or contains unsafe characters.",
                details=auth_details,
            )
        )
    elif environment_token_used:
        findings.append(
            finding(
                "fail",
                "production.native-api-direct.auth-boundary",
                "Direct native API exposure uses a bearer token from environment variables; use the ignored runtime secret file boundary instead of publishing auth material through process/container environment.",
                details=auth_details,
            )
        )
    elif secret_file_used and secret_metadata["host_metadata_available"] and not secret_metadata["permission_ok"]:
        findings.append(
            finding(
                "fail",
                "production.native-api-direct.auth-boundary",
                "Direct native API exposure uses a bearer-token file that is missing or group/world accessible on the host.",
                details=auth_details,
            )
        )
    elif secret_file_used and not secret_metadata["host_metadata_available"]:
        findings.append(
            finding(
                "warn",
                "production.native-api-direct.auth-boundary",
                "Direct native API exposure uses a running container bearer-token file path that the host posture helper cannot inspect.",
                details=auth_details,
            )
        )
    elif token_sources:
        findings.append(
            finding(
                "pass",
                "production.native-api-direct.auth-boundary",
                "Direct native API exposure has an explicit bearer-token auth boundary configured.",
                details=auth_details,
            )
        )
    else:
        findings.append(
            finding(
                "fail",
                "production.native-api-direct.auth-boundary",
                "Direct native API exposure appears enabled without a bearer-token environment value or token-file boundary in the requested environment or running container; do not expose /api/v1 without the explicit B-130 auth boundary.",
                details=auth_details,
            )
        )
    return findings


def gsad_binding_transition_findings(repo_root: Path) -> list[dict[str, Any]]:
    current = current_gsad_published_hosts(repo_root)
    if not current:
        return []
    requested = gsad_hosts(repo_root)
    current_external = external_hosts(current)
    requested_external = external_hosts(requested)
    lost_external = tuple(host for host in current_external if host not in requested_external)
    if not lost_external:
        return []
    return [
        finding(
            "warn",
