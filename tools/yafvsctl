def command_runtime_smoke(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    findings.extend(ensure_runtime_dirs(repo_root))
    config = run_command(compose_command(repo_root, "config", "--quiet"), repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if config.returncode == 0 else "fail", "compose.config", f"Compose config validation exit code {config.returncode}.", str(compose_file(repo_root).relative_to(repo_root)), {"output_tail": config.stdout.splitlines()[-40:]}))
    port_config = run_command(compose_command(repo_root, "config"), repo_root, env=runtime_env(repo_root))
    broad_bindings = [line.strip() for line in port_config.stdout.splitlines() if "0.0.0.0:" in line or "[::]:" in line]
    findings.append(finding("fail" if broad_bindings else "pass", "runtime.ports", "No broad host port bindings found." if not broad_bindings else "Broad host port bindings found.", details={"broad_bindings": broad_bindings}))
    for service in RUNTIME_SERVICES:
        findings.append(finding("pass" if container_running(repo_root, service) else "fail", "runtime.running", f"{service} container is running.", details={"service": service}))
    if container_running(repo_root, "postgres"):
        result = postgres_ready(repo_root)
        findings.append(finding("pass" if result.returncode == 0 else "fail", "postgres.ready", f"pg_isready exit code {result.returncode}.", details={"output_tail": result.stdout.splitlines()[-20:]}))
        for collation in ensure_postgres_collation(repo_root, refresh_empty=False):
            if collation["status"] == "warn":
                collation = dict(collation)
                collation["status"] = "fail"
            findings.append(collation)
        extension = pg_gvm_extension_status(repo_root)
        if extension["status"] == "warn":
            extension = dict(extension)
            extension["status"] = "fail"
        findings.append(extension)
    if container_running(repo_root, "redis-openvas"):
        result = scanner_redis_ping(repo_root)
        findings.append(finding("pass" if result.returncode == 0 and "PONG" in result.stdout else "fail", "redis-openvas.ready", f"scanner Redis Unix socket ping exit code {result.returncode}.", str(scanner_redis_socket_path(repo_root)), {"output_tail": result.stdout.splitlines()[-20:]}))
        findings.append(finding("pass" if scanner_redis_socket_path(repo_root).is_socket() else "fail", "redis-openvas.socket", "scanner Redis Unix socket exists." if scanner_redis_socket_path(repo_root).is_socket() else "scanner Redis Unix socket is missing.", str(scanner_redis_socket_path(repo_root))))
    if container_running(repo_root, "mosquitto"):
        result = exec_in_service(repo_root, "mosquitto", mqtt_health_probe_command())
        findings.append(finding("pass" if result.returncode == 0 else "fail", "mosquitto.ready", f"mosquitto_pub broker check exit code {result.returncode}.", details={"output_tail": result.stdout.splitlines()[-20:]}))
    return make_result("runtime-smoke", repo_root, "Runtime smoke checks completed.", findings, [str(runtime_dir(repo_root))])


def _command_gvmd_smoke_unlocked(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    findings.append(active_feed_generation_finding(repo_root))
    if aggregate_status(findings) == "fail":
        return make_result("gvmd-smoke", repo_root, "gvmd smoke stopped at feed activation prerequisites.", findings)
    if pg_gvm_extension_status(repo_root)["status"] != "pass":
        findings.append(finding("fail", "gvmd.pg-gvm", "pg-gvm extension is not initialized; run just runtime-init before gvmd smoke."))
        return make_result("gvmd-smoke", repo_root, "gvmd smoke stopped before service startup.", findings)
    app_env = runtime_app_env(repo_root)
    receipt, receipt_error = require_app_deployment_receipt(
        repo_root, app_env=app_env
    )
    findings.append(finding("pass" if receipt_error is None else "fail", "runtime.app-deployment-receipt", "Prepared application deployment receipt is valid for the gvmd smoke." if receipt_error is None else receipt_error, str(app_deployment_receipt_path(repo_root))))
    if receipt_error is not None or receipt is None:
        return make_result("gvmd-smoke", repo_root, "gvmd smoke stopped because no verified application deployment was prepared.", findings)
    up_command = compose_command_with_app_images(repo_root, receipt["image_ids"], "--profile", "app", "up", "-d", "--no-deps", "--no-build", "--pull", "never", "gvmd", env=app_env)
    result = run_command(up_command, repo_root, env=app_env)
    findings.append(finding("pass" if result.returncode == 0 else "fail", "gvmd.up", f"docker compose up gvmd exit code {result.returncode}.", details={"output_tail": result.stdout.splitlines()[-80:]}))
    if result.returncode != 0:
        return make_result("gvmd-smoke", repo_root, "gvmd smoke stopped at container startup.", findings)
    probe = exec_in_service(repo_root, "gvmd", ["sh", "-lc", "command -v gvmd && gvmd --version"])
    findings.append(finding("pass" if probe.returncode == 0 else "warn", "gvmd.binary", f"gvmd binary probe exit code {probe.returncode}.", details={"output_tail": probe.stdout.splitlines()[-40:]}))
    db_probe = exec_in_service(
        repo_root,
        "gvmd",
        [
            "sh",
            "-lc",
            "env PGPASSWORD=${POSTGRES_PASSWORD:-yafvs-dev} psql -h postgres -U ${POSTGRES_USER:-yafvs} -d ${POSTGRES_DB:-yafvs} -At -c \"SELECT extversion FROM pg_extension WHERE extname = 'pg-gvm';\"",
        ],
    )
    findings.append(finding("pass" if db_probe.returncode == 0 and db_probe.stdout.strip() else "warn", "gvmd.database", f"gvmd profile DB probe exit code {db_probe.returncode}.", details={"output_tail": db_probe.stdout.splitlines()[-40:]}))
    findings.append(finding("warn", "gvmd.deferred", "This smoke does not start the full manager daemon yet; certificates, scanner registration, feeds, and runtime paths remain follow-up work."))
    return make_result("gvmd-smoke", repo_root, "gvmd profile smoke completed.", findings, [str(runtime_dir(repo_root))])


def command_gvmd_smoke(repo_root: Path) -> dict[str, Any]:
    try:
        with acquire_runtime_lock(repo_root, FEED_ACTIVATION_LOCK, "gvmd-smoke"):
            return _command_gvmd_smoke_unlocked(repo_root)
    except RuntimeLockTimeout as error:
        return make_result(
            "gvmd-smoke",
            repo_root,
            "gvmd smoke stopped while waiting for the feed lifecycle lock.",
            [runtime_lock_timeout_finding(error, "feed-generation.activation-lock")],
            [str(runtime_lock_dir(repo_root))],
        )


def quality_gate_doctor_status(doctor_result: dict[str, Any]) -> tuple[str, str]:
    allowed_warnings = {"git.worktree", "surface.deferred"}
    non_pass = [item for item in doctor_result.get("findings", []) if item.get("status") != "pass"]
    if doctor_result.get("status") == "warn" and non_pass and all(item.get("status") == "warn" and item.get("check") in allowed_warnings for item in non_pass):
        return "pass", "Doctor completed with only worktree/deferred-surface notes."
    return doctor_result.get("status", "fail"), doctor_result.get("summary", "Doctor status unavailable.")


def quality_gate_compact_step(result: dict[str, Any]) -> dict[str, Any]:
    non_pass = [item for item in result.get("findings", []) if item.get("status") != "pass"]
    return {
        "status": result.get("status", "fail"),
        "summary": result.get("summary", "Status unavailable."),
        "non_pass_findings": non_pass,
    }


def quality_gate_status_finding(check: str, result: dict[str, Any]) -> dict[str, Any]:
    step = quality_gate_compact_step(result)
    return finding(
        step["status"],
        check,
        step["summary"],
        details={"status": step["status"], "non_pass_count": len(step["non_pass_findings"])},
    )


def command_quality_gate(repo_root: Path, include_runtime: bool = False) -> dict[str, Any]:
    artifact_dir = quality_gate_artifact_dir(repo_root)
    artifact_dir.mkdir(parents=True, exist_ok=True)
    findings: list[dict[str, Any]] = []
    details: dict[str, Any] = {"steps": {}}

    license_result = rust_license_report_result(repo_root)
    details["steps"]["license-report"] = {"status": license_result["status"], "summary": license_result["summary"]}
    findings.append(finding(license_result["status"], "quality.license-report", license_result["summary"], details={"status": license_result["status"]}))

    doctor_result = rust_doctor_result(repo_root)
    doctor_status, doctor_summary = quality_gate_doctor_status(doctor_result)
    doctor_non_pass = [item for item in doctor_result.get("findings", []) if item.get("status") != "pass"]
    details["steps"]["doctor"] = {
        "status": doctor_result["status"],
        "quality_status": doctor_status,
        "summary": doctor_result["summary"],
        "non_pass_findings": doctor_non_pass,
    }
    findings.append(finding(doctor_status, "quality.doctor", doctor_summary, details={"status": doctor_result["status"], "quality_status": doctor_status}))

    native_contract_checks = (
        ("native-tooling-state", "quality.native-tooling-state", command_native_tooling_state(repo_root, status_only=True)),
        ("native-api-client-contract", "quality.native-api-client-contract", command_native_api_client_contract(repo_root, status_only=True)),
        ("native-api-migration-matrix", "quality.native-api-migration-matrix", command_native_api_migration_matrix(repo_root, status_only=True)),
    )
    for step_name, check_name, check_result in native_contract_checks:
        details["steps"][step_name] = quality_gate_compact_step(check_result)
        findings.append(quality_gate_status_finding(check_name, check_result))

    unit_command = [sys.executable, "-m", "unittest", "tools.tests.test_yafvsctl"]
    unit = run_command(unit_command, repo_root, env=quality_gate_unit_env(repo_root), timeout=300)
    details["steps"]["python-unit"] = {"exit_code": unit.returncode, "output_tail": output_tail(unit.stdout, 120)}
    findings.append(process_step_finding("pass" if unit.returncode == 0 else "fail", "quality.python-unit", f"Python tool unit tests exit code {unit.returncode}.", unit, unit_command))

    rust_cli_manifest = repo_root / YAFVSCTL_RUST_CRATE / "Cargo.toml"
    if rust_cli_manifest.is_file():
        rust_cli_fmt_command = ["cargo", "fmt", "--manifest-path", str(rust_cli_manifest), "--check"]
        rust_cli_fmt = run_command(rust_cli_fmt_command, repo_root, env=build_env(repo_root), timeout=120)
        details["steps"]["yafvsctl-rust-fmt"] = {"exit_code": rust_cli_fmt.returncode, "output_tail": output_tail(rust_cli_fmt.stdout, 120)}
        findings.append(process_step_finding("pass" if rust_cli_fmt.returncode == 0 else "fail", "quality.yafvsctl-rust-fmt", f"Rust yafvsctl cargo fmt exit code {rust_cli_fmt.returncode}.", rust_cli_fmt, rust_cli_fmt_command))

        rust_cli_test_command = [
            "cargo",
            "test",
            "--locked",
            "--target-dir",
            "build/yafvsctl-rs",
            "--manifest-path",
            str(rust_cli_manifest),
        ]
        rust_cli_test = run_command(rust_cli_test_command, repo_root, env=build_env(repo_root), timeout=300)
        details["steps"]["yafvsctl-rust-test"] = {"exit_code": rust_cli_test.returncode, "output_tail": output_tail(rust_cli_test.stdout, 160)}
        findings.append(process_step_finding("pass" if rust_cli_test.returncode == 0 else "fail", "quality.yafvsctl-rust-test", f"Rust yafvsctl cargo test exit code {rust_cli_test.returncode}.", rust_cli_test, rust_cli_test_command))

    py_files = [repo_root / "tools" / "yafvsctl", *sorted((repo_root / "tools").glob("runtime_*.py"))]
    py_compile_command = [sys.executable, "-m", "py_compile", *[str(path.relative_to(repo_root)) for path in py_files]]
    py_compile = run_command(py_compile_command, repo_root, env=build_env(repo_root), timeout=120)
    details["steps"]["py_compile"] = {"exit_code": py_compile.returncode, "files": [str(path.relative_to(repo_root)) for path in py_files], "output_tail": output_tail(py_compile.stdout, 120)}
    findings.append(process_step_finding("pass" if py_compile.returncode == 0 else "fail", "quality.py-compile", f"Python compile check exit code {py_compile.returncode}.", py_compile, py_compile_command))

    compose_command_line = compose_command(repo_root, "--profile", "app", "config", "--quiet")
    compose = run_command(compose_command_line, repo_root, env=runtime_env(repo_root), timeout=120)
    details["steps"]["compose-config"] = {"exit_code": compose.returncode, "output_tail": output_tail(compose.stdout, 120)}
    findings.append(process_step_finding("pass" if compose.returncode == 0 else "fail", "quality.compose-config", f"Compose config validation exit code {compose.returncode}.", compose, compose_command_line))

    api_manifest = repo_root / "services" / "yafvs-api" / "Cargo.toml"
    if api_manifest.is_file():
        cargo_fmt_command = ["bash", "-lc", "cd services/yafvs-api && cargo fmt --check"]
        cargo_fmt = run_command(cargo_fmt_command, repo_root, env=build_env(repo_root), timeout=120)
        details["steps"]["yafvs-api-fmt"] = {"exit_code": cargo_fmt.returncode, "output_tail": output_tail(cargo_fmt.stdout, 120)}
        findings.append(process_step_finding("pass" if cargo_fmt.returncode == 0 else "fail", "quality.yafvs-api-fmt", f"yafvs-api cargo fmt exit code {cargo_fmt.returncode}.", cargo_fmt, cargo_fmt_command))

        cargo_test_command = ["bash", "-lc", "cd services/yafvs-api && cargo test --locked"]
        cargo_test = run_command(cargo_test_command, repo_root, env=build_env(repo_root), timeout=600)
        details["steps"]["yafvs-api-test"] = {"exit_code": cargo_test.returncode, "output_tail": output_tail(cargo_test.stdout, 160)}
        findings.append(process_step_finding("pass" if cargo_test.returncode == 0 else "fail", "quality.yafvs-api-test", f"yafvs-api cargo test exit code {cargo_test.returncode}.", cargo_test, cargo_test_command))

    try:
        with acquire_runtime_lock(repo_root, GSA_OPERATION_LOCK, "quality-gate GSA checks"):
            gsa_type = run_command(["bash", "-lc", "cd components/gsa && npm run type-check"], repo_root, env=gsa_quality_env(repo_root), timeout=600)
            details["steps"]["gsa-type-check"] = {"exit_code": gsa_type.returncode, "output_tail": output_tail(gsa_type.stdout, 120)}
            findings.append(process_step_finding("pass" if gsa_type.returncode == 0 else "fail", "quality.gsa-type-check", f"GSA type-check exit code {gsa_type.returncode}.", gsa_type, ["bash", "-lc", "cd components/gsa && npm run type-check"]))

            gsa_fast = run_command(["bash", "-lc", "cd components/gsa && npm run test:web-fast"], repo_root, env=gsa_quality_env(repo_root), timeout=900)
            details["steps"]["gsa-test-web-fast"] = {"exit_code": gsa_fast.returncode, "output_tail": output_tail(gsa_fast.stdout, 160)}
            findings.append(process_step_finding("pass" if gsa_fast.returncode == 0 else "fail", "quality.gsa-test-web-fast", f"GSA web-fast test exit code {gsa_fast.returncode}.", gsa_fast, ["bash", "-lc", "cd components/gsa && npm run test:web-fast"]))
    except RuntimeLockTimeout as exc:
        details["steps"]["gsa-lock"] = {"status": "fail", "holder": exc.metadata}
        findings.append(runtime_lock_timeout_finding(exc, "quality.gsa-lock"))

    if include_runtime:
        for name, command_result in (
            ("runtime-status", rust_result_envelope(repo_root, "runtime-status", ["runtime-status"])),
            ("runtime-log-review", rust_runtime_log_review_result(repo_root)),
            ("runtime-data-state", rust_runtime_data_state_result(repo_root)),
        ):
            details["steps"][name] = {"status": command_result["status"], "summary": command_result["summary"], "artifacts": command_result.get("artifacts", [])}
            findings.append(finding(command_result["status"], f"quality.{name}", command_result["summary"], details={"status": command_result["status"], "artifacts": command_result.get("artifacts", [])}))

    latest_path, timestamped_path = retained_json_artifact_paths(artifact_dir, "quality-gate", "quality-gate.json")
    result = make_result("quality-gate", repo_root, "Local quality gate completed.", findings, [str(latest_path), str(timestamped_path)])
    result["details"] = details
    write_retained_json_artifact(latest_path, timestamped_path, result, "quality-gate", RETAINED_QUALITY_GATE_ARTIFACTS)
    return result


def print_human(result: dict[str, Any]) -> None:
    print(f"{result['status'].upper()}: {result['summary']}")
    for item in result["findings"]:
        line = f"[{item['status']}] {item['check']}: {item['message']}"
        if "path" in item:
            line += f" ({item['path']})"
        print(line)


def emit(result: dict[str, Any], as_json: bool) -> int:
    if as_json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        print_human(result)
    return 1 if result["status"] == "fail" else 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="YAFVS monorepo health checks")
    parser.add_argument("--json", action="store_true", help="emit machine-readable JSON")
    subparsers = parser.add_subparsers(dest="command", required=True)
    common = argparse.ArgumentParser(add_help=False)
    common.add_argument("--json", action="store_true", default=argparse.SUPPRESS, help=argparse.SUPPRESS)
    native_tooling_state = subparsers.add_parser("native-tooling-state", parents=[common], help="inventory inherited GMP/python-gvm/gvm-tools dependency surfaces")
    native_tooling_state.add_argument("--compact", action="store_true", help="alias for --status-only; emit chat-safe counts and only non-pass findings")
    native_tooling_state.add_argument("--summary", action="store_true", help="emit status/count contract summaries without removal-candidate paths or endpoint inventories")
    native_tooling_state.add_argument("--status-only", action="store_true", help="emit compact details and only non-pass findings for chat-safe closeout checks")
    migration_matrix = subparsers.add_parser("native-api-migration-matrix", parents=[common], help="show native API migration metadata by endpoint")
    migration_matrix.add_argument("--compact", action="store_true", help="alias for --status-only; emit compact planning details and only non-pass findings")
    migration_matrix.add_argument("--summary", action="store_true", help="alias for --status-only; emit compact planning details and only non-pass findings")
    migration_matrix.add_argument("--status-only", action="store_true", help="emit summary/contract details and only non-pass findings for chat-safe API planning")
    migration_matrix.add_argument("--focus", action="append", help="comma-separated terms used to keep only matching migration rows; may be repeated")
    native_api_client_contract = subparsers.add_parser("native-api-client-contract", parents=[common], help="check the generated-client native API contract surface")
    native_api_client_contract.add_argument("--status-only", action="store_true", help="emit compact details and only non-pass findings for chat-safe generated-client checks")
    native_api_replacement_dashboard = subparsers.add_parser("native-api-replacement-dashboard", parents=[common], help="summarize native API replacement progress as a weighted estimate")
    native_api_replacement_dashboard.add_argument("--status-only", action="store_true", help="emit compact dashboard details and only non-pass findings")
    closeout_readiness = subparsers.add_parser("closeout-readiness", parents=[common], help="summarize commit closeout readiness signals without running broad gates")
    closeout_readiness.add_argument("--status-only", action="store_true", help="emit compact closeout readiness details and only non-pass findings")
    configure = subparsers.add_parser("configure", parents=[common], help="configure a CMake component")
    configure.add_argument("component", help="component name")
    configure.add_argument("--profile", choices=C_BUILD_PROFILES, help="isolated C build profile")
    build = subparsers.add_parser("build", parents=[common], help="build a CMake component")
    build.add_argument("component", help="component name")
    build.add_argument("--install", action="store_true", help="install into build/prefix after successful build")
    build.add_argument("--profile", choices=C_BUILD_PROFILES, help="isolated C build profile")
    build_core_c = subparsers.add_parser("build-core-c", parents=[common], help="build gvm-libs, openvas-smb, and openvas-scanner")
    build_core_c.add_argument("--profile", choices=C_BUILD_PROFILES, help="isolated C build profile")
    build_c_services = subparsers.add_parser("build-c-services", parents=[common], help="build current C service baseline")
    build_c_services.add_argument("--profile", choices=C_BUILD_PROFILES, help="isolated C build profile")
    subparsers.add_parser("build-ui", parents=[common], help="build the web UI")
    subparsers.add_parser("build-python", parents=[common], help="build/import-check Python components")
    subparsers.add_parser("build-baseline", parents=[common], help="build the inherited stack baseline")
    subparsers.add_parser("up", parents=[common], help="start runtime infrastructure services")
    subparsers.add_parser("runtime-init", parents=[common], help="initialize persistent runtime database prerequisites")
    subparsers.add_parser("runtime-manager-init", parents=[common], help="initialize persistent gvmd database/user prerequisites")
    subparsers.add_parser("runtime-scanner-redis-init", parents=[common], help="initialize dedicated OpenVAS scanner Redis runtime")
    subparsers.add_parser("runtime-scanner-register", parents=[common], help="create or verify the OpenVAS scanner registration")
    subparsers.add_parser("runtime-smoke", parents=[common], help="run runtime infrastructure smoke checks")
    runtime_app_up = subparsers.add_parser("runtime-app-up", parents=[common], help="start experimental application services")
    runtime_app_up.add_argument("--status-only", action="store_true", help="emit compact app startup status and only non-pass findings for chat-safe validation")
    subparsers.add_parser("runtime-app-build", parents=[common], help="build application images explicitly without starting or changing feed state")
    subparsers.add_parser("runtime-app-smoke", parents=[common], help="run experimental application service smoke checks")
    native_api_smoke = subparsers.add_parser("runtime-native-api-smoke", parents=[common], help="verify the internal YAFVS native API sidecar")
    native_api_smoke.add_argument("--status-only", action="store_true", help="emit compact native API smoke status and only non-pass findings for chat-safe validation")
    native_api_direct_smoke = subparsers.add_parser("runtime-native-api-direct-smoke", parents=[common], help="verify the opt-in direct bearer-auth native API listener")
    native_api_direct_smoke.add_argument("--status-only", action="store_true", help="emit compact direct-smoke status and only non-pass findings for chat-safe validation")
    native_api_direct_write_smoke = subparsers.add_parser("runtime-native-api-direct-write-smoke", parents=[common], help="verify guarded direct native API write-control with zero-residue tag metadata writes")
    native_api_direct_write_smoke.add_argument("--status-only", action="store_true", help="emit compact write-smoke status and only non-pass findings for chat-safe validation")
    subparsers.add_parser("runtime-native-api-rebuild", parents=[common], help="rebuild and restart only the internal YAFVS native API sidecar")
    browser_smoke = subparsers.add_parser("runtime-browser-smoke", parents=[common], help="verify report workflows through a headless browser")
    browser_smoke.add_argument("--route", action="append", help="focus browser smoke on one route label or path; may be repeated")
    browser_smoke.add_argument("--status-only", action="store_true", help="emit compact browser-smoke status and only non-pass findings for chat-safe validation")
    browser_smoke.add_argument("--write-filter-smoke", action="store_true", help="create/clone/delete a disposable saved filter through browser native POST proxy validation")
    browser_regression = subparsers.add_parser("runtime-browser-regression", parents=[common], help="run deep browser route/link/pagination regression checks")
    browser_regression.add_argument("--status-only", action="store_true", help="emit compact browser-regression status and only non-pass findings for chat-safe validation")
    quality_gate = subparsers.add_parser("quality-gate", parents=[common], help="run the local deterministic quality gate")
    quality_gate.add_argument("--runtime", action="store_true", help="include runtime-safe status/log/data diagnostics")
    subparsers.add_parser("gvmd-smoke", parents=[common], help="run a narrow gvmd runtime profile smoke")
    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    cwd = Path.cwd()
    repo_root = find_repo_root(cwd)
    if repo_root is None:
        result = command_repository_unavailable(cwd, args.command)
        return emit(result, args.json)
    if args.command == "native-tooling-state":
        result = command_native_tooling_state(repo_root, compact=args.compact, summary_only=args.summary, status_only=args.status_only)
    elif args.command == "native-api-migration-matrix":
        result = command_native_api_migration_matrix(repo_root, status_only=args.status_only or args.compact or args.summary, focus=args.focus)
    elif args.command == "native-api-client-contract":
        result = command_native_api_client_contract(repo_root, status_only=args.status_only)
    elif args.command == "native-api-replacement-dashboard":
        result = command_native_api_replacement_dashboard(repo_root, status_only=args.status_only)
    elif args.command == "closeout-readiness":
        result = command_closeout_readiness(repo_root, status_only=args.status_only)
    elif args.command == "configure":
        result = command_configure(repo_root, args.component, args.profile)
    elif args.command == "build":
        result = command_build(repo_root, args.component, install=args.install, profile=args.profile)
    elif args.command == "build-core-c":
        result = command_build_core_c(repo_root, args.profile)
    elif args.command == "build-c-services":
        result = command_build_c_services(repo_root, args.profile)
    elif args.command == "build-ui":
        result = command_build_ui(repo_root)
    elif args.command == "build-python":
        result = command_build_python_chain(repo_root)
    elif args.command == "build-baseline":
        result = command_build_baseline(repo_root)
    elif args.command == "up":
        result = command_up(repo_root)
    elif args.command == "runtime-init":
        result = command_runtime_init(repo_root)
    elif args.command == "runtime-manager-init":
        result = command_runtime_manager_init(repo_root)
    elif args.command == "runtime-scanner-redis-init":
        result = command_runtime_scanner_redis_init(repo_root)
    elif args.command == "runtime-scanner-register":
        result = command_runtime_scanner_register(repo_root)
    elif args.command == "runtime-smoke":
        result = command_runtime_smoke(repo_root)
    elif args.command == "runtime-app-up":
        result = command_runtime_app_up(repo_root, status_only=args.status_only)
    elif args.command == "runtime-app-build":
        result = command_runtime_app_build(repo_root)
    elif args.command == "runtime-app-smoke":
        result = command_runtime_app_smoke(repo_root)
    elif args.command == "runtime-native-api-smoke":
        result = command_runtime_native_api_smoke(repo_root, status_only=args.status_only)
    elif args.command == "runtime-native-api-direct-smoke":
        result = command_runtime_native_api_direct_smoke(repo_root, status_only=args.status_only)
    elif args.command == "runtime-native-api-direct-write-smoke":
        result = command_runtime_native_api_direct_write_smoke(repo_root, status_only=args.status_only)
    elif args.command == "runtime-native-api-rebuild":
        result = command_runtime_native_api_rebuild(repo_root)
    elif args.command == "runtime-browser-smoke":
        result = command_runtime_browser_smoke(repo_root, args.route, write_filter_smoke=args.write_filter_smoke, status_only=args.status_only)
    elif args.command == "runtime-browser-regression":
        result = command_runtime_browser_regression(repo_root, status_only=args.status_only)
    elif args.command == "quality-gate":
        result = command_quality_gate(repo_root, include_runtime=args.runtime)
    elif args.command == "gvmd-smoke":
        result = command_gvmd_smoke(repo_root)
    else:
        parser.error(f"unknown command {args.command}")
    return emit(result, args.json)


if __name__ == "__main__":
    raise SystemExit(main())
