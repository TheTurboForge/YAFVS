            query_patch = direct_native_api_curl(repo_root, f"/api/v1/tags/{urllib.parse.quote(tag_id)}?unexpected=1", token=token, env=env, method="PATCH", body=query_patch_body, extra_headers=content_type)
            query_patch_json, query_patch_status = parse_json_output_with_http_status(query_patch)
