def command_runtime_rbac_smoke(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    secret_path = runtime_secret_path(repo_root, DEV_ADMIN_SECRET)
    python = venv_python(repo_root, "python-gvm")
    probe = runtime_rbac_smoke_probe_path(repo_root)
    artifact_dir = rbac_smoke_artifact_dir(repo_root)
    findings.append(finding("pass" if gvmd_socket_path(repo_root).is_socket() else "fail", "gvmd.socket", "gvmd socket is ready." if gvmd_socket_path(repo_root).is_socket() else "gvmd socket is not ready.", str(gvmd_socket_path(repo_root))))
    findings.append(finding("pass" if secret_path.is_file() else "fail", "runtime.admin-secret", "Development admin secret exists." if secret_path.is_file() else "Development admin secret is missing.", str(secret_path)))
    findings.append(finding("pass" if python.is_file() else "fail", "python-gvm.venv", "python-gvm runtime venv exists." if python.is_file() else "python-gvm venv is missing.", str(python.relative_to(repo_root)) if python.exists() else str(python)))
    findings.append(finding("pass" if probe.is_file() else "fail", "runtime-rbac.probe", "Runtime RBAC smoke helper exists." if probe.is_file() else "Runtime RBAC smoke helper is missing.", str(probe.relative_to(repo_root)) if probe.exists() else str(probe)))
    try:
        artifact_dir.mkdir(parents=True, exist_ok=True)
        findings.append(finding("pass", "runtime-rbac.artifact-dir", "Runtime RBAC smoke artifact directory is ready.", str(artifact_dir)))
    except OSError as error:
        findings.append(finding("fail", "runtime-rbac.artifact-dir", f"Runtime RBAC smoke artifact directory is not usable: {error}", str(artifact_dir)))

    if aggregate_status(findings) == "fail":
        return make_result("runtime-rbac-smoke", repo_root, "Runtime RBAC smoke stopped at prerequisites.", findings, [str(artifact_dir)])

    args = [
        str(python),
        str(probe),
        "--socket",
        str(gvmd_socket_path(repo_root)),
        "--username",
        DEV_ADMIN_USER,
        "--password-file",
        str(secret_path),
        "--artifact-dir",
        str(artifact_dir),
    ]
    result = run_command(args, repo_root, env=build_env(repo_root), timeout=180)
    try:
        parsed = json.loads(result.stdout)
    except json.JSONDecodeError:
        parsed = None
    helper_status = parsed.get("status") if parsed else None
    finding_status = helper_status if result.returncode == 0 and helper_status in {"pass", "warn"} else "fail"
    password = secret_path.read_text(encoding="utf-8").strip() if secret_path.is_file() else ""
    findings.append(
        finding(
            finding_status,
            "runtime-rbac.operator-account",
            parsed.get("summary", f"Runtime RBAC smoke helper exit code {result.returncode}.") if parsed else f"Runtime RBAC smoke helper exit code {result.returncode}.",
            details={"helper": parsed, "output_tail": output_tail(result.stdout, 120, [password])},
        )
    )
    artifacts = list(parsed.get("artifacts", [])) if parsed and isinstance(parsed.get("artifacts"), list) else [str(artifact_dir)]
    summary = parsed.get("summary") if parsed else f"Runtime RBAC smoke completed with exit code {result.returncode}."
    return make_result("runtime-rbac-smoke", repo_root, summary, findings, artifacts)

