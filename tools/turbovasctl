def command_feed_cache_sync(repo_root: Path) -> dict[str, Any]:
    findings = ensure_runtime_dirs(repo_root)
    binary = feed_sync_binary(repo_root)
    findings.append(finding("pass" if binary.is_file() else "fail", "feed-sync.available", "greenbone-feed-sync venv command is available." if binary.is_file() else "greenbone-feed-sync venv command is missing; run just build-python or just build-baseline.", str(binary)))
    findings.append(finding("pass" if shutil.which("rsync") else "fail", "rsync.available", "rsync is available." if shutil.which("rsync") else "rsync is missing."))
    findings.append(finding("pass" if shutil.which("tmux") else "fail", "tmux.available", "tmux is available." if shutil.which("tmux") else "tmux is missing."))
    if aggregate_status(findings) == "fail":
        return make_result("feed-cache-sync", repo_root, "Feed cache sync stopped at prerequisites.", findings, [str(feed_cache_var_lib(repo_root))])

    selftest = run_command(feed_sync_command(repo_root, selftest=True), repo_root, env=build_env(repo_root), timeout=120)
    findings.append(finding("pass" if selftest.returncode == 0 else "fail", "feed-sync.selftest", f"greenbone-feed-sync selftest exit code {selftest.returncode}.", details={"output_tail": output_tail(selftest.stdout, 80)}))
    if selftest.returncode != 0:
        return make_result("feed-cache-sync", repo_root, "Feed cache sync stopped at greenbone-feed-sync selftest.", findings, [str(feed_cache_var_lib(repo_root))])

    session_check = run_command(["tmux", "has-session", "-t", FEED_SYNC_SESSION], repo_root)
    if session_check.returncode == 0:
        findings.append(finding("warn", "feed-sync.session", f"tmux session {FEED_SYNC_SESSION} is already running; not starting another sync.", details={"session": FEED_SYNC_SESSION}))
        return make_result("feed-cache-sync", repo_root, "Feed cache sync is already running.", findings, [str(feed_cache_var_lib(repo_root))])

    feed_sync_log_dir(repo_root).mkdir(parents=True, exist_ok=True)
    timestamp = datetime.now(timezone.utc).strftime("%Y%m%dT%H%M%SZ")
    log_path = feed_sync_log_dir(repo_root) / f"community-{FEED_RELEASE}-{timestamp}.log"
    sync_command = feed_sync_command(repo_root)
    sync_line = " ".join(shlex.quote(part) for part in sync_command)
    inner_command = (
        f"cd {shlex.quote(str(repo_root))} && "
        "set -o pipefail && "
        f"{{ printf '%s\\n' 'TurboVAS feed cache sync started at {timestamp}'; "
        f"{sync_line}; "
        "status=$?; "
        "printf '%s\\n' \"TurboVAS feed cache sync exited with status $status\"; "
        "exit $status; "
        f"}} 2>&1 | tee -a {shlex.quote(str(log_path))}"
    )
    shell_command = f"bash -lc {shlex.quote(inner_command)}"
    start = run_command(["tmux", "new-session", "-d", "-s", FEED_SYNC_SESSION, shell_command], repo_root)
    findings.append(finding("pass" if start.returncode == 0 else "fail", "feed-sync.session-start", f"Start tmux feed sync session exit code {start.returncode}.", details={"session": FEED_SYNC_SESSION, "log_path": str(log_path), "output_tail": output_tail(start.stdout, 80)}))
    return make_result("feed-cache-sync", repo_root, "Feed cache sync session start attempted.", findings, [str(feed_cache_var_lib(repo_root)), str(log_path)])


def command_feed_copy_to_runtime(repo_root: Path) -> dict[str, Any]:
    findings = ensure_runtime_dirs(repo_root)
    findings.append(finding("pass" if shutil.which("rsync") else "fail", "rsync.available", "rsync is available." if shutil.which("rsync") else "rsync is missing."))
    if aggregate_status(findings) == "fail":
        return make_result("feed-copy-to-runtime", repo_root, "Feed copy stopped at prerequisites.", findings, [str(feed_runtime_root(repo_root))])

    for feed_class, source, _destination in feed_copy_pairs(repo_root):
        summary = feed_path_summary(source, feed_class.markers)
        marker_missing = [row["path"] for row in summary["markers"] if not row["exists"]]
        if not summary["exists"] or summary["file_count"] == 0:
            findings.append(finding("fail", f"feed.cache.{feed_class.key}", f"{feed_class.label} cache is missing or empty; refusing to copy an incomplete feed cache.", str(source), {"summary": summary}))
        elif marker_missing:
            findings.append(finding("warn", f"feed.cache.{feed_class.key}", f"{feed_class.label} cache has files but expected markers are missing.", str(source), {"summary": summary, "missing_markers": marker_missing}))
        else:
            findings.append(finding("pass", f"feed.cache.{feed_class.key}", f"{feed_class.label} cache is ready to copy.", str(source), {"summary": summary}))
    if aggregate_status(findings) == "fail":
        return make_result("feed-copy-to-runtime", repo_root, "Feed copy stopped because the cache is incomplete.", findings, [str(feed_cache_var_lib(repo_root)), str(feed_runtime_root(repo_root))])

    for feed_class, source, destination in feed_copy_pairs(repo_root):
        destination.parent.mkdir(parents=True, exist_ok=True)
        copy = run_command(["rsync", "-a", "--delete", f"{source}/", f"{destination}/"], repo_root, timeout=3600)
        findings.append(finding("pass" if copy.returncode == 0 else "fail", f"feed.copy.{feed_class.key}", f"Copy {feed_class.label} to runtime exit code {copy.returncode}.", details={"source": str(source), "destination": str(destination), "output_tail": output_tail(copy.stdout, 80)}))
        if copy.returncode != 0:
            break
    findings.extend(feed_location_findings(repo_root, "runtime", feed_runtime_root(repo_root), "runtime_rel"))
    return make_result("feed-copy-to-runtime", repo_root, "Feed cache copy to runtime attempted.", findings, [str(feed_cache_var_lib(repo_root)), str(feed_runtime_root(repo_root))])


def runtime_app_up_status_only_result(result: dict[str, Any]) -> dict[str, Any]:
    compact = dict(result)
    findings = result.get("findings", [])
    non_pass = [compact_doctor_finding(item) for item in findings if item.get("status") != "pass"]
    checks = {
        item.get("check"): item.get("status")
        for item in findings
        if isinstance(item, dict) and item.get("check")
    }
    service_status = {
        item.get("details", {}).get("service"): item.get("status")
        for item in findings
        if isinstance(item, dict)
        and item.get("check") == "runtime.app.running"
        and isinstance(item.get("details"), dict)
        and item.get("details", {}).get("service")
    }
    important_checks = {
        check: checks[check]
        for check in (
            "compose.config",
            "runtime.infrastructure",
            "runtime.database-init",
            "runtime.scanner-redis",
            "runtime.feed-keyring",
            "gsa.build.index",
            "gsa.static-stage",
            "gsa.config-js",
            "compose.app-up",
        )
        if check in checks
    }
    compact["details"] = {
        "finding_count": len(findings),
        "non_pass_count": len(non_pass),
        "artifact_count": len(result.get("artifacts", [])) if isinstance(result.get("artifacts"), list) else 0,
        "important_checks": important_checks,
        "service_status": service_status,
    }
    compact["findings"] = non_pass or [
        finding("pass", "runtime-app-up.status-only", "Application runtime startup passed; no non-pass findings.")
    ]
    return compact


