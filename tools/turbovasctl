def native_api_migration_matrix_rows(repo_root: Path) -> list[dict[str, Any]]:
    items = native_tooling_inventory(repo_root)
    summary = summarize_native_tooling(items, repo_root)
    annotate_native_tooling_direct_api(summary, repo_root)

    inventory_by_key: dict[tuple[str, str], dict[str, Any]] = {}
    for item in summary.get("implemented_native_endpoints", []):
        if not isinstance(item, dict) or not isinstance(item.get("endpoint"), str):
            continue
        method = str(item.get("method", "get"))
        key = (method, normalize_native_api_endpoint_template(item["endpoint"]))
        inventory_by_key.setdefault(key, item)

    openapi_by_key: dict[tuple[str, str], dict[str, Any]] = {}
    for operation in openapi_contract_operations(repo_root):
        method = str(operation.get("method", ""))
        path = operation.get("path")
        if not method or not isinstance(path, str):
            continue
        endpoint = f"/api/v1{path}"
        key = (method, normalize_native_api_endpoint_template(endpoint))
        openapi_by_key.setdefault(key, operation)

    def row_endpoint(key: tuple[str, str]) -> str:
        operation = openapi_by_key.get(key)
        if operation and isinstance(operation.get("path"), str):
            return f"/api/v1{operation['path']}"
        inventory = inventory_by_key.get(key, {})
        endpoint = inventory.get("endpoint")
        return endpoint if isinstance(endpoint, str) else key[1]

    rows: list[dict[str, Any]] = []
    for key in sorted(set(inventory_by_key) | set(openapi_by_key), key=row_endpoint):
        method, _normalized = key
        inventory = inventory_by_key.get(key)
        operation = openapi_by_key.get(key)
        endpoint = row_endpoint(key)
        fields = set(operation.get("x_turbovas_fields", [])) if isinstance(operation, dict) else set()
        values = operation.get("x_turbovas_values", {}) if isinstance(operation, dict) and isinstance(operation.get("x_turbovas_values"), dict) else {}
        status = inventory.get("status") if isinstance(inventory, dict) and isinstance(inventory.get("status"), str) else "unknown"
        if status == "unknown" and openapi_operation_is_pending_write_control(operation):
            status = "openapi_preview_write_control"
        if method != "get" and status != "openapi_preview_write_control":
            operation_status = native_browser_proxy_operation_status(repo_root, method, endpoint)
            if operation_status != "planned_internal_and_browser_proxied":
                status = operation_status
        if isinstance(inventory, dict) and isinstance(inventory.get("direct_access"), str):
            direct_access = inventory["direct_access"]
        elif status == "openapi_preview_write_control":
            direct_access = "internal_only"
        else:
            direct_access = native_api_direct_access(endpoint)
        replacement_candidates = inventory.get("replacement_candidates", []) if isinstance(inventory, dict) else []
        if not isinstance(replacement_candidates, list):
            replacement_candidates = []
        rows.append(
            {
                "endpoint": endpoint,
                "method": method,
                "status": status,
                "browser_access": native_api_browser_access_from_status(status),
                "direct_access": direct_access,
                "operation_id": operation.get("operation_id") if isinstance(operation, dict) else None,
                "openapi_path": operation.get("path") if isinstance(operation, dict) else None,
                "inventory_endpoint": inventory.get("endpoint") if isinstance(inventory, dict) else None,
                "openapi_direct_marker": "x-turbovas-direct" in fields if isinstance(operation, dict) else None,
                "x_turbovas_exposure": values.get("x-turbovas-exposure"),
                "x_turbovas_maturity": values.get("x-turbovas-maturity"),
                "x_turbovas_operator_identity": values.get("x-turbovas-operator-identity"),
                "x_turbovas_owner_semantics": values.get("x-turbovas-owner-semantics"),
                "x_turbovas_replaces": values.get("x-turbovas-replaces"),
                "x_turbovas_inherited_still_owns": values.get("x-turbovas-inherited-still-owns"),
                "x_turbovas_safety_contract": values.get("x-turbovas-safety-contract"),
                "x_turbovas_side_effect": values.get("x-turbovas-side-effect"),
                "replacement_candidates": replacement_candidates,
            }
        )
    return rows


def native_api_migration_matrix_summary(rows: list[dict[str, Any]]) -> dict[str, Any]:
    def counts(field: str) -> dict[str, int]:
        result: dict[str, int] = {}
        for row in rows:
            value = row.get(field)
            key = str(value) if value is not None else "null"
            result[key] = result.get(key, 0) + 1
        return dict(sorted(result.items()))

    def percentage(count: int, total: int) -> float:
        return round((100.0 * count / total), 1) if total else 0.0

    contract = native_api_migration_matrix_contract_summary(rows)
    total_rows = len(rows)
    openapi_rows = sum(1 for row in rows if row.get("openapi_path") is not None)
    inventory_rows = sum(1 for row in rows if row.get("inventory_endpoint") is not None)
    replacement_candidate_rows = sum(1 for row in rows if row.get("replacement_candidates"))
    metadata_rows = sum(1 for row in rows if any(row.get(field) is not None for field in NATIVE_API_MIGRATION_MATRIX_METADATA_FIELDS))
    browser_access_counts = counts("browser_access")
    direct_access_counts = counts("direct_access")
    return {
        "total_rows": total_rows,
        "openapi_operation_rows": openapi_rows,
        "inventory_rows": inventory_rows,
        "rows_with_replacement_candidates": replacement_candidate_rows,
        "rows_with_checked_migration_metadata": metadata_rows,
        "checked_migration_field_counts": {field: sum(1 for row in rows if row.get(field) is not None) for field in NATIVE_API_MIGRATION_MATRIX_METADATA_FIELDS},
        "rows_missing_openapi_count": len(contract["rows_missing_openapi"]),
        "rows_missing_inventory_count": len(contract["rows_missing_inventory"]),
        "rows_missing_migration_metadata_count": len(contract["rows_missing_migration_metadata"]),
        "direct_exposure_mismatch_count": len(contract["direct_exposure_mismatches"]),
        "direct_marker_mismatch_count": len(contract["direct_marker_mismatches"]),
        "progress_percentages": {
            "openapi_operation_rows_percent": percentage(openapi_rows, total_rows),
            "inventory_rows_percent": percentage(inventory_rows, total_rows),
            "rows_with_replacement_candidates_percent": percentage(replacement_candidate_rows, total_rows),
            "rows_with_checked_migration_metadata_percent": percentage(metadata_rows, total_rows),
            "browser_proxied_percent": percentage(browser_access_counts.get("browser_proxied", 0), total_rows),
            "scriptable_read_percent": percentage(direct_access_counts.get("scriptable_read", 0), total_rows),
            "internal_only_percent": percentage(direct_access_counts.get("internal_only", 0), total_rows),
        },
        "by_status": counts("status"),
        "by_browser_access": browser_access_counts,
        "by_direct_access": direct_access_counts,
    }


def native_api_migration_matrix_contract_summary(rows: list[dict[str, Any]]) -> dict[str, list[dict[str, Any]]]:
    rows_missing_openapi = [
        {"endpoint": row.get("endpoint"), "method": row.get("method"), "inventory_endpoint": row.get("inventory_endpoint")}
        for row in rows
        if row.get("openapi_path") is None
    ]
    rows_missing_inventory = [
        {"endpoint": row.get("endpoint"), "method": row.get("method"), "openapi_path": row.get("openapi_path")}
        for row in rows
        if row.get("inventory_endpoint") is None and row.get("status") != "openapi_preview_write_control"
    ]
    rows_missing_migration_metadata = []
    direct_exposure_mismatches = []
    direct_marker_mismatches = []
    for row in rows:
        missing_fields = [field for field in NATIVE_API_MIGRATION_MATRIX_METADATA_FIELDS if row.get(field) is None]
        if missing_fields:
            rows_missing_migration_metadata.append(
                {"endpoint": row.get("endpoint"), "method": row.get("method"), "missing_fields": missing_fields}
            )

        direct_access = row.get("direct_access")
        expected_exposure = None
        expected_marker = None
        if direct_access == "scriptable_read":
            expected_exposure = "direct-read"
            expected_marker = True
        elif direct_access == "internal_only":
            expected_exposure = "internal-only"
            expected_marker = False
        elif direct_access == "direct_write_control":
            expected_exposure = "direct-write"
            expected_marker = True

        if expected_exposure is not None and row.get("x_turbovas_exposure") != expected_exposure:
            direct_exposure_mismatches.append(
                {
                    "endpoint": row.get("endpoint"),
                    "method": row.get("method"),
                    "direct_access": direct_access,
                    "actual": row.get("x_turbovas_exposure"),
                    "expected": expected_exposure,
                }
            )
        if expected_marker is not None and row.get("openapi_direct_marker") is not expected_marker:
            direct_marker_mismatches.append(
                {
                    "endpoint": row.get("endpoint"),
                    "method": row.get("method"),
                    "direct_access": direct_access,
                    "actual": row.get("openapi_direct_marker"),
                    "expected": expected_marker,
                }
            )

    return {
        "rows_missing_openapi": rows_missing_openapi,
        "rows_missing_inventory": rows_missing_inventory,
        "rows_missing_migration_metadata": rows_missing_migration_metadata,
        "direct_exposure_mismatches": direct_exposure_mismatches,
        "direct_marker_mismatches": direct_marker_mismatches,
    }


