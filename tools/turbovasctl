def command_runtime_init(repo_root: Path) -> dict[str, Any]:
    findings = ensure_runtime_dirs(repo_root)
    config = run_command(compose_command(repo_root, "config", "--quiet"), repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if config.returncode == 0 else "fail", "compose.config", f"Compose config validation exit code {config.returncode}.", str(compose_file(repo_root).relative_to(repo_root)), {"output_tail": config.stdout.splitlines()[-40:]}))
    findings.extend(pg_gvm_artifacts(repo_root)[0])
    if aggregate_status(findings) == "fail":
        return make_result("runtime-init", repo_root, "Runtime initialization stopped before Postgres changes.", findings)

    result = run_command(compose_command(repo_root, "up", "-d", "--build", "postgres"), repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if result.returncode == 0 else "fail", "postgres.up", f"docker compose up postgres exit code {result.returncode}.", details={"output_tail": result.stdout.splitlines()[-80:]}))
    if result.returncode != 0:
        return make_result("runtime-init", repo_root, "Runtime initialization stopped at Postgres startup.", findings)

    ready_result: subprocess.CompletedProcess[str] | None = None
    for _ in range(30):
        ready_result = postgres_ready(repo_root)
        if ready_result.returncode == 0:
            break
        import time

        time.sleep(2)
    findings.append(finding("pass" if ready_result and ready_result.returncode == 0 else "fail", "postgres.ready", f"pg_isready exit code {ready_result.returncode if ready_result else 'unavailable'}.", details={"output_tail": ready_result.stdout.splitlines()[-20:] if ready_result else []}))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-init", repo_root, "Runtime initialization stopped before database setup.", findings)

    findings.extend(ensure_postgres_collation(repo_root))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-init", repo_root, "Runtime initialization stopped at Postgres collation check.", findings)

    findings.extend(copy_pg_gvm_extension(repo_root))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-init", repo_root, "Runtime initialization stopped while installing pg-gvm files.", findings)

    create_dba = psql(repo_root, "DO $$ BEGIN CREATE ROLE dba WITH SUPERUSER NOINHERIT; EXCEPTION WHEN duplicate_object THEN NULL; END $$;")
    findings.append(finding("pass" if create_dba.returncode == 0 else "fail", "postgres.role.dba", f"Create/verify dba role exit code {create_dba.returncode}.", details={"output_tail": create_dba.stdout.splitlines()[-40:]}))
    grant_dba = psql(repo_root, f"GRANT dba TO {sql_identifier(postgres_user(repo_root))};")
    findings.append(finding("pass" if grant_dba.returncode == 0 else "fail", "postgres.role.grant", f"Grant dba to {postgres_user(repo_root)} exit code {grant_dba.returncode}.", details={"output_tail": grant_dba.stdout.splitlines()[-40:]}))
    create_extension = psql(repo_root, f'CREATE EXTENSION IF NOT EXISTS "{PG_GVM_EXTENSION}";')
    findings.append(finding("pass" if create_extension.returncode == 0 else "fail", "postgres.extension.pg-gvm", f"Create/verify pg-gvm extension exit code {create_extension.returncode}.", details={"output_tail": create_extension.stdout.splitlines()[-80:]}))
    findings.append(pg_gvm_extension_status(repo_root))
    return make_result("runtime-init", repo_root, "Runtime database initialization completed.", findings, [str(runtime_dir(repo_root)), "build/prefix"])


def command_runtime_certs_init(repo_root: Path) -> dict[str, Any]:
    findings = ensure_runtime_dirs(repo_root)
    cert_private_dir(repo_root).mkdir(parents=True, exist_ok=True)
    cert_public_dir(repo_root).mkdir(parents=True, exist_ok=True)
    try:
        cert_private_dir(repo_root).chmod(0o700)
        cert_public_dir(repo_root).chmod(0o755)
    except OSError as error:
        findings.append(finding("warn", "runtime.cert.permissions", f"Could not adjust certificate directory permissions: {error}."))

    script = repo_root / "build" / "prefix" / "bin" / "gvm-manage-certs"
    findings.append(finding("pass" if shutil.which("certtool") else "fail", "certtool.available", "certtool is available." if shutil.which("certtool") else "certtool is missing; install gnutls-bin."))
    findings.append(finding("pass" if script.is_file() else "fail", "gvm-manage-certs.available", "gvm-manage-certs is available in build/prefix." if script.is_file() else "gvm-manage-certs is missing; build/install gvmd first.", str(script)))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-certs-init", repo_root, "Certificate initialization stopped before generation.", findings, [str(runtime_dir(repo_root))])

    if certs_partial(repo_root):
        findings.extend(cert_file_findings(repo_root))
        findings.append(finding("fail", "runtime.cert.partial", "Partial certificate infrastructure exists; refusing to overwrite or rotate automatically."))
        return make_result("runtime-certs-init", repo_root, "Certificate initialization stopped at partial existing state.", findings, [str(runtime_dir(repo_root))])

    if not certs_complete(repo_root):
        create = run_command([str(script), "-a"], repo_root, env=gvm_cert_env(repo_root))
        findings.append(finding("pass" if create.returncode == 0 else "fail", "runtime.cert.create", f"gvm-manage-certs -a exit code {create.returncode}.", details={"output_tail": output_tail(create.stdout, 80)}))
        if create.returncode != 0:
            return make_result("runtime-certs-init", repo_root, "Certificate generation failed.", findings, [str(runtime_dir(repo_root))])
    else:
        findings.append(finding("pass", "runtime.cert.exists", "Complete certificate infrastructure already exists; not regenerating."))

    verify = run_command([str(script), "-V"], repo_root, env=gvm_cert_env(repo_root))
    findings.append(finding("pass" if verify.returncode == 0 else "fail", "runtime.cert.verify", f"gvm-manage-certs -V exit code {verify.returncode}.", details={"output_tail": output_tail(verify.stdout, 80)}))
    findings.extend(cert_file_findings(repo_root))
    return make_result("runtime-certs-init", repo_root, "Runtime certificate initialization completed.", findings, [str(cert_public_dir(repo_root)), str(cert_private_dir(repo_root))])


def command_runtime_scanner_redis_init(repo_root: Path, probe_openvas: bool = True) -> dict[str, Any]:
    findings = ensure_runtime_dirs(repo_root)
    config = run_command(compose_command(repo_root, "config", "--quiet"), repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if config.returncode == 0 else "fail", "compose.config", f"Compose config validation exit code {config.returncode}.", str(compose_file(repo_root).relative_to(repo_root)), {"output_tail": output_tail(config.stdout, 40)}))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-scanner-redis-init", repo_root, "Scanner Redis initialization stopped before service startup.", findings, [str(runtime_dir(repo_root))])

    result = run_command(compose_command(repo_root, "up", "-d", "redis-openvas"), repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if result.returncode == 0 else "fail", "redis-openvas.up", f"docker compose up redis-openvas exit code {result.returncode}.", details={"output_tail": output_tail(result.stdout, 80)}))
    if result.returncode != 0:
        return make_result("runtime-scanner-redis-init", repo_root, "Scanner Redis initialization stopped at service startup.", findings, [str(runtime_dir(repo_root))])

    ping: subprocess.CompletedProcess[str] | None = None
    for _ in range(20):
        if container_running(repo_root, "redis-openvas"):
            ping = scanner_redis_ping(repo_root)
            if ping.returncode == 0 and "PONG" in ping.stdout:
                break
        time.sleep(1)
    findings.append(finding("pass" if ping and ping.returncode == 0 and "PONG" in ping.stdout else "fail", "redis-openvas.ready", f"scanner Redis Unix socket ping exit code {ping.returncode if ping else 'unavailable'}.", str(scanner_redis_socket_path(repo_root)), {"output_tail": output_tail(ping.stdout if ping else "", 20)}))

    config_path = write_openvas_runtime_config(repo_root)
    findings.append(finding("pass", "openvas.config", "OpenVAS runtime config points db_address and feed plugin paths to runtime state.", str(config_path.relative_to(repo_root))))
    if not probe_openvas:
        findings.append(finding("pass", "openvas.config-probe", "OpenVAS settings probe deferred until app services are built and started."))
        return make_result("runtime-scanner-redis-init", repo_root, "Scanner Redis initialization completed.", findings, [str(runtime_dir(repo_root)), str(config_path.relative_to(repo_root))])
    app_build = run_command(compose_command(repo_root, "--profile", "app", "build", "ospd-openvas"), repo_root, env=runtime_env(repo_root), timeout=900)
    findings.append(finding("pass" if app_build.returncode == 0 else "fail", "compose.ospd-build", f"docker compose build ospd-openvas exit code {app_build.returncode}.", details={"output_tail": output_tail(app_build.stdout, 120)}))
    if app_build.returncode != 0:
        return make_result("runtime-scanner-redis-init", repo_root, "Scanner Redis initialization stopped while building ospd-openvas image.", findings, [str(runtime_dir(repo_root))])
    openvas_settings = run_app_oneoff(repo_root, "ospd-openvas", ["openvas", "-s"], no_deps=False)
    db_lines = [line for line in openvas_settings.stdout.splitlines() if line.startswith("db_address")]
    plugin_lines = [line for line in openvas_settings.stdout.splitlines() if line.startswith("plugins_folder")]
    include_lines = [line for line in openvas_settings.stdout.splitlines() if line.startswith("include_folders")]
    db_ok = openvas_settings.returncode == 0 and any("/runtime/run/redis-openvas/redis.sock" in line for line in db_lines)
    plugins_ok = openvas_settings.returncode == 0 and any("/runtime/feeds/openvas/plugins" in line for line in plugin_lines)
    include_ok = openvas_settings.returncode == 0 and any("/runtime/feeds/openvas/plugins" in line for line in include_lines)
    findings.append(finding("pass" if db_ok else "fail", "openvas.db_address", f"openvas -s runtime db_address check exit code {openvas_settings.returncode}.", details={"db_address_lines": db_lines, "output_tail": output_tail(openvas_settings.stdout, 80)}))
    findings.append(finding("pass" if plugins_ok else "fail", "openvas.plugins_folder", f"openvas -s runtime plugins_folder check exit code {openvas_settings.returncode}.", details={"plugins_folder_lines": plugin_lines, "output_tail": output_tail(openvas_settings.stdout, 80)}))
    findings.append(finding("pass" if include_ok else "fail", "openvas.include_folders", f"openvas -s runtime include_folders check exit code {openvas_settings.returncode}.", details={"include_folders_lines": include_lines, "output_tail": output_tail(openvas_settings.stdout, 80)}))
    return make_result("runtime-scanner-redis-init", repo_root, "Scanner Redis initialization completed.", findings, [str(runtime_dir(repo_root)), str(config_path.relative_to(repo_root))])


def command_runtime_manager_init(repo_root: Path) -> dict[str, Any]:
    try:
        with acquire_runtime_lock(repo_root, RUNTIME_MANAGER_LOCK, "runtime-manager-init"):
            return command_runtime_manager_init_unlocked(repo_root)
    except RuntimeLockTimeout as exc:
        return make_result(
            "runtime-manager-init",
            repo_root,
            "Runtime manager initialization stopped while waiting for another manager operation.",
            [runtime_lock_timeout_finding(exc, "runtime.manager-lock")],
            [str(runtime_dir(repo_root))],
        )


def command_runtime_manager_init_unlocked(repo_root: Path) -> dict[str, Any]:
    findings = ensure_runtime_dirs(repo_root)
    findings.extend(ensure_build_runtime_dirs(repo_root))
    db_init = command_runtime_init(repo_root)
    findings.append(finding(db_init["status"], "runtime.database-init", db_init["summary"], details={"status": db_init["status"]}))
    if db_init["status"] == "fail":
        return make_result("runtime-manager-init", repo_root, "Manager initialization stopped at database prerequisites.", findings, db_init["artifacts"])

    password, created = read_or_create_runtime_secret(repo_root, DEV_ADMIN_SECRET, DEV_ADMIN_PASSWORD)
    secret_path = runtime_secret_path(repo_root, DEV_ADMIN_SECRET)
    if password != DEV_ADMIN_PASSWORD:
        password = DEV_ADMIN_PASSWORD
        secret_path.write_text(password + "\n", encoding="utf-8")
        secret_path.chmod(0o600)
        created = False
        findings.append(finding("pass", "runtime.admin-secret", "Development admin password was aligned to the local default in persistent runtime secrets.", str(secret_path)))
    else:
        findings.append(finding("pass", "runtime.admin-secret", f"Development admin password {'created' if created else 'reused'} in persistent runtime secrets.", str(secret_path)))
    findings.extend(cert_file_findings(repo_root))

    app_build = run_command(compose_command(repo_root, "--profile", "app", "build", "gvmd"), repo_root, env=runtime_env(repo_root), timeout=900)
    findings.append(finding("pass" if app_build.returncode == 0 else "fail", "compose.app-build", f"docker compose build gvmd exit code {app_build.returncode}.", details={"output_tail": output_tail(app_build.stdout, 120, [password])}))
    if app_build.returncode != 0:
        return make_result("runtime-manager-init", repo_root, "Manager initialization stopped while building the app image.", findings, [str(runtime_dir(repo_root))])

    migrate = run_gvmd_oneoff(repo_root, ["--migrate"], no_deps=False)
    migrate_details: dict[str, Any] = {"output_tail": output_tail(migrate.stdout, 100, [password])}
    if migrate.returncode != 0:
        migrate_details["runtime_manager_diagnostics"] = runtime_manager_diagnostics(repo_root)
    findings.append(finding("pass" if migrate.returncode == 0 else "fail", "gvmd.migrate", f"gvmd --migrate exit code {migrate.returncode}.", details=migrate_details))
    if migrate.returncode != 0:
        return make_result("runtime-manager-init", repo_root, "Manager initialization stopped at database migration.", findings, [str(runtime_dir(repo_root))])

    users = run_gvmd_oneoff(repo_root, ["--get-users", "--verbose"], no_deps=False)
    admin_uuid = parse_user_uuid(users.stdout, DEV_ADMIN_USER) if users.returncode == 0 else None
    findings.append(finding("pass" if users.returncode == 0 else "warn", "gvmd.get-users", f"gvmd --get-users --verbose exit code {users.returncode}.", details={"admin_uuid_found": bool(admin_uuid), "output_tail": output_tail(users.stdout, 80, [password])}))

    if not admin_uuid:
        create = run_gvmd_oneoff(repo_root, [f"--create-user={DEV_ADMIN_USER}", f"--password={password}", "--disable-password-policy"], no_deps=False)
        findings.append(finding("pass" if create.returncode == 0 else "fail", "gvmd.create-admin", f"Create/verify development admin user exit code {create.returncode}.", details={"output_tail": output_tail(create.stdout, 80, [password])}))
        if create.returncode != 0:
            return make_result("runtime-manager-init", repo_root, "Manager initialization stopped at admin user creation.", findings, [str(runtime_dir(repo_root))])
        users = run_gvmd_oneoff(repo_root, ["--get-users", "--verbose"], no_deps=False)
        admin_uuid = parse_user_uuid(users.stdout, DEV_ADMIN_USER) if users.returncode == 0 else None
        findings.append(finding("pass" if admin_uuid else "warn", "gvmd.admin-uuid", f"Development admin UUID {'found' if admin_uuid else 'not found after creation'}.", details={"admin_uuid": admin_uuid, "output_tail": output_tail(users.stdout, 80, [password])}))

    if admin_uuid:
        update_password = run_gvmd_oneoff(repo_root, [f"--user={DEV_ADMIN_USER}", f"--new-password={password}", "--disable-password-policy"], no_deps=False)
        findings.append(finding("pass" if update_password.returncode == 0 else "fail", "gvmd.admin-password", f"Set development admin password exit code {update_password.returncode}.", details={"output_tail": output_tail(update_password.stdout, 80, [password])}))
        if update_password.returncode != 0:
            return make_result("runtime-manager-init", repo_root, "Manager initialization stopped at admin password update.", findings, [str(runtime_dir(repo_root))])

    if admin_uuid:
        owner = run_gvmd_oneoff(repo_root, [f"--modify-setting={FEED_IMPORT_OWNER_SETTING}", f"--value={admin_uuid}"], no_deps=False)
        findings.append(finding("pass" if owner.returncode == 0 else "warn", "gvmd.feed-owner", f"Set feed import owner exit code {owner.returncode}.", details={"admin_uuid": admin_uuid, "output_tail": output_tail(owner.stdout, 80, [password])}))
    else:
        findings.append(finding("warn", "gvmd.feed-owner", "Feed import owner was not set because the admin UUID could not be determined."))

    return make_result("runtime-manager-init", repo_root, "Runtime manager initialization completed.", findings, [str(runtime_dir(repo_root)), str(secret_path)])


def command_runtime_gmp_smoke(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    secret_path = runtime_secret_path(repo_root, DEV_ADMIN_SECRET)
    socket_path = gvmd_socket_path(repo_root)
    python = venv_python(repo_root, "python-gvm")
    probe = repo_root / "tools" / "runtime_gmp_smoke.py"
    findings.append(socket_readiness_finding("gvmd.socket", "gvmd", socket_path, missing_status="fail"))
    findings.append(finding("pass" if secret_path.is_file() else "fail", "runtime.admin-secret", "Development admin secret exists." if secret_path.is_file() else "Development admin secret is missing; run just runtime-manager-init.", str(secret_path)))
    findings.append(finding("pass" if python.is_file() else "fail", "python-gvm.venv", "python-gvm runtime venv exists." if python.is_file() else "python-gvm venv is missing; run just build-python.", str(python.relative_to(repo_root)) if python.exists() else str(python)))
    findings.append(finding("pass" if probe.is_file() else "fail", "gmp.probe", "GMP smoke probe exists." if probe.is_file() else "GMP smoke probe is missing.", str(probe.relative_to(repo_root))))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-gmp-smoke", repo_root, "GMP smoke stopped at prerequisites.", findings, [str(runtime_dir(repo_root))])

    result = run_command([str(python), str(probe), "--socket", str(socket_path), "--username", DEV_ADMIN_USER, "--password-file", str(secret_path)], repo_root, env=build_env(repo_root), timeout=60)
    try:
        parsed = json.loads(result.stdout)
    except json.JSONDecodeError:
        parsed = None
    probe_status = parsed.get("status") if parsed else None
    findings.append(finding("pass" if result.returncode == 0 and probe_status == "pass" else "fail", "gvmd.gmp", f"python-gvm authenticated get_version exit code {result.returncode}.", details={"probe": parsed, "output_tail": output_tail(result.stdout, 60)}))
    return make_result("runtime-gmp-smoke", repo_root, "Runtime GMP smoke completed.", findings, [str(runtime_dir(repo_root))])


def wait_for_runtime_gmp_smoke(repo_root: Path, *, attempts: int = 3, interval_seconds: int = 5) -> tuple[dict[str, Any], int]:
    last_result: dict[str, Any] | None = None
    for attempt in range(1, attempts + 1):
        last_result = command_runtime_gmp_smoke(repo_root)
        if last_result.get("status") == "pass":
            return last_result, attempt
        if attempt < attempts:
            time.sleep(interval_seconds)
    return last_result or make_result("runtime-gmp-smoke", repo_root, "Runtime GMP smoke did not run.", []), attempts


def browser_gmp_readiness_finding(repo_root: Path, *, check: str) -> dict[str, Any]:
    gmp_result, attempts = wait_for_runtime_gmp_smoke(repo_root)
    status = "pass" if gmp_result.get("status") == "pass" else "fail"
    return finding(
        status,
        check,
        "Authenticated GMP readiness was verified before browser validation." if status == "pass" else "Authenticated GMP readiness did not become available before browser validation.",
        details={
            "attempts": attempts,
            "status": gmp_result.get("status"),
            "summary": gmp_result.get("summary"),
            "failed_checks": [item for item in gmp_result.get("findings", []) if item.get("status") == "fail"],
        },
    )


def command_runtime_scanner_register(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    socket_path = ospd_socket_path(repo_root)
    findings.append(finding("pass" if socket_path.is_socket() else "fail", "ospd.socket", "ospd-openvas socket is ready." if socket_path.is_socket() else "ospd-openvas socket is not ready; run just runtime-app-up and inspect ospd-openvas logs.", str(socket_path)))
    gmp_smoke = command_runtime_gmp_smoke(repo_root)
    findings.append(finding(gmp_smoke["status"], "gvmd.gmp", gmp_smoke["summary"], details={"status": gmp_smoke["status"]}))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-scanner-register", repo_root, "Scanner registration stopped at prerequisites.", findings, [str(runtime_dir(repo_root))])

    scanners = run_gvmd_oneoff(repo_root, ["--get-scanners"], no_deps=False)
    scanner_uuid = parse_named_uuid(scanners.stdout, "OpenVAS Default") if scanners.returncode == 0 else None
    findings.append(finding("pass" if scanners.returncode == 0 else "fail", "gvmd.get-scanners", f"gvmd --get-scanners exit code {scanners.returncode}.", details={"scanner_uuid": scanner_uuid, "output_tail": output_tail(scanners.stdout, 80)}))
    if scanners.returncode != 0:
        return make_result("runtime-scanner-register", repo_root, "Scanner registration stopped while listing scanners.", findings, [str(runtime_dir(repo_root))])

    scanner_args = [
        "--scanner-name=OpenVAS Default",
        "--scanner-type=OpenVAS",
        "--scanner-host=/runtime/run/ospd/ospd-openvas.sock",
        "--scanner-port=0",
        "--no-default-certs",
    ]
    if scanner_uuid:
        change = run_gvmd_oneoff(repo_root, [f"--modify-scanner={scanner_uuid}", *scanner_args], no_deps=False)
        findings.append(finding("pass" if change.returncode == 0 else "fail", "gvmd.modify-scanner", f"Modify OpenVAS Default scanner exit code {change.returncode}.", details={"scanner_uuid": scanner_uuid, "output_tail": output_tail(change.stdout, 80)}))
    else:
        change = run_gvmd_oneoff(repo_root, ["--create-scanner=OpenVAS Default", *scanner_args[1:]], no_deps=False)
        scanner_uuid = parse_named_uuid(change.stdout, "OpenVAS Default") or parse_named_uuid(change.stdout, "Scanner")
        findings.append(finding("pass" if change.returncode == 0 else "fail", "gvmd.create-scanner", f"Create OpenVAS Default scanner exit code {change.returncode}.", details={"scanner_uuid": scanner_uuid, "output_tail": output_tail(change.stdout, 80)}))

    scanners_after = run_gvmd_oneoff(repo_root, ["--get-scanners"], no_deps=False)
    scanner_uuid = parse_named_uuid(scanners_after.stdout, "OpenVAS Default") if scanners_after.returncode == 0 else scanner_uuid
    findings.append(finding("pass" if scanner_uuid else "fail", "gvmd.scanner.openvas-default", "OpenVAS Default scanner is registered." if scanner_uuid else "OpenVAS Default scanner registration could not be confirmed.", details={"scanner_uuid": scanner_uuid, "output_tail": output_tail(scanners_after.stdout, 80)}))
    if scanner_uuid:
        verify = run_gvmd_oneoff(repo_root, [f"--verify-scanner={scanner_uuid}"], no_deps=False)
        findings.append(finding("pass" if verify.returncode == 0 else "warn", "gvmd.verify-scanner", f"Verify OpenVAS Default scanner exit code {verify.returncode}.", details={"scanner_uuid": scanner_uuid, "output_tail": output_tail(verify.stdout, 100)}))
    return make_result("runtime-scanner-register", repo_root, "Runtime scanner registration completed.", findings, [str(runtime_dir(repo_root))])


def command_runtime_feed_keyring_init(repo_root: Path) -> dict[str, Any]:
    findings = ensure_runtime_dirs(repo_root)
    home = feed_gnupg_home(repo_root)
    key_path = feed_community_key_path(repo_root)
    try:
        home.mkdir(parents=True, exist_ok=True)
        home.chmod(0o700)
        key_path.parent.mkdir(parents=True, exist_ok=True)
        findings.append(finding("pass", "feed-keyring.dir", "Shared feed signature keyring directory is ready.", str(home)))
    except OSError as error:
        findings.append(finding("fail", "feed-keyring.dir", f"Shared feed signature keyring directory is not usable: {error}", str(home)))

    findings.append(finding("pass" if shutil.which("gpg") else "fail", "gpg.available", "gpg is available." if shutil.which("gpg") else "gpg is missing."))
    findings.append(finding("pass" if shutil.which("curl") else "fail", "curl.available", "curl is available." if shutil.which("curl") else "curl is missing."))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-feed-keyring-init", repo_root, "Feed keyring initialization stopped at prerequisites.", findings, [str(home)])

    if key_path.is_file() and key_path.stat().st_size > 0:
        findings.append(finding("pass", "feed-keyring.community-key", "Greenbone Community signing key artifact already exists.", str(key_path)))
    else:
        download = run_command(feed_community_key_download_command(repo_root), repo_root, timeout=120)
        findings.append(finding("pass" if download.returncode == 0 else "fail", "feed-keyring.community-key", f"Download Greenbone Community signing key exit code {download.returncode}.", str(key_path), {"url": GREENBONE_COMMUNITY_KEY_URL, "output_tail": output_tail(download.stdout, 80)}))
        if download.returncode != 0:
            return make_result("runtime-feed-keyring-init", repo_root, "Feed keyring initialization stopped while downloading the signing key.", findings, [str(home), str(key_path)])

    imported = run_command(gpg_command(repo_root, "--import", str(key_path)), repo_root, timeout=120)
    findings.append(finding("pass" if imported.returncode == 0 else "fail", "feed-keyring.import", f"Import Greenbone Community signing key exit code {imported.returncode}.", details={"output_tail": output_tail(imported.stdout, 80)}))
    if imported.returncode != 0:
        return make_result("runtime-feed-keyring-init", repo_root, "Feed keyring initialization stopped while importing the signing key.", findings, [str(home), str(key_path)])

    ownertrust = run_command(gpg_command(repo_root, "--import-ownertrust"), repo_root, timeout=60, input_text=f"{GREENBONE_COMMUNITY_KEY_FPR}:6:\n")
    findings.append(finding("pass" if ownertrust.returncode == 0 else "fail", "feed-keyring.ownertrust", f"Set Greenbone Community signing key ownertrust exit code {ownertrust.returncode}.", details={"fingerprint": GREENBONE_COMMUNITY_KEY_FPR, "output_tail": output_tail(ownertrust.stdout, 80)}))

    fingerprint = run_command(gpg_command(repo_root, "--with-colons", "--fingerprint", GREENBONE_COMMUNITY_KEY_FPR), repo_root, timeout=60)
    fingerprint_ok = fingerprint.returncode == 0 and GREENBONE_COMMUNITY_KEY_FPR in fingerprint.stdout.replace(" ", "").upper()
    findings.append(finding("pass" if fingerprint_ok else "fail", "feed-keyring.fingerprint", "Greenbone Community signing key fingerprint is present." if fingerprint_ok else "Greenbone Community signing key fingerprint was not found after import.", details={"fingerprint": GREENBONE_COMMUNITY_KEY_FPR, "output_tail": output_tail(fingerprint.stdout, 80)}))

    for subtree, checksums, signature in notus_signature_files(repo_root):
        paths_ok = checksums.is_file() and signature.is_file()
        findings.append(finding("pass" if paths_ok else "fail", f"feed-keyring.notus-{subtree}-files", f"Notus {subtree} signature files are present." if paths_ok else f"Notus {subtree} signature files are missing.", details={"checksums": str(checksums), "signature": str(signature)}))
        if paths_ok:
            verify = run_command(gpg_command(repo_root, "--verify", str(signature), str(checksums)), repo_root, timeout=120)
            findings.append(finding("pass" if verify.returncode == 0 else "fail", f"feed-keyring.notus-{subtree}-signature", f"Verify Notus {subtree} sha256sums signature exit code {verify.returncode}.", details={"output_tail": output_tail(verify.stdout, 80)}))

    return make_result("runtime-feed-keyring-init", repo_root, "Shared feed signature keyring initialization completed.", findings, [str(home), str(key_path)])


def command_runtime_feed_import_init(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    feed_state = command_feed_state(repo_root)
    findings.extend(feed_state["findings"])
    runtime_findings = [item for item in feed_state["findings"] if item["check"].startswith("feed.runtime.")]
    runtime_class_findings = [item for item in runtime_findings if item["check"] != "feed.runtime.root"]
    if any(item["status"] != "pass" for item in runtime_class_findings):
        findings.append(finding("fail", "feed.runtime.ready", "Runtime feed copy is incomplete; refusing local feed import."))
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped because runtime feed classes are missing.", findings, [str(feed_runtime_root(repo_root))])
    findings.append(finding("pass", "feed.runtime.ready", "Runtime feed copy has all required feed classes."))

    findings.extend(ensure_runtime_feed_mappings(repo_root))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped while mapping runtime feed paths.", findings, [str(feed_runtime_root(repo_root))])

    pre_manager_stop = run_command(compose_command(repo_root, "--profile", "app", "stop", "gvmd"), repo_root, env=runtime_env(repo_root), timeout=120)
    findings.append(finding("pass" if pre_manager_stop.returncode == 0 else "fail", "gvmd.stop-for-manager-init", f"Stop gvmd service before manager one-shot initialization exit code {pre_manager_stop.returncode}.", details={"output_tail": output_tail(pre_manager_stop.stdout, 80)}))
    if pre_manager_stop.returncode != 0:
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped because gvmd could not be stopped before manager initialization.", findings, [str(runtime_dir(repo_root))])

    manager = command_runtime_manager_init(repo_root)
    findings.append(finding(manager["status"], "runtime.manager-init", manager["summary"], details={"status": manager["status"]}))
    scanner_redis = command_runtime_scanner_redis_init(repo_root, probe_openvas=False)
    findings.append(finding(scanner_redis["status"], "runtime.scanner-redis", scanner_redis["summary"], details={"status": scanner_redis["status"]}))
    keyring = command_runtime_feed_keyring_init(repo_root)
    findings.append(finding(keyring["status"], "runtime.feed-keyring", keyring["summary"], details={"status": keyring["status"]}))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped at runtime prerequisites.", findings, [str(runtime_dir(repo_root))])

    scanner_services = ("ospd-openvas", "notus-scanner")
    scanner_up = run_command(compose_command(repo_root, "--profile", "app", "up", "-d", "--no-deps", "--build", *scanner_services), repo_root, env=runtime_env(repo_root), timeout=900)
    findings.append(finding("pass" if scanner_up.returncode == 0 else "fail", "runtime.scanner-services-up", f"Start scanner-side app services for feed import exit code {scanner_up.returncode}.", details={"services": list(scanner_services), "output_tail": output_tail(scanner_up.stdout, 120)}))
    for service in scanner_services:
        running = container_running(repo_root, service)
        findings.append(finding("pass" if running else "fail", "runtime.scanner-service.running", f"{service} container is {'running' if running else 'not running'}.", details={"service": service, "logs_tail": [] if running else service_log_tail(repo_root, service)}))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped because scanner-side services are not ready.", findings, [str(runtime_dir(repo_root))])

    ospd_ready = wait_for_socket(ospd_socket_path(repo_root), timeout_seconds=30)
    findings.append(finding("pass" if ospd_ready else "fail", "ospd.socket", "ospd-openvas socket is ready for VT metadata rebuild." if ospd_ready else "ospd-openvas socket is not ready; cannot rebuild VT metadata.", str(ospd_socket_path(repo_root))))
    if not ospd_ready:
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped because OSPD is not ready.", findings, [str(runtime_dir(repo_root))])

    vt_status, vt_lines = wait_for_ospd_vt_load(repo_root, timeout_seconds=300)
    findings.append(
        finding(
            "pass" if vt_status == "pass" else "fail",
            "ospd.vt-load",
            "ospd-openvas finished loading VTs before manager rebuild." if vt_status == "pass" else "ospd-openvas did not finish loading VTs before manager rebuild.",
            details={"status": vt_status, "log_lines": vt_lines[-20:]},
        )
    )
    if vt_status != "pass":
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped because OSPD did not finish loading VTs.", findings, [str(runtime_dir(repo_root))])

    gvm_cli = gvm_cli_path(repo_root)
    findings.append(finding("pass" if gvm_cli.is_file() else "fail", "gvm-tools.cli", "gvm-cli is available for direct OSP readiness probes." if gvm_cli.is_file() else "gvm-cli is missing; run just build-python or just build-baseline.", str(gvm_cli.relative_to(repo_root)) if gvm_cli.exists() else str(gvm_cli)))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped because the OSP readiness probe is unavailable.", findings, [str(runtime_dir(repo_root))])

    ospd_feed_version, ospd_probe_tail = wait_for_ospd_vts_version(repo_root, timeout_seconds=180)
    findings.append(
        finding(
            "pass" if ospd_feed_version else "fail",
            "ospd.vts-version",
            f"ospd-openvas reports VT feed version {ospd_feed_version}." if ospd_feed_version else "ospd-openvas did not report a VT feed version before the readiness timeout.",
            details={"feed_version": ospd_feed_version, "output_tail": ospd_probe_tail},
        )
    )

    db_version_result = psql(repo_root, nvts_feed_version_query())
    db_feed_version = psql_value(db_version_result) if db_version_result.returncode == 0 else ""
    findings.append(
        finding(
            "pass" if db_version_result.returncode == 0 else "warn",
            "gvmd.nvts-feed-version",
            f"gvmd NVT database feed version is {db_feed_version or 'empty'}." if db_version_result.returncode == 0 else f"gvmd NVT database feed version query exit code {db_version_result.returncode}.",
            details={"feed_version": db_feed_version, "output_tail": output_tail(db_version_result.stdout, 40)},
        )
    )
    if not ospd_feed_version:
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped because OSPD did not report a VT feed version.", findings, [str(runtime_dir(repo_root))])

    stop_gvmd = run_command(compose_command(repo_root, "--profile", "app", "stop", "gvmd"), repo_root, env=runtime_env(repo_root), timeout=120)
    findings.append(finding("pass" if stop_gvmd.returncode == 0 else "fail", "gvmd.stop-for-import", f"Stop gvmd service before one-shot feed import exit code {stop_gvmd.returncode}.", details={"output_tail": output_tail(stop_gvmd.stdout, 80)}))
    if stop_gvmd.returncode != 0:
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped because gvmd could not be stopped cleanly.", findings, [str(runtime_dir(repo_root))])

    import_steps: list[tuple[str, list[str]]] = []
    if db_feed_version == ospd_feed_version:
        findings.append(finding("pass", "gvmd.rebuild-nvt", f"NVT database already matches OSPD feed version {ospd_feed_version}; skipped full NVT rebuild."))
    else:
        import_steps.append(("gvmd.rebuild-nvt", ["--rebuild", f"--osp-vt-update=/runtime/run/ospd/{ospd_socket_path(repo_root).name}"]))
    import_steps.extend([
        ("gvmd.rebuild-gvmd-data", ["--rebuild-gvmd-data=all"]),
        ("gvmd.rebuild-scap", ["--rebuild-scap"]),
    ])
    import_failed = False
    for check, args in import_steps:
        result = run_gvmd_runtime_oneoff(repo_root, args, no_deps=False, timeout=GVMD_IMPORT_TIMEOUT_SECONDS)
        findings.append(finding("pass" if result.returncode == 0 else "fail", check, f"gvmd {' '.join(args)} exit code {result.returncode}.", details={"output_tail": output_tail(result.stdout, 120)}))
        if result.returncode != 0:
            import_failed = True
            break

    restart = run_command(compose_command(repo_root, "--profile", "app", "up", "-d", "--no-deps", "--build", *APP_SERVICES), repo_root, env=runtime_env(repo_root), timeout=900)
    findings.append(finding("pass" if restart.returncode == 0 else "fail", "runtime.app-restart", f"Restart app services after feed import exit code {restart.returncode}.", details={"output_tail": output_tail(restart.stdout, 120)}))
    for service in APP_SERVICES:
        running = container_running(repo_root, service)
        findings.append(finding("pass" if running else "fail", "runtime.app.running", f"{service} container is {'running' if running else 'not running'} after feed import.", details={"service": service, "logs_tail": [] if running else service_log_tail(repo_root, service)}))
    if import_failed or restart.returncode != 0:
        return make_result("runtime-feed-import-init", repo_root, "Feed import stopped because a rebuild/import step failed.", findings, [str(runtime_dir(repo_root))])

    gvmd_ready = wait_for_socket(gvmd_socket_path(repo_root), timeout_seconds=180)
    findings.append(finding("pass" if gvmd_ready else "fail", "gvmd.socket-wait", "gvmd socket became ready after feed import restart." if gvmd_ready else "gvmd socket did not become ready after feed import restart.", str(gvmd_socket_path(repo_root))))

    probe_findings: list[dict[str, Any]] = []
    secret_path = runtime_secret_path(repo_root, DEV_ADMIN_SECRET)
    python = venv_python(repo_root, "python-gvm")
    probe = runtime_feed_objects_probe_path(repo_root)
    probe_findings.append(finding("pass" if gvmd_socket_path(repo_root).is_socket() else "fail", "gvmd.socket", "gvmd socket is ready." if gvmd_socket_path(repo_root).is_socket() else "gvmd socket is not ready.", str(gvmd_socket_path(repo_root))))
    probe_findings.append(finding("pass" if secret_path.is_file() else "fail", "runtime.admin-secret", "Development admin secret exists." if secret_path.is_file() else "Development admin secret is missing.", str(secret_path)))
    probe_findings.append(finding("pass" if python.is_file() else "fail", "python-gvm.venv", "python-gvm runtime venv exists." if python.is_file() else "python-gvm venv is missing.", str(python.relative_to(repo_root)) if python.exists() else str(python)))
    probe_findings.append(finding("pass" if probe.is_file() else "fail", "feed-objects.probe", "Runtime feed object probe exists." if probe.is_file() else "Runtime feed object probe is missing.", str(probe.relative_to(repo_root)) if probe.exists() else str(probe)))
    findings.extend(probe_findings)
    if aggregate_status(probe_findings) == "fail":
        return make_result("runtime-feed-import-init", repo_root, "Feed import completed but GMP feed object verification could not start.", findings, [str(runtime_dir(repo_root))])

    verify = run_command([str(python), str(probe), "--socket", str(gvmd_socket_path(repo_root)), "--username", DEV_ADMIN_USER, "--password-file", str(secret_path)], repo_root, env=build_env(repo_root), timeout=120)
    try:
        parsed = json.loads(verify.stdout)
    except json.JSONDecodeError:
        parsed = None
    verify_status = parsed.get("status") if parsed else None
    password = secret_path.read_text(encoding="utf-8").strip() if secret_path.is_file() else ""
    findings.append(finding("pass" if verify.returncode == 0 and verify_status == "pass" else "fail", "feed-objects.gmp", f"GMP feed object verification exit code {verify.returncode}.", details={"probe": parsed, "output_tail": output_tail(verify.stdout, 80, [password])}))
    return make_result("runtime-feed-import-init", repo_root, "Runtime feed import and verification completed.", findings, [str(runtime_dir(repo_root)), str(feed_runtime_root(repo_root))])


def command_runtime_scanner_capability_check(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    service = "ospd-openvas"
    running = container_running(repo_root, service)
    findings.append(finding("pass" if running else "fail", "ospd.running", "ospd-openvas container is running." if running else "ospd-openvas container is not running; run just runtime-app-up.", details={"service": service}))
    if not running:
        return make_result("runtime-scanner-capability-check", repo_root, "Scanner capability check stopped because ospd-openvas is not running.", findings)

    pid_probe = exec_in_service(repo_root, service, ["sh", "-lc", "ps -eo pid,comm,args | awk '$2 == \"ospd-openvas\" && /--foreground/ { print $1; exit }'"])
    scanner_pid = pid_probe.stdout.strip().splitlines()[0] if pid_probe.stdout.strip() else ""
    findings.append(finding("pass" if pid_probe.returncode == 0 and scanner_pid else "fail", "ospd.pid", f"ospd-openvas scanner process PID is {scanner_pid}." if scanner_pid else "ospd-openvas scanner process PID could not be found.", details={"output_tail": output_tail(pid_probe.stdout, 20)}))
    status_path = f"/proc/{scanner_pid}/status" if scanner_pid else "/proc/1/status"
    status = exec_in_service(repo_root, service, ["sh", "-lc", f"sed -n 's/^Uid:/Uid:/p; s/^Gid:/Gid:/p; s/^CapInh:/CapInh:/p; s/^CapPrm:/CapPrm:/p; s/^CapEff:/CapEff:/p; s/^CapBnd:/CapBnd:/p; s/^CapAmb:/CapAmb:/p' {shlex.quote(status_path)}"])
    values = parse_proc_status(status.stdout)
    expected_uid = runtime_env(repo_root)["TURBOVAS_UID"]
    expected_gid = runtime_env(repo_root)["TURBOVAS_GID"]
    actual_uid = first_proc_status_id(values.get("Uid"))
    actual_gid = first_proc_status_id(values.get("Gid"))
    findings.append(finding("pass" if status.returncode == 0 else "fail", "ospd.proc-status", f"{status_path} read exit code {status.returncode}.", details={"output_tail": output_tail(status.stdout, 40)}))
    findings.append(finding("pass" if actual_uid == expected_uid else "fail", "ospd.uid", f"ospd-openvas scanner process UID is {actual_uid}; expected {expected_uid}.", details={"uid_line": values.get("Uid"), "expected": expected_uid, "pid": scanner_pid}))
    findings.append(finding("pass" if actual_gid == expected_gid else "fail", "ospd.gid", f"ospd-openvas scanner process GID is {actual_gid}; expected {expected_gid}.", details={"gid_line": values.get("Gid"), "expected": expected_gid, "pid": scanner_pid}))

    hostname_probe = exec_in_service(repo_root, service, ["sh", "-lc", "hostname; getent hosts $(hostname)"])
    hostname_lines = hostname_probe.stdout.strip().splitlines()
    scanner_hostname = hostname_lines[0].strip() if hostname_lines else ""
    hostname_ok = hostname_probe.returncode == 0 and scanner_hostname == OSPD_STABLE_HOSTNAME and not hostname_looks_like_docker_short_id(scanner_hostname)
    findings.append(
        finding(
            "pass" if hostname_ok else "fail",
            "ospd.hostname",
            f"ospd-openvas hostname is the stable value {OSPD_STABLE_HOSTNAME}." if hostname_ok else f"ospd-openvas hostname is {scanner_hostname or 'unreadable'}; expected {OSPD_STABLE_HOSTNAME}.",
            details={"hostname": scanner_hostname, "expected": OSPD_STABLE_HOSTNAME, "output_tail": output_tail(hostname_probe.stdout, 20)},
        )
    )

    for cap_field in ("CapPrm", "CapEff", "CapAmb"):
        missing = missing_required_caps(values.get(cap_field))
        findings.append(
            finding(
                "pass" if not missing else "fail",
                f"ospd.{cap_field.lower()}",
                f"{cap_field} includes NET_RAW and NET_ADMIN." if not missing else f"{cap_field} is missing required capabilities: {', '.join(missing)}.",
                details={"value": values.get(cap_field), "missing": missing},
            )
        )

    raw_probe = exec_in_service(repo_root, service, ospd_setpriv_raw_socket_probe_command(repo_root))
    findings.append(finding("pass" if raw_probe.returncode == 0 and "raw-ok" in raw_probe.stdout else "fail", "ospd.raw-socket-probe", f"Service-user raw ICMP socket probe exit code {raw_probe.returncode}.", details={"output_tail": output_tail(raw_probe.stdout, 40)}))
    return make_result("runtime-scanner-capability-check", repo_root, "Scanner capability check completed.", findings)


def command_runtime_scanner_process_check(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    service = "ospd-openvas"
    running = container_running(repo_root, service)
    findings.append(finding("pass" if running else "fail", "ospd.running", "ospd-openvas container is running." if running else "ospd-openvas container is not running; run just runtime-app-up.", details={"service": service}))
    if not running:
        return make_result("runtime-scanner-process-check", repo_root, "Scanner process check stopped because ospd-openvas is not running.", findings)

    process_probe = exec_in_service(repo_root, service, ["ps", "-eo", "pid,ppid,stat,comm,args"])
    summary = summarize_scanner_processes(process_probe.stdout)
    zombie_count = summary["zombie_count"]
    active_count = summary["active_scanner_child_count"]
    if process_probe.returncode != 0:
        status = "fail"
        message = f"Scanner process table probe exit code {process_probe.returncode}."
    elif zombie_count and active_count:
        status = "warn"
        message = f"ospd-openvas has {zombie_count} zombie child process(es) while scanner children are active."
    elif zombie_count:
        status = "fail"
        message = f"ospd-openvas has {zombie_count} zombie child process(es) with no active scanner children."
    else:
        status = "pass"
        message = "ospd-openvas has no zombie child processes."
    findings.append(
        finding(
            status,
            "ospd.process-zombies",
            message,
            details={"process_summary": summary, "output_tail": output_tail(process_probe.stdout, 80)},
        )
    )
    return make_result("runtime-scanner-process-check", repo_root, "Scanner process check completed.", findings)


def command_runtime_nmap_capability_check(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    service = "ospd-openvas"
    running = container_running(repo_root, service)
    findings.append(finding("pass" if running else "fail", "ospd.running", "ospd-openvas container is running." if running else "ospd-openvas container is not running; run just runtime-app-up.", details={"service": service}))
    if not running:
        return make_result("runtime-nmap-capability-check", repo_root, "Nmap capability check stopped because ospd-openvas is not running.", findings)

    nmap_path = exec_in_service(repo_root, service, ["sh", "-lc", "command -v nmap"])
    path = nmap_path.stdout.strip().splitlines()[-1] if nmap_path.stdout.strip() else ""
    findings.append(finding("pass" if nmap_path.returncode == 0 and path else "fail", "nmap.path", f"nmap path probe exit code {nmap_path.returncode}.", details={"path": path, "output_tail": output_tail(nmap_path.stdout, 20)}))

    getcap = exec_in_service(repo_root, service, ["sh", "-lc", "command -v getcap >/dev/null 2>&1 && getcap /usr/bin/nmap || true"])
    caps_output = getcap.stdout.strip()
    file_caps_ok = "cap_net_raw" in caps_output and "cap_net_admin" in caps_output
    findings.append(
        finding(
            "pass" if getcap.returncode == 0 and file_caps_ok else "fail",
            "nmap.file-capabilities",
            "nmap has file capabilities for NET_RAW and NET_ADMIN." if file_caps_ok else "nmap is missing expected NET_RAW/NET_ADMIN file capabilities.",
            details={"output_tail": output_tail(getcap.stdout, 40)},
        )
    )

    env_probe = exec_in_service(repo_root, service, ["sh", "-lc", f"printf '%s' \"${{{NMAP_PRIVILEGED_ENV}:-}}\""])
    env_ok = env_probe.returncode == 0 and env_probe.stdout.strip() == "1"
    findings.append(
        finding(
            "pass" if env_ok else "fail",
            "nmap.env",
            f"{NMAP_PRIVILEGED_ENV}=1 is present in the scanner service environment." if env_ok else f"{NMAP_PRIVILEGED_ENV}=1 is missing from the scanner service environment.",
            details={"output_tail": output_tail(env_probe.stdout, 20)},
        )
    )

    for check, command in ospd_setpriv_nmap_probe_commands(repo_root):
        probe = exec_in_service(repo_root, service, command)
        privilege_warning = nmap_privilege_warning_present(probe.stdout)
        findings.append(
            finding(
                "pass" if probe.returncode == 0 and not privilege_warning else "fail",
                check,
                f"{check} probe exit code {probe.returncode}." if not privilege_warning else f"{check} probe still reports that root privileges are required.",
                details={"privilege_warning": privilege_warning, "output_tail": output_tail(probe.stdout, 80)},
            )
        )

    return make_result("runtime-nmap-capability-check", repo_root, "Nmap capability check completed.", findings)


def command_runtime_full_test_scan(repo_root: Path, action: str, confirm_authorized_lan: bool = False) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    secret_path = runtime_secret_path(repo_root, DEV_ADMIN_SECRET)
    python = venv_python(repo_root, "python-gvm")
    probe = runtime_full_test_scan_probe_path(repo_root)
    artifact_dir = full_test_scan_artifact_dir(repo_root)
    findings.append(finding("pass" if gvmd_socket_path(repo_root).is_socket() else "fail", "gvmd.socket", "gvmd socket is ready." if gvmd_socket_path(repo_root).is_socket() else "gvmd socket is not ready.", str(gvmd_socket_path(repo_root))))
    findings.append(finding("pass" if secret_path.is_file() else "fail", "runtime.admin-secret", "Development admin secret exists." if secret_path.is_file() else "Development admin secret is missing.", str(secret_path)))
    findings.append(finding("pass" if python.is_file() else "fail", "python-gvm.venv", "python-gvm runtime venv exists." if python.is_file() else "python-gvm venv is missing.", str(python.relative_to(repo_root)) if python.exists() else str(python)))
    findings.append(finding("pass" if probe.is_file() else "fail", "full-test-scan.probe", "Full test scan helper exists." if probe.is_file() else "Full test scan helper is missing.", str(probe.relative_to(repo_root)) if probe.exists() else str(probe)))
    try:
        artifact_dir.mkdir(parents=True, exist_ok=True)
        findings.append(finding("pass", "full-test-scan.artifact-dir", "Full test scan artifact directory is ready.", str(artifact_dir)))
    except OSError as error:
        findings.append(finding("fail", "full-test-scan.artifact-dir", f"Full test scan artifact directory is not usable: {error}", str(artifact_dir)))

    if action in {"preflight", "start"}:
        capability = command_runtime_scanner_capability_check(repo_root)
        findings.append(finding(capability["status"], "ospd.capability-check", capability["summary"], details={"status": capability["status"], "findings": capability["findings"]}))
        process_check = command_runtime_scanner_process_check(repo_root)
        findings.append(finding(process_check["status"], "ospd.process-check", process_check["summary"], details={"status": process_check["status"], "findings": process_check["findings"]}))
        nmap_capability = command_runtime_nmap_capability_check(repo_root)
        findings.append(finding(nmap_capability["status"], "nmap.capability-check", nmap_capability["summary"], details={"status": nmap_capability["status"], "findings": nmap_capability["findings"]}))

    command_name = f"runtime-full-test-scan-{action}"
    if aggregate_status(findings) == "fail":
        return make_result(command_name, repo_root, "Full test scan command stopped at prerequisites.", findings, [str(artifact_dir)])

    args = [
        str(python),
        str(probe),
        action,
        "--socket",
        str(gvmd_socket_path(repo_root)),
        "--username",
        DEV_ADMIN_USER,
        "--password-file",
        str(secret_path),
        "--artifact-dir",
        str(artifact_dir),
        "--ospd-log-file",
        str(runtime_path(repo_root, "logs", "ospd", "ospd-openvas.log")),
    ]
    if confirm_authorized_lan:
        args.append("--confirm-authorized-lan")
    result = run_command(args, repo_root, env=build_env(repo_root), timeout=120)
    try:
        parsed = json.loads(result.stdout)
    except json.JSONDecodeError:
        parsed = None
    helper_status = parsed.get("status") if parsed else None
    finding_status = helper_status if result.returncode == 0 and helper_status in {"pass", "warn"} else "fail"
    password = secret_path.read_text(encoding="utf-8").strip() if secret_path.is_file() else ""
    findings.append(
        finding(
            finding_status,
            f"full-test-scan.{action}",
            parsed.get("summary", f"Full test scan helper exit code {result.returncode}.") if parsed else f"Full test scan helper exit code {result.returncode}.",
            details={"helper": parsed, "output_tail": output_tail(result.stdout, 120, [password])},
        )
    )
    artifacts = list(parsed.get("artifacts", [])) if parsed and isinstance(parsed.get("artifacts"), list) else [str(artifact_dir)]
    summary = parsed.get("summary") if parsed else f"Full test scan {action} command completed with exit code {result.returncode}."
    return make_result(command_name, repo_root, summary, findings, artifacts)


