    for name, path_summary in paths.items():
        classification = path_summary.get("classification", "unknown")
        bucket = summary["by_classification"].setdefault(
            classification,
            {"path_count": 0, "existing_path_count": 0, "file_count": 0, "byte_count": 0, "paths": []},
        )
        bucket["path_count"] += 1
        if path_summary.get("exists"):
            bucket["existing_path_count"] += 1
        bucket["file_count"] += int(path_summary.get("file_count") or 0)
        bucket["byte_count"] += int(path_summary.get("byte_count") or 0)
        bucket["paths"].append(name)
