def split_gsad_hosts(value: str | None) -> tuple[str, ...]:
    if not value:
        return ()
    hosts: list[str] = []
    seen: set[str] = set()
    for raw_host in value.split(","):
        host = raw_host.strip()
        if not host or host in seen:
            continue
        hosts.append(host)
        seen.add(host)
    return tuple(hosts)


def env_truthy(value: str | None) -> bool:
    return bool(value) and value.strip().lower() in {"1", "true", "yes", "on"}


def gsad_hosts(repo_root: Path) -> tuple[str, ...]:
    env = runtime_env(repo_root)
    return gsad_hosts_from_env(env)


def gsad_hosts_from_env(env: dict[str, str]) -> tuple[str, ...]:
    hosts = split_gsad_hosts(env.get(GSAD_HOSTS_ENV))
    if hosts:
        return hosts
    return split_gsad_hosts(env.get(GSAD_HOST_ENV)) or (DEFAULT_GSAD_HOST,)


def native_api_direct_requested(env: dict[str, str]) -> bool:
    return env_truthy(env.get(TURBOVAS_API_DIRECT_ENV)) or any(
        env.get(name)
        for name in (
            TURBOVAS_API_DIRECT_HOST_ENV,
            TURBOVAS_API_DIRECT_PORT_ENV,
            TURBOVAS_API_DIRECT_BIND_ENV,
        )
    )


def native_api_direct_host(env: dict[str, str]) -> str:
