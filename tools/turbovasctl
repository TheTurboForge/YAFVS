def stage_gsa_static(repo_root: Path) -> list[dict[str, Any]]:
    findings: list[dict[str, Any]] = []
    source = gsa_build_dir(repo_root)
    destination = gsad_static_dir(repo_root)
    index = source / "index.html"
    findings.append(finding("pass" if index.is_file() else "fail", "gsa.build.index", "GSA production build index.html exists." if index.is_file() else "GSA production build is missing index.html; run just build-ui.", str(index)))
    if aggregate_status(findings) == "fail":
        return findings
    if destination.exists():
        shutil.rmtree(destination)
    destination.parent.mkdir(parents=True, exist_ok=True)
    shutil.copytree(source, destination)
    config_js = destination / "config.js"
    fallback_api_server = f"{gsad_host(repo_root)}:{GSAD_PORT}"
    config_js.write_text(
        "config = {\n"
        "  apiProtocol: (window.location.protocol || 'https:').replace(':', ''),\n"
        f"  apiServer: window.location.host || '{fallback_api_server}',\n"
        "};\n",
        encoding="utf-8",
    )
    findings.append(finding("pass", "gsa.static-stage", "GSA production build is staged for gsad.", str(destination)))
    findings.append(finding("pass", "gsa.config-js", "GSA config.js uses the browser host with a fallback gsad endpoint.", str(config_js), {"api_protocol": "browser", "api_server_fallback": fallback_api_server, "hosts": list(gsad_hosts(repo_root))}))
    return findings


def first_gsa_asset_rel(index_html: str) -> str | None:
    match = re.search(r"""(?:src|href)=["']/(assets/[^"']+)["']""", index_html)
    return match.group(1) if match else None


def path_latest_mtime(path: Path, *, skip_dirs: frozenset[str] = frozenset()) -> float | None:
    try:
        if path.is_file():
            return path.stat().st_mtime
        if not path.is_dir():
            return None
    except OSError:
        return None
    latest: float | None = None
    for root, dirs, files in os.walk(path):
        dirs[:] = [dirname for dirname in dirs if dirname not in skip_dirs]
        root_path = Path(root)
        for filename in files:
            try:
                mtime = (root_path / filename).stat().st_mtime
            except OSError:
                continue
            latest = mtime if latest is None else max(latest, mtime)
    return latest


def paths_latest_mtime(repo_root: Path, rel_paths: Iterable[str], *, skip_dirs: frozenset[str] = frozenset()) -> tuple[float | None, str | None]:
    latest: float | None = None
    latest_path: str | None = None
    for rel_path in rel_paths:
        mtime = path_latest_mtime(repo_root / rel_path, skip_dirs=skip_dirs)
        if mtime is None:
            continue
        if latest is None or mtime > latest:
            latest = mtime
            latest_path = rel_path
    return latest, latest_path


def iso_mtime(mtime: float | None) -> str | None:
    return datetime.fromtimestamp(mtime, timezone.utc).replace(microsecond=0).isoformat() if mtime is not None else None


def parse_container_started_at(value: Any) -> float | None:
    if not isinstance(value, str) or not value:
        return None
    try:
        parsed = datetime.fromisoformat(value.replace("Z", "+00:00"))
    except ValueError:
        return None
    return parsed.timestamp()


def qualified_table_name(schema: str, table: str) -> str:
    return f"{sql_identifier(schema)}.{sql_identifier(table)}"


def qualified_table_row_count(repo_root: Path, schema: str, table: str) -> int | None:
    result = psql(repo_root, f"SELECT count(*) FROM {qualified_table_name(schema, table)};")
    if result.returncode != 0:
        return None
    value = psql_value(result)
    try:
        return int(value)
    except ValueError:
        return None


def introspection_table_presence(repo_root: Path) -> tuple[subprocess.CompletedProcess[str], dict[str, bool]]:
    values = ",".join(f"({sql_literal(schema)}, {sql_literal(table)})" for schema, table in DB_INTROSPECT_TABLES)
    query = (
        f"WITH wanted(schema_name, table_name) AS (VALUES {values}) "
        "SELECT wanted.schema_name || '.' || wanted.table_name || '|' || (tables.table_name IS NOT NULL) "
        "FROM wanted LEFT JOIN information_schema.tables tables "
        "ON tables.table_schema = wanted.schema_name AND tables.table_name = wanted.table_name "
        "ORDER BY wanted.schema_name, wanted.table_name;"
    )
    result = psql(repo_root, query)
    rows: dict[str, bool] = {}
    if result.returncode == 0:
        for line in result.stdout.splitlines():
            if "|" not in line:
                continue
            name, value = line.strip().split("|", 1)
            rows[name] = value.strip().lower() in ("t", "true", "1")
    return result, rows


def introspection_column_presence(repo_root: Path) -> tuple[subprocess.CompletedProcess[str], dict[str, bool]]:
    values = ",".join(f"({sql_literal(schema)}, {sql_literal(table)}, {sql_literal(column)})" for schema, table, column in DB_INTROSPECT_COLUMNS)
    query = (
        f"WITH wanted(schema_name, table_name, column_name) AS (VALUES {values}) "
        "SELECT wanted.schema_name || '.' || wanted.table_name || '.' || wanted.column_name || '|' || (columns.column_name IS NOT NULL) "
        "FROM wanted LEFT JOIN information_schema.columns columns "
        "ON columns.table_schema = wanted.schema_name AND columns.table_name = wanted.table_name AND columns.column_name = wanted.column_name "
        "ORDER BY wanted.schema_name, wanted.table_name, wanted.column_name;"
    )
    result = psql(repo_root, query)
    rows: dict[str, bool] = {}
    if result.returncode == 0:
        for line in result.stdout.splitlines():
            if "|" not in line:
                continue
            name, value = line.strip().split("|", 1)
            rows[name] = value.strip().lower() in ("t", "true", "1")
    return result, rows


def runtime_gsa_freshness_findings(repo_root: Path) -> list[dict[str, Any]]:
    findings: list[dict[str, Any]] = []
    staged = gsad_static_dir(repo_root)
    staged_latest, staged_latest_path = paths_latest_mtime(repo_root, (str(staged.relative_to(repo_root)),)) if staged.exists() else (None, None)
    source_latest, source_latest_path = paths_latest_mtime(repo_root, GSA_FRESHNESS_SOURCE_PATHS, skip_dirs=GSA_FRESHNESS_SKIP_DIRS)
    if staged_latest is not None and source_latest is not None and source_latest > staged_latest:
        findings.append(
            finding(
                "warn",
                "gsa.static-freshness",
                "GSA source inputs are newer than staged gsad static assets; run just build-ui before browser validation.",
                str(staged),
                {
                    "latest_source_path": source_latest_path,
                    "latest_source_mtime": iso_mtime(source_latest),
                    "latest_staged_path": staged_latest_path,
                    "latest_staged_mtime": iso_mtime(staged_latest),
                },
            )
        )
    elif staged_latest is not None:
        findings.append(finding("pass", "gsa.static-freshness", "Staged GSA static assets are not older than tracked GSA source inputs.", str(staged), {"latest_staged_mtime": iso_mtime(staged_latest), "latest_source_mtime": iso_mtime(source_latest)}))

    gsad_state = docker_container_state(repo_root, "gsad")
    started_at = parse_container_started_at(gsad_state.get("StartedAt") if gsad_state else None)
    gsad_source_latest, gsad_source_latest_path = paths_latest_mtime(repo_root, GSAD_FRESHNESS_SOURCE_PATHS)
    gsad_build_latest, gsad_build_latest_path = paths_latest_mtime(repo_root, GSAD_FRESHNESS_BUILD_PATHS)
    compare_latest = max([value for value in (staged_latest, gsad_source_latest, gsad_build_latest) if value is not None], default=None)
    if started_at is not None and compare_latest is not None and compare_latest > started_at:
        findings.append(
            finding(
                "warn",
                "gsad.runtime-freshness",
                "Running gsad predates relevant static or native-proxy build inputs; run just build-c-services, just build-ui, then refresh runtime-app-up before browser validation.",
                details={
                    "container_id": gsad_state.get("container_id") if gsad_state else None,
                    "started_at": gsad_state.get("StartedAt") if gsad_state else None,
                    "latest_gsad_source_path": gsad_source_latest_path,
                    "latest_gsad_source_mtime": iso_mtime(gsad_source_latest),
                    "latest_gsad_build_path": gsad_build_latest_path,
                    "latest_gsad_build_mtime": iso_mtime(gsad_build_latest),
                    "latest_staged_mtime": iso_mtime(staged_latest),
                },
            )
        )
    elif started_at is not None:
        findings.append(finding("pass", "gsad.runtime-freshness", "Running gsad is not older than relevant static or native-proxy build inputs.", details={"started_at": gsad_state.get("StartedAt") if gsad_state else None}))
    return findings


def feed_path_summary(path: Path, markers: tuple[str, ...]) -> dict[str, Any]:
    file_count = 0
    byte_count = 0
    latest_mtime: float | None = None
    errors: list[str] = []
    if path.is_dir():
        for entry in path.rglob("*"):
            try:
                if entry.is_file():
                    stat = entry.stat()
                    file_count += 1
                    byte_count += stat.st_size
                    latest_mtime = stat.st_mtime if latest_mtime is None else max(latest_mtime, stat.st_mtime)
            except OSError as error:
                errors.append(f"{entry}: {error}")
    marker_rows = [{"path": marker, "exists": (path / marker).exists()} for marker in markers]
    latest = datetime.fromtimestamp(latest_mtime, timezone.utc).replace(microsecond=0).isoformat() if latest_mtime is not None else None
    return {
        "exists": path.is_dir(),
        "file_count": file_count,
        "byte_count": byte_count,
        "latest_mtime": latest,
        "markers": marker_rows,
        "errors": errors[:20],
    }


def feed_location_findings(repo_root: Path, location: str, root: Path, rel_attr: str) -> list[dict[str, Any]]:
    findings: list[dict[str, Any]] = []
    findings.append(finding("pass" if root.is_dir() else "warn", f"feed.{location}.root", f"{location} feed root {'exists' if root.is_dir() else 'is missing'}.", str(root)))
    for feed_class in FEED_CLASSES:
        rel = getattr(feed_class, rel_attr)
        path = root / rel
        summary = feed_path_summary(path, feed_class.markers)
        marker_missing = [row["path"] for row in summary["markers"] if not row["exists"]]
        status = "pass" if summary["exists"] and summary["file_count"] > 0 and not marker_missing and not summary["errors"] else "warn"
        if not summary["exists"]:
            message = f"{feed_class.label} directory is missing."
        elif summary["file_count"] == 0:
            message = f"{feed_class.label} directory exists but contains no files."
        elif marker_missing:
            message = f"{feed_class.label} has files but expected markers are missing."
        elif summary["errors"]:
            message = f"{feed_class.label} state has filesystem inspection errors."
        else:
            message = f"{feed_class.label} is present."
        findings.append(finding(status, f"feed.{location}.{feed_class.key}", message, str(path), {"summary": summary, "missing_markers": marker_missing}))
    return findings


