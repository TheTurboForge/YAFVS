def native_tooling_markers(path: Path, relative_path: str) -> list[str]:
    try:
        text = path.read_text(encoding="utf-8", errors="ignore")
    except OSError:
        return []
    lower = text.lower()
    excluded = NATIVE_TOOLING_MARKER_EXCLUSIONS.get(relative_path, frozenset())
    return [marker for marker in NATIVE_TOOLING_MARKERS if marker not in excluded and marker.lower() in lower]


def native_tooling_category(relative_path: str) -> tuple[str, str] | None:
    path = Path(relative_path)
    if relative_path.startswith(GSA_NATIVE_API_CLIENT_PREFIX):
        return None
    if relative_path == "components/gsa/src/gmp/__tests__/gmp.test.ts":
        return "compatibility_bridge", "GSA session tests characterize compatibility login/logout behavior; they are not a product workflow."
    if relative_path == "tools/runtime_browser_smoke.py":
        return "compatibility_bridge", "Browser smoke keeps a bounded raw GMP cleanup fallback for test artifacts; it imports neither removed legacy client."
    if relative_path == "tools/yafvsctl-rs/src/commands/runtime_probe.rs":
        return "compatibility_bridge", "Rust CLI orchestration retains bounded raw GMP smoke helpers without depending on removed python-gvm or gvm-tools clients."
    if relative_path == "tools/yafvsctl":
        return "compatibility_bridge", "yafvsctl measures the completed legacy-client teardown and remaining GMP owner tails."
    if relative_path.startswith("tools/runtime_") and relative_path.endswith(".py"):
        return "required_runtime", "YAFVS runtime/helper command path still depends on inherited GMP/python-gvm plumbing."
    if relative_path.startswith("tools/tests/"):
        return "compatibility_bridge", "Diagnostic tests characterize and guard inherited GMP/python-gvm/gvm-tools retirement; they do not require legacy clients at runtime."
    if relative_path == "components/gsa/src/gmp/commands/entity.ts":
        return "compatibility_bridge", "Shared GSA command base remains compatibility plumbing until the last inherited command owner is removed; it is not an independent product workflow."
    if relative_path == "components/gsa/src/gmp/commands/overrides.js":
        return "compatibility_bridge", "GSA Override command adapter delegates retained create, read, modify, clone, export, and delete behavior to the native API; it has no inherited command execution."
    if relative_path == "components/gsa/src/gmp/commands/user.ts":
        return "compatibility_bridge", "The fully native User command adapter retains the inherited gmp namespace and logger name only; it executes no GMP command."
    if relative_path.startswith("components/gsa/src/gmp/commands/") and "/__tests__/" not in relative_path:
        return "product_workflow", "GSA product workflow still reads or writes through an inherited GMP command owner."
    if relative_path.startswith("components/gsa/src/gmp/"):
        return "compatibility_bridge", "Generic GSA model, locale, parser, HTTP, or test plumbing remains until inherited GMP command owners are removed."
    if relative_path.startswith("docs/") or relative_path in {"README.md", "UPSTREAMS.md", "LICENSE_AUDIT.md", "BUILDING.md"}:
        return "compatibility_bridge", "Documentation references inherited tooling while the native API retirement map is active."
    return None


def native_tooling_scan_candidate(relative_path: str) -> bool:
    if relative_path.startswith(GSA_NATIVE_API_CLIENT_PREFIX):
        return False
    return relative_path in NATIVE_TOOLING_SCAN_FILES or any(relative_path.startswith(prefix) for prefix in NATIVE_TOOLING_SCAN_PREFIXES)


def native_tooling_inventory(repo_root: Path) -> list[dict[str, Any]]:
    tracked = git_tracked_files(repo_root) or []
    items: list[dict[str, Any]] = []
    for relative_path in tracked:
        if not native_tooling_scan_candidate(relative_path):
            continue
        path = repo_root / relative_path
        if not path.is_file():
            continue
        markers = native_tooling_markers(path, relative_path)
        if not markers:
            continue
        classified = native_tooling_category(relative_path)
        category, reason = classified if classified else ("unknown", "Inherited tooling marker appears outside the current retirement map classification.")
        item = {"category": category, "path": relative_path, "markers": markers, "reason": reason}
        residue = native_tooling_residue(relative_path, category)
        if residue is not None:
            residue_kind, residue_reason = residue
            item["residue_kind"] = residue_kind
            item["residue_reason"] = residue_reason
        items.append(item)
    return sorted(items, key=lambda item: (NATIVE_TOOLING_CATEGORIES.index(item["category"]), item["path"]))


def source_file_contains(repo_root: Path | None, relative_path: str, needle: str) -> bool:
    if repo_root is None:
