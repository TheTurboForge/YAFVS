def command_runtime_scope(repo_root: Path, action: str) -> dict[str, Any]:
    if action == "summary":
        return command_runtime_scope_report_summary_native(repo_root)

    findings: list[dict[str, Any]] = []
    secret_path = runtime_secret_path(repo_root, DEV_ADMIN_SECRET)
    python = venv_python(repo_root, "python-gvm")
    probe = runtime_scope_probe_path(repo_root)
    artifact_dir = scope_report_artifact_dir(repo_root)
    findings.append(finding("pass" if gvmd_socket_path(repo_root).is_socket() else "fail", "gvmd.socket", "gvmd socket is ready." if gvmd_socket_path(repo_root).is_socket() else "gvmd socket is not ready.", str(gvmd_socket_path(repo_root))))
    findings.append(finding("pass" if secret_path.is_file() else "fail", "runtime.admin-secret", "Development admin secret exists." if secret_path.is_file() else "Development admin secret is missing.", str(secret_path)))
    findings.append(finding("pass" if python.is_file() else "fail", "python-gvm.venv", "python-gvm runtime venv exists." if python.is_file() else "python-gvm venv is missing.", str(python.relative_to(repo_root)) if python.exists() else str(python)))
    findings.append(finding("pass" if probe.is_file() else "fail", "runtime-scope.probe", "Runtime scope helper exists." if probe.is_file() else "Runtime scope helper is missing.", str(probe.relative_to(repo_root)) if probe.exists() else str(probe)))
    try:
        artifact_dir.mkdir(parents=True, exist_ok=True)
        findings.append(finding("pass", "runtime-scope.artifact-dir", "Runtime scope artifact directory is ready.", str(artifact_dir)))
    except OSError as error:
        findings.append(finding("fail", "runtime-scope.artifact-dir", f"Runtime scope artifact directory is not usable: {error}", str(artifact_dir)))

    command_name = "runtime-scope-smoke" if action == "smoke" else "runtime-scope-report-summary"
    if aggregate_status(findings) == "fail":
        return make_result(command_name, repo_root, "Runtime scope command stopped at prerequisites.", findings, [str(artifact_dir)])

    args = [
        str(python),
        str(probe),
        action,
        "--socket",
        str(gvmd_socket_path(repo_root)),
        "--username",
        DEV_ADMIN_USER,
        "--password-file",
        str(secret_path),
        "--artifact-dir",
        str(artifact_dir),
    ]
    result = run_command(args, repo_root, env=build_env(repo_root), timeout=180)
    try:
        parsed = json.loads(result.stdout)
    except json.JSONDecodeError:
        parsed = None
    helper_status = parsed.get("status") if parsed else None
    finding_status = helper_status if result.returncode == 0 and helper_status in {"pass", "warn"} else "fail"
    password = secret_path.read_text(encoding="utf-8").strip() if secret_path.is_file() else ""
    findings.append(
        finding(
            finding_status,
            f"runtime-scope.{action}",
            parsed.get("summary", f"Runtime scope helper exit code {result.returncode}.") if parsed else f"Runtime scope helper exit code {result.returncode}.",
            details={"helper": parsed, "output_tail": output_tail(result.stdout, 120, [password])},
        )
    )
    if action == "smoke":
        organization_proof = runtime_scope_organization_proof_finding(parsed)
        if organization_proof is not None:
            findings.append(organization_proof)
    artifacts = list(parsed.get("artifacts", [])) if parsed and isinstance(parsed.get("artifacts"), list) else [str(artifact_dir)]
    summary = parsed.get("summary") if parsed else f"Runtime scope {action} command completed with exit code {result.returncode}."
    return make_result(command_name, repo_root, summary, findings, artifacts)



def runtime_scope_organization_proof_finding(parsed: dict[str, Any] | None) -> dict[str, Any] | None:
    if not parsed or parsed.get("status") not in {"pass", "warn"}:
        return None
    details = parsed.get("details")
    if not isinstance(details, dict):
        return None
    organization = details.get("organization_scope")
    organization_report = details.get("organization_scope_report")
    scope_after_add = details.get("scope_after_add")
    scope_after_remove = details.get("scope_after_remove")
    cleanup = details.get("cleanup")
    if not all(
        isinstance(value, dict)
        for value in (organization, organization_report, scope_after_add, scope_after_remove, cleanup)
    ):
        return None

    proof = {
        "organization_target_count": organization.get("target_count"),
        "organization_host_count": organization.get("host_count"),
        "organization_source_report_count": organization_report.get("source_report_count"),
        "scope_after_add_target_count": scope_after_add.get("target_count"),
        "scope_after_add_host_count": scope_after_add.get("host_count"),
        "scope_after_remove_target_count": scope_after_remove.get("target_count"),
        "scope_after_remove_host_count": scope_after_remove.get("host_count"),
        "cleanup_scope": cleanup.get("scope"),
        "cleanup_scope_report": cleanup.get("scope_report"),
    }
    expected = {
        "organization_target_count": lambda value: isinstance(value, int) and value > 0,
        "organization_host_count": lambda value: isinstance(value, int) and value > 0,
        "organization_source_report_count": lambda value: isinstance(value, int) and value > 0,
        "scope_after_add_target_count": lambda value: isinstance(value, int) and value >= 2,
        "scope_after_add_host_count": lambda value: isinstance(value, int) and value >= 2,
        "scope_after_remove_target_count": lambda value: value == 1,
        "scope_after_remove_host_count": lambda value: value == 1,
        "cleanup_scope": lambda value: value == "deleted",
        "cleanup_scope_report": lambda value: value == "deleted",
    }
    status = "pass" if all(check(proof.get(key)) for key, check in expected.items()) else "warn"
    return finding(
        status,
        "runtime-scope.organization-proof",
        "Organization scope membership and source-report proof is available."
        if status == "pass"
        else "Organization scope membership proof is incomplete; inspect the scope smoke artifact.",
        details=proof,
    )


