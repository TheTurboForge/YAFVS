    openvas_settings = run_app_oneoff(repo_root, "ospd-openvas", ["openvas", "-s"], no_deps=False)
    db_lines = [line for line in openvas_settings.stdout.splitlines() if line.startswith("db_address")]
    plugin_lines = [line for line in openvas_settings.stdout.splitlines() if line.startswith("plugins_folder")]
    include_lines = [line for line in openvas_settings.stdout.splitlines() if line.startswith("include_folders")]
    db_ok = openvas_settings.returncode == 0 and any("/runtime/run/redis-openvas/redis.sock" in line for line in db_lines)
    plugins_ok = openvas_settings.returncode == 0 and any("/runtime/feeds/openvas/plugins" in line for line in plugin_lines)
    include_ok = openvas_settings.returncode == 0 and any("/runtime/feeds/openvas/plugins" in line for line in include_lines)
    findings.append(finding("pass" if db_ok else "fail", "openvas.db_address", f"openvas -s runtime db_address check exit code {openvas_settings.returncode}.", details={"db_address_lines": db_lines, "output_tail": output_tail(openvas_settings.stdout, 80)}))
    findings.append(finding("pass" if plugins_ok else "fail", "openvas.plugins_folder", f"openvas -s runtime plugins_folder check exit code {openvas_settings.returncode}.", details={"plugins_folder_lines": plugin_lines, "output_tail": output_tail(openvas_settings.stdout, 80)}))
    findings.append(finding("pass" if include_ok else "fail", "openvas.include_folders", f"openvas -s runtime include_folders check exit code {openvas_settings.returncode}.", details={"include_folders_lines": include_lines, "output_tail": output_tail(openvas_settings.stdout, 80)}))
