def quality_gate_schedule_status_details(repo_root: Path) -> tuple[list[dict[str, Any]], dict[str, Any]]:
    findings: list[dict[str, Any]] = []
    unit_dir = systemd_user_unit_dir()
    details: dict[str, Any] = {
        "host": socket.gethostname(),
        "user": os.environ.get("USER") or Path.home().name,
        "unit_dir": str(unit_dir),
        "units": {},
    }
    systemd = systemctl_user(repo_root, "status", timeout=30)
    details["systemd_user_available"] = systemd.returncode == 0
    findings.append(process_step_finding("pass" if systemd.returncode == 0 else "fail", "quality-gate-schedule.systemd-user", f"systemctl --user status exit code {systemd.returncode}.", systemd, ["systemctl", "--user", "status"]))

    for unit in QUALITY_GATE_SYSTEMD_UNITS:
        path = unit_dir / unit
        unit_details: dict[str, Any] = {"path": str(path), "exists": path.is_file()}
        if path.is_file():
            findings.append(finding("pass", "quality-gate-schedule.unit-file", f"{unit} is installed in the user unit directory.", str(path)))
        else:
            findings.append(finding("warn", "quality-gate-schedule.unit-file", f"{unit} is not installed in the user unit directory.", str(path)))
        show = systemctl_user(repo_root, "show", unit, "--property=LoadState,UnitFileState,ActiveState,SubState,NextElapseUSecRealtime,LastTriggerUSecRealtime", timeout=30)
        unit_details["systemctl_show_exit_code"] = show.returncode
        properties = systemd_show_properties(show.stdout) if show.returncode == 0 else {}
        unit_details["properties"] = properties
        if show.returncode == 0 and properties.get("ActiveState") == "failed":
            findings.append(finding("fail", "quality-gate-schedule.unit-state", f"{unit} is in failed state.", str(path), details=properties))
        details["units"][unit] = unit_details

    enabled = systemctl_user(repo_root, "is-enabled", QUALITY_GATE_TIMER_NAME, timeout=30)
    active = systemctl_user(repo_root, "is-active", QUALITY_GATE_TIMER_NAME, timeout=30)
    details["timer_enabled"] = enabled.stdout.strip()
    details["timer_active"] = active.stdout.strip()
    if (unit_dir / QUALITY_GATE_TIMER_NAME).is_file():
        findings.append(process_step_finding("pass" if enabled.returncode == 0 else "warn", "quality-gate-schedule.enabled", f"{QUALITY_GATE_TIMER_NAME} enablement is {enabled.stdout.strip() or 'unknown'}.", enabled, ["systemctl", "--user", "is-enabled", QUALITY_GATE_TIMER_NAME]))
        findings.append(process_step_finding("pass" if active.returncode == 0 else "warn", "quality-gate-schedule.active", f"{QUALITY_GATE_TIMER_NAME} activity is {active.stdout.strip() or 'unknown'}.", active, ["systemctl", "--user", "is-active", QUALITY_GATE_TIMER_NAME]))
    return findings, details


