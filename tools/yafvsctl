def native_empty_trash_preview_payload(value: Any) -> dict[str, Any] | None:
    if not isinstance(value, dict) or set(value) != {"scope", "items", "total", "snapshot_digest"}:
        return None
    scope = value.get("scope")
    items = value.get("items")
    total = value.get("total")
    snapshot_digest = value.get("snapshot_digest")
    if (
        scope != NATIVE_EMPTY_TRASH_SCOPE
        or type(total) is not int
        or total < 0
        or not isinstance(items, list)
        or not isinstance(snapshot_digest, str)
        or re.fullmatch(r"[0-9a-f]{64}", snapshot_digest) is None
    ):
        return None
    normalized_items: list[dict[str, Any]] = []
    resource_types: set[str] = set()
    for item in items:
        if not isinstance(item, dict) or set(item) != {"resource_type", "count"}:
            return None
        resource_type = item.get("resource_type")
        count = item.get("count")
        if not isinstance(resource_type, str) or not resource_type or type(count) is not int or count < 0:
            return None
        if resource_type in resource_types:
            return None
        resource_types.add(resource_type)
        normalized_items.append({"resource_type": resource_type, "count": count})
    if resource_types != NATIVE_EMPTY_TRASH_RESOURCE_TYPES:
        return None
    if sum(item["count"] for item in normalized_items) != total:
        return None
    return {
        "scope": scope,
        "items": normalized_items,
        "total": total,
        "snapshot_digest": snapshot_digest,
    }


