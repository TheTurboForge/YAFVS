def run_git(repo_root: Path, args: list[str]) -> str | None:
    try:
        result = subprocess.run(["git", *args], cwd=repo_root, text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, check=True)
    except (OSError, subprocess.CalledProcessError):
        return None
    return result.stdout.strip()


def run_command(command: list[str], cwd: Path, env: dict[str, str] | None = None) -> subprocess.CompletedProcess[str]:
    return subprocess.run(command, cwd=cwd, env=env, text=True, stdout=subprocess.PIPE, stderr=subprocess.STDOUT)


def find_repo_root(start: Path) -> Path:
    git_root = run_git(start, ["rev-parse", "--show-toplevel"])
    if git_root:
        return Path(git_root)
    return start.resolve()


def metadata(repo_root: Path, command: str) -> dict[str, Any]:
    return {
        "command": command,
        "generated_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat(),
        "repo_root": str(repo_root),
        "head": run_git(repo_root, ["rev-parse", "--short", "HEAD"]),
    }


def status_rank(status: str) -> int:
    return STATUSES.index(status)


def aggregate_status(findings: Iterable[dict[str, Any]]) -> str:
    final = "pass"
    for item in findings:
        status = str(item.get("status", "pass"))
        if status not in STATUSES:
            status = "fail"
        if status_rank(status) > status_rank(final):
            final = status
    return final


def make_result(command: str, repo_root: Path, summary: str, findings: list[dict[str, Any]], artifacts: list[str] | None = None) -> dict[str, Any]:
    return {"status": aggregate_status(findings), "summary": summary, "findings": findings, "artifacts": artifacts or [], "metadata": metadata(repo_root, command)}


def finding(status: str, check: str, message: str, path: str | None = None, details: dict[str, Any] | None = None) -> dict[str, Any]:
    item: dict[str, Any] = {"status": status, "check": check, "message": message}
    if path:
        item["path"] = path
    if details:
        item["details"] = details
    return item


def build_env(repo_root: Path) -> dict[str, str]:
    env = dict(os.environ)
    prefix = repo_root / "build" / "prefix"
    pkg_paths = [str(prefix / "lib" / "pkgconfig"), str(prefix / "lib64" / "pkgconfig")]
    current_pkg = env.get("PKG_CONFIG_PATH")
    if current_pkg:
        pkg_paths.append(current_pkg)
    env["PKG_CONFIG_PATH"] = ":".join(pkg_paths)
    env["CMAKE_PREFIX_PATH"] = str(prefix)
    ld_paths = [str(prefix / "lib"), str(prefix / "lib64")]
    current_ld = env.get("LD_LIBRARY_PATH")
    if current_ld:
        ld_paths.append(current_ld)
    env["LD_LIBRARY_PATH"] = ":".join(ld_paths)
    return env


def component_inventory(repo_root: Path, scope: str | None = None) -> list[dict[str, Any]]:
    scope_path = (repo_root / scope).resolve() if scope else None
    rows: list[dict[str, Any]] = []
    for component in COMPONENTS:
        component_path = repo_root / component.path
        if scope_path and not component_path.resolve().is_relative_to(scope_path):
            continue
        rows.append(
            {
                "name": component.name,
                "path": component.path,
                "role": component.role,
                "exists": component_path.is_dir(),
                "license_files": [{"path": f"{component.path}/{license_file}", "exists": (component_path / license_file).is_file()} for license_file in component.licenses],
                "markers": [{"path": f"{component.path}/{marker}", "exists": (component_path / marker).exists()} for marker in component.markers],
            }
        )
    return rows


def nested_git_dirs(repo_root: Path) -> list[str]:
    components = repo_root / "components"
    if not components.is_dir():
        return []
    return sorted(str(path.relative_to(repo_root)) for path in components.rglob(".git"))


def selected_build_metas(component: str | None = None) -> list[BuildMeta]:
    if component:
        meta = BUILD_META.get(component)
        if not meta:
            raise KeyError(component)
        return [meta]
    return sorted(BUILD_META.values(), key=lambda meta: meta.order)


def pkg_config_version(module: str, env: dict[str, str]) -> str | None:
    result = run_command(["pkg-config", "--modversion", module], Path.cwd(), env=env)
    if result.returncode == 0:
        return result.stdout.strip()
    return None


def command_status(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    branch = run_git(repo_root, ["branch", "--show-current"]) or "(detached or unavailable)"
    head = run_git(repo_root, ["rev-parse", "--short", "HEAD"]) or "unavailable"
    porcelain = run_git(repo_root, ["status", "--short"]) or ""
    upstream = run_git(repo_root, ["rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{upstream}"])
    findings.append(finding("pass", "git.repository", f"Repository root: {repo_root}"))
    findings.append(finding("pass", "git.head", f"Current branch {branch} at {head}"))
    findings.append(finding("pass" if upstream else "warn", "git.upstream", f"Tracking upstream: {upstream}" if upstream else "No upstream tracking branch is configured."))
    if porcelain:
        findings.append(finding("warn", "git.worktree", "Worktree has uncommitted changes.", details={"changed_files": porcelain.splitlines()}))
    else:
        findings.append(finding("pass", "git.worktree", "Worktree is clean."))
    return make_result("status", repo_root, "Repository status collected.", findings)


def command_inventory(repo_root: Path, scope: str | None = None) -> dict[str, Any]:
    rows = component_inventory(repo_root, scope)
    findings: list[dict[str, Any]] = []
    if scope and not rows:
        findings.append(finding("warn", "inventory.scope", f"No expected components matched scope {scope}."))
    for row in rows:
        findings.append(finding("pass" if row["exists"] else "fail", "component.exists", f"{row['name']}: {row['role']}", row["path"]))
    return make_result("inventory", repo_root, f"Inventory contains {len(rows)} expected component(s).", findings)


def command_license_report(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    for component in COMPONENTS:
        component_path = repo_root / component.path
        for license_file in component.licenses:
            relative = f"{component.path}/{license_file}"
            findings.append(finding("pass" if (component_path / license_file).is_file() else "fail", "license.file", f"{component.name}: expected {license_file}", relative))
    findings.append(finding("warn", "license.scope", "This report checks preserved license/provenance files only; it is not a legal conclusion."))
    return make_result("license-report", repo_root, "License/provenance file presence checked.", findings)


def command_deps(repo_root: Path, component: str | None = None) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    env = build_env(repo_root)
    try:
        metas = selected_build_metas(component)
    except KeyError:
        return make_result("deps", repo_root, f"Unknown component {component}.", [finding("fail", "component.known", f"Unknown component {component}.")])
    for meta in metas:
        component_path = COMPONENT_BY_NAME[meta.name].path
        findings.append(finding("pass", "build.metadata", f"{meta.name}: {meta.build_system}", component_path, {"order": meta.order, "package_hints": list(meta.package_hints)}))
        for program in meta.programs:
            found = shutil.which(program)
            findings.append(finding("pass" if found else "fail", "program.available", f"{meta.name}: {program}" + (f" at {found}" if found else " not found"), details={"component": meta.name, "program": program}))
        for module in meta.pkg_config:
            version = pkg_config_version(module, env)
            findings.append(finding("pass" if version else "fail", "pkg-config.module", f"{meta.name}: {module}" + (f" {version}" if version else " not found"), details={"component": meta.name, "module": module}))
    return make_result("deps", repo_root, "Dependency readiness checked.", findings)


def cmake_paths(repo_root: Path, component: str) -> tuple[Path, Path, Path]:
    source = repo_root / COMPONENT_BY_NAME[component].path
    build = repo_root / "build" / component
    prefix = repo_root / "build" / "prefix"
    return source, build, prefix


def cmake_configure(repo_root: Path, meta: BuildMeta) -> subprocess.CompletedProcess[str]:
    source, build, prefix = cmake_paths(repo_root, meta.name)
    build.mkdir(parents=True, exist_ok=True)
    prefix.mkdir(parents=True, exist_ok=True)
    run_dir = repo_root / "build" / "run" / "gvm"
    state_dir = repo_root / "build" / "var"
    sysconf_dir = prefix / "etc"
    command = [
        "cmake",
        "-S",
        str(source),
        "-B",
        str(build),
        "-G",
        "Ninja",
        f"-DCMAKE_INSTALL_PREFIX={prefix}",
        f"-DCMAKE_PREFIX_PATH={prefix}",
        f"-DSYSCONFDIR={sysconf_dir}",
        f"-DLOCALSTATEDIR={state_dir}",
        f"-DGVM_RUN_DIR={run_dir}",
        *meta.cmake_args,
    ]
    return run_command(command, repo_root, env=build_env(repo_root))


def command_configure(repo_root: Path, component: str) -> dict[str, Any]:
    meta = BUILD_META.get(component)
    if not meta:
        return make_result("configure", repo_root, f"Unknown component {component}.", [finding("fail", "component.known", f"Unknown component {component}.")])
    if meta.build_system != "cmake":
        return make_result("configure", repo_root, f"{component} is not a CMake component.", [finding("warn", "build.unsupported", f"{component} uses {meta.build_system}, not cmake.")])
    result = cmake_configure(repo_root, meta)
    _, build, _ = cmake_paths(repo_root, component)
    status = "pass" if result.returncode == 0 else "fail"
    return make_result("configure", repo_root, f"Configure {component} completed with exit code {result.returncode}.", [finding(status, "cmake.configure", f"{component} configure {'succeeded' if status == 'pass' else 'failed'}.", str(build.relative_to(repo_root)), {"output_tail": result.stdout.splitlines()[-80:]})], [str(build.relative_to(repo_root))])


def command_build(repo_root: Path, component: str, install: bool = False, configure_first: bool = True) -> dict[str, Any]:
    meta = BUILD_META.get(component)
    if not meta:
        return make_result("build", repo_root, f"Unknown component {component}.", [finding("fail", "component.known", f"Unknown component {component}.")])
    if meta.build_system != "cmake":
        return make_result("build", repo_root, f"{component} is not a CMake component.", [finding("warn", "build.unsupported", f"{component} uses {meta.build_system}, not cmake.")])
    findings: list[dict[str, Any]] = []
    _, build, prefix = cmake_paths(repo_root, component)
    if configure_first:
        configure = cmake_configure(repo_root, meta)
        findings.append(finding("pass" if configure.returncode == 0 else "fail", "cmake.configure", f"{component} configure exit code {configure.returncode}.", str(build.relative_to(repo_root)), {"output_tail": configure.stdout.splitlines()[-60:]}))
        if configure.returncode != 0:
            return make_result("build", repo_root, f"Build {component} stopped at configure.", findings, [str(build.relative_to(repo_root))])
    build_result = run_command(["cmake", "--build", str(build), "--parallel"], repo_root, env=build_env(repo_root))
    findings.append(finding("pass" if build_result.returncode == 0 else "fail", "cmake.build", f"{component} build exit code {build_result.returncode}.", str(build.relative_to(repo_root)), {"output_tail": build_result.stdout.splitlines()[-80:]}))
    if build_result.returncode == 0 and (install or meta.install_for_dependents):
        install_result = run_command(["cmake", "--install", str(build)], repo_root, env=build_env(repo_root))
        findings.append(finding("pass" if install_result.returncode == 0 else "fail", "cmake.install", f"{component} install exit code {install_result.returncode}.", str(prefix.relative_to(repo_root)), {"output_tail": install_result.stdout.splitlines()[-60:]}))
    return make_result("build", repo_root, f"Build {component} completed.", findings, [str(build.relative_to(repo_root)), str(prefix.relative_to(repo_root))])


def command_build_core_c(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    artifacts: list[str] = []
    for component in CORE_C_CHAIN:
        result = command_build(repo_root, component, install=BUILD_META[component].install_for_dependents)
        artifacts.extend(result["artifacts"])
        findings.append(finding(result["status"], "core-c.component", f"{component}: {result['summary']}", details={"component": component}))
        for item in result["findings"]:
            item = dict(item)
            item["check"] = f"{component}.{item['check']}"
            findings.append(item)
        if result["status"] == "fail":
            break
    return make_result("build-core-c", repo_root, "Core C build chain attempted.", findings, sorted(set(artifacts)))


def command_doctor(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    findings.append(finding("pass" if (repo_root / ".git").exists() else "fail", "repo.git", "Repository metadata is present." if (repo_root / ".git").exists() else "Repository metadata is missing.", ".git"))
    porcelain = run_git(repo_root, ["status", "--short"]) or ""
    findings.append(finding("warn" if porcelain else "pass", "git.worktree", "Worktree has uncommitted changes." if porcelain else "Worktree is clean."))
    for doc in EXPECTED_ROOT_DOCS:
        findings.append(finding("pass" if (repo_root / doc).is_file() else "fail", "root.doc", f"Expected root document {doc}", doc))
    for row in component_inventory(repo_root):
        findings.append(finding("pass" if row["exists"] else "fail", "component.exists", f"Expected component {row['name']}", row["path"]))
        for license_file in row["license_files"]:
            findings.append(finding("pass" if license_file["exists"] else "fail", "component.license", f"Expected license/provenance file for {row['name']}", license_file["path"]))
    nested = nested_git_dirs(repo_root)
    findings.append(finding("fail" if nested else "pass", "component.nested_git", "Nested .git directories were found." if nested else "No nested .git directories found under components/.", details={"paths": nested} if nested else None))
    for tool in BASELINE_TOOLS:
        findings.append(finding("pass" if shutil.which(tool) else "warn", "tool.available", f"{tool} is available." if shutil.which(tool) else f"{tool} is not available on PATH."))
    findings.append(finding("pass", "surface.available", "Build readiness surface is available.", details={"commands": ["just deps", "just configure", "just build", "just build-core-c"]}))
    findings.append(finding("warn", "surface.deferred", "Test command surface is deferred until component checks are mapped.", details={"command": "just test"}))
    findings.append(finding("warn", "surface.deferred", "Runtime orchestration is deferred until Docker design is implemented.", details={"command": "just up"}))
    findings.append(finding("warn", "surface.deferred", "Runtime orchestration is deferred until Docker design is implemented.", details={"command": "just down"}))
    findings.append(finding("warn", "surface.deferred", "Runtime log command is deferred until service orchestration exists.", details={"command": "just logs"}))
    return make_result("doctor", repo_root, "Monorepo health checks completed.", findings)


def print_human(result: dict[str, Any]) -> None:
    print(f"{result['status'].upper()}: {result['summary']}")
    for item in result["findings"]:
        line = f"[{item['status']}] {item['check']}: {item['message']}"
        if "path" in item:
            line += f" ({item['path']})"
        print(line)


def emit(result: dict[str, Any], as_json: bool) -> int:
    if as_json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        print_human(result)
    return 1 if result["status"] == "fail" else 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="TurboVAS monorepo health checks")
    parser.add_argument("--json", action="store_true", help="emit machine-readable JSON")
    subparsers = parser.add_subparsers(dest="command", required=True)
    common = argparse.ArgumentParser(add_help=False)
    common.add_argument("--json", action="store_true", default=argparse.SUPPRESS, help=argparse.SUPPRESS)
    subparsers.add_parser("status", parents=[common], help="show repository status")
    inventory = subparsers.add_parser("inventory", parents=[common], help="show expected component inventory")
    inventory.add_argument("--scope", help="limit inventory to a path under the repository")
    subparsers.add_parser("doctor", parents=[common], help="run structural and environment health checks")
    subparsers.add_parser("license-report", parents=[common], help="check preserved license/provenance files")
    deps = subparsers.add_parser("deps", parents=[common], help="check dependency readiness")
    deps.add_argument("component", nargs="?", help="component name")
    configure = subparsers.add_parser("configure", parents=[common], help="configure a CMake component")
    configure.add_argument("component", help="component name")
    build = subparsers.add_parser("build", parents=[common], help="build a CMake component")
    build.add_argument("component", help="component name")
    build.add_argument("--install", action="store_true", help="install into build/prefix after successful build")
    subparsers.add_parser("build-core-c", parents=[common], help="build gvm-libs, openvas-smb, and openvas-scanner")
    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    repo_root = find_repo_root(Path.cwd())
    if args.command == "status":
        result = command_status(repo_root)
    elif args.command == "inventory":
        result = command_inventory(repo_root, args.scope)
    elif args.command == "doctor":
        result = command_doctor(repo_root)
    elif args.command == "license-report":
        result = command_license_report(repo_root)
    elif args.command == "deps":
        result = command_deps(repo_root, args.component)
    elif args.command == "configure":
        result = command_configure(repo_root, args.component)
    elif args.command == "build":
        result = command_build(repo_root, args.component, install=args.install)
    elif args.command == "build-core-c":
        result = command_build_core_c(repo_root)
    else:
        parser.error(f"unknown command {args.command}")
    return emit(result, args.json)


if __name__ == "__main__":
    raise SystemExit(main())
