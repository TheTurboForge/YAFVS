def native_api_direct_config_errors(env: dict[str, str]) -> tuple[str, ...]:
    errors: list[str] = []
    for value, env_name, validator in (
        (native_api_direct_host(env), TURBOVAS_API_DIRECT_HOST_ENV, validate_native_api_direct_host_value),
        (native_api_direct_port(env), TURBOVAS_API_DIRECT_PORT_ENV, validate_native_api_direct_port_value),
    ):
        try:
            validator(value, env_name=env_name)
        except ValueError as exc:
            errors.append(str(exc))
    direct_bind = env.get(TURBOVAS_API_DIRECT_BIND_ENV)
    if direct_bind:
        try:
            validate_native_api_direct_bind_value(direct_bind, env_name=TURBOVAS_API_DIRECT_BIND_ENV)
        except ValueError as exc:
            errors.append(str(exc))
    operator_uuid = env.get(TURBOVAS_API_OPERATOR_UUID_ENV, "").strip()
    operator_name = env.get(TURBOVAS_API_OPERATOR_NAME_ENV, "")
    if operator_uuid:
        try:
            validate_native_api_operator_uuid_value(operator_uuid, env_name=TURBOVAS_API_OPERATOR_UUID_ENV)
        except ValueError as exc:
            errors.append(str(exc))
    elif operator_name.strip():
        errors.append(f"{TURBOVAS_API_OPERATOR_NAME_ENV} requires {TURBOVAS_API_OPERATOR_UUID_ENV}")
    if operator_name.strip():
        try:
            validate_native_api_operator_name_value(operator_name, env_name=TURBOVAS_API_OPERATOR_NAME_ENV)
        except ValueError as exc:
            errors.append(str(exc))
    write_control = env.get(TURBOVAS_API_DIRECT_WRITE_CONTROL_ENV, "")
    if write_control.strip():
        try:
            normalized_write_control = validate_native_api_direct_write_control_value(
                write_control,
                env_name=TURBOVAS_API_DIRECT_WRITE_CONTROL_ENV,
            )
            if normalized_write_control in {"1", "true", "yes", "on"} and not operator_uuid:
                errors.append(f"{TURBOVAS_API_DIRECT_WRITE_CONTROL_ENV} requires {TURBOVAS_API_OPERATOR_UUID_ENV}")
        except ValueError as exc:
            errors.append(str(exc))
    return tuple(errors)


def native_api_direct_config_shape_finding(env: dict[str, str], *, check: str) -> dict[str, Any]:
    errors = native_api_direct_config_errors(env)
    return finding(
        "fail" if errors else "pass",
        check,
        "Direct native API host, port, and bind settings have a valid local shape."
        if not errors
        else "Direct native API host, port, or bind settings are malformed.",
        details={
            "host_env": TURBOVAS_API_DIRECT_HOST_ENV,
            "host": native_api_direct_host(env),
            "port_env": TURBOVAS_API_DIRECT_PORT_ENV,
            "port": native_api_direct_port(env),
            "bind_env": TURBOVAS_API_DIRECT_BIND_ENV,
            "bind": env.get(TURBOVAS_API_DIRECT_BIND_ENV),
            "write_control_env": TURBOVAS_API_DIRECT_WRITE_CONTROL_ENV,
            "write_control": env.get(TURBOVAS_API_DIRECT_WRITE_CONTROL_ENV),
            "errors": list(errors),
        },
    )


def native_api_direct_port_binding(env: dict[str, str]) -> str:
    return f"{native_api_direct_host(env)}:{native_api_direct_port(env)}:{TURBOVAS_API_DIRECT_CONTAINER_PORT}"


def direct_api_bearer_token_is_acceptable(token: str) -> bool:
    return TURBOVAS_API_BEARER_TOKEN_MIN_LENGTH <= len(token) <= TURBOVAS_API_BEARER_TOKEN_MAX_LENGTH and all(
        char.isascii() and not char.isspace() and 33 <= ord(char) <= 126 for char in token
    )


def native_api_direct_base_url(env: dict[str, str]) -> str:
    return f"http://{native_api_direct_host(env)}:{native_api_direct_port(env)}"


def native_api_direct_runtime_env(repo_root: Path) -> dict[str, str]:
    env = runtime_env(repo_root)
    env[TURBOVAS_API_DIRECT_ENV] = "1"
    env.setdefault(TURBOVAS_API_DIRECT_HOST_ENV, TURBOVAS_API_DIRECT_DEFAULT_HOST)
    env.setdefault(TURBOVAS_API_DIRECT_PORT_ENV, TURBOVAS_API_DIRECT_DEFAULT_PORT)
    env.setdefault(TURBOVAS_API_DIRECT_BIND_ENV, f"0.0.0.0:{TURBOVAS_API_DIRECT_CONTAINER_PORT}")
    if not env.get(TURBOVAS_API_BEARER_TOKEN_ENV) and not env.get(TURBOVAS_API_BEARER_TOKEN_FILE_ENV):
        read_or_create_runtime_secret(repo_root, TURBOVAS_API_BEARER_TOKEN_SECRET)
        env[TURBOVAS_API_BEARER_TOKEN_FILE_ENV] = TURBOVAS_API_BEARER_TOKEN_CONTAINER_FILE
    return env


def native_api_direct_bearer_token(repo_root: Path, env: dict[str, str]) -> str:
    token = env.get(TURBOVAS_API_BEARER_TOKEN_ENV, "")
    if token:
        return token
    file_value = env.get(TURBOVAS_API_BEARER_TOKEN_FILE_ENV, "")
    if file_value == TURBOVAS_API_BEARER_TOKEN_CONTAINER_FILE:
        return runtime_secret_path(repo_root, TURBOVAS_API_BEARER_TOKEN_SECRET).read_text(encoding="utf-8").strip()
    if file_value:
        return Path(file_value).expanduser().read_text(encoding="utf-8").strip()
    return runtime_secret_path(repo_root, TURBOVAS_API_BEARER_TOKEN_SECRET).read_text(encoding="utf-8").strip()


def gsad_host(repo_root: Path) -> str:
    return gsad_hosts(repo_root)[0]


def gsad_base_url(repo_root: Path) -> str:
    return f"https://{gsad_host(repo_root)}:{GSAD_PORT}"


def gsad_base_urls(repo_root: Path) -> tuple[str, ...]:
    return tuple(f"https://{host}:{GSAD_PORT}" for host in gsad_hosts(repo_root))


def gsad_port_bindings(repo_root: Path) -> tuple[str, ...]:
    return tuple(f"{host}:{GSAD_PORT}:{GSAD_CONTAINER_PORT}" for host in gsad_hosts(repo_root))


def host_is_wildcard(host: str) -> bool:
    normalized = host.strip().lower().strip("[]")
    return normalized in {"0.0.0.0", "::"}


def host_is_loopback(host: str) -> bool:
    normalized = host.strip().lower().strip("[]")
    return normalized in {"localhost", "::1"} or normalized.startswith("127.")


def external_hosts(hosts: Iterable[str]) -> tuple[str, ...]:
    return tuple(host for host in hosts if not host_is_loopback(host))


def current_gsad_published_hosts(repo_root: Path) -> tuple[str, ...]:
    cid = container_id(repo_root, "gsad")
    if not cid:
        return ()
    result = run_command(["docker", "inspect", "-f", "{{json .NetworkSettings.Ports}}", cid], repo_root, env=runtime_env(repo_root))
    if result.returncode != 0 or not result.stdout.strip():
        return ()
    try:
        ports = json.loads(result.stdout)
    except json.JSONDecodeError:
        return ()
    bindings = ports.get(f"{GSAD_CONTAINER_PORT}/tcp") or []
    hosts: list[str] = []
    seen: set[str] = set()
    for binding in bindings:
        if not isinstance(binding, dict):
            continue
        host = str(binding.get("HostIp") or "").strip()
        port = str(binding.get("HostPort") or "").strip()
        if not host or port != GSAD_PORT or host in seen:
            continue
        hosts.append(host)
        seen.add(host)
    return tuple(hosts)


def current_native_api_direct_published_bindings(repo_root: Path) -> tuple[dict[str, str], ...]:
    cid = container_id(repo_root, "turbovas-api")
    if not cid:
        return ()
    result = run_command(["docker", "inspect", "-f", "{{json .NetworkSettings.Ports}}", cid], repo_root, env=runtime_env(repo_root))
    if result.returncode != 0 or not result.stdout.strip():
        return ()
    try:
        ports = json.loads(result.stdout)
    except json.JSONDecodeError:
        return ()
    bindings = ports.get(f"{TURBOVAS_API_DIRECT_CONTAINER_PORT}/tcp") or []
    published: list[dict[str, str]] = []
    seen: set[tuple[str, str]] = set()
    for binding in bindings:
        if not isinstance(binding, dict):
            continue
        host = str(binding.get("HostIp") or "0.0.0.0").strip()
        host_port = str(binding.get("HostPort") or "").strip()
        if not host_port or (host, host_port) in seen:
            continue
        published.append({"host": host, "host_port": host_port, "container_port": TURBOVAS_API_DIRECT_CONTAINER_PORT})
        seen.add((host, host_port))
    return tuple(published)


def running_service_env_has_key(repo_root: Path, service: str, key: str) -> bool:
    cid = container_id(repo_root, service)
    if not cid:
        return False
    result = run_command(["docker", "inspect", "-f", "{{json .Config.Env}}", cid], repo_root, env=runtime_env(repo_root))
    if result.returncode != 0 or not result.stdout.strip():
        return False
    try:
        values = json.loads(result.stdout)
    except json.JSONDecodeError:
        return False
    if not isinstance(values, list):
        return False
    return env_values_have_nonempty_key(values, key)


def env_values_have_nonempty_key(values: Iterable[Any], key: str) -> bool:
    prefix = f"{key}="
    return any(isinstance(value, str) and value.startswith(prefix) and bool(value[len(prefix) :].strip()) for value in values)


def running_service_env_value(repo_root: Path, service: str, key: str) -> str | None:
    cid = container_id(repo_root, service)
    if not cid:
        return None
    result = run_command(["docker", "inspect", "-f", "{{json .Config.Env}}", cid], repo_root, env=runtime_env(repo_root))
    if result.returncode != 0 or not result.stdout.strip():
        return None
    try:
        values = json.loads(result.stdout)
    except json.JSONDecodeError:
        return None
    if not isinstance(values, list):
        return None
    prefix = f"{key}="
    for value in values:
        if isinstance(value, str) and value.startswith(prefix) and value[len(prefix) :].strip():
            return value[len(prefix) :]
    return None


