[Unit]
Description=Run the YAFVS local quality gate daily
Documentation=file:@REPO_ROOT@/README.md

[Timer]
OnCalendar=*-*-* 03:30:00
Persistent=true
RandomizedDelaySec=20m
Unit=yafvs-quality-gate.service

[Install]
WantedBy=timers.target
