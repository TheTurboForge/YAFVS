        for route_method, route_endpoint in rust_native_api_route_operations(repo_root, function_name)
    }


def rust_match_pattern_to_endpoint(segment_source: str) -> str | None:
    tokens = [token.strip() for token in segment_source.split(",")]
    if len(tokens) < 4 or tokens[:3] != ['""', '"api"', '"v1"']:
        return None
    parts: list[str] = ["", "api", "v1"]
    for token in tokens[3:]:
        token = token.strip()
        if not token:
            continue
        if token == "_" or re.fullmatch(r"[A-Za-z_][A-Za-z0-9_]*", token):
            parts.append("{}")
            continue
        quoted = re.fullmatch(r'"([^"]+)"', token)
        if quoted:
            parts.append(quoted.group(1))
            continue
        return None
    return "/".join(parts)


def rust_direct_scope_report_section_templates(function_body: str) -> list[str]:
    match = re.search(r"matches!\s*\(\s*\*section\s*,(?P<body>.*?)\)\s*&&", function_body, re.DOTALL)
    if match is None:
        return []
    return sorted(
        f"/api/v1/scopes/{{}}/reports/{{}}/{section}"
        for section in re.findall(r'"([^"]+)"', match.group("body"))
    )


def rust_direct_api_source(repo_root: Path | None) -> str:
    if repo_root is None:
        return ""
    for relative_path in (
        "services/turbovas-api/src/direct_api_contract.rs",
        "services/turbovas-api/src/direct_api.rs",
        "services/turbovas-api/src/main.rs",
    ):
        try:
            candidate = (repo_root / relative_path).read_text(encoding="utf-8")
        except OSError:
            continue
        if rust_source_function_body(candidate, "direct_api_v1_path_is_allowed"):
            return candidate
    return ""


def rust_direct_api_segment_guard_summary(repo_root: Path | None) -> dict[str, Any]:
    source = rust_direct_api_source(repo_root)

    def guard_summary(name: str) -> dict[str, Any]:
        body = rust_source_function_body(source, name)
        return {
            "name": name,
            "present": bool(body),
            "rejects_empty": any(
                marker in body
                for marker in ("!part.is_empty()", "!segment.is_empty()", "!tail.is_empty()")
            ),
            "rejects_dot": '!= "."' in body,
            "rejects_dotdot": '!= ".."' in body,
        }

    guards = [
        guard_summary("direct_api_segments_are_nonempty"),
        guard_summary("direct_api_wildcard_tail_is_allowed"),
    ]
    missing = [
        {"guard": guard["name"], "property": property_name}
        for guard in guards
        for property_name in ("present", "rejects_empty", "rejects_dot", "rejects_dotdot")
        if not guard.get(property_name)
    ]
    return {
        "alignment_status": "pass" if not missing else "warn",
        "guards": guards,
        "missing_guard_properties": missing,
    }


def rust_repo_file_source(repo_root: Path | None, relative_path: str) -> str:
