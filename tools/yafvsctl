def latest_completed_full_test_report_id(repo_root: Path) -> tuple[str | None, str | None, subprocess.CompletedProcess[str] | None]:
    if not container_running(repo_root, "postgres"):
        return None, "Postgres is not running; start the app profile before selecting the latest full-test report.", None
    query = (
        "SELECT r.uuid FROM reports r "
        "JOIN tasks t ON t.id = r.task "
        f"WHERE t.name LIKE {sql_literal(FULL_TEST_TASK_PREFIX + '%')} "
        f"AND coalesce(r.scan_run_status, 0) = {COMPLETED_SCAN_RUN_STATUS} "
        "AND coalesce(r.start_time, 0) > 0 "
        "ORDER BY coalesce(r.end_time, 0) DESC, coalesce(r.start_time, 0) DESC, r.id DESC "
        "LIMIT 1;"
    )
    result = psql(repo_root, query)
    if result.returncode != 0:
        return None, "Latest full-test report selection query failed.", result
    report_id = psql_value(result).strip()
    if not report_id:
        return None, "No completed full-test raw report exists; pass --report-id to inspect a specific report.", result
    return report_id, None, result


def runtime_app_up_status_only_result(result: dict[str, Any]) -> dict[str, Any]:
    compact = dict(result)
    findings = result.get("findings", [])
    non_pass = [compact_doctor_finding(item) for item in findings if item.get("status") != "pass"]
    checks = {
        item.get("check"): item.get("status")
        for item in findings
        if isinstance(item, dict) and item.get("check")
    }
    service_status = {
        item.get("details", {}).get("service"): item.get("status")
        for item in findings
        if isinstance(item, dict)
        and item.get("check") == "runtime.app.running"
        and isinstance(item.get("details"), dict)
        and item.get("details", {}).get("service")
    }
    important_checks = {
        check: checks[check]
        for check in (
            "compose.config",
            "production.app-execution-mounts",
            "feed-generation.current",
            "runtime.infrastructure",
            "runtime.database-init",
            "runtime.scanner-redis",
            "runtime.feed-keyring",
            "gsa.build.index",
            "gsa.static-stage",
            "gsa.config-js",
            "compose.app-up",
            "runtime.gvmd-control-socket",
        )
        if check in checks
    }
    compact["details"] = {
        "finding_count": len(findings),
        "non_pass_count": len(non_pass),
        "artifact_count": len(result.get("artifacts", [])) if isinstance(result.get("artifacts"), list) else 0,
        "important_checks": important_checks,
        "service_status": service_status,
    }
    compact["findings"] = non_pass or [
        finding("pass", "runtime-app-up.status-only", "Application runtime startup passed; no non-pass findings.")
    ]
    return compact


