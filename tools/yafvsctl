        )
    )
    if config.returncode != 0:
        return make_result("runtime-app-build", repo_root, "Application image build stopped at Compose validation.", findings, [str(compose_file(repo_root))])
    build_command = compose_command(repo_root, "--profile", "app", "build", *APP_SERVICES, env=app_env)
    built = run_command(build_command, repo_root, env=app_env, timeout=1800)
    findings.append(
        process_step_finding(
            "pass" if built.returncode == 0 else "fail",
            "compose.app-build",
            f"Build explicit application images exit code {built.returncode}.",
            built,
            build_command,
        )
    )
    if built.returncode != 0:
        return make_result("runtime-app-build", repo_root, "Application image build failed.", findings, [str(compose_file(repo_root))])
    findings.extend(stage_gsa_static(repo_root))
    image_ids, image_error = resolve_app_service_image_ids(repo_root, prefer_running=False, app_env=app_env)
    findings.append(
        finding(
            "pass" if image_error is None else "fail",
            "compose.app-images",
            "All application image identities were resolved after the explicit build."
            if image_error is None
            else image_error,
            details={"image_ids": image_ids},
        )
    )
    if image_error is None and aggregate_status(findings) != "fail":
        try:
            runtime_artifacts = app_runtime_artifact_manifest(repo_root)
            receipt = write_app_deployment_receipt(
                repo_root, image_ids, runtime_artifacts, app_env=app_env
            )
        except (OSError, ValueError) as error:
            findings.append(finding("fail", "runtime.app-deployment-receipt", f"Prepared application deployment receipt could not be written: {error}"))
        else:
            findings.append(
                finding(
                    "pass",
                    "runtime.app-deployment-receipt",
                    "Prepared application images and bind-mounted runtime artifacts were recorded for explicit deployment.",
                    str(app_deployment_receipt_path(repo_root)),
                    receipt,
                )
            )
    return make_result(
        "runtime-app-build",
        repo_root,
        "Application deployment was built and recorded explicitly."
        if aggregate_status(findings) != "fail"
        else "Application deployment preparation failed.",
        findings,
        [str(compose_file(repo_root))],
    )


