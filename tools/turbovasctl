def feed_signature_log_errors(lines: Iterable[str]) -> list[str]:
    errors: list[str] = []
    marker_words = ("gpg", "signature", "sha256", "advisories", "notus")
    error_words = ("error", "failed", "failure", "invalid", "not loaded")
    for line in lines:
        lower = line.lower()
        if any(marker in lower for marker in marker_words) and any(word in lower for word in error_words):
            errors.append(line)
    return errors


