# Escalator method script: SCP.

USERNAME=$1
HOST=$2
PORT=$3
DEST=$4
KNOWN_HOSTS_FILE=$5
PRIVATE_KEY_FILE=$6
PASSWORD_FILE=$7
REPORT_FILE=$8

umask 077

ERROR_FILE=$(mktemp) || {
  exit 1
}

# shellcheck disable=SC2317  # Invoked by the trap below.
cleanup() {
  rm -f -- "$PASSWORD_FILE" "$ERROR_FILE"
}
trap cleanup EXIT HUP INT TERM

if [ ! -s "$KNOWN_HOSTS_FILE" ]
then
  printf '%s\n' "SCP alert: required pinned host key is missing" >&2
  exit 1
fi

log_error() {
  logger -- "SCP alert: $1"
  printf '%s\n' "$1" >&2
}

shell_esc() {
  printf "%q" "$1"
}

if [ -z "$GVMD_SCP_ALERT_TIMEOUT" ]
then
  TIMEOUT="15m"
else
  TIMEOUT="$GVMD_SCP_ALERT_TIMEOUT"
fi
if [[ ! "$TIMEOUT" =~ ^[1-9][0-9]*([smh])?$ ]]
then
  log_error "Invalid configured timeout"
  exit 1
fi

# Escape destination because it is also expanded on the remote end.
DEST_ESC=$(shell_esc "$DEST")

SCP_OPTIONS=(
  -F /dev/null
  -P "$PORT"
  -o HashKnownHosts=no
  -o StrictHostKeyChecking=yes
  -o "UserKnownHostsFile=$KNOWN_HOSTS_FILE"
  -o GlobalKnownHostsFile=/dev/null
  -o IdentityAgent=none
  -o IdentitiesOnly=yes
)

if [ -z "$PRIVATE_KEY_FILE" ]
then
  timeout "$TIMEOUT" sshpass -f "$PASSWORD_FILE" scp "${SCP_OPTIONS[@]}" -- \
    "$REPORT_FILE" "${USERNAME}@${HOST}:${DEST_ESC}" 2>"$ERROR_FILE"
else
  timeout "$TIMEOUT" sshpass -f "$PASSWORD_FILE" -P "passphrase" scp \
    "${SCP_OPTIONS[@]}" -i "$PRIVATE_KEY_FILE" -o PasswordAuthentication=no -- \
    "$REPORT_FILE" "${USERNAME}@${HOST}:${DEST_ESC}" 2>"$ERROR_FILE"
fi

EXIT_CODE=$?

if [ $EXIT_CODE -eq 1 ]
then
  log_error "SCP delivery failed: invalid command line argument"
elif [ $EXIT_CODE -eq 2 ]
then
  log_error "SCP delivery failed: conflicting arguments"
elif [ $EXIT_CODE -eq 3 ]
then
  log_error "SCP delivery failed: runtime error"
elif [ $EXIT_CODE -eq 4 ]
then
  log_error "SCP delivery failed: unrecognized SSH response"
elif [ $EXIT_CODE -eq 5 ]
then
  log_error "SCP delivery failed: authentication rejected"
elif [ $EXIT_CODE -eq 6 ]
then
  log_error "SCP delivery failed: host key rejected"
elif [ $EXIT_CODE -eq 124 ]
then
  log_error "SCP delivery failed: timeout after $TIMEOUT"
elif [ $EXIT_CODE -eq 127 ]
then
  log_error "SCP delivery failed: required command not found"
elif [ $EXIT_CODE -ne 0 ]
then
  log_error "SCP delivery failed with exit code ${EXIT_CODE}"
fi

exit $EXIT_CODE
