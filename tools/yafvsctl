def feed_generation_id_valid(value: Any) -> bool:
    return isinstance(value, str) and re.fullmatch(r"[0-9a-f]{64}", value) is not None


def validate_app_service_image_ids(value: Any) -> dict[str, str]:
    if not isinstance(value, dict) or set(value) != set(APP_SERVICES):
        raise ValueError("feed activation app image identities are incomplete")
    normalized: dict[str, str] = {}
    for service in APP_SERVICES:
        image_id = value.get(service)
        if not isinstance(image_id, str) or re.fullmatch(r"sha256:[0-9a-f]{64}", image_id) is None:
            raise ValueError(f"feed activation app image identity is invalid for {service}")
        normalized[service] = image_id
    return normalized


def validate_app_runtime_artifact_manifest(value: Any) -> dict[str, Any]:
    if not isinstance(value, dict) or set(value) != {
        "schema_version",
        "algorithm",
        "digest",
        "entry_count",
        "byte_count",
        "roots",
    }:
        raise ValueError("feed activation runtime artifact identity is invalid")
    expected_roots = [str(path) for path in (*APP_RUNTIME_ARTIFACT_ROOTS, *APP_RUNTIME_ARTIFACT_FILES)]
    if (
        value.get("schema_version") != 1
        or value.get("algorithm") != "sha256"
        or re.fullmatch(r"[0-9a-f]{64}", str(value.get("digest", ""))) is None
        or not isinstance(value.get("entry_count"), int)
        or value.get("entry_count", 0) < 1
        or not isinstance(value.get("byte_count"), int)
        or value.get("byte_count", -1) < 0
        or value.get("roots") != expected_roots
    ):
        raise ValueError("feed activation runtime artifact identity is invalid")
    return value


def validate_app_compose_contract(value: Any) -> dict[str, Any]:
    if not isinstance(value, dict) or set(value) != {
        "schema_version",
        "algorithm",
        "digest",
        "services",
    }:
        raise ValueError("application Compose execution contract is invalid")
    if (
        value.get("schema_version") != 1
        or value.get("algorithm") != "sha256"
        or re.fullmatch(r"[0-9a-f]{64}", str(value.get("digest", ""))) is None
        or value.get("services") != list(APP_SERVICES)
    ):
        raise ValueError("application Compose execution contract is invalid")
    return value


def validate_feed_activation_state(payload: Any) -> dict[str, Any]:
    if not isinstance(payload, dict) or payload.get("schema_version") != 1:
        raise ValueError("feed activation state schema is invalid")
    status = payload.get("status")
    if status not in {"active", "transitioning"}:
        raise ValueError("feed activation state status is invalid")
    current_id = payload.get("current_generation_id")
    target_id = payload.get("target_generation_id")
    previous_id = payload.get("previous_generation_id")
    rollback_id = payload.get("rollback_generation_id")
    if status == "active":
        if not feed_generation_id_valid(current_id) or target_id is not None or previous_id is not None:
            raise ValueError("active feed activation state identifiers are invalid")
    else:
        if payload.get("action") not in {"activate", "rollback"} or not feed_generation_id_valid(target_id):
            raise ValueError("transitioning feed activation state is invalid")
        if current_id is not None:
            raise ValueError("transitioning feed activation state must not claim an active generation")
    for name, value in (("previous_generation_id", previous_id), ("rollback_generation_id", rollback_id)):
        if value is not None and not feed_generation_id_valid(value):
            raise ValueError(f"feed activation state {name} is invalid")
    restore_gsad_hosts = payload.get("restore_gsad_hosts")
    if restore_gsad_hosts is not None:
        if (
            not isinstance(restore_gsad_hosts, list)
            or not restore_gsad_hosts
            or len(restore_gsad_hosts) > 16
        ):
            raise ValueError("feed activation state restore_gsad_hosts is invalid")
        seen_hosts: set[str] = set()
        for host in restore_gsad_hosts:
            if not isinstance(host, str) or host in seen_hosts:
                raise ValueError("feed activation state restore_gsad_hosts is invalid")
            try:
                if str(ipaddress.ip_address(host)) != host:
                    raise ValueError
            except ValueError as error:
                raise ValueError(
                    "feed activation state restore_gsad_hosts is invalid"
                ) from error
            seen_hosts.add(host)
    app_image_ids = payload.get("app_image_ids")
    app_artifacts = payload.get("app_runtime_artifacts")
    app_compose_contract = payload.get("app_compose_contract")
    if status == "transitioning" and (
        app_image_ids is None
        or app_artifacts is None
        or app_compose_contract is None
    ):
        raise ValueError("transitioning feed activation state lacks deployment identity")
    if app_image_ids is not None:
        validate_app_service_image_ids(app_image_ids)
    if app_artifacts is not None:
        validate_app_runtime_artifact_manifest(app_artifacts)
    if app_compose_contract is not None:
        validate_app_compose_contract(app_compose_contract)
    return payload


def read_feed_activation_state(repo_root: Path) -> dict[str, Any] | None:
    path = feed_activation_state_path(repo_root)
    try:
        path.lstat()
    except FileNotFoundError:
        return None
    try:
        payload = json.loads(read_private_text(path, 16 * 1024))
    except json.JSONDecodeError as error:
        raise ValueError(f"feed activation state is not valid JSON: {error}") from error
    return validate_feed_activation_state(payload)


def ensure_feed_activation_state_directory(repo_root: Path) -> None:
    root = runtime_dir(repo_root)
    try:
        current_fd, _ = open_absolute_directory_nofollow(root)
    except FileNotFoundError:
        parent_fd, _ = open_absolute_directory_nofollow(root.parent)
        try:
            try:
                os.mkdir(root.name, mode=0o700, dir_fd=parent_fd)
            except FileExistsError:
                pass
            else:
                os.fsync(parent_fd)
        finally:
            os.close(parent_fd)
        current_fd, _ = open_absolute_directory_nofollow(root)
    root_metadata = os.fstat(current_fd)
    if root_metadata.st_uid != os.geteuid():
        os.close(current_fd)
        raise PermissionError(f"Runtime directory is not owner-owned: {root}")
    try:
        for name in ("state", "feed-generation"):
            child_fd = -1
            try:
                try:
                    os.mkdir(name, mode=0o700, dir_fd=current_fd)
                except FileExistsError:
                    pass
                else:
                    # Every new journal directory entry must survive a crash.
                    os.fsync(current_fd)
                metadata = os.stat(name, dir_fd=current_fd, follow_symlinks=False)
                if stat.S_ISLNK(metadata.st_mode) or not stat.S_ISDIR(metadata.st_mode):
                    raise OSError(
                        errno.EINVAL,
                        f"Feed activation state path component is not a real directory: {name}",
                    )
                child_fd = os.open(
                    name,
                    os.O_RDONLY | os.O_DIRECTORY | os.O_NOFOLLOW | os.O_CLOEXEC,
                    dir_fd=current_fd,
                )
                opened = os.fstat(child_fd)
                if opened.st_uid != os.geteuid():
                    raise PermissionError(
                        f"Feed activation state directory is not owner-owned: {name}"
                    )
                os.fchmod(child_fd, 0o700)
                os.fsync(child_fd)
            except BaseException:
                if child_fd >= 0:
                    os.close(child_fd)
                raise
            os.close(current_fd)
            current_fd = child_fd
    finally:
        os.close(current_fd)


def write_feed_activation_state(repo_root: Path, payload: dict[str, Any]) -> None:
    candidate = validate_feed_activation_state({"schema_version": 1, **payload})
    path = feed_activation_state_path(repo_root)
    text = json.dumps(candidate, indent=2, sort_keys=True) + "\n"
    ensure_feed_activation_state_directory(repo_root)
    write_private_text(path, text)


def validate_feed_generation_db_attestation(value: Any) -> dict[str, Any]:
    if not isinstance(value, dict) or set(value) != {
        "schema_version",
        "generation_id",
        "feed_release",
        "manifest_schema_version",
        "import_contract",
        "completed_at",
    }:
        raise ValueError("feed generation database attestation is invalid")
    if (
        type(value.get("schema_version")) is not int
        or value.get("schema_version") != 1
        or not feed_generation_id_valid(value.get("generation_id"))
        or value.get("feed_release") != FEED_RELEASE
        or type(value.get("manifest_schema_version")) is not int
        or value.get("manifest_schema_version") != 1
        or value.get("import_contract") != FEED_DB_ATTESTATION_IMPORT_CONTRACT
    ):
        raise ValueError("feed generation database attestation is invalid")
    completed_at = value.get("completed_at")
    if not isinstance(completed_at, str):
        raise ValueError("feed generation database attestation timestamp is invalid")
    try:
        parsed = datetime.fromisoformat(completed_at.replace("Z", "+00:00"))
    except ValueError as error:
        raise ValueError(
            "feed generation database attestation timestamp is invalid"
        ) from error
    if parsed.tzinfo is None or parsed.utcoffset() != timedelta(0):
        raise ValueError("feed generation database attestation timestamp is invalid")
    return value


def reject_duplicate_json_object_keys(
    pairs: list[tuple[str, Any]],
) -> dict[str, Any]:
    value: dict[str, Any] = {}
    for key, item in pairs:
        if key in value:
            raise ValueError(f"duplicate JSON object key: {key}")
        value[key] = item
    return value


def feed_generation_db_attestation_payload(
    generation_id: str, completed_at: str
) -> dict[str, Any]:
    return validate_feed_generation_db_attestation(
        {
            "schema_version": 1,
            "generation_id": generation_id,
            "feed_release": FEED_RELEASE,
            "manifest_schema_version": 1,
            "import_contract": FEED_DB_ATTESTATION_IMPORT_CONTRACT,
            "completed_at": completed_at,
        }
    )


def read_feed_generation_db_attestation(repo_root: Path) -> dict[str, Any] | None:
    result = psql(
        repo_root,
        "SELECT CASE "
        f"WHEN octet_length(value) > {FEED_DB_ATTESTATION_MAX_BYTES} THEN '__OVERSIZED__' "
        "ELSE COALESCE(encode(convert_to(value, 'UTF8'), 'hex'), '') END "
        "FROM public.meta "
        f"WHERE name = {sql_literal(FEED_DB_ATTESTATION_META_NAME)};",
    )
    if result.returncode != 0:
        raise OSError(
            "feed generation database attestation query failed: "
            + "; ".join(output_tail(result.stdout, 20))
        )
    raw_hex = psql_value(result)
    if not raw_hex:
        return None
    if raw_hex == "__OVERSIZED__":
        raise ValueError("feed generation database attestation is oversized")
    if (
        len(raw_hex) > FEED_DB_ATTESTATION_MAX_BYTES * 2
        or len(raw_hex) % 2
        or re.fullmatch(r"[0-9a-f]+", raw_hex) is None
    ):
        raise ValueError("feed generation database attestation encoding is invalid")
    try:
        raw = bytes.fromhex(raw_hex).decode("utf-8")
    except (ValueError, UnicodeDecodeError) as error:
        raise ValueError(
            "feed generation database attestation encoding is invalid"
        ) from error
    try:
        payload = json.loads(raw, object_pairs_hook=reject_duplicate_json_object_keys)
    except json.JSONDecodeError as error:
        raise ValueError(
            f"feed generation database attestation is not valid JSON: {error}"
        ) from error
    return validate_feed_generation_db_attestation(payload)


def write_feed_generation_db_attestation(
    repo_root: Path, generation_id: str, completed_at: str
) -> dict[str, Any]:
    payload = feed_generation_db_attestation_payload(generation_id, completed_at)
    encoded = json.dumps(
        payload, ensure_ascii=True, separators=(",", ":"), sort_keys=True
    )
    result = psql(
        repo_root,
        "INSERT INTO public.meta (name, value) VALUES "
        f"({sql_literal(FEED_DB_ATTESTATION_META_NAME)}, {sql_literal(encoded)}) "
        "ON CONFLICT (name) DO UPDATE SET value = EXCLUDED.value;",
    )
    if result.returncode != 0:
        raise OSError(
            "feed generation database attestation write failed: "
            + "; ".join(output_tail(result.stdout, 20))
        )
    observed = read_feed_generation_db_attestation(repo_root)
    if observed != payload:
        raise OSError("feed generation database attestation readback mismatch")
    return payload


