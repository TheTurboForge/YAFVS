def openapi_indented_scalar_fields(block: list[str]) -> dict[str, str]:
    stack: list[tuple[int, str]] = []
    values: dict[str, str] = {}
    for line in block:
        if not line.strip() or line.lstrip().startswith("#"):
            continue
        indent = len(line) - len(line.lstrip(" "))
        text = line.strip()
        if ":" not in text or text.startswith("-"):
            continue
        key, raw_value = text.split(":", 1)
        key = key.strip().strip("'\"")
        value = raw_value.strip().strip("'\"")
        while stack and indent <= stack[-1][0]:
            stack.pop()
        path = ".".join([item[1] for item in stack] + [key])
        if value:
            values[path] = value
        else:
            stack.append((indent, key))
    return values


def openapi_error_schema_contract_drift(repo_root: Path | None) -> dict[str, Any]:
    block = openapi_component_schema_block(repo_root, "Error")
    values = openapi_indented_scalar_fields(block)
    missing = []
    invalid = []
    for field, expected in sorted(OPENAPI_ERROR_SCHEMA_EXPECTED_FIELDS.items()):
        if field not in values:
            missing.append({"field": field, "expected": expected})
            continue
        actual = values[field]
        if actual != expected:
            invalid.append({"field": field, "actual": actual, "expected": expected})
    return {
        "expected_error_schema_fields": dict(sorted(OPENAPI_ERROR_SCHEMA_EXPECTED_FIELDS.items())),
        "error_schema_fields": dict(sorted(values.items())),
        "missing_error_schema_fields": missing,
        "invalid_error_schema_fields": invalid,
    }


def rust_collection_contract_constants(repo_root: Path | None) -> dict[str, int | None]:
    if repo_root is None:
        return {"default_page_size": None, "max_page_size": None, "max_filter_length": None}
    path = repo_root / "services" / "turbovas-api" / "src" / "collections.rs"
    try:
        source = path.read_text(encoding="utf-8")
    except OSError:
        source = ""

    def const_int(name: str) -> int | None:
        match = re.search(rf"pub\(crate\)\s+const\s+{re.escape(name)}\s*:\s*(?:i64|usize)\s*=\s*([0-9]+)\s*;", source)
        return int(match.group(1)) if match else None

    return {
        "default_page_size": const_int("DEFAULT_COLLECTION_PAGE_SIZE"),
        "max_page_size": const_int("MAX_COLLECTION_PAGE_SIZE"),
        "max_filter_length": const_int("MAX_COLLECTION_FILTER_LENGTH"),
    }


def rust_collection_contract_paths(repo_root: Path | None) -> list[str]:
    if repo_root is None:
        return []
    path = repo_root / "services" / "turbovas-api" / "src" / "main.rs"
    try:
        source = path.read_text(encoding="utf-8")
    except OSError:
        return []
    return sorted(
        {
            path
            for path in re.findall(r'path:\s*"(/api/v1[^"]+)"', source)
            if ":" not in path
        }
    )


