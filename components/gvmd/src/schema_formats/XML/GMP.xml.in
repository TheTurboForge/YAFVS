<!-- GMP schema with embedded documentation, in GMP. -->

<protocol>
  <name>Greenbone Management Protocol</name>
  <abbreviation>GMP</abbreviation>
  <summary>The management protocol of the Greenbone Vulnerability Manager</summary>
  <version>@GMP_VERSION@</version>

  <!-- Types. -->

  <type>
    <name>alive_test</name>
    <summary>An alive test</summary>
    <pattern>
      xsd:token { pattern = "ICMP Ping|TCP-ACK Service Ping|TCP-SYN Service Ping|ARP Ping|Consider Alive|Scan Config Default" }
    </pattern>
  </type>
  <type>
    <name>base64</name>
    <summary>Base64 encoded data</summary>
    <pattern>xsd:base64Binary</pattern>
  </type>
  <type>
    <name>boolean</name>
    <summary>A true or false value</summary>
    <description>
      Zero is false, anything else is true.  As a result, the empty string is
      considered true.
    </description>
    <pattern>text</pattern>
  </type>
  <type>
    <name>boolean_atoi</name>
    <summary>A true or false value, after conversion to an integer</summary>
    <description>
      Zero is false, anything else is true.  The value is first converted to
      an integer, as by the C `atoi' routine.  This means that an empty string
      is considered false.
    </description>
    <pattern>text</pattern>
  </type>
  <type>
    <name>compliance_levels</name>
    <summary>A string selecting compliance levels that may include the characters y, n, i and u</summary>
    <description>
      The meanings of the letters for each level are: "y" for "yes" (compliant),
      "n" for "no" (not compliant), "i" for "incomplete" and "u" for "undefined"
      (without compliance information). 
    </description>
    <pattern>xsd:token { pattern = "y?n?i?u?" }</pattern>
  </type>
  <type>
    <name>compliance_status</name>
    <summary>A compliance status</summary>
    <pattern>
      xsd:token { pattern = "yes|no|incomplete|undefined" }
    </pattern>
  </type>
  <type>
    <name>ctime</name>
    <summary>A date and time, in the C `ctime' format</summary>
    <description>
      An example string in this format is "Wed Jun 30 21:49:08 1993\n".
    </description>
    <pattern>text</pattern>
  </type>
  <type>
    <name>decimal</name>
    <summary>A decimal number that can have a fractional part</summary>
    <pattern>xsd:decimal</pattern>
  </type>
  <type>
    <name>type_name</name>
    <summary>A name of a data type</summary>
    <pattern>xsd:Name</pattern>
  </type>
  <type>
    <name>integer</name>
    <summary>An integer</summary>
    <pattern>xsd:integer</pattern>
  </type>
  <type>
    <name>iso_time</name>
    <summary>A date and time, in ISO 8601 format</summary>
    <description>
      An example string in this format is "2011-11-08T19:57:06+02:00".
    </description>
    <pattern>text</pattern>
  </type>
  <type>
    <name>levels</name>
    <summary>A string selecting severity levels that may include the characters c, h, m, l, g and f</summary>
    <description>
      The meanings of the letters for each level are: "c" for "critical",
      "h" for "high", "m" for "medium", "l" for "low", "g" for "log" and
      "f" for "false positive".
    </description>
    <pattern>xsd:token { pattern = "c?h?m?l?g?f?" }</pattern>
  </type>
  <type>
    <name>name</name>
    <summary>A name</summary>
    <description>
      Typically this is the name of one of the manager resources, like a
      task or target.
    </description>
    <pattern>xsd:string</pattern>
  </type>
  <type>
    <name>port</name>
    <summary>A port</summary>
    <pattern>xsd:token { pattern = "[0-9]{1,5}" }</pattern>
  </type>
  <type>
    <name>port_range</name>
    <summary>A comma separated list of port ranges, prefixed with "T:" for TCP and "U:" for UDP, allowing whitespace</summary>
    <pattern>xsd:token { pattern = "[TU]:[0-9]{1,5}(-[0-9]{1,5})?(,\s*[TU]:[0-9]{1,5}(-[0-9]{1,5})?)*" }</pattern>
  </type>
  <type>
    <name>user_list</name>
    <summary>A space separated list of users</summary>
    <pattern>text</pattern>
  </type>
  <type>
    <name>oid</name>
    <summary>An Object Identifier (OID)</summary>
    <pattern>xsd:token { pattern = "[0-9\.]{1,80}" }</pattern>
  </type>
  <type>
    <name>scanner_type</name>
    <summary>A number specifying the type of a scanner</summary>
    <description>
      The mapping of the numbers is as follows:
      '2' for OpenVAS (classic), '3' for CVE, '5' for OSP Sensor,
      '6' for OpenVASD and '8' for OpenVASD Sensor.
    </description>
    <pattern>xsd:token { pattern = "2|3|5|6|8" }</pattern>
  </type>
  <type>
    <name>severity</name>
    <summary>A severity score</summary>
    <description>
      A severity score is a decimal number between 0.0 and 10.0 (inclusive) with
      one digit after the decimal point or a special negative value
      (-1.0, -2.0 or -3.0).
      If a single severity score defines a constraint, e.g. on whether an
      override applies, for values 0.0 and lower the severity must be equal
      to match while for &gt; 0.0 the compared value must be greater or equal.
    </description>
    <pattern>xsd:token { pattern = "-[1-3](\.0)?|[0-9](\.[0-9])?|10(\.0)?" }</pattern>
  </type>
  <type>
    <name>sort_order</name>
    <summary>A string describing an order for sorting</summary>
    <description>
      The string "descending" denotes descending order, anything else means
      ascending.
    </description>
    <pattern>text</pattern>
  </type>
  <type>
    <name>status</name>
    <summary>The success or failure status of a command</summary>
    <pattern>xsd:token { pattern = "200|201|202|400|401|403|404|409|500|503" }</pattern>
  </type>
  <type>
    <name>task_status</name>
    <summary>A task run status</summary>
    <pattern>
      xsd:token { pattern = "Delete Requested|Done|New|Processing|Requested|Running|Stop Requested|Stopped|Interrupted" }
    </pattern>
  </type>
  <type>
    <name>task_trend</name>
    <summary>The trend of results for a task</summary>
    <pattern>
      xsd:token { pattern = "up|down|more|less|same" }
    </pattern>
  </type>
  <type>
    <name>threat</name>
    <summary>A threat level</summary>
    <description>
      Threat levels are a classification of severity scores only
      supported for importing reports from OpenVAS-6 and older.
      The use of these elements is deprecated as they are otherwise replaced by
      severity elements, which should be used instead.
    </description>
    <pattern>xsd:token { pattern = "High|Medium|Low|Alarm|Log" }</pattern>
  </type>
  <type>
    <name>time_unit</name>
    <summary>A unit of time</summary>
    <pattern>xsd:token { pattern = "second|minute|hour|day|week|month|year|decade" }</pattern>
  </type>
  <type>
    <name>timezone</name>
    <summary>A timezone</summary>
    <description>
      <p>
        The format of a timezone is the same as that of the TZ environment
        variable on GNU/Linux systems.  That is, the same value accepted by the
        tzset C function.  There are three versions of the format.  Note the lack
        of spaces in the examples.
      </p>

      <p>
        "std offset" defines a simple timezone.  For example,
        "FOO+2" defines a timezone FOO which is 2 hours behind UTC.
      </p>
      <p>
        "std offset dst [offset],start[/time],end[/time]" defines a timezone,
        including daylight savings time.  For example,
        "NZST-12.00:00NZDT-13:00:00,M10.1.0,M3.3.0".
      </p>
      <p>
        ":[filespec]" refers to a predefined timezone.  For example,
        ":Africa/Johannesburg".  Note that the colon is optional.  Certain
        acronyms are predefined, such as GB, NZ and CET.
      </p>
    </description>
    <pattern>text</pattern>
  </type>
  <type>
    <name>uuid</name>
    <summary>A Universally Unique Identifier (UUID)</summary>
    <pattern>xsd:token { pattern = "[0-9abcdefABCDEF\-]{1,40}" }</pattern>
  </type>
  <type>
    <name>uuid_or_empty</name>
    <summary>A Universally Unique Identifier (UUID), or the empty string</summary>
    <pattern>xsd:token { pattern = "[0-9abcdefABCDEF\-]{0,40}" }</pattern>
  </type>

  <!-- Elements. -->

  <element>
    <name>c</name>
    <summary>A reference to a command</summary>
    <pattern>text</pattern>
  </element>
  <element>
    <name>e</name>
    <summary>A reference to an element</summary>
    <pattern>text</pattern>
  </element>
  <element>
    <name>r</name>
    <summary>A reference to a response</summary>
    <pattern>text</pattern>
  </element>
  <element>
    <name>o</name>
    <summary>An optional pattern item</summary>
    <pattern>
      <or>
        <e>c</e>
        <e>e</e>
        <e>r</e>
        <e>g</e>
      </or>
    </pattern>
  </element>
  <element>
    <name>g</name>
    <summary>A group of pattern items</summary>
    <pattern>
      <any><e>c</e></any>
      <any><e>e</e></any>
      <any><e>r</e></any>
      <any><e>o</e></any>
      <any><e>any</e></any>
    </pattern>
  </element>
  <element>
    <name>any</name>
    <summary>Pattern item indicating "any number of"</summary>
    <pattern>
      <or>
        <e>c</e>
        <e>e</e>
        <e>r</e>
        <e>g</e>
      </or>
    </pattern>
  </element>
  <element>
    <name>pattern</name>
    <summary>The pattern element of a command or command descendant</summary>
    <description>
      It's actually either a 't' element, or the word "text", or "".
    </description>
    <pattern>
      <any><e>attrib</e></any>
      <any><e>c</e></any>
      <any><e>e</e></any>
      <any><e>r</e></any>
      <any><e>o</e></any>
      <any><e>g</e></any>
      <any><e>any</e></any>
      <o><e>t</e></o>
      text
    </pattern>
    <ele>
      <name>attrib</name>
      <summary>An attribute</summary>
      <pattern>
        <e>name</e>
        <e>type</e>
        <e>required</e>
        <any><e>filter_keywords</e></any>
      </pattern>
      <ele>
        <name>name</name>
        <pattern><t>type_name</t></pattern>
      </ele>
      <ele>
        <name>type</name>
        <pattern><t>type_name</t></pattern>
      </ele>
      <ele>
        <name>required</name>
        <pattern><t>boolean</t></pattern>
      </ele>
      <ele>
        <name>filter_keywords</name>
        <pattern><t>filter_keywords</t></pattern>
        <summary>Optional description of filter keywords usable in the attribute</summary>
      </ele>
    </ele>
    <ele>
      <name>t</name>
      <summary>The type of the text of the element</summary>
      <pattern><t>type_name</t></pattern>
    </ele>
  </element>
  <element>
    <name>command_definition</name>
    <summary>Definition of a command in GMP describing HELP command</summary>
    <pattern>
      <e>name</e>
      <o><e>summary</e></o>
      <o><e>description</e></o>
      <or>
        <g>
          <e>pattern</e>
          <e>response</e>
        </g>
        <g>
          <e>type</e>
          <any><e>ele</e></any>
        </g>
      </or>
      <any><e>example</e></any>
    </pattern>
    <ele>
      <name>name</name>
      <summary>The name of the command</summary>
      <description>The name must be unique</description>
      <pattern><t>type_name</t></pattern>
    </ele>
    <ele>
      <name>summary</name>
      <summary>A summary of the command</summary>
      <pattern>text</pattern>
    </ele>
    <ele>
      <name>description</name>
      <summary>A description of the command</summary>
      <pattern>
        <any><e>p</e></any>
        text
      </pattern>
      <ele>
        <name>p</name>
        <summary>A paragraph</summary>
        <pattern>text</pattern>
      </ele>
    </ele>
    <ele>
      <name>pattern</name>
      <type>pattern</type>
    </ele>
    <ele>
      <name>response</name>
      <type>pattern</type>
    </ele>
    <ele>
      <name>example</name>
      <pattern>
        <o><e>summary</e></o>
        <o><e>description</e></o>
        <e>request</e>
        <e>response</e>
      </pattern>
      <ele>
        <name>summary</name>
        <pattern>text</pattern>
      </ele>
      <ele>
        <name>description</name>
        <pattern>text</pattern>
      </ele>
      <ele>
        <name>request</name>
        <summary>Example request</summary>
        <description>This can actually contain any XML</description>
        <pattern>text</pattern>
      </ele>
      <ele>
        <name>response</name>
        <summary>Response to example request</summary>
        <description>This can actually contain any XML</description>
        <pattern>text</pattern>
      </ele>
    </ele>
    <ele>
      <name>type</name>
      <summary>The type of the element</summary>
      <pattern>text</pattern>
    </ele>
    <ele>
      <name>ele</name>
      <summary>An element</summary>
      <description>
        <p>
          This is a recursive definition.
        </p>
        <p>
          command_definition actually includes an extra response element, but
          it's convenient to use it for the elements.
        </p>
      </description>
      <type>command_definition</type>
    </ele>
  </element>
  <element>
    <name>filter_keywords</name>
    <summary>A group of filter keywords usable in an attribute or element text</summary>
    <pattern>
      <o><e>condition</e></o>
      <any><e>column</e></any>
      <any><e>option</e></any>
    </pattern>
    <ele>
      <name>condition</name>
      <pattern>text</pattern>
      <summary>Description of the condition under which the group of keywords applies</summary>
    </ele>
    <ele>
      <name>column</name>
      <pattern>
        <e>name</e>
        <e>type</e>
        <e>summary</e>
      </pattern>
      <summary>A column that can be used multiple times with operators and in sorting</summary>
      <ele>
        <name>name</name>
        <pattern>name</pattern>
        <summary>Name of the keyword as used in the filter</summary>
      </ele>
      <ele>
        <name>type</name>
        <pattern><t>type_name</t></pattern>
        <summary>Type of the values the keyword can use</summary>
      </ele>
      <ele>
        <name>summary</name>
        <pattern>text</pattern>
        <summary>Short description of the keyword</summary>
      </ele>
    </ele>
    <ele>
      <name>option</name>
      <pattern>
        <e>name</e>
        <e>type</e>
        <e>summary</e>
      </pattern>
      <summary>An option only applied once which cannot be used with operators or in sorting</summary>
      <ele>
        <name>name</name>
        <pattern>name</pattern>
        <summary>Name of the keyword as used in the filter</summary>
      </ele>
      <ele>
        <name>type</name>
        <pattern><t>type_name</t></pattern>
        <summary>Type of the values the keyword can use</summary>
      </ele>
      <ele>
        <name>summary</name>
        <pattern>text</pattern>
        <summary>Short description of the keyword</summary>
      </ele>
    </ele>
  </element>
  <element>
    <name>certificate_info</name>
    <summary>Info about a certificate</summary>
    <pattern>
      <e>time_status</e>
      <e>activation_time</e>
      <e>expiration_time</e>
      <e>issuer</e>
      <e>md5_fingerprint</e>
      <o><e>sha256_fingerprint</e></o>
      <o><e>subject</e></o>
      <o><e>serial</e></o>
    </pattern>
    <ele>
      <name>time_status</name>
      <summary>
        Whether the certificate is valid, expired or not active yet
      </summary>
      <pattern>
        <alts>
          <alt>expired</alt>
          <alt>inactive</alt>
          <alt>unknown</alt>
          <alt>valid</alt>
        </alts>
      </pattern>
    </ele>
    <ele>
      <name>activation_time</name>
      <summary>Time before which the certificate is not valid</summary>
      <pattern>text</pattern>
    </ele>
    <ele>
      <name>expiration_time</name>
      <summary>Time after which the certificate is no longer valid</summary>
      <pattern>text</pattern>
    </ele>
    <ele>
      <name>issuer</name>
      <summary>DN of the issuer of the certificate</summary>
      <pattern>text</pattern>
    </ele>
    <ele>
      <name>md5_fingerprint</name>
      <summary>MD5 fingerprint of the certificate</summary>
      <pattern>text</pattern>
    </ele>
    <ele>
      <name>sha256_fingerprint</name>
      <summary>SHA-256 fingerprint of the certificate</summary>
      <pattern>text</pattern>
    </ele>
    <ele>
      <name>subject</name>
      <summary>Name of the certificate</summary>
      <pattern>text</pattern>
    </ele>
    <ele>
      <name>serial</name>
      <summary>Serial number of certificate</summary>
      <pattern>text</pattern>
    </ele>
  </element>
  <element>
    <name>nvt</name>
    <summary>Meta information of a network vulnerability test</summary>
    <pattern>
      <attrib>
        <name>id</name>
        <type>oid</type>
        <required>1</required>
      </attrib>
      <e>name</e>
      <e>creation_time</e>
      <e>modification_time</e>
      <e>category</e>
      <e>family</e>
      <e>cvss_base</e>
      <e>severities</e>
      <e>qod</e>
      <e>refs</e>
      <e>tags</e>
      <e>preference_count</e>
      <e>timeout</e>
      <e>default_timeout</e>
      <e>solution</e>
      <o><e>epss</e></o>
      <e>preferences</e>
    </pattern>
    <ele>
      <name>name</name>
      <summary>Name of the vulnerability test</summary>
      <pattern><t>text</t></pattern>
    </ele>
    <ele>
      <name>creation_time</name>
      <summary>Date and time the vulnerability test was created</summary>
      <pattern><t>iso_time</t></pattern>
    </ele>
    <ele>
      <name>modification_time</name>
      <summary>Date and time the vulnerability test was last modified</summary>
      <pattern><t>iso_time</t></pattern>
    </ele>
    <ele>
      <name>category</name>
      <summary>Category of the vulnerability test</summary>
      <pattern><t>integer</t></pattern>
    </ele>
    <ele>
      <name>family</name>
      <summary>Family of the vulnerability test</summary>
      <pattern><t>text</t></pattern>
    </ele>
    <ele>
      <name>cvss_base</name>
      <summary>CVSS base score of the vulnerability test</summary>
      <pattern><t>text</t></pattern>
    </ele>
    <ele>
      <name>severities</name>
      <summary>Severity information of the NVT</summary>
      <type>severities</type>
    </ele>
    <ele>
      <name>qod</name>
      <summary>Quality of Detection</summary>
      <pattern>
        <e>value</e>
        <e>type</e>
      </pattern>
      <ele>
        <name>value</name>
        <summary>The value of the QoD</summary>
        <pattern><t>integer</t></pattern>
      </ele>
      <ele>
        <name>type</name>
        <summary>The type of the QoD</summary>
        <pattern><t>name</t></pattern>
      </ele>
    </ele>
    <ele>
      <name>refs</name>
      <summary>List of references of the vulnerability test</summary>
      <pattern><any><e>ref</e></any></pattern>
    </ele>
    <ele>
      <name>tags</name>
      <summary>Additional information about vulnerability test in pipe-separated syntax</summary>
      <pattern><t>text</t></pattern>
    </ele>
    <ele>
      <name>preference_count</name>
      <summary>The number of preferences</summary>
      <pattern><t>integer</t></pattern>
    </ele>
    <ele>
      <name>timeout</name>
      <summary>The timeout of the vulnerability test</summary>
      <pattern><t>integer</t></pattern>
    </ele>
    <ele>
      <name>default_timeout</name>
      <summary>The default timeout of the vulnerability test</summary>
      <pattern><t>integer</t></pattern>
    </ele>
    <ele>
      <name>solution</name>
      <summary>The solution information for the vulnerability test</summary>
      <pattern>
        <attrib>
          <name>type</name>
          <summary>The solution type, for example "VendorFix"</summary>
          <type>name</type>
          <required>0</required>
        </attrib>
        <attrib>
          <name>method</name>
          <summary>The solution method, for example "DebianAPTUpgrade"</summary>
          <type>name</type>
          <required>0</required>
        </attrib>
      </pattern>
    </ele>
    <ele>
      <name>epss</name>
      <summary>Exploit Prediction Scoring System (EPSS) info if available</summary>
      <pattern>
        <e>max_severity</e>
        <e>max_epss</e>
      </pattern>
      <ele>
        <name>max_severity</name>
        <summary>
          EPSS info of the referenced CVE with the highest severity
        </summary>
        <description>
          In case there are multiple CVEs referenced by the NVT tied for the
          highest severity, they are also sorted by EPSS score and modification
          time and the first one is chosen.
        </description>
        <pattern>
          <e>score</e>
          <e>percentile</e>
          <e>cve</e>
        </pattern>
        <ele>
          <name>score</name>
          <summary>EPSS score of the CVE</summary>
          <pattern>
            <t>decimal</t>
          </pattern>
        </ele>
        <ele>
          <name>percentile</name>
          <summary>EPSS percentile of the CVE</summary>
          <pattern>
            <t>decimal</t>
          </pattern>
        </ele>
        <ele>
          <name>cve</name>
          <summary>The representative CVE chosen</summary>
          <pattern>
            <attrib>
              <name>id</name>
              <summary>CVE-ID of the CVE</summary>
              <type>text</type>
            </attrib>
            <o><e>severity</e></o>
          </pattern>
          <ele>
            <name>severity</name>
            <summary>Severity (CVSS) score of the CVE if available</summary>
            <pattern>
              <t>severity</t>
            </pattern>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>max_epss</name>
        <summary>
          EPSS info of the referenced CVE with the highest EPSS score
        </summary>
        <description>
          In case there are multiple CVEs referenced by the NVT tied for the
          highest EPSS score, they are also sorted by severity and modification
          time and the first one is chosen.
        </description>
        <pattern>
          <e>score</e>
          <e>percentile</e>
          <e>cve</e>
        </pattern>
        <ele>
          <name>score</name>
          <summary>EPSS score of the CVE</summary>
          <pattern>
            <t>decimal</t>
          </pattern>
        </ele>
        <ele>
          <name>percentile</name>
          <summary>EPSS percentile of the CVE</summary>
          <pattern>
            <t>decimal</t>
          </pattern>
        </ele>
        <ele>
          <name>cve</name>
          <summary>The representative CVE chosen</summary>
          <pattern>
            <attrib>
              <name>id</name>
              <summary>CVE-ID of the CVE</summary>
              <type>text</type>
            </attrib>
            <o><e>severity</e></o>
          </pattern>
          <ele>
            <name>severity</name>
            <summary>Severity (CVSS) score of the CVE if available</summary>
            <pattern>
              <t>severity</t>
            </pattern>
          </ele>
        </ele>
      </ele>
    </ele>
    <ele>
      <name>preferences</name>
      <summary>The list of preferences</summary>
      <pattern><t>text</t></pattern>
    </ele>
  </element>
  <element>
    <name>override</name>
    <summary>An override</summary>
    <pattern>
      <attrib>
        <name>id</name>
        <type>uuid</type>
        <required>1</required>
      </attrib>
      <e>permissions</e>
      <e>owner</e>
      <e>nvt</e>
      <e>creation_time</e>
      <e>modification_time</e>
      <e>writable</e>
      <e>in_use</e>
      <e>active</e>
      <e>text</e>
      <e>threat</e>
      <e>severity</e>
      <e>new_threat</e>
      <e>new_severity</e>
      <e>orphan</e>
      <o><e>user_tags</e></o>
      <o>
        <g>
          <e>hosts</e>
          <e>port</e>
          <e>task</e>
          <e>end_time</e>
          <o><e>result</e></o>
        </g>
      </o>
    </pattern>
    <ele>
      <name>permissions</name>
      <summary>Permissions that the current user has on the override</summary>
      <pattern>
        <any><e>permission</e></any>
      </pattern>
      <ele>
        <name>permission</name>
        <pattern>
          <e>name</e>
        </pattern>
        <ele>
          <name>name</name>
          <summary>The name of the permission</summary>
          <pattern><t>name</t></pattern>
        </ele>
      </ele>
    </ele>
    <ele>
      <name>owner</name>
      <summary>Owner of the override</summary>
      <pattern>
        <e>name</e>
      </pattern>
      <ele>
        <name>name</name>
        <pattern><t>name</t></pattern>
      </ele>
    </ele>
    <ele>
      <name>nvt</name>
      <pattern>
        <attrib>
          <name>oid</name>
          <type>oid</type>
          <required>1</required>
        </attrib>
        <e>name</e>
        <e>type</e>
      </pattern>
      <ele>
        <name>name</name>
        <pattern><t>name</t></pattern>
      </ele>
      <ele>
        <name>type</name>
        <summary>The type of the NVT: nvt, cve, ...</summary>
        <pattern>text</pattern>
      </ele>
    </ele>
    <ele>
      <name>creation_time</name>
      <summary>Date and time the override was created</summary>
      <pattern><t>iso_time</t></pattern>
    </ele>
    <ele>
      <name>modification_time</name>
      <summary>Date and time the override was last modified</summary>
      <pattern><t>iso_time</t></pattern>
    </ele>
    <ele>
      <name>writable</name>
      <pattern><t>boolean</t></pattern>
    </ele>
    <ele>
      <name>in_use</name>
      <pattern><t>boolean</t></pattern>
    </ele>
    <ele>
      <name>active</name>
      <summary>Whether the override is currently active</summary>
      <pattern><t>boolean</t></pattern>
    </ele>
    <ele>
      <name>text</name>
      <summary>The text of the override</summary>
      <pattern>
        <attrib>
          <name>excerpt</name>
          <summary>Whether the contents is an excerpt of the full text</summary>
          <type>boolean</type>
          <required>1</required>
        </attrib>
        text
      </pattern>
    </ele>
    <ele>
      <name>threat</name>
      <summary>
        Threat level to which override applies, derived from severity
      </summary>
      <pattern>
        <t>threat</t>
      </pattern>
    </ele>
    <ele>
      <name>severity</name>
      <summary>Severity score to which override applies</summary>
      <pattern>
        <t>severity</t>
      </pattern>
    </ele>
    <ele>
      <name>new_threat</name>
      <summary>New threat for result</summary>
      <pattern>
        <t>threat</t>
      </pattern>
    </ele>
    <ele>
      <name>new_severity</name>
      <summary>New severity score for result</summary>
      <pattern>
        <t>severity</t>
      </pattern>
    </ele>
    <ele>
      <name>orphan</name>
      <summary>Whether the override is an orphan</summary>
      <pattern><t>boolean</t></pattern>
    </ele>
    <ele>
      <name>user_tags</name>
      <summary>Info on tags attached to the override</summary>
      <pattern>
        <e>count</e>
        <any><e>tag</e></any>
      </pattern>
      <ele>
        <name>count</name>
        <summary>Number of attached tags</summary>
        <pattern><t>integer</t></pattern>
      </ele>
      <ele>
        <name>tag</name>
        <summary>
          Short info on an individual tag
          (only if details were requested)
        </summary>
        <pattern>
          <attrib>
            <name>id</name>
            <type>uuid</type>
            <summary>UUID of the tag</summary>
            <required>1</required>
          </attrib>
          <e>name</e>
          <e>value</e>
          <e>comment</e>
        </pattern>
        <ele>
          <name>name</name>
          <summary>Name of the tag (usually namespace:predicate)</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>value</name>
          <summary>Value of the tag</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>comment</name>
          <summary>Comment for the tag</summary>
          <pattern>text</pattern>
        </ele>
      </ele>
    </ele>
    <ele>
      <name>hosts</name>
      <summary>A comma-separated list of hosts</summary>
      <pattern>
        text
      </pattern>
    </ele>
    <ele>
      <name>port</name>
      <summary>Port (location) to which override applies</summary>
      <pattern>
        text
      </pattern>
    </ele>
    <ele>
      <name>task</name>
      <summary>Task to which override applies</summary>
      <pattern>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
        <e>name</e>
        <e>trash</e>
      </pattern>
      <ele>
        <name>name</name>
        <summary>Task name</summary>
        <pattern>text</pattern>
      </ele>
      <ele>
        <name>trash</name>
        <summary>Whether the task is in the trashcan</summary>
        <type>boolean</type>
      </ele>
    </ele>
    <ele>
      <name>active</name>
      <summary>Whether the override is active</summary>
      <pattern><t>integer</t></pattern>
    </ele>
    <ele>
      <name>end_time</name>
      <summary>Override end time in case of limit, else empty</summary>
      <pattern>text</pattern>
    </ele>
    <ele>
      <name>result</name>
      <summary>Result to which override applies</summary>
      <type>result</type>
    </ele>
  </element>
  <element>
    <name>result</name>
    <summary>A result</summary>
    <pattern>
      <attrib>
        <name>id</name>
        <type>uuid</type>
        <required>1</required>
      </attrib>
      <e>name</e>
      <e>owner</e>
      <e>comment</e>
      <e>creation_time</e>
      <e>modification_time</e>
      <o><e>user_tags</e></o>
      <o><e>report</e></o>
      <o><e>task</e></o>
      <e>host</e>
      <e>port</e>
      <o><e>path</e></o>
      <e>nvt</e>
      <e>scan_nvt_version</e>
      <e>threat</e>
      <e>severity</e>
      <e>qod</e>
      <o><e>original_threat</e></o>
      <o><e>original_severity</e></o>
      <e>compliance</e>
      <e>description</e>
      <o><e>detection</e></o>
      <o><e>overrides</e></o>
    </pattern>
    <ele>
      <name>name</name>
      <summary>The name of the result</summary>
      <pattern>text</pattern>
    </ele>
    <ele>
      <name>owner</name>
      <summary>Owner of the result</summary>
      <pattern>
        <e>name</e>
      </pattern>
      <ele>
        <name>name</name>
        <summary>The name of the owner</summary>
        <pattern><t>name</t></pattern>
      </ele>
    </ele>
    <ele>
      <name>comment</name>
      <summary>The comment on the result</summary>
      <pattern>text</pattern>
    </ele>
    <ele>
      <name>creation_time</name>
      <summary>Date and time the result was created</summary>
      <pattern><t>iso_time</t></pattern>
    </ele>
    <ele>
      <name>modification_time</name>
      <summary>Date and time the result was last modified</summary>
      <pattern><t>iso_time</t></pattern>
    </ele>
    <ele>
      <name>user_tags</name>
      <summary>Info on tags attached to the result</summary>
      <pattern>
        <e>count</e>
        <any><e>tag</e></any>
      </pattern>
      <ele>
        <name>count</name>
        <summary>Number of attached tags</summary>
        <pattern><t>integer</t></pattern>
      </ele>
      <ele>
        <name>tag</name>
        <summary>
          Short info on an individual tag
          (only if details were requested)
        </summary>
        <pattern>
          <attrib>
            <name>id</name>
            <type>uuid</type>
            <summary>UUID of the tag</summary>
            <required>1</required>
          </attrib>
          <e>name</e>
          <e>value</e>
          <e>comment</e>
        </pattern>
        <ele>
          <name>name</name>
          <summary>Name of the tag (usually namespace:predicate)</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>value</name>
          <summary>Value of the tag</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>comment</name>
          <summary>Comment for the tag</summary>
          <pattern>text</pattern>
        </ele>
      </ele>
    </ele>
    <ele>
      <name>report</name>
      <summary>
        Report the result belongs to (only when details were requested)
      </summary>
      <pattern>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <summary>UUID of the report the result belongs to</summary>
          <required>1</required>
        </attrib>
      </pattern>
    </ele>
    <ele>
      <name>task</name>
      <summary>
        Task the result applies to (only when details were requested)
      </summary>
      <pattern>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <summary>UUID of the task the result applies to</summary>
          <required>1</required>
        </attrib>
        <e>name</e>
      </pattern>
      <ele>
        <name>name</name>
        <pattern>text</pattern>
        <summary>Name of the task the result applies to</summary>
      </ele>
    </ele>
    <ele>
      <name>host</name>
      <summary>The host the result applies to</summary>
      <pattern>
        <e>asset</e>
        <e>hostname</e>
        text
      </pattern>
      <ele>
        <name>asset</name>
        <summary>Asset linked to host</summary>
        <pattern>
          <attrib>
            <name>asset_id</name>
            <type>uuid</type>
            <required>1</required>
          </attrib>
        </pattern>
      </ele>
      <ele>
        <name>hostname</name>
        <summary>
          If available, the hostname the result was created for, else the
          one from host details
        </summary>
        <pattern>text</pattern>
      </ele>
    </ele>
    <ele>
      <name>port</name>
      <summary>The port (location) on the host</summary>
      <pattern>text</pattern>
    </ele>
    <ele>
      <name>path</name>
      <summary>The local path on the host, e.g. a file location</summary>
      <pattern>text</pattern>
    </ele>
    <ele>
      <name>nvt</name>
      <summary>NVT to which result applies</summary>
      <pattern>
        <attrib>
          <name>oid</name>
          <type>oid</type>
          <required>1</required>
        </attrib>
        <e>name</e>
        <e>type</e>
        <e>family</e>
        <e>cvss_base</e>
        <e>severities</e>
        <e>cpe</e>
        <e>tags</e>
        <o><e>epss</e></o>
        <e>refs</e>
      </pattern>
      <ele>
        <name>name</name>
        <summary>The name of the NVT</summary>
        <pattern><t>name</t></pattern>
      </ele>
      <ele>
        <name>type</name>
        <summary>The type of the NVT: nvt, cve, ...</summary>
        <pattern>text</pattern>
      </ele>
      <ele>
        <name>family</name>
        <summary>The family the NVT is in</summary>
        <pattern><t>name</t></pattern>
      </ele>
      <ele>
        <name>cvss_base</name>
        <summary>CVSS base value associated with the NVT</summary>
        <pattern><t>integer</t></pattern>
      </ele>
      <ele>
        <name>severities</name>
        <summary>Severity score information of the NVT</summary>
        <type>severities</type>
      </ele>
      <ele>
        <name>cpe</name>
        <summary>The CPE which produced the CVE (for "cve" results)</summary>
        <pattern>text</pattern>
      </ele>
      <ele>
        <name>tags</name>
        <summary>Tags associated with the NVT</summary>
        <pattern>text</pattern>
      </ele>
      <ele>
        <name>epss</name>
        <summary>Exploit Prediction Scoring System (EPSS) info if available</summary>
        <pattern>
          <e>max_severity</e>
          <e>max_epss</e>
        </pattern>
        <ele>
          <name>max_severity</name>
          <summary>
            EPSS info of the referenced CVE with the highest severity
          </summary>
          <description>
            In case there are multiple CVEs referenced by the NVT tied for the
            highest severity, they are also sorted by EPSS score and modification
            time and the first one is chosen.
          </description>
          <pattern>
            <e>score</e>
            <e>percentile</e>
            <e>cve</e>
          </pattern>
          <ele>
            <name>score</name>
            <summary>EPSS score of the CVE</summary>
            <pattern>
              <t>decimal</t>
            </pattern>
          </ele>
          <ele>
            <name>percentile</name>
            <summary>EPSS percentile of the CVE</summary>
            <pattern>
              <t>decimal</t>
            </pattern>
          </ele>
          <ele>
            <name>cve</name>
            <summary>The representative CVE chosen</summary>
            <pattern>
              <attrib>
                <name>id</name>
                <summary>CVE-ID of the CVE</summary>
                <type>text</type>
              </attrib>
              <o><e>severity</e></o>
            </pattern>
            <ele>
              <name>severity</name>
              <summary>Severity (CVSS) score of the CVE if available</summary>
              <pattern>
                <t>severity</t>
              </pattern>
            </ele>
          </ele>
        </ele>
        <ele>
          <name>max_epss</name>
          <summary>
            EPSS info of the referenced CVE with the highest EPSS score
          </summary>
          <description>
            In case there are multiple CVEs referenced by the NVT tied for the
            highest EPSS score, they are also sorted by severity and modification
            time and the first one is chosen.
          </description>
          <pattern>
            <e>score</e>
            <e>percentile</e>
            <e>cve</e>
          </pattern>
          <ele>
            <name>score</name>
            <summary>EPSS score of the CVE</summary>
            <pattern>
              <t>decimal</t>
            </pattern>
          </ele>
          <ele>
            <name>percentile</name>
            <summary>EPSS percentile of the CVE</summary>
            <pattern>
              <t>decimal</t>
            </pattern>
          </ele>
          <ele>
            <name>cve</name>
            <summary>The representative CVE chosen</summary>
            <pattern>
              <attrib>
                <name>id</name>
                <summary>CVE-ID of the CVE</summary>
                <type>text</type>
              </attrib>
              <o><e>severity</e></o>
            </pattern>
            <ele>
              <name>severity</name>
              <summary>Severity (CVSS) score of the CVE if available</summary>
              <pattern>
                <t>severity</t>
              </pattern>
            </ele>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>refs</name>
        <summary>List of references of various types for this vulnerability test</summary>
        <pattern>
          <any><e>ref</e></any>
        </pattern>
        <ele>
          <name>ref</name>
          <summary>A reference</summary>
          <pattern>
            <attrib>
              <name>id</name>
              <summary>ID of the reference</summary>
              <type>text</type>
            </attrib>
            <attrib>
              <name>type</name>
              <summary>Type of the reference, for example "cve", "dfn-cert", "cert-bund"
              </summary>
              <type>text</type>
            </attrib>
          </pattern>
        </ele>
      </ele>
    </ele>
    <ele>
      <name>scan_nvt_version</name>
      <summary>Version of the NVT used in the scan</summary>
      <pattern>text</pattern>
    </ele>
    <ele>
      <name>threat</name>
      <pattern><t>threat</t></pattern>
    </ele>
    <ele>
      <name>severity</name>
      <pattern><t>severity</t></pattern>
    </ele>
    <ele>
      <name>qod</name>
      <summary>The quality of detection (QoD) of the result</summary>
      <pattern>
        <e>value</e>
        <e>type</e>
      </pattern>
      <ele>
        <name>value</name>
        <summary>The numeric QoD value</summary>
        <pattern><t>integer</t></pattern>
      </ele>
      <ele>
        <name>type</name>
        <summary>The QoD type</summary>
        <pattern>text</pattern>
      </ele>
    </ele>
    <ele>
      <name>original_threat</name>
      <summary>Original threat when overridden</summary>
      <pattern><t>threat</t></pattern>
    </ele>
    <ele>
      <name>original_severity</name>
      <summary>Original severity when overridden</summary>
      <pattern><t>severity</t></pattern>
    </ele>
    <ele>
      <name>compliance</name>
      <summary>Result compliance ("yes", "no", "incomplete" or "undefined")</summary>
      <pattern><t>compliance_status</t></pattern>
    </ele>    
    <ele>
      <name>description</name>
      <summary>Description of the result</summary>
      <pattern>text</pattern>
    </ele>
    <ele>
      <name>detection</name>
      <summary>Detection details</summary>
      <pattern><e>result</e></pattern>
      <ele>
        <name>result</name>
        <summary>Detection result</summary>
        <pattern>
          <attrib>
            <name>id</name>
            <summary>UUID of the detection result</summary>
            <required>1</required>
            <type>uuid</type>
          </attrib>
          <e>details</e>
        </pattern>
        <ele>
          <name>details</name>
          <pattern>
            <any><e>detail</e></any>
          </pattern>
          <ele>
            <name>detail</name>
            <summary>A detail associated with the detection result</summary>
            <pattern>
              <e>name</e>
              <e>value</e>
            </pattern>
            <ele>
              <name>name</name>
              <summary>The name of the detail</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>value</name>
              <summary>The value of the detail</summary>
              <pattern>text</pattern>
            </ele>
          </ele>
        </ele>
      </ele>
    </ele>
    <ele>
      <name>overrides</name>
      <summary>List of overrides on the result</summary>
      <pattern>
        <any><e>override</e></any>
      </pattern>
      <ele>
        <name>override</name>
        <type>override</type>
      </ele>
    </ele>
  </element>
  <element>
    <name>report</name>
    <summary>Actually attributes and either base64 or a report</summary>
    <pattern>
      <attrib>
        <name>id</name>
        <type>uuid</type>
        <required>1</required>
      </attrib>
      <attrib>
        <name>format_id</name>
        <type>uuid</type>
        <summary>UUID of the report format used</summary>
        <required>1</required>
      </attrib>
      <attrib>
        <name>extension</name>
        <type>text</type>
        <required>1</required>
      </attrib>
      <attrib>
        <name>content_type</name>
        <type>text</type>
        <required>1</required>
      </attrib>
      <attrib>
        <name>type</name>
        <type>
          <alts>
            <alt>scan</alt>
            <alt>assets</alt>
          </alts>
        </type>
      </attrib>
      <t>base64</t>
      <e>owner</e>
      <e>name</e>
      <e>comment</e>
      <e>creation_time</e>
      <e>modification_time</e>
      <e>writable</e>
      <e>in_use</e>
      <e>task</e>
      <o><e>report_format</e></o>
      <e>report</e>
    </pattern>
    <ele>
      <name>owner</name>
      <summary>Owner of the report</summary>
      <pattern>
        <e>name</e>
      </pattern>
      <ele>
        <name>name</name>
        <summary>The name of the owner</summary>
        <pattern><t>name</t></pattern>
      </ele>
    </ele>
    <ele>
      <name>name</name>
      <summary>Creation time as compatibility placeholder</summary>
      <pattern></pattern>
    </ele>
    <ele>
      <name>comment</name>
      <summary>The comment on the report</summary>
      <pattern>text</pattern>
    </ele>
    <ele>
      <name>creation_time</name>
      <summary>Date and time the report was created</summary>
      <pattern><t>iso_time</t></pattern>
    </ele>
    <ele>
      <name>modification_time</name>
      <summary>Date and time the report was last modified</summary>
      <pattern><t>iso_time</t></pattern>
    </ele>
    <ele>
      <name>in_use</name>
      <summary>Whether the report is in use</summary>
      <pattern><t>boolean</t></pattern>
    </ele>
    <ele>
      <name>writable</name>
      <summary>Whether the report is writable</summary>
      <pattern><t>boolean</t></pattern>
    </ele>
    <ele>
      <name>task</name>
      <summary>The task the report belongs to</summary>
      <pattern>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
        <e>name</e>
      </pattern>
      <ele>
        <name>name</name>
        <summary>The name of the task</summary>
        <pattern><t>name</t></pattern>
      </ele>
    </ele>
    <ele>
      <name>report_format</name>
      <summary>The report format used</summary>
      <pattern>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
        <e>name</e>
      </pattern>
      <ele>
        <name>name</name>
        <summary>The name of the report format</summary>
        <pattern><t>name</t></pattern>
      </ele>
    </ele>
    <ele>
      <name>report</name>
      <pattern>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>type</name>
          <type>
            <alts>
              <alt>scan</alt>
              <alt>assets</alt>
            </alts>
          </type>
        </attrib>
        <e>gmp</e>
        <e>report_format</e>
        <e>sort</e>
        <e>filters</e>
        <o>
          <g>
            <e>timezone</e>
            <e>timezone_abbrev</e>
            <e>permissions</e>
            <o><e>user_tags</e></o>
            <e>scan_run_status</e>
            <o>
              <e>result_count</e>
              <e>severity</e>
            </o>
            <o><e>compliance_count</e></o>
            <o><e>compliance</e></o>
            <e>task</e>
            <e>ports</e>
            <e>results</e>
            <e>hosts</e>
            <e>cves</e>
            <e>vulns</e>
            <e>os</e>
            <e>apps</e>
            <e>ssl_certs</e>
            <any><e>host</e></any>
            <e>tls_certificates</e>
            <e>timestamp</e>
            <e>scan_start</e>
            <e>scan_end</e>
            <e>errors</e>
          </g>
        </o>
      </pattern>
      <ele>
        <name>gmp</name>
        <summary>Information of the GMP server</summary>
        <pattern>
          <e>version</e>
        </pattern>
        <ele>
          <name>version</name>
          <summary>The GMP version</summary>
          <pattern>
            text
          </pattern>
        </ele>
      </ele>
      <ele>
        <name>report_format</name>
        <pattern>
          <e>param</e>
        </pattern>
        <ele>
          <name>param</name>
          <summary>Report format parameter</summary>
          <pattern>
            <e>name</e>
            <e>value</e>
          </pattern>
          <ele>
            <name>name</name>
            <summary>Parameter name</summary>
            <pattern>
              text
            </pattern>
          </ele>
          <ele>
            <name>value</name>
            <summary>Parameter value</summary>
            <pattern>
              text
            </pattern>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>sort</name>
        <summary>Result sorting information</summary>
        <pattern>
          <e>field</e>
        </pattern>
        <ele>
          <name>field</name>
          <summary>Sort field</summary>
          <pattern>
            text
            <e>order</e>
          </pattern>
          <ele>
            <name>order</name>
            <summary>Sort order of field</summary>
            <pattern>
              <alts>
                <alt>ascending</alt>
                <alt>descending</alt>
              </alts>
            </pattern>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>filters</name>
        <summary>Result filtering information</summary>
        <pattern>
          <attrib>
            <name>id</name>
            <summary>Filter used if any, else 0</summary>
            <type>uuid</type>
          </attrib>
          <t>levels</t>
          <e>term</e>
          <e>phrase</e>
          <e>overrides</e>
          <e>apply_overrides</e>
          <e>result_hosts_only</e>
          <e>min_qod</e>
          <any><e>filter</e></any>
          <o><e>delta</e></o>
        </pattern>
        <ele>
          <name>term</name>
          <summary>Filter term</summary>
          <pattern>
            <t>text</t>
          </pattern>
        </ele>
        <ele>
          <name>phrase</name>
          <summary>Search phrase</summary>
          <pattern>
            <t>text</t>
          </pattern>
        </ele>
        <ele>
          <name>overrides</name>
          <summary>Whether overrides are included</summary>
          <pattern>
            <alts><alt>0</alt><alt>1</alt></alts>
          </pattern>
        </ele>
        <ele>
          <name>apply_overrides</name>
          <summary>Whether overrides are applied</summary>
          <pattern>
            <alts><alt>0</alt><alt>1</alt></alts>
          </pattern>
        </ele>
        <ele>
          <name>result_hosts_only</name>
          <summary>
            Whether only those hosts that have results are included
          </summary>
          <pattern>
            <alts><alt>0</alt><alt>1</alt></alts>
          </pattern>
        </ele>
        <ele>
          <name>min_qod</name>
          <summary>Minimum QoD if in effect, else empty string</summary>
          <pattern>
            text
          </pattern>
        </ele>
        <ele>
          <name>filter</name>
          <summary>Level filter</summary>
          <pattern>
            <alts>
              <alt>Critical</alt>
              <alt>High</alt>
              <alt>Medium</alt>
              <alt>Low</alt>
              <alt>Log</alt>
            </alts>
          </pattern>
        </ele>
      </ele>
      <ele>
        <name>timezone</name>
        <summary>Name of timezone used for dates</summary>
        <pattern>
          timezone
        </pattern>
      </ele>
      <ele>
        <name>timezone_abbrev</name>
        <summary>Abbreviation used for timezone</summary>
        <pattern>
          text
        </pattern>
      </ele>
      <ele>
        <name>permissions</name>
        <summary>Permissions that the current user has on the report</summary>
        <pattern>
          <any><e>permission</e></any>
        </pattern>
        <ele>
          <name>permission</name>
          <pattern>
            <e>name</e>
          </pattern>
          <ele>
            <name>name</name>
            <summary>The name of the permission</summary>
            <pattern><t>name</t></pattern>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>user_tags</name>
        <summary>Info on tags attached to the report</summary>
        <pattern>
          <e>count</e>
          <any><e>tag</e></any>
        </pattern>
        <ele>
          <name>count</name>
          <summary>Number of attached tags</summary>
          <pattern><t>integer</t></pattern>
        </ele>
        <ele>
          <name>tag</name>
          <summary>
            Short info on an individual tag
            (only if details were requested)
          </summary>
          <pattern>
            <attrib>
              <name>id</name>
              <type>uuid</type>
              <summary>UUID of the tag</summary>
              <required>1</required>
            </attrib>
            <e>name</e>
            <e>value</e>
            <e>comment</e>
          </pattern>
          <ele>
            <name>name</name>
            <summary>Name of the tag (usually namespace:predicate)</summary>
            <pattern>text</pattern>
          </ele>
          <ele>
            <name>value</name>
            <summary>Value of the tag</summary>
            <pattern>text</pattern>
          </ele>
          <ele>
            <name>comment</name>
            <summary>Comment for the tag</summary>
            <pattern>text</pattern>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>scan_run_status</name>
        <summary>Run status of task scan at time of report</summary>
        <pattern><t>task_status</t></pattern>
      </ele>
      <ele>
        <name>result_count</name>
        <summary>Counts of results produced by scan</summary>
        <description>
          <p>
            The text contains the full count -- the total number of results
            produced by scan.
          </p>
        </description>
        <pattern>
          text
          <e>full</e>
          <e>filtered</e>
          <e>critical</e>
          <e>hole</e>
          <e>high</e>
          <e>info</e>
          <e>low</e>
          <e>log</e>
          <e>warning</e>
          <e>medium</e>
        </pattern>
        <ele>
          <name>full</name>
          <summary>Total number of results produced by scan</summary>
          <pattern><t>integer</t></pattern>
        </ele>
        <ele>
          <name>filtered</name>
          <summary>Number of results after filtering</summary>
          <pattern><t>integer</t></pattern>
        </ele>
        <ele>
          <name>critical</name>
          <summary>
            Number of "critical" results (threat level critical)
          </summary>
          <pattern>
            <e>full</e>
            <e>filtered</e>
          </pattern>
          <ele>
            <name>full</name>
            <summary>Total number of results</summary>
            <pattern><t>integer</t></pattern>
          </ele>
          <ele>
            <name>filtered</name>
            <summary>Number of results after filtering</summary>
            <pattern><t>integer</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>hole</name>
          <summary>
            Number of "hole" results (threat level High)
            ,will be deprecated. Use high instead
          </summary>
          <pattern>
            <e>full</e>
            <e>filtered</e>
          </pattern>
          <ele>
            <name>full</name>
            <summary>Total number of results</summary>
            <pattern><t>integer</t></pattern>
          </ele>
          <ele>
            <name>filtered</name>
            <summary>Number of results after filtering</summary>
            <pattern><t>integer</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>high</name>
          <summary>
            Number of "high" results (threat level High)
          </summary>
          <pattern>
            <e>full</e>
            <e>filtered</e>
          </pattern>
          <ele>
            <name>full</name>
            <summary>Total number of results</summary>
            <pattern><t>integer</t></pattern>
          </ele>
          <ele>
            <name>filtered</name>
            <summary>Number of results after filtering</summary>
            <pattern><t>integer</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>info</name>
          <summary>
            Number of "info" results (threat level Low)
            ,will be deprecated. Use low instead
          </summary>
          <pattern>
            <e>full</e>
            <e>filtered</e>
          </pattern>
          <ele>
            <name>full</name>
            <summary>Total number of results</summary>
            <pattern><t>integer</t></pattern>
          </ele>
          <ele>
            <name>filtered</name>
            <summary>Number of results after filtering</summary>
            <pattern><t>integer</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>low</name>
          <summary>
            Number of "low" results (threat level Low)
          </summary>
          <pattern>
            <e>full</e>
            <e>filtered</e>
          </pattern>
          <ele>
            <name>full</name>
            <summary>Total number of results</summary>
            <pattern><t>integer</t></pattern>
          </ele>
          <ele>
            <name>filtered</name>
            <summary>Number of results after filtering</summary>
            <pattern><t>integer</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>log</name>
          <summary>
            Number of "log" results (threat level Log)
          </summary>
          <pattern>
            <e>full</e>
            <e>filtered</e>
          </pattern>
          <ele>
            <name>full</name>
            <summary>Total number of results</summary>
            <pattern><t>integer</t></pattern>
          </ele>
          <ele>
            <name>filtered</name>
            <summary>Number of results after filtering</summary>
            <pattern><t>integer</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>warning</name>
          <summary>
            Number of "warning" results (threat level Medium)
            ,will be deprecated. Use medium instead
          </summary>
          <pattern>
            <e>full</e>
            <e>filtered</e>
          </pattern>
          <ele>
            <name>full</name>
            <summary>Total number of results</summary>
            <pattern><t>integer</t></pattern>
          </ele>
          <ele>
            <name>filtered</name>
            <summary>Number of results after filtering</summary>
            <pattern><t>integer</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>medium</name>
          <summary>
            Number of "medium" results (threat level Medium)
          </summary>
          <pattern>
            <e>full</e>
            <e>filtered</e>
          </pattern>
          <ele>
            <name>full</name>
            <summary>Total number of results</summary>
            <pattern><t>integer</t></pattern>
          </ele>
          <ele>
            <name>filtered</name>
            <summary>Number of results after filtering</summary>
            <pattern><t>integer</t></pattern>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>severity</name>
        <pattern>
          <e>full</e>
          <e>filtered</e>
        </pattern>
        <ele>
          <name>full</name>
          <pattern><t>severity</t></pattern>
          <summary>Maximum severity of the full report</summary>
        </ele>
        <ele>
          <name>filtered</name>
          <pattern><t>severity</t></pattern>
          <summary>Maximum severity of the report after filtering</summary>
        </ele>
      </ele>
      <ele>
        <name>compliance</name>
        <pattern>
          <e>full</e>
          <e>filtered</e>
        </pattern>
        <ele>
          <name>full</name>
          <pattern><t>compliance_status</t></pattern>
          <summary>Compliance of the full report ("yes", "no", "incomplete" or "undefined")</summary>
        </ele>
        <ele>
          <name>filtered</name>
          <pattern><t>compliance_status</t></pattern>
          <summary>Compliance of the report after filtering ("yes", "no", "incomplete" or "undefined")</summary>
        </ele>
      </ele>
      <ele>
        <name>task</name>
        <pattern>
          <attrib>
            <name>id</name>
            <type>uuid</type>
            <required>1</required>
          </attrib>
          <e>name</e>
          <e>comment</e>
          <e>target</e>
          <e>progress</e>
          <o><e>user_tags</e></o>
        </pattern>
        <ele>
          <name>name</name>
          <summary>The name of the task</summary>
          <pattern><t>name</t></pattern>
        </ele>
        <ele>
          <name>comment</name>
          <summary>Comment for the task</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>target</name>
          <summary>The target of the task</summary>
          <pattern>
            <attrib>
              <name>id</name>
              <type>uuid</type>
              <summary>The UUID of the target</summary>
            </attrib>
            <e>trash</e>
            <e>name</e>
            <e>comment</e>
          </pattern>
          <ele>
            <name>trash</name>
            <summary>Whether the target is in the trashcan</summary>
            <type>boolean</type>
          </ele>
          <ele>
            <name>name</name>
            <summary>The name of the target</summary>
            <pattern><t>name</t></pattern>
          </ele>
          <ele>
            <name>comment</name>
            <summary>Comment for the target</summary>
            <pattern>text</pattern>
          </ele>
        </ele>
        <ele>
          <name>progress</name>
          <summary>The percentage of the task that is complete</summary>
          <pattern>
            <t>integer</t>
          </pattern>
        </ele>
        <ele>
          <name>user_tags</name>
          <summary>Info on tags attached to the task</summary>
          <pattern>
            <e>count</e>
            <any><e>tag</e></any>
          </pattern>
          <ele>
            <name>count</name>
            <summary>Number of attached tags</summary>
            <pattern><t>integer</t></pattern>
          </ele>
          <ele>
            <name>tag</name>
            <summary>
              Short info on an individual tag
            </summary>
            <pattern>
              <attrib>
                <name>id</name>
                <type>uuid</type>
                <summary>UUID of the tag</summary>
                <required>1</required>
              </attrib>
              <e>name</e>
              <e>value</e>
              <e>comment</e>
            </pattern>
            <ele>
              <name>name</name>
              <summary>Name of the tag (usually namespace:predicate)</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>value</name>
              <summary>Value of the tag</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>comment</name>
              <summary>Comment for the tag</summary>
              <pattern>text</pattern>
            </ele>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>ports</name>
        <pattern>
          <attrib>
            <name>start</name>
            <type>integer</type>
            <required>1</required>
          </attrib>
          <attrib>
            <name>max</name>
            <type>integer</type>
            <required>1</required>
          </attrib>
          <any><e>port</e></any>
        </pattern>
        <ele>
          <name>port</name>
          <pattern>
            text
            <e>host</e>
            <e>severity</e>
            <e>threat</e>
          </pattern>
          <ele>
            <name>host</name>
            <pattern>text</pattern>
          </ele>
          <ele>
            <name>severity</name>
            <pattern><t>severity</t></pattern>
          </ele>
          <ele>
            <name>threat</name>
            <pattern><t>threat</t></pattern>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>results</name>
        <pattern>
          <attrib>
            <name>start</name>
            <type>integer</type>
            <required>1</required>
          </attrib>
          <attrib>
            <name>max</name>
            <type>integer</type>
            <required>1</required>
          </attrib>
          <any><e>result</e></any>
        </pattern>
        <ele>
          <name>result</name>
          <summary>A result</summary>
          <type>result</type>
        </ele>
      </ele>
      <ele>
        <name>hosts</name>
        <description>
          <p>
            Analogous to the results element, but for hosts, in the "assets"
            report.  However to keep backward compatibility the host elements
            are siblings of this element, instead of children.
          </p>
          <p>
            Contains only the count outside the "assets" report.
          </p>
        </description>
        <pattern>
          <or>
            <g>
              <attrib>
                <name>start</name>
                <type>integer</type>
                <required>1</required>
              </attrib>
              <attrib>
                <name>max</name>
                <type>integer</type>
                <required>1</required>
              </attrib>
            </g>
            <e>count</e>
          </or>
        </pattern>
        <ele>
          <name>count</name>
          <summary>Number of hosts</summary>
        </ele>
      </ele>
      <ele>
        <name>cves</name>
        <summary></summary>
        <pattern>
          <e>count</e>
        </pattern>
        <ele>
          <name>count</name>
          <summary>The number of CVEs</summary>
        </ele>
      </ele>
      <ele>
        <name>vulns</name>
        <summary></summary>
        <pattern>
          <e>count</e>
        </pattern>
        <ele>
          <name>count</name>
          <summary>The number of Vulnerabilities</summary>
        </ele>
      </ele>
      <ele>
        <name>os</name>
        <summary></summary>
        <pattern>
          <e>count</e>
        </pattern>
        <ele>
          <name>count</name>
          <summary>The number of operating systems</summary>
        </ele>
      </ele>
      <ele>
        <name>apps</name>
        <summary></summary>
        <pattern>
          <e>count</e>
        </pattern>
        <ele>
          <name>count</name>
          <summary>The number of Applications</summary>
        </ele>
      </ele>
      <ele>
        <name>ssl_certs</name>
        <summary></summary>
        <pattern>
          <e>count</e>
        </pattern>
        <ele>
          <name>count</name>
          <summary>The number of SSL certificates</summary>
        </ele>
      </ele>
      <ele>
        <name>host</name>
        <pattern>
          <e>ip</e>
          <e>asset</e>
          <e>start</e>
          <e>end</e>
          <e>port_count</e>
          <o>
            <e>result_count</e>
          </o>
          <o><e>compliance_count</e></o>
          <o><e>host_compliance</e></o>
          <any><e>detail</e></any>
        </pattern>
        <ele>
          <name>ip</name>
          <summary>IP of the host</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>asset</name>
          <summary>Asset linked to host</summary>
          <pattern>
            <attrib>
              <name>asset_id</name>
              <type>uuid</type>
              <required>1</required>
            </attrib>
          </pattern>
        </ele>
        <ele>
          <name>start</name>
          <summary>Scan start time for this host</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>end</name>
          <summary>Scan end time for this host</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>port_count</name>
          <summary></summary>
          <pattern>
            <e>page</e>
          </pattern>
          <ele>
            <name>page</name>
            <summary>Number of ports of current host on current page</summary>
            <pattern><t>integer</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>result_count</name>
          <summary></summary>
          <pattern>
            <e>page</e>
            <e>critical</e>
            <e>hole</e>
            <e>high</e>
            <e>info</e>
            <e>low</e>
            <e>log</e>
            <e>warning</e>
            <e>medium</e>
            <e>false_positive</e>
          </pattern>
          <ele>
            <name>page</name>
            <summary>Total number of results for current host on current page</summary>
            <pattern><t>integer</t></pattern>
          </ele>
          <ele>
            <name>critical</name>
            <summary>
              Number of "critical" results (level "Critical")
            </summary>
            <pattern>
              <e>page</e>
            </pattern>
            <ele>
              <name>page</name>
              <summary>Number of results on current page</summary>
              <pattern><t>integer</t></pattern>
            </ele>
          </ele>
          <ele>
            <name>hole</name>
            <summary>
              Number of "hole" results (level "High")
              ,will be deprecated. Use high instead
            </summary>
            <pattern>
              <e>page</e>
            </pattern>
            <ele>
              <name>page</name>
              <summary>Number of results on current page</summary>
              <pattern><t>integer</t></pattern>
            </ele>
          </ele>
          <ele>
            <name>high</name>
            <summary>
              Number of "high" results (level "High")
            </summary>
            <pattern>
              <e>page</e>
            </pattern>
            <ele>
              <name>page</name>
              <summary>Number of results on current page</summary>
              <pattern><t>integer</t></pattern>
            </ele>
          </ele>
          <ele>
            <name>warning</name>
            <summary>
              Number of "warning" results (level "Medium")
              ,will be deprecated. Use medium instead
            </summary>
            <pattern>
              <e>page</e>
            </pattern>
            <ele>
              <name>page</name>
              <summary>Number of results on current page</summary>
              <pattern><t>integer</t></pattern>
            </ele>
          </ele>
          <ele>
            <name>medium</name>
            <summary>
              Number of "medium" results (level "Medium")
            </summary>
            <pattern>
              <e>page</e>
            </pattern>
            <ele>
              <name>page</name>
              <summary>Number of results on current page</summary>
              <pattern><t>integer</t></pattern>
            </ele>
          </ele>
          <ele>
            <name>info</name>
            <summary>
              Number of "info" results (level "Low")
              ,will be deprecated. Use low instead
            </summary>
            <pattern>
              <e>page</e>
            </pattern>
            <ele>
              <name>page</name>
              <summary>Number of results on current page</summary>
              <pattern><t>integer</t></pattern>
            </ele>
          </ele>
          <ele>
            <name>low</name>
            <summary>Number of "low" results (level "Low")</summary>
            <pattern>
              <e>page</e>
            </pattern>
            <ele>
              <name>page</name>
              <summary>Number of results on current page</summary>
              <pattern><t>integer</t></pattern>
            </ele>
          </ele>
          <ele>
            <name>log</name>
            <summary>Number of "log" results</summary>
            <pattern>
              <e>page</e>
            </pattern>
            <ele>
              <name>page</name>
              <summary>Number of results on current page</summary>
              <pattern><t>integer</t></pattern>
            </ele>
          </ele>
          <ele>
            <name>false_positive</name>
            <summary>Number of "false positive" results</summary>
            <pattern>
              <e>page</e>
            </pattern>
            <ele>
              <name>page</name>
              <summary>Number of results on current page</summary>
              <pattern><t>integer</t></pattern>
            </ele>
          </ele>
        </ele>
        <ele>
          <name>detail</name>
          <summary>A detail associated with the host</summary>
          <pattern>
            <e>name</e>
            <e>value</e>
            <e>source</e>
            <e>extra</e>
          </pattern>
          <ele>
            <name>name</name>
            <summary>The name of the detail</summary>
            <pattern>text</pattern>
          </ele>
          <ele>
            <name>value</name>
            <summary>The value of the detail</summary>
            <pattern>text</pattern>
          </ele>
          <ele>
            <name>source</name>
            <summary>Where the detail comes from</summary>
            <pattern>
              <e>type</e>
              <e>name</e>
              <e>description</e>
            </pattern>
            <ele>
              <name>type</name>
              <summary>The type of the detail source</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>name</name>
              <summary>The name of the detail source</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>description</name>
              <summary>A description of the detail source</summary>
              <pattern>text</pattern>
            </ele>
          </ele>
          <ele>
            <name>extra</name>
            <summary>Extra info (NVT CVSS for closed CVE results)</summary>
            <pattern>text</pattern>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>tls_certificates</name>
        <summary>List of TLS certificates found with the scan</summary>
        <pattern>
          <any><e>tls_certificate</e></any>
        </pattern>
        <ele>
          <name>tls_certificate</name>
          <summary>TLS certificate found with the scan</summary>
          <pattern>
            <e>name</e>
            <e>certificate</e>
            <e>sha256_fingerprint</e>
            <e>md5_fingerprint</e>
            <e>valid</e>
            <e>activation_time</e>
            <e>expiration_time</e>
            <e>subject_dn</e>
            <e>issuer_dn</e>
            <e>serial</e>
            <e>host</e>
            <e>ports</e>
          </pattern>
          <ele>
            <name>name</name>
            <summary>The name of the TLS certificate</summary>
            <pattern>text</pattern>
          </ele>
          <ele>
            <name>certificate</name>
            <summary>The Base64 encoded certificate data</summary>
            <pattern>
              <attrib>
                <name>format</name>
                <summary>The format of the certificate</summary>
                <type>
                  <alts>
                    <alt>DER</alt>
                    <alt>PEM</alt>
                    <alt>unknown</alt>
                  </alts>
                </type>
                <required>1</required>
              </attrib>
            </pattern>
          </ele>
          <ele>
            <name>sha256_fingerprint</name>
            <summary>The SHA256 fingerprint of the certificate</summary>
            <pattern>text</pattern>
          </ele>
          <ele>
            <name>md5_fingerprint</name>
            <summary>The MD5 fingerprint of the certificate</summary>
            <pattern>text</pattern>
          </ele>
          <ele>
            <name>valid</name>
            <summary>Whether the certificate is currently valid</summary>
            <pattern><t>boolean</t></pattern>
          </ele>
          <ele>
            <name>activation_time</name>
            <summary>Time before which the certificate is not valid</summary>
            <pattern><t>iso_time</t></pattern>
          </ele>
          <ele>
            <name>expiration_time</name>
            <summary>Time after which the certificate is not valid</summary>
            <pattern><t>iso_time</t></pattern>
          </ele>
          <ele>
            <name>subject_dn</name>
            <summary>Distinguished name (DN) of the certificate subject</summary>
            <pattern>text</pattern>
          </ele>
          <ele>
            <name>issuer_dn</name>
            <summary>Distinguished name (DN) of the certificate issuer</summary>
            <pattern>text</pattern>
          </ele>
          <ele>
            <name>serial</name>
            <summary>Hexadecimal serial number of the certificate</summary>
            <pattern>text</pattern>
          </ele>
          <ele>
            <name>host</name>
            <summary>Host where the certificate was found</summary>
            <pattern>
              <e>ip</e>
              <e>hostname</e>
            </pattern>
            <ele>
              <name>ip</name>
              <summary>IP address of the host</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>hostname</name>
              <summary>If available, the hostname from host details</summary>
              <pattern>text</pattern>
            </ele>
          </ele>
          <ele>
            <name>ports</name>
            <summary>List of ports where the certificate was found</summary>
            <pattern>
              <any><e>port</e></any>
            </pattern>
            <ele>
              <name>port</name>
              <summary>Port where the certificate was found</summary>
              <pattern><t>integer</t></pattern>
            </ele>           
          </ele>
        </ele>
      </ele>
      <ele>
        <name>timestamp</name>
        <summary>The time the scan was requested</summary>
        <pattern><t>iso_time</t></pattern>
      </ele>
      <ele>
        <name>scan_start</name>
        <summary>Start time of scan</summary>
        <pattern><t>iso_time</t></pattern>
      </ele>
      <ele>
        <name>scan_end</name>
        <summary>End time of scan</summary>
        <pattern><t>iso_time</t></pattern>
      </ele>
      <ele>
        <name>errors</name>
        <pattern>
          <e>count</e>
          <any><e>error</e></any>
        </pattern>
        <ele>
          <name>count</name>
          <summary>The number of error messages</summary>
        </ele>
        <ele>
          <name>error</name>
          <summary>An error message</summary>
          <pattern>
            <e>host</e>
            <e>port</e>
            <e>description</e>
            <e>nvt</e>
            <e>scan_nvt_version</e>
            <e>severity</e>
          </pattern>
          <ele>
            <name>host</name>
            <summary>The host of the error message</summary>
            <pattern>
              <e>asset</e>
              text
            </pattern>
            <ele>
              <name>asset</name>
              <summary>Asset linked to host</summary>
              <pattern>
                <attrib>
                  <name>asset_id</name>
                  <type>uuid</type>
                  <required>1</required>
                </attrib>
              </pattern>
            </ele>
          </ele>
          <ele>
            <name>port</name>
            <summary>The port (location) of the error message</summary>
            <pattern><t>port</t></pattern>
          </ele>
          <ele>
            <name>description</name>
            <summary>The description of the error message</summary>
            <pattern>text</pattern>
          </ele>
          <ele>
            <name>nvt</name>
            <summary>The NVT that generated the error message</summary>
            <pattern>
              <attrib>
                <name>oid</name>
                <required>1</required>
              </attrib>
              <e>name</e>
              <e>type</e>
              <e>cvss_base</e>
            </pattern>
            <ele>
              <name>name</name>
              <summary>The name of the NVT</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>type</name>
              <summary>The type of the NVT: nvt, cve, ...</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>cvss_base</name>
              <summary>The base CVSS score of the NVT</summary>
              <pattern><t>severity</t></pattern>
            </ele>
          </ele>
          <ele>
            <name>scan_nvt_version</name>
            <summary>The NVT version that generated the error</summary>
            <pattern>text</pattern>
          </ele>
          <ele>
            <name>severity</name>
            <summary>The severity score of the error message</summary>
            <pattern><t>severity</t></pattern>
          </ele>
        </ele>
      </ele>
    </ele>
  </element>
  <element>
    <name>severities</name>
    <summary>A collection of severity scoring info</summary>
    <pattern>
      <attrib>
        <name>score</name>
        <required>1</required>
        <summary>The maximum severity score</summary>
        <type>severity</type>
      </attrib>
      <any><e>severity</e></any>
    </pattern>
    <ele>
      <name>severity</name>
      <summary>Individual severity ratings and info</summary>
      <pattern>
        <attrib>
          <name>type</name>
          <type>text</type>
          <required>1</required>
          <summary>Type of severity rating, e.g. cvss_base_v2</summary>
        </attrib>
        <e>origin</e>
        <e>date</e>
        <e>score</e>
        <e>value</e>
      </pattern>
      <ele>
        <name>origin</name>
        <summary>Origin of severity rating</summary>
        <pattern>text</pattern>
      </ele>
      <ele>
        <name>date</name>
        <summary>Date the severity was defined</summary>
        <pattern><t>iso_time</t></pattern>
      </ele>
      <ele>
        <name>score</name>
        <summary>Numeric score ranging from 0.0 to 10.0</summary>
        <pattern><t>severity</t></pattern>
      </ele>
      <ele>
        <name>value</name>
        <summary>Detailed rating value, e.g. a CVSS vector</summary>
        <pattern>text</pattern>
      </ele>
    </ele>
  </element>

  <!-- Commands. -->

  <command>
    <name>authenticate</name>
    <summary>Authenticate with the manager</summary>
    <description>
      <p>
        The client uses the authenticate command to authenticate with the
        Manager.
      </p>
      <p>
        The client normally executes this command at the beginning of each
        connection.  The only command permitted before authentication is
        get_version.
      </p>
    </description>
    <pattern>
@IF_ENABLE_JWT_AUTH@
      <attrib>
        <name>token</name>
        <summary>Whether to request a token from the manager</summary>
        <type>boolean</type>
        <required>0</required>
      </attrib>
@ENDIF_ENABLE_JWT_AUTH@
      <e>credentials</e>
    </pattern>
    <ele>
      <name>credentials</name>
      <pattern>
@IF_ENABLE_JWT_AUTH@
        <or>
          <g>
            <e>username</e>
            <e>password</e>
          </g>
          <e>token</e>
        </or>
@ENDIF_ENABLE_JWT_AUTH@
@IF_NOT_ENABLE_JWT_AUTH@
        <e>username</e>
        <e>password</e>
@ENDIF_NOT_ENABLE_JWT_AUTH@
      </pattern>
      <ele>
        <name>username</name>
        <summary>The login name of the user</summary>
        <pattern>
          text
        </pattern>
      </ele>
      <ele>
        <name>password</name>
        <summary>The user's password</summary>
        <pattern>
          text
        </pattern>
      </ele>
@IF_ENABLE_JWT_AUTH@
      <ele>
        <name>token</name>
        <summary>
          An access token, usually from a previous authenticate response
        </summary>
        <pattern>
          text
        </pattern>
      </ele>
@ENDIF_ENABLE_JWT_AUTH@
    </ele>
    <response>
      <pattern>
        <attrib>
          <name>status</name>
          <type>status</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>status_text</name>
          <type>text</type>
          <required>1</required>
        </attrib>
        <e>role</e>
        <e>timezone</e>
@IF_ENABLE_JWT_AUTH@
        <o><e>token</e></o>
@ENDIF_ENABLE_JWT_AUTH@
      </pattern>
      <ele>
        <name>role</name>
        <summary>The user's role</summary>
        <type>
          <alts>
            <alt>User</alt>
            <alt>Admin</alt>
            <alt>Observer</alt>
          </alts>
        </type>
      </ele>
      <ele>
        <name>timezone</name>
        <summary>The user's timezone</summary>
        <pattern>
          timezone
        </pattern>
      </ele>
@IF_ENABLE_JWT_AUTH@
      <ele>
        <name>token</name>
        <summary>An authentication token if requested</summary>
        <pattern>text</pattern>
      </ele>
@ENDIF_ENABLE_JWT_AUTH@
    </response>
    <example>
      <summary>Authenticate with a good password</summary>
      <request>
        <authenticate>
          <credentials>
            <username>sally</username>
            <password>secret</password>
          </credentials>
        </authenticate>
      </request>
      <response>
        <authenticate_response status="200" status_text="OK">
          <role>User</role>
          <timezone>UTC</timezone>
        </authenticate_response>
      </response>
    </example>
    <example>
      <summary>Authenticate with a bad password</summary>
      <request>
        <authenticate>
          <credentials>
            <username>sally</username>
            <password>secrte</password>
          </credentials>
        </authenticate>
      </request>
      <response>
        <authenticate_response status="400"
                               status_text="Authentication failed"/>
      </response>
    </example>
  </command>
  <command>
    <name>create_config</name>
    <summary>Create a config</summary>
    <description>
      <p>
        The client uses the create_config command to create a new config.
      </p>
      <l>
        <lh>This command can be called in three ways:</lh>
        <li>
          With a copy element.  The new config is a copy of the existing
          config, with the given name.
        </li>
        <li>
          With an embedded get_configs response element.  The config is
          created as defined by the get_configs response element.  Name is
          actually optional in this case.  The config is given the name of
          the config in the get_configs response.  If there is already a
          config with this name, then a number is attached to the name to
          make it unique.
        </li>
        <li>
          With a scanner element referencing an OSP scanner.
          The config is then created by retrieving the expected preferences
          from the given scanner via OSP.
        </li>
      </l>
    </description>
    <pattern>
      <o><e>comment</e></o>
      <or>
        <e>copy</e>
        <r>get_configs</r>
      </or>
      <e>name</e>
      <o><e>usage_type</e></o>
    </pattern>
    <ele>
      <name>comment</name>
      <summary>A comment on the config</summary>
      <pattern>
        text
      </pattern>
    </ele>
    <ele>
      <name>copy</name>
      <summary>The UUID of an existing config</summary>
      <pattern>
        <t>uuid</t>
      </pattern>
    </ele>
    <ele>
      <name>name</name>
      <summary>A name for the config</summary>
      <pattern><t>name</t></pattern>
    </ele>
    <ele>
      <name>usage_type</name>
      <summary>Usage type for the config. Only scan configs are supported.</summary>
      <pattern>
        <alts>
          <alt>scan</alt>
        </alts>
      </pattern>
    </ele>
    <response>
      <pattern>
        <attrib>
          <name>status</name>
          <type>status</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>status_text</name>
          <type>text</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
      </pattern>
    </response>
    <example>
      <summary>Copy a config</summary>
      <request>
        <create_config>
          <copy>daba56c8-73ec-11df-a475-002264764cea</copy>
          <name>Full</name>
        </create_config>
      </request>
      <response>
        <create_config_response status="201" status_text="OK, resource created"
                                id="254cd3ef-bbe1-4d58-859d-21b8d0c046c6">
        </create_config_response>
      </response>
    </example>
    <example>
      <summary>Create a config from a GET_CONFIGS response</summary>
      <request>
        <create_config>
          <get_configs_response>
            <config id="daba56c8-73ec-11df-a475-002264764cea">
              <name>Full and fast</name>
              <truncated>...</truncated>
            </config>
          </get_configs_response>
        </create_config>
      </request>
      <response>
        <create_config_response status="201" status_text="OK, resource created"
                                id="254cd3ef-bbe1-4d58-859d-21b8d0c046c6">
        </create_config_response>
      </response>
    </example>
  </command>
  <command>
    <name>create_credential</name>
    <summary>Create a credential</summary>
    <description>
      <p>
        The client uses the create_credential command to create a new
        credential for local security checks and other functions
        requiring authentication.
      </p>
      <p>
        If the command includes a key, then the manager creates a key-based
        credential from the key.  If the command includes a password, then
        the manager creates a password only credential.  Otherwise the
        manager autogenerates a key-based credential.
      </p>
    </description>
    <pattern>
      <e>name</e>
      <o><e>comment</e></o>
      <o><e>allow_insecure</e></o>
      <o><e>certificate</e></o>
      <o><e>kdc</e></o>
      <o><e>kdcs</e></o>
      <o><e>key</e></o>
      <o><e>login</e></o>
      <o><e>password</e></o>
      <o><e>auth_algorithm</e></o>
      <o><e>community</e></o>
      <o><e>privacy</e></o>
      <o><e>realm</e></o>
      <o><e>type</e></o>
    </pattern>
    <ele>
      <name>name</name>
      <summary>A name for the credential</summary>
      <pattern><t>name</t></pattern>
    </ele>
    <ele>
      <name>comment</name>
      <summary>A comment on the credential</summary>
      <pattern>
        text
      </pattern>
    </ele>
    <ele>
      <name>allow_insecure</name>
      <summary>Whether to allow insecure use of the credential</summary>
      <pattern>
        <t>boolean</t>
      </pattern>
    </ele>
    <ele>
      <name>certificate</name>
      <summary>The certificate of the credential</summary>
      <pattern>
        text
      </pattern>
    </ele>
    <ele>
      <name>kdc</name>
      <pattern>text</pattern>
      <summary>Deprecated: This element is deprecated. Use kdcs instead. The Kerberos KDC (key distribution center(s))</summary>
    </ele>
    <ele>
      <name>kdcs</name>
      <summary>Multiple Kerberos KDCs</summary>
      <description>
        <p>List of one or more Kerberos Key Distribution Centers (KDCs).</p>
      </description>
      <pattern>
        <any><e>kdc</e></any>
      </pattern>
      <ele>
        <name>kdc</name>
        <summary>A single Kerberos Key Distribution Center</summary>
        <pattern>text</pattern>
      </ele>
    </ele>
    <ele>
      <name>key</name>
      <pattern>
        <o><e>phrase</e></o>
        <or>
          <e>private</e>
          <e>public</e>
        </or>
      </pattern>
      <ele>
        <name>phrase</name>
        <summary>Key passphrase</summary>
        <pattern>
          text
        </pattern>
      </ele>
      <ele>
        <name>private</name>
        <summary>Private key</summary>
        <pattern>
          text
        </pattern>
      </ele>
      <ele>
        <name>public</name>
        <summary>Public key</summary>
        <pattern>
          text
        </pattern>
      </ele>
    </ele>
    <ele>
      <name>login</name>
      <summary>The user name of the credential</summary>
      <pattern>
        text
      </pattern>
    </ele>
    <ele>
      <name>password</name>
      <summary>The password for the credential login</summary>
      <pattern>
        text
      </pattern>
    </ele>
    <ele>
      <name>community</name>
      <summary>The SNMP community</summary>
      <pattern>
        text
      </pattern>
    </ele>
    <ele>
      <name>auth_algorithm</name>
      <summary>Authentication algorithm for SNMP, either md5 or sha1</summary>
      <pattern>
        <alts>
          <alt>md5</alt>
          <alt>sha1</alt>
        </alts>
      </pattern>
    </ele>
    <ele>
      <name>privacy</name>
      <pattern>
        <e>algorithm</e>
        <e>password</e>
      </pattern>
      <ele>
        <name>algorithm</name>
        <summary>The SNMP privacy algorithm, either aes or des</summary>
        <pattern>
          <alts>
            <alt>aes</alt>
            <alt>des</alt>
          </alts>
        </pattern>
      </ele>
      <ele>
        <name>password</name>
        <summary>The SNMP privacy password</summary>
        <pattern>
          text
        </pattern>
      </ele>
    </ele>
    <ele>
      <name>realm</name>
      <pattern>text</pattern>
      <summary>The Kerberos realm</summary>
    </ele>
    <ele>
      <name>type</name>
      <summary>The type of credential to create</summary>
      <description>
        <p>cc: Client certificate</p>
        <p>krb5: Kerberos 5</p>
        <p>pgp: PGP encryption key</p>
        <p>pw: Password only</p>
        <p>smime: S/MIME certificate</p>
        <p>snmp: SNMP</p>
        <p>up: User name + password</p>
        <p>usk: User name + SSH key</p>
      </description>
      <pattern>
        <alts>
          <alt>cc</alt>
          <alt>krb5</alt>
          <alt>pgp</alt>
          <alt>pw</alt>
          <alt>smime</alt>
          <alt>snmp</alt>
          <alt>up</alt>
          <alt>usk</alt>
        </alts>
      </pattern>
    </ele>
    <response>
      <pattern>
        <attrib>
          <name>status</name>
          <type>status</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>status_text</name>
          <type>text</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
      </pattern>
    </response>
    <example>
      <summary>Create an LSC credential</summary>
      <request>
        <create_credential>
          <name>cluster sally</name>
          <login>sally</login>
          <password>secret</password>
          <comment>Sally's login to the cluster.</comment>
        </create_credential>
      </request>
      <response>
        <create_credential_response status="201"
                                    status_text="OK, resource created"
                                    id="254cd3ef-bbe1-4d58-859d-21b8d0c046c6">
        </create_credential_response>
      </response>
    </example>
    <example>
      <summary>Create a PGP public key credential</summary>
      <request>
        <create_credential>
          <name>Email public key</name>
          <type>pgp</type>
          <key>
            <public>-----BEGIN PGP PUBLIC KEY BLOCK-----
              [...]
            </public>
          </key>
        </create_credential>
      </request>
      <response>
        <create_credential_response status="201"
                                    status_text="OK, resource created"
                                    id="e81be3f4-a9a6-45a0-853f-980383a5d9eb">
        </create_credential_response>
      </response>
    </example>
    <example>
      <summary>Create an S/MIME credential</summary>
      <request>
        <create_credential>
          <name>Email certificate</name>
          <type>smime</type>
          <certificate>-----BEGIN PKCS7-----
            [...]
          </certificate>
        </create_credential>
      </request>
      <response>
        <create_credential_response status="201"
                                    status_text="OK, resource created"
                                    id="4aa5bf8a-502d-4023-96b0-352fe202a097">
        </create_credential_response>
      </response>
    </example>
    <example>
      <summary>Create a Kerberos credential with multiple KDCs</summary>
      <request>
        <create_credential>
          <name>Kerberos Cluster Auth</name>
          <type>krb5</type>
          <login>admin</login>
          <password>secret123</password>
          <realm>EXAMPLE.COM</realm>
          <kdc>kdc1.example.com,kdc2.example.com,192.168.1.10</kdc>
          <kdcs>
            <kdc>kdc1.example.com</kdc>
            <kdc>kdc2.example.com</kdc>
            <kdc>192.168.1.10</kdc>
          </kdcs>
        </create_credential>
      </request>
      <response>
        <create_credential_response status="201"
                                    status_text="OK, resource created"
                                    id="b2a4a8c3-9f44-4e7f-bd64-7c69b0ec100e">
        </create_credential_response>
      </response>
    </example>
  </command>
  <command>
    <name>create_target</name>
    <summary>Create a target</summary>
    <description>
      <p>
        The client uses the create_target command to create a new target.
      </p>
      <p>
        If the list of hosts is empty, the command must also include a
        target locator.
      </p>
      <p>
        If the SSH elevate credential is set, the SSH credential must
        also be set. The SSH elevate credential and the SSH credential
        must differ.
      </p>
    </description>
    <pattern>
      <e>name</e>
      <o><e>comment</e></o>
      <o><e>copy</e></o>
      <or>
        <e>asset_hosts</e>
        <e>hosts</e>
      </or>
      <o><e>exclude_hosts</e></o>
      <o><e>ssh_credential</e></o>
      <o><e>ssh_elevate_credential</e></o>
      <o>
        <or>
          <e>krb5_credential</e>
          <e>smb_credential</e>
        </or>
      </o>
      <o><e>esxi_credential</e></o>
      <o><e>snmp_credential</e></o>
      <o><e>ssh_lsc_credential</e></o>
      <o><e>smb_lsc_credential</e></o>
      <o><e>esxi_lsc_credential</e></o>
      <o><e>alive_tests</e></o>
      <o><e>allow_simultaneous_ips</e></o>
      <o><e>reverse_lookup_only</e></o>
      <o><e>reverse_lookup_unify</e></o>
      <or>
        <e>port_range</e>
        <e>port_list</e>
      </or>
    </pattern>
    <ele>
      <name>name</name>
      <summary>A name for the target</summary>
      <pattern>
        <t>name</t>
      </pattern>
    </ele>
    <ele>
      <name>comment</name>
      <summary>A comment on the target</summary>
      <pattern>
        text
      </pattern>
    </ele>
    <ele>
      <name>copy</name>
      <summary>The UUID of an existing target</summary>
      <pattern>
        <t>uuid</t>
      </pattern>
    </ele>
    <ele>
      <name>asset_hosts</name>
      <summary>Hosts from which to create the target</summary>
      <pattern>
        <attrib>
          <name>filter</name>
          <type>text</type>
          <summary>Filter term that defines the list of hosts</summary>
          <required>1</required>
        </attrib>
      </pattern>
    </ele>
    <ele>
      <name>hosts</name>
      <summary>A comma-separated list of hosts, which may be empty</summary>
      <pattern>
        text
      </pattern>
    </ele>
    <ele>
      <name>exclude_hosts</name>
      <summary>A list of hosts to exclude</summary>
      <pattern>
        text
      </pattern>
    </ele>
    <ele>
      <name>ssh_credential</name>
      <summary>SSH login credentials for target</summary>
      <pattern>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
        <o><e>port</e></o>
      </pattern>
      <ele>
        <name>port</name>
        <summary>The port the LSCs will use</summary>
        <pattern>text</pattern>
      </ele>
    </ele>
    <ele>
      <name>ssh_elevate_credential</name>
      <summary>SSH elevate credentials for target</summary>
      <pattern>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
      </pattern>
    </ele>
    <ele>
      <name>krb5_credential</name>
      <summary>Kerberos 5 login credentials for target</summary>
      <pattern>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
      </pattern>
    </ele>
    <ele>
      <name>smb_credential</name>
      <summary>SMB login credentials for target</summary>
      <pattern>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
      </pattern>
    </ele>
    <ele>
      <name>esxi_credential</name>
      <summary>ESXi credential to use on target</summary>
      <pattern>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
      </pattern>
    </ele>
    <ele>
      <name>snmp_credential</name>
      <summary>SNMP credentials to use on target</summary>
      <pattern>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
      </pattern>
    </ele>
    <ele>
      <name>ssh_lsc_credential</name>
      <summary>Deprecated: use ssh_credential. SSH credential</summary>
      <pattern>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
        <o><e>port</e></o>
      </pattern>
      <ele>
        <name>port</name>
        <summary>The port the LSCs will use</summary>
        <pattern>text</pattern>
      </ele>
    </ele>
    <ele>
      <name>smb_lsc_credential</name>
      <summary>Deprecated: use ssh_credential. SMB credential</summary>
      <pattern>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
      </pattern>
    </ele>
    <ele>
      <name>esxi_lsc_credential</name>
      <summary>Deprecated: use esxi_credential. ESXi credential</summary>
      <pattern>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
      </pattern>
    </ele>
    <ele>
      <name>alive_tests</name>
      <summary>Which alive tests to use</summary>
      <pattern>
        <any><e>alive_test</e></any>
      </pattern>
      <description>
        Instead of the sub-elements a string representation of the
        old predefined alive test selections can be used, but this is
        deprecated.
      </description>
      <ele>
        <name>alive_test</name>
        <summary>
          A single alive test to use.
          "Scan Config Default" and "Consider Alive" can only be used alone
        </summary>
        <pattern>
          <t>alive_test</t>
        </pattern>
      </ele>
    </ele>
    <ele>
      <name>allow_simultaneous_ips</name>
      <summary>
        Whether to scan multiple IPs of the same host simultaneously
      </summary>
      <pattern><t>boolean</t></pattern>
    </ele>
    <ele>
      <name>reverse_lookup_only</name>
      <summary>Whether to scan only hosts that have names</summary>
      <pattern><t>boolean</t></pattern>
    </ele>
    <ele>
      <name>reverse_lookup_unify</name>
      <summary>
        Whether to scan only one IP when multiple IPs have the same name
      </summary>
      <pattern><t>boolean</t></pattern>
    </ele>
    <ele>
      <name>port_range</name>
      <summary>
        Comma separated list of port ranges for the target
        (allowing whitespace)
      </summary>
      <pattern>
        <t>port_range</t>
      </pattern>
    </ele>
    <ele>
      <name>port_list</name>
      <summary>Port list for the target</summary>
      <description>Overrides port_range.</description>
      <pattern>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
      </pattern>
    </ele>
    <response>
      <pattern>
        <attrib>
          <name>status</name>
          <type>status</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>status_text</name>
          <type>text</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
      </pattern>
    </response>
    <example>
      <summary>Create a target, giving a host list</summary>
      <request>
        <create_target>
          <name>All GNU/Linux machines</name>
          <hosts>192.168.1.0/24</hosts>
          <port_list id="33d0cd82-57c6-11e1-8ed1-406186ea4fc5"/>
        </create_target>
      </request>
      <response>
        <create_target_response status="201"
                                status_text="OK, resource created"
                                id="254cd3ef-bbe1-4d58-859d-21b8d0c046c6">
        </create_target_response>
      </response>
    </example>
  </command>
  <command>
    <name>create_task</name>
    <summary>Create a task</summary>
    <description>
      <p>
        The client uses the create_task command to create a new task.
      </p>
    </description>
    <pattern>
      <e>name</e>
      <o><e>comment</e></o>
      <o><e>copy</e></o>
      <o><e>usage_type</e></o>
      <e>config</e>
<e>target</e>
      <e>scanner</e>
      <any><e>alert</e></any>
      <o><e>schedule</e></o>
      <o><e>schedule_periods</e></o>
      <o><e>preferences</e></o>
    </pattern>
    <ele>
      <name>name</name>
      <summary>A name for the task</summary>
      <pattern><t>name</t></pattern>
    </ele>
    <ele>
      <name>comment</name>
      <summary>A comment on the task</summary>
      <pattern>
        text
      </pattern>
    </ele>
    <ele>
      <name>copy</name>
      <summary>The UUID of an existing task</summary>
      <pattern>
        <t>uuid</t>
      </pattern>
    </ele>
    <ele>
      <name>usage_type</name>
      <summary>Usage type for the task. Only scan tasks are supported.</summary>
      <pattern>
        <alts>
          <alt>scan</alt>
        </alts>
      </pattern>
    </ele>
    <ele>
      <name>config</name>
      <summary>The scan configuration used by the task</summary>
      <pattern>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
      </pattern>
    </ele>
    <ele>
      <name>target</name>
      <summary>The hosts scanned by the task</summary>
      <pattern>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
      </pattern>
    </ele>
<ele>
      <name>scanner</name>
      <summary>The scanner to use for scanning the target</summary>
      <pattern>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
      </pattern>
    </ele>
    <ele>
      <name>alert</name>
      <summary>An alert that applies to the task</summary>
      <pattern>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
      </pattern>
    </ele>
    <ele>
      <name>schedule</name>
      <summary>When the task will run</summary>
      <pattern>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
      </pattern>
    </ele>
    <ele>
      <name>schedule_periods</name>
      <summary>
        A limit to the number of times the task will be scheduled, or 0 for no limit
      </summary>
      <pattern>
        <t>integer</t>
      </pattern>
    </ele>
    <ele>
      <name>preferences</name>
      <pattern>
        <any><e>preference</e></any>
      </pattern>
      <ele>
        <name>preference</name>
        <pattern>
          <e>scanner_name</e>
          <e>value</e>
        </pattern>
        <ele>
          <name>scanner_name</name>
          <summary>Compact name of preference, from scanner</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>value</name>
          <pattern>text</pattern>
        </ele>
      </ele>
    </ele>
    <response>
      <pattern>
        <attrib>
          <name>status</name>
          <type>status</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>status_text</name>
          <type>text</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>id</name>
          <type>uuid</type>
          <required>1</required>
        </attrib>
      </pattern>
    </response>
    <example>
      <summary>Create a task, giving a host list</summary>
      <request>
        <create_task>
          <name>Scan Webserver</name>
          <comment>Hourly scan of the webserver</comment>
          <config id="daba56c8-73ec-11df-a475-002264764cea"/>
          <target id="b493b7a8-7489-11df-a3ec-002264764cea"/>
          <scanner id="15348381-3180-213f-4eec-123591912388"/>
        </create_task>
      </request>
      <response>
        <create_task_response status="201"
                              status_text="OK, resource created"
                              id="254cd3ef-bbe1-4d58-859d-21b8d0c046c6">
        </create_task_response>
      </response>
    </example>
    <example>
      <summary>Create an import task, for importing reports</summary>
      <request>
        <create_task>
          <name>Import Example</name>
          <comment>This task provides for importing reports</comment>
          <target id="0"/>
        </create_task>
      </request>
      <response>
        <create_task_response status="201"
                              status_text="OK, resource created"
                              id="b7f0afbe-bdb3-11e9-9847-28d24461215b">
        </create_task_response>
      </response>
    </example>
</command>
  <command>
    <name>delete_config</name>
    <summary>Delete a config</summary>
    <description>
      <p>
        The client uses the delete_config command to delete an existing config.
      </p>
      <p>
        Since this is a destructive command, the client is advised to ask
        for confirmation from the user before sending this command to the
        Manager.
      </p>
    </description>
    <pattern>
      <attrib>
        <name>config_id</name>
        <type>uuid</type>
        <required>1</required>
      </attrib>
      <attrib>
        <name>ultimate</name>
        <summary>Whether to remove entirely, or to the trashcan</summary>
        <type>boolean</type>
        <required>1</required>
      </attrib>
    </pattern>
    <response>
      <pattern>
        <attrib>
          <name>status</name>
          <type>status</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>status_text</name>
          <type>text</type>
          <required>1</required>
        </attrib>
      </pattern>
    </response>
    <example>
      <summary>Delete a config</summary>
      <request>
        <delete_config config_id="267a3405-e84a-47da-97b2-5fa0d2e8995e">
        </delete_config>
      </request>
      <response>
        <delete_config_response status="200" status_text="OK"/>
      </response>
    </example>
  </command>
  <command>
    <name>delete_report</name>
    <summary>Delete a report</summary>
    <description>
      <p>
        The client uses the delete_report command to delete an existing report.
      </p>
      <p>
        Since this is a destructive command, the client is advised to ask
        for confirmation from the user before sending this command to the
        Manager.
      </p>
    </description>
    <pattern>
      <attrib>
        <name>report_id</name>
        <type>uuid</type>
        <required>1</required>
      </attrib>
    </pattern>
    <response>
      <pattern>
        <attrib>
          <name>status</name>
          <type>status</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>status_text</name>
          <type>text</type>
          <required>1</required>
        </attrib>
      </pattern>
    </response>
    <example>
      <summary>Delete a report</summary>
      <request>
        <delete_report report_id="267a3405-e84a-47da-97b2-5fa0d2e8995e">
        </delete_report>
      </request>
      <response>
        <delete_report_response status="200" status_text="OK"/>
      </response>
    </example>
  </command>
  <command>
    <name>delete_target</name>
    <summary>Delete a target</summary>
    <description>
      <p>
        The client uses the delete_target command to delete an existing target.
      </p>
      <p>
        Since this is a destructive command, the client is advised to ask
        for confirmation from the user before sending this command to the
        Manager.
      </p>
    </description>
    <pattern>
      <attrib>
        <name>target_id</name>
        <type>uuid</type>
        <required>1</required>
      </attrib>
      <attrib>
        <name>ultimate</name>
        <summary>Whether to remove entirely, or to the trashcan</summary>
        <type>boolean</type>
        <required>1</required>
      </attrib>
    </pattern>
    <response>
      <pattern>
        <attrib>
          <name>status</name>
          <type>status</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>status_text</name>
          <type>text</type>
          <required>1</required>
        </attrib>
      </pattern>
    </response>
    <example>
      <summary>Delete a target</summary>
      <request>
        <delete_target target_id="267a3405-e84a-47da-97b2-5fa0d2e8995e">
        </delete_target>
      </request>
      <response>
        <delete_target_response status="200" status_text="OK"/>
      </response>
    </example>
  </command>
  <command>
    <name>delete_task</name>
    <summary>Delete a task</summary>
    <description>
      <p>
        The client uses the delete_task command to delete an existing task,
        including all reports associated with the task.
      </p>
      <p>
        Since this is a destructive command, the client is advised to ask
        for confirmation from the user before sending this command to the
        Manager.
      </p>
    </description>
    <pattern>
      <attrib>
        <name>task_id</name>
        <type>uuid</type>
        <required>1</required>
      </attrib>
      <attrib>
        <name>ultimate</name>
        <summary>Whether to remove entirely, or to the trashcan</summary>
        <type>boolean</type>
        <required>1</required>
      </attrib>
    </pattern>
    <response>
      <pattern>
        <attrib>
          <name>status</name>
          <type>status</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>status_text</name>
          <type>text</type>
          <required>1</required>
        </attrib>
      </pattern>
    </response>
    <example>
      <summary>Delete a task</summary>
      <request>
        <delete_task task_id="267a3405-e84a-47da-97b2-5fa0d2e8995e">
        </delete_task>
      </request>
      <response>
        <delete_task_response status="200" status_text="OK"/>
      </response>
    </example>
  </command>
  <command>
    <name>get_aggregates</name>
    <summary>Get aggregates of various resources</summary>
    <description>
      <p>
        The client uses the get_aggregate command to get aggregated data like
        counts or averages of various resources.
      </p>
      <p>
        Unlike other get_... commands, get_aggregates ignores the filter
        keywords "first" and "rows". It also does not support selecting single
        items by id or getting items from the trashcan.
      </p>
    </description>
    <pattern>
      <attrib>
        <name>filter</name>
        <summary>Filter term to use to filter query of the resources to aggregate (see get_... commands of selected type for keywords)</summary>
        <type>text</type>
      </attrib>
      <attrib>
        <name>filt_id</name>
        <summary>ID of filter to use to filter query of the resources to aggregate</summary>
        <type>uuid</type>
      </attrib>
      <attrib>
        <name>type</name>
        <summary>The GMP resource type to gather data from</summary>
        <type>text</type>
        <required>1</required>
      </attrib>
      <attrib>
        <name>data_column</name>
        <summary>A single column to get the data to aggregate from</summary>
        <type>text</type>
      </attrib>
      <attrib>
        <name>group_column</name>
        <summary>The field to group the resources by</summary>
        <type>text</type>
      </attrib>
      <attrib>
        <name>subgroup_column</name>
        <summary>The field to further group the resources inside groups by</summary>
        <type>text</type>
      </attrib>
      <attrib>
        <name>sort_field</name>
        <summary>The column to sort the aggregated rows by</summary>
        <description>
          With a subgroup column, groups will be sorted by the group_column first.
        </description>
        <type>text</type>
      </attrib>
      <attrib>
        <name>sort_order</name>
        <summary>The order to sort by</summary>
        <type>
          <alts>
            <alt>ascending</alt>
            <alt>descending</alt>
          </alts>
        </type>
      </attrib>
      <attrib>
        <name>sort_stat</name>
        <summary>The statistic to sort the aggregated rows by</summary>
        <type>
          <alts>
            <alt>min</alt>
            <alt>max</alt>
            <alt>mean</alt>
            <alt>sum</alt>
            <alt>count</alt>
            <alt>value</alt>
          </alts>
        </type>
      </attrib>
      <attrib>
        <name>first_group</name>
        <summary>The index of the first aggregate group to return</summary>
        <type>integer</type>
      </attrib>
      <attrib>
        <name>max_groups</name>
        <summary>The maximum number of aggregate groups to return, -1 for all</summary>
        <type>integer</type>
      </attrib>
      <attrib>
        <name>mode</name>
        <summary>Special mode for aggregation</summary>
        <type>
          <alts>
            <alt></alt>
            <alt>word_counts</alt>
          </alts>
        </type>
      </attrib>
      <attrib>
        <name>usage_type</name>
        <summary>Optional usage type to limit configs and tasks to</summary>
        <type>
          <alts>
            <alt>scan</alt>
            <alt></alt>
          </alts>
        </type>
      </attrib>
      <any><e>sort</e></any>
      <any><e>data_column</e></any>
      <any><e>text_column</e></any>
    </pattern>
    <ele>
      <name>sort</name>
      <summary>Optional tuples of sort criteria</summary>
      <pattern>
        <attrib>
          <name>field</name>
          <summary>The column to sort the aggregated rows by</summary>
          <description>
            With a subgroup column, groups will be sorted by the group_column first.
          </description>
          <type>text</type>
        </attrib>
        <attrib>
          <name>order</name>
          <summary>The order to sort by</summary>
          <type>
            <alts>
              <alt>ascending</alt>
              <alt>descending</alt>
            </alts>
          </type>
        </attrib>
        <attrib>
          <name>stat</name>
          <summary>The statistic to sort the aggregated rows by</summary>
          <type>
            <alts>
              <alt>min</alt>
              <alt>max</alt>
              <alt>mean</alt>
              <alt>sum</alt>
              <alt>count</alt>
              <alt>value</alt>
            </alts>
          </type>
        </attrib>
      </pattern>
    </ele>
    <ele>
      <name>data_column</name>
      <summary>A column to get the data to aggregate from</summary>
      <type>text</type>
    </ele>
    <ele>
      <name>text_column</name>
      <summary>A simple text column which no statistics are calculated for</summary>
      <type>text</type>
    </ele>
    <response>
      <pattern>
        <attrib>
          <name>status</name>
          <type>status</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>status_text</name>
          <type>text</type>
          <required>1</required>
        </attrib>
        <any><e>aggregate</e></any>
        <e>filters</e>
      </pattern>
      <ele>
        <name>aggregate</name>
        <summary>A collection of aggregated data of the selected type</summary>
        <pattern>
          <e>data_type</e>
          <any><e>data_column</e></any>
          <o><e>group_column</e></o>
          <o><e>subgroup_column</e></o>
          <any><e>text_column</e></any>
          <or>
            <any><e>group</e></any>
            <e>overall</e>
          </or>
          <o><e>subgroups</e></o>
          <e>column_info</e>
        </pattern>
        <ele>
          <name>data_type</name>
          <summary>The resource type the data is aggregated from</summary>
          <pattern><t>text</t></pattern>
        </ele>
        <ele>
          <name>data_column</name>
          <summary>A column the data is aggregated from</summary>
          <pattern><t>text</t></pattern>
        </ele>
        <ele>
          <name>group_column</name>
          <summary>The column the data is grouped by</summary>
          <pattern><t>text</t></pattern>
        </ele>
        <ele>
          <name>subgroup_column</name>
          <summary>The column to further group the resources by</summary>
          <pattern><t>text</t></pattern>
        </ele>
        <ele>
          <name>text_column</name>
          <summary>A simple text column</summary>
          <pattern><t>text</t></pattern>
        </ele>
        <ele>
          <name>group</name>
          <summary>Aggregate data for a group of resources</summary>
          <pattern>
            <e>value</e>
            <any><e>subgroup</e></any>
            <e>count</e>
            <e>c_count</e>
            <any><e>stats</e></any>
            <any><e>text</e></any>
          </pattern>
          <ele>
            <name>value</name>
            <summary>Value of the group column</summary>
            <pattern><t>text</t></pattern>
          </ele>
          <ele>
            <name>subgroup</name>
            <summary>Aggregate data for a subgroup of resources</summary>
            <pattern>
              <e>value</e>
              <e>count</e>
              <e>c_count</e>
              <any><e>stats</e></any>
            </pattern>
            <ele>
              <name>value</name>
              <summary>Value of the subgroup column</summary>
              <pattern><t>text</t></pattern>
            </ele>
            <ele>
              <name>count</name>
              <summary>Number of resources in the subgroup</summary>
              <pattern><t>integer</t></pattern>
            </ele>
            <ele>
              <name>c_count</name>
              <summary>Cumulative number of resources in the current subgroup</summary>
              <pattern><t>integer</t></pattern>
            </ele>
            <ele>
              <name>stats</name>
              <summary>Statistics of a data column for the current subgroup</summary>
              <pattern>
                <attrib>
                  <name>column</name>
                  <summary>Name of the column the stats apply to</summary>
                  <type>text</type>
                </attrib>
                <e>min</e>
                <e>max</e>
                <e>mean</e>
                <e>sum</e>
                <e>c_sum</e>
              </pattern>
              <ele>
                <name>min</name>
                <summary>Minimum value of the data column</summary>
                <pattern><t>text</t></pattern>
              </ele>
              <ele>
                <name>max</name>
                <summary>Maximum value of the data column</summary>
                <pattern><t>text</t></pattern>
              </ele>
              <ele>
                <name>mean</name>
                <summary>Arithmetic mean of the numeric values of the data</summary>
                <pattern><t>text</t></pattern>
              </ele>
              <ele>
                <name>sum</name>
                <summary>Sum of the numeric values of the data column</summary>
                <pattern><t>text</t></pattern>
              </ele>
              <ele>
                <name>c_sum</name>
                <summary>Cumulative sum of the data column</summary>
                <pattern><t>text</t></pattern>
              </ele>
            </ele>
          </ele>
          <ele>
            <name>count</name>
            <summary>Number of resources in the group</summary>
            <pattern><t>integer</t></pattern>
          </ele>
          <ele>
            <name>c_count</name>
            <summary>Cumulative number of resources in all groups up to and including the current one</summary>
            <pattern><t>integer</t></pattern>
          </ele>
          <ele>
            <name>text</name>
            <summary>The value of a simple text column</summary>
            <pattern>
              <attrib>
                <name>name</name>
                <summary>Name of the text column</summary>
                <type>text</type>
              </attrib>
              text
            </pattern>
          </ele>
          <ele>
            <name>stats</name>
            <summary>Statistics of a data column</summary>
            <pattern>
              <attrib>
                <name>column</name>
                <summary>Name of the column the stats apply to</summary>
                <type>text</type>
              </attrib>
              <e>min</e>
              <e>max</e>
              <e>mean</e>
              <e>sum</e>
              <e>c_sum</e>
            </pattern>
            <ele>
              <name>min</name>
              <summary>Minimum value of the data column</summary>
              <pattern><t>text</t></pattern>
            </ele>
            <ele>
              <name>max</name>
              <summary>Maximum value of the data column</summary>
              <pattern><t>text</t></pattern>
            </ele>
            <ele>
              <name>mean</name>
              <summary>Arithmetic mean of the numeric values of the data</summary>
              <pattern><t>text</t></pattern>
            </ele>
            <ele>
              <name>sum</name>
              <summary>Sum of the numeric values of the data column</summary>
              <pattern><t>text</t></pattern>
            </ele>
            <ele>
              <name>c_sum</name>
              <summary>Cumulative sum of the numeric values of the data column for all groups up to and including the current one</summary>
              <pattern><t>text</t></pattern>
            </ele>
          </ele>
        </ele>
        <ele>
          <name>overall</name>
          <summary>Aggregate data for all resources of the selected type</summary>
          <pattern>
            <e>count</e>
            <e>c_count</e>
            <any><e>stats</e></any>
            <any><e>text</e></any>
          </pattern>
          <ele>
            <name>count</name>
            <summary>Overall number of resources</summary>
            <pattern><t>integer</t></pattern>
          </ele>
          <ele>
            <name>c_count</name>
            <summary>Cumulative number of resources</summary>
            <description>For overall this is always the same as count.</description>
            <pattern><t>integer</t></pattern>
          </ele>
          <ele>
            <name>stats</name>
            <summary>Statistics of a data column</summary>
            <pattern>
              <attrib>
                <name>column</name>
                <summary>Name of the column the stats apply to</summary>
                <type>text</type>
              </attrib>
              <e>min</e>
              <e>max</e>
              <e>mean</e>
              <e>sum</e>
              <e>c_sum</e>
            </pattern>
            <ele>
              <name>min</name>
              <summary>Overall minimum value of the data column</summary>
              <pattern><t>text</t></pattern>
            </ele>
            <ele>
              <name>max</name>
              <summary>Overall maximum value of the data column</summary>
              <pattern><t>text</t></pattern>
            </ele>
            <ele>
              <name>mean</name>
              <summary>Overall arithmetic mean of the numeric values of the data</summary>
              <pattern><t>text</t></pattern>
            </ele>
            <ele>
              <name>sum</name>
              <summary>Overall sum of the numeric values of the data column</summary>
              <pattern><t>text</t></pattern>
            </ele>
            <ele>
              <name>c_sum</name>
              <summary>Cumulative sum of the numeric values of the data column</summary>
              <description>For overall this is always the same as sum.</description>
              <pattern><t>text</t></pattern>
            </ele>
          </ele>
          <ele>
            <name>text</name>
            <summary>The value of a simple text column</summary>
            <pattern>
              <attrib>
                <name>name</name>
                <summary>Name of the text column</summary>
                <type>text</type>
              </attrib>
              text
            </pattern>
          </ele>
        </ele>
        <ele>
          <name>subgroups</name>
          <summary>Overview of all subgroup values</summary>
          <pattern>
            <any><e>value</e></any>
          </pattern>
          <ele>
            <name>value</name>
            <summary>Value of the subgroup column</summary>
            <pattern><t>text</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>column_info</name>
          <summary>Info on the aggregate columns</summary>
          <pattern>
            <any><e>aggregate_column</e></any>
          </pattern>
          <ele>
            <name>aggregate_column</name>
            <summary>Info on one column of the aggregate</summary>
            <pattern>
              <e>name</e>
              <e>stat</e>
              <e>type</e>
              <e>column</e>
              <e>data_type</e>
            </pattern>
            <ele>
              <name>name</name>
              <summary>Name of the column as it appears in the group or overall element</summary>
              <pattern><t>text</t></pattern>
            </ele>
            <ele>
              <name>stat</name>
              <summary>The type of statistic in the column, e.g. min, max, mean</summary>
              <pattern><t>text</t></pattern>
            </ele>
            <ele>
              <name>type</name>
              <summary>The resource type</summary>
              <pattern><t>text</t></pattern>
            </ele>
            <ele>
              <name>column</name>
              <summary>Name of the column in the non-aggregated table</summary>
              <pattern><t>text</t></pattern>
            </ele>
            <ele>
              <name>data_type</name>
              <summary>The data type of the column, e.g. integer, text, cvss</summary>
              <pattern><t>text</t></pattern>
            </ele>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>filters</name>
        <pattern>
          <attrib>
            <name>id</name>
            <summary>UUID of filter if any, else 0</summary>
            <type>uuid</type>
            <required>1</required>
          </attrib>
          <e>term</e>
          <o><e>name</e></o>
          <e>keywords</e>
        </pattern>
        <ele>
          <name>term</name>
          <summary>Filter term</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>name</name>
          <summary>Filter name, if applicable</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>keywords</name>
          <summary>Filter broken down into keywords</summary>
          <pattern><any><e>keyword</e></any></pattern>
          <ele>
            <name>keyword</name>
            <pattern>
              <e>column</e>
              <e>relation</e>
              <e>value</e>
            </pattern>
            <ele>
              <name>column</name>
              <summary>Column prefix</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>relation</name>
              <summary>Relation operator</summary>
              <pattern>
                <alts>
                  <alt>=</alt>
                  <alt>:</alt>
                  <alt>~</alt>
                  <alt>&gt;</alt>
                  <alt>&lt;</alt>
                </alts>
              </pattern>
            </ele>
            <ele>
              <name>value</name>
              <summary>The filter text</summary>
              <pattern>text</pattern>
            </ele>
          </ele>
        </ele>
      </ele>
    </response>
    <example>
      <summary>Get severity statistics of NVTs by family</summary>
      <request>
        <get_aggregates type="nvt" group_column="family" data_column="severity">
        </get_aggregates>
      </request>
      <response>
        <get_aggregates_response status_text="OK" status="200">
          <aggregate>
            <data_type>nvt</data_type>
            <data_column>severity</data_column>
            <group_column>family</group_column>
            <group>
              <value>AIX Local Security Checks</value>
              <count>1</count>
              <c_count>1</c_count>
              <min>3.3</min>
              <max>3.3</max>
              <mean>3.3</mean>
              <sum>3.3</sum>
              <c_sum>3.3</c_sum>
            </group>
            <group>
              <value>Brute force attacks</value>
              <count>8</count>
              <c_count>9</c_count>
              <min>0</min>
              <max>7.8</max>
              <mean>6.275</mean>
              <sum>50.2</sum>
              <c_sum>53.5</c_sum>
            </group>
            <group>
              <value>Buffer overflow</value>
              <count>519</count>
              <c_count>528</c_count>
              <min>10</min>
              <max>9.7</max>
              <mean>8.63083</mean>
              <sum>4479.4</sum>
              <c_sum>4532.9</c_sum>
            </group>
            <truncated>...</truncated>
            <column_info>
              <aggregate_column>
                <name>value</name>
                <stat>value</stat>
                <type>nvt</type>
                <column>family</column>
                <data_type>text</data_type>
              </aggregate_column>
              <aggregate_column>
                <name>count</name>
                <stat>count</stat>
                <type>nvt</type>
                <column></column>
                <data_type>integer</data_type>
              </aggregate_column>
              <aggregate_column>
                <name>c_count</name>
                <stat>c_count</stat>
                <type>nvt</type>
                <column></column>
                <data_type>integer</data_type>
              </aggregate_column>
              <aggregate_column>
                <name>min</name>
                <stat>min</stat>
                <type>nvt</type>
                <column>severity</column>
                <data_type>cvss</data_type>
              </aggregate_column>
              <truncated>...</truncated>
            </column_info>
          </aggregate>
          <filters id="">
            <term>first=1 rows=-1 sort=name</term>
            <keywords>
              <keyword>
                <column>first</column>
                <relation>=</relation>
                <value>1</value>
              </keyword>
              <keyword>
                <column>rows</column>
                <relation>=</relation>
                <value>-1</value>
              </keyword>
              <keyword>
                <column>sort</column>
                <relation>=</relation>
                <value>name</value>
              </keyword>
            </keywords>
          </filters>
        </get_aggregates_response>
      </response>
    </example>
  </command>
  <command>
    <name>get_assets</name>
    <summary>Get one or many assets</summary>
    <description>
      The client uses the get_assets command to get asset information.
    </description>
    <pattern>
      <attrib>
        <name>asset_id</name>
        <summary>ID of single asset to get</summary>
        <type>uuid</type>
      </attrib>
      <attrib>
        <name>filter</name>
        <summary>Filter term to use to filter query</summary>
        <type>text</type>
        <filter_keywords>
          <option>
            <name>first</name>
            <type>integer</type>
            <summary>
              Index of the first item returned, starting at 1 (e.g. first=5
              starts at the 5th item)
            </summary>
          </option>
          <option>
            <name>rows</name>
            <type>integer</type>
            <summary>Number of items to return</summary>
          </option>
          <option>
            <name>sort</name>
            <type>text</type>
            <summary>Column to sort by in ascending order</summary>
          </option>
          <option>
            <name>sort-reverse</name>
            <type>text</type>
            <summary>Column to sort by in descending order</summary>
          </option>
          <column>
            <name>tag</name>
            <type>text</type>
            <summary>
              Name and optional "=" separted value of an attached tag
              (e.g. "mytag" or "mytag=myvalue")
            </summary>
          </column>
          <column>
            <name>tag_id</name>
            <type>UUID</type>
            <summary>
              UUID of an attached tag
            </summary>
          </column>
          <column>
            <name>uuid</name>
            <type>uuid</type>
            <summary>Unique ID</summary>
          </column>
          <column>
            <name>name</name>
            <type>name</type>
            <summary>Name</summary>
          </column>
          <column>
            <name>comment</name>
            <type>text</type>
            <summary>Comment text</summary>
          </column>
          <column>
            <name>created</name>
            <type>iso_time</type>
            <summary>Creation time</summary>
          </column>
          <column>
            <name>modified</name>
            <type>iso_time</type>
            <summary>Modification time</summary>
          </column>
          <column>
            <name>owner</name>
            <type>name</type>
            <summary>Name of the owner</summary>
          </column>
        </filter_keywords>
        <filter_keywords>
          <condition>type is "host"</condition>
          <option>
            <name>os_id</name>
            <type>UUID</type>
            <summary>
              UUID of an OS asset that was detected on the hosts but
              does not have to be the best match
            </summary>
          </option>
          <column>
            <name>best_os_cpe</name>
            <type>text</type>
            <summary>CPE-ID of best matching OS</summary>
          </column>
          <column>
            <name>severity</name>
            <type>severity</type>
            <summary>Highest severity of the asset from latest report</summary>
          </column>
          <column>
            <name>severity_level</name>
            <type>threat</type>
            <summary>
              Highest severity level of the asset from latest report,
              e.g. "High" or "Low"
            </summary>
          </column>
          <column>
            <name>os</name>
            <type>text</type>
            <summary>Best matching OS, either name or CPE-ID</summary>
          </column>
          <column>
            <name>oss</name>
            <type>text</type>
            <summary>Comma-separated list of all OSs of the host</summary>
          </column>
          <column>
            <name>hostname</name>
            <type>text</type>
            <summary>Hostname</summary>
          </column>
          <column>
            <name>ip</name>
            <type>text</type>
            <summary>IP address</summary>
          </column>
          <column>
            <name>updated</name>
            <type>iso_time</type>
            <summary>Time of last update (alias of modified)</summary>
          </column>
        </filter_keywords>
        <filter_keywords>
          <condition>type is "os"</condition>
          <column>
            <name>all_hosts</name>
            <type>integer</type>
            <summary>
              Number of all hosts using the asset, even if the OS
              is not the best match
            </summary>
          </column>
          <column>
            <name>title</name>
            <type>text</type>
            <summary>CPE title of the asset</summary>
          </column>
          <column>
            <name>hosts</name>
            <type>integer</type>
            <summary>Number of hosts using the asset as best OS match</summary>
          </column>
          <column>
            <name>latest_severity</name>
            <type>severity</type>
            <summary>Latest severity of the asset</summary>
          </column>
          <column>
            <name>highest_severity</name>
            <type>severity</type>
            <summary>Latest severity of the asset</summary>
          </column>
          <column>
            <name>average_severity</name>
            <type>severity</type>
            <summary>Average severity of the asset</summary>
          </column>
          <column>
            <name>severity</name>
            <type>severity</type>
            <summary>
              Average severity of the asset (alias of average_severity)
            </summary>
          </column>
          <column>
            <name>average_severity_score</name>
            <type>decimal</type>
            <summary>
              Average severity times the number of hosts the asset was found on
            </summary>
          </column>
        </filter_keywords>
      </attrib>
      <attrib>
        <name>filt_id</name>
        <summary>ID of filter to use to filter query</summary>
        <type>uuid</type>
      </attrib>
      <attrib>
        <name>ignore_pagination</name>
        <summary>
          Whether to ignore info used to split the report into pages
          like the filter terms "first" and "rows"
        </summary>
        <type>boolean</type>
      </attrib>
      <attrib>
        <name>type</name>
        <summary>Type of assets to get</summary>
        <type>
          <alts>
            <alt>host</alt>
            <alt>os</alt>
          </alts>
        </type>
      </attrib>
      <attrib>
        <name>details</name>
        <summary>Whether to include additional information (e.g. tags)</summary>
        <type>boolean</type>
      </attrib>
    </pattern>
    <response>
      <pattern>
        <attrib>
          <name>status</name>
          <type>status</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>status_text</name>
          <type>text</type>
          <required>1</required>
        </attrib>
        <any><e>asset</e></any>
        <e>filters</e>
        <e>sort</e>
        <e>assets</e>
        <e>asset_count</e>
      </pattern>
      <ele>
        <name>asset</name>
        <pattern>
          <attrib>
            <name>id</name>
            <type>uuid</type>
            <required>1</required>
          </attrib>
          <e>owner</e>
          <e>name</e>
          <e>comment</e>
          <e>creation_time</e>
          <e>modification_time</e>
          <e>writable</e>
          <e>in_use</e>
          <e>permissions</e>
          <o><e>user_tags</e></o>
          <o><e>identifiers</e></o>
          <e>type</e>
          <or>
            <e>host</e>
            <e>os</e>
          </or>
        </pattern>
        <ele>
          <name>owner</name>
          <summary>Owner of the asset</summary>
          <pattern>
            <e>name</e>
          </pattern>
          <ele>
            <name>name</name>
            <summary>The name of the owner</summary>
            <pattern><t>name</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>name</name>
          <summary>The name of the asset</summary>
          <pattern><t>name</t></pattern>
        </ele>
        <ele>
          <name>comment</name>
          <summary>The comment on the asset</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>creation_time</name>
          <summary>Date and time the asset was created</summary>
          <pattern><t>iso_time</t></pattern>
        </ele>
        <ele>
          <name>modification_time</name>
          <summary>Date and time the asset was last modified</summary>
          <pattern><t>iso_time</t></pattern>
        </ele>
        <ele>
          <name>identifiers</name>
          <summary>Host identifiers</summary>
          <pattern>
            <e>identifier</e>
          </pattern>
          <ele>
            <name>identifier</name>
            <summary>A single identifier</summary>
            <pattern>
              <e>name</e>
              <e>value</e>
              <e>creation_time</e>
              <e>modification_time</e>
              <e>source</e>
              <o><e>os</e></o>
            </pattern>
            <ele>
              <name>name</name>
              <summary>The name of the identifier</summary>
              <pattern><t>name</t></pattern>
            </ele>
            <ele>
              <name>value</name>
              <summary>The value of the identifier</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>creation_time</name>
              <summary>Date and time the identifier was created</summary>
              <pattern><t>iso_time</t></pattern>
            </ele>
            <ele>
              <name>modification_time</name>
              <summary>Date and time the identifier was last modified</summary>
              <pattern><t>iso_time</t></pattern>
            </ele>
            <ele>
              <name>source</name>
              <summary>The source of the identifier</summary>
              <pattern>
                <attrib>
                  <name>id</name>
                  <type>uuid</type>
                  <required>1</required>
                </attrib>
                <e>type</e>
                <e>data</e>
                <e>deleted</e>
                <e>name</e>
              </pattern>
              <ele>
                <name>type</name>
                <summary>Type of source</summary>
                <pattern>text</pattern>
              </ele>
              <ele>
                <name>data</name>
                <summary>Extra data, depends on type of source</summary>
                <pattern>text</pattern>
              </ele>
              <ele>
                <name>deleted</name>
                <summary>Whether the source has been deleted</summary>
                <pattern>boolean</pattern>
              </ele>
              <ele>
                <name>name</name>
                <summary>User name when source type is User, else empty</summary>
                <pattern>boolean</pattern>
              </ele>
            </ele>
            <ele>
              <name>os</name>
              <pattern>
                <attrib>
                  <name>id</name>
                  <type>uuid</type>
                  <required>1</required>
                </attrib>
                <e>title</e>
              </pattern>
              <ele>
                <name>title</name>
                <summary>Title of OS</summary>
                <pattern>text</pattern>
              </ele>
            </ele>
          </ele>
        </ele>
        <ele>
          <name>type</name>
          <summary>Either "host" or "os"</summary>
          <pattern>
            xsd:token { pattern = "host|os" }
          </pattern>
        </ele>
        <ele>
          <name>host</name>
          <summary>A host</summary>
          <pattern>
            <e>severity</e>
            <any><e>detail</e></any>
            <o><e>routes</e></o>
          </pattern>
          <ele>
            <name>severity</name>
            <summary>Severity of the host</summary>
            <pattern>
              <e>value</e>
            </pattern>
            <ele>
              <name>value</name>
              <pattern><t>severity</t></pattern>
            </ele>
          </ele>
          <ele>
            <name>detail</name>
            <summary>A host detail</summary>
            <pattern>
              <e>name</e>
              <e>value</e>
              <e>source</e>
            </pattern>
            <ele>
              <name>name</name>
              <summary>The name of the detail</summary>
              <pattern><t>name</t></pattern>
            </ele>
            <ele>
              <name>value</name>
              <summary>The value of the detail</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>source</name>
              <summary>The source of the detail</summary>
              <pattern>
                <attrib>
                  <name>id</name>
                  <type>uuid</type>
                  <required>1</required>
                </attrib>
                <e>type</e>
              </pattern>
              <ele>
                <name>type</name>
                <summary>Type of source</summary>
                <pattern>text</pattern>
              </ele>
            </ele>
          </ele>
          <ele>
            <name>routes</name>
            <summary>List of routes to the host, with most recent ones first</summary>
            <pattern>
              <any><e>route</e></any>
            </pattern>
            <ele>
              <name>route</name>
              <summary>List of hosts on the route to the host</summary>
              <pattern>
                <any><e>host</e></any>
              </pattern>
              <ele>
                <name>host</name>
                <summary>A host on the route</summary>
                <pattern>
                  <attrib>
                    <name>id</name>
                    <summary>UUID if the host is in the asset management</summary>
                    <type>uuid</type>
                  </attrib>
                  <attrib>
                    <name>distance</name>
                    <summary>Distance from the scanner</summary>
                    <type>number</type>
                  </attrib>
                  <attrib>
                    <name>same_source</name>
                    <summary>Whether the current host asset has the same source as the target host</summary>
                    <type>boolean</type>
                  </attrib>
                  <e>ip</e>
                </pattern>
                <ele>
                  <name>ip</name>
                  <summary>IP address of the host</summary>
                  <pattern>text</pattern>
                </ele>
              </ele>
            </ele>
          </ele>
        </ele>
        <ele>
          <name>os</name>
          <summary>An OS</summary>
          <pattern>
            <e>title</e>
            <e>installs</e>
            <e>all_installs</e>
            <e>latest_severity</e>
            <e>highest_severity</e>
            <e>average_severity</e>
            <e>hosts</e>
          </pattern>
          <ele>
            <name>title</name>
            <summary>Title of the OS</summary>
            <pattern>text</pattern>
          </ele>
          <ele>
            <!-- FIX hosts/host_count? -->
            <name>installs</name>
            <summary>
              Number of hosts on which OS has been detected as the best match
            </summary>
            <pattern>integer</pattern>
          </ele>
          <ele>
            <name>all_installs</name>
            <summary>
              Number of hosts on which OS has been detected,
              not necessarily as the best match
            </summary>
            <pattern>integer</pattern>
          </ele>
          <ele>
            <name>latest_severity</name>
            <summary>Latest severity</summary>
            <pattern>
              <e>value</e>
            </pattern>
            <ele>
              <name>value</name>
              <pattern>text</pattern>
            </ele>
          </ele>
          <ele>
            <name>highest_severity</name>
            <summary>Highest severity</summary>
            <pattern>
              <e>value</e>
            </pattern>
            <ele>
              <name>value</name>
              <pattern>text</pattern>
            </ele>
          </ele>
          <ele>
            <name>average_severity</name>
            <summary>Average severity</summary>
            <pattern>
              <e>value</e>
            </pattern>
            <ele>
              <name>value</name>
              <pattern>text</pattern>
            </ele>
          </ele>
          <ele>
            <name>hosts</name>
            <summary>
              Hosts on which this OS has been detected as the best match
            </summary>
            <pattern>
              <any><e>asset</e></any>
            </pattern>
            <ele>
              <name>asset</name>
              <summary>The host</summary>
              <pattern>
                <attrib>
                  <name>id</name>
                  <type>uuid</type>
                  <required>1</required>
                </attrib>
                <e>name</e>
                <e>severity</e>
              </pattern>
              <ele>
                <name>name</name>
                <summary>The name of the host</summary>
                <pattern><t>name</t></pattern>
              </ele>
              <ele>
                <name>severity</name>
                <summary>Severity of the host</summary>
                <pattern>
                  <e>value</e>
                </pattern>
                <ele>
                  <name>value</name>
                  <pattern>text</pattern>
                </ele>
              </ele>
            </ele>
          </ele>
        </ele>
        <ele>
          <name>in_use</name>
          <summary>Whether the asset is in use</summary>
          <pattern><t>boolean</t></pattern>
        </ele>
        <ele>
          <name>writable</name>
          <summary>Whether the asset is writable</summary>
          <pattern><t>boolean</t></pattern>
        </ele>
        <ele>
          <name>permissions</name>
          <summary>Permissions that the current user has on the asset</summary>
          <pattern>
            <any><e>permission</e></any>
          </pattern>
          <ele>
            <name>permission</name>
            <pattern>
              <e>name</e>
            </pattern>
            <ele>
              <name>name</name>
              <summary>The name of the permission</summary>
              <pattern><t>name</t></pattern>
            </ele>
          </ele>
        </ele>
        <ele>
          <name>user_tags</name>
          <summary>Info on tags attached to the asset</summary>
          <pattern>
            <e>count</e>
            <any><e>tag</e></any>
          </pattern>
          <ele>
            <name>count</name>
            <summary>Number of attached tags</summary>
            <pattern><t>integer</t></pattern>
          </ele>
          <ele>
            <name>tag</name>
            <summary>
              Short info on an individual tag
              (only if details were requested)
            </summary>
            <pattern>
              <attrib>
                <name>id</name>
                <type>uuid</type>
                <summary>UUID of the tag</summary>
                <required>1</required>
              </attrib>
              <e>name</e>
              <e>value</e>
              <e>comment</e>
            </pattern>
            <ele>
              <name>name</name>
              <summary>Name of the tag (usually namespace:predicate)</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>value</name>
              <summary>Value of the tag</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>comment</name>
              <summary>Comment for the tag</summary>
              <pattern>text</pattern>
            </ele>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>filters</name>
        <pattern>
          <attrib>
            <name>id</name>
            <summary>UUID of filter if any, else 0</summary>
            <type>uuid</type>
            <required>1</required>
          </attrib>
          <e>term</e>
          <o><e>name</e></o>
          <e>keywords</e>
        </pattern>
        <ele>
          <name>term</name>
          <summary>Filter term</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>name</name>
          <summary>Filter name, if applicable</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>keywords</name>
          <summary>Filter broken down into keywords</summary>
          <pattern><any><e>keyword</e></any></pattern>
          <ele>
            <name>keyword</name>
            <pattern>
              <e>column</e>
              <e>relation</e>
              <e>value</e>
            </pattern>
            <ele>
              <name>column</name>
              <summary>Column prefix</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>relation</name>
              <summary>Relation operator</summary>
              <pattern>
                <alts>
                  <alt>=</alt>
                  <alt>:</alt>
                  <alt>~</alt>
                  <alt>&gt;</alt>
                  <alt>&lt;</alt>
                </alts>
              </pattern>
            </ele>
            <ele>
              <name>value</name>
              <summary>The filter text</summary>
              <pattern>text</pattern>
            </ele>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>sort</name>
        <pattern>
          text
          <e>field</e>
        </pattern>
        <ele>
          <name>field</name>
          <pattern>
            <e>order</e>
          </pattern>
          <ele>
            <name>order</name>
            <pattern>
              <alts>
                <alt>ascending</alt>
                <alt>descending</alt>
              </alts>
            </pattern>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>assets</name>
        <pattern>
          <attrib>
            <name>start</name>
            <summary>First asset</summary>
            <type>integer</type>
            <required>1</required>
          </attrib>
          <attrib>
            <name>max</name>
            <summary>Maximum number of assets</summary>
            <type>integer</type>
            <required>1</required>
          </attrib>
        </pattern>
      </ele>
      <ele>
        <name>asset_count</name>
        <pattern>
          <e>filtered</e>
          <e>page</e>
        </pattern>
        <ele>
          <name>filtered</name>
          <summary>Number of assets after filtering</summary>
          <pattern><t>integer</t></pattern>
        </ele>
        <ele>
          <name>page</name>
          <summary>Number of assets on current page</summary>
          <pattern><t>integer</t></pattern>
        </ele>
      </ele>
    </response>
    <example>
      <summary>Get one or many assets</summary>
      <request>
        <get_assets></get_assets>
      </request>
      <response>
        <get_assets_response status="200" status_text="OK">
          <asset id="b493b7a8-7489-11df-a3ec-002264764cea">
            <name>Localhost</name>
            <comment></comment>
            <creation_time>2018-08-29T20:21:33Z</creation_time>
            <modification_time>2018-08-29T20:21:33Z</modification_time>
            <writable>0</writable>
            <in_use>7</in_use>
            <hosts>localhost</hosts>
            <max_hosts>1</max_hosts>
            <ssh_credential id="">
              <name></name>
            </ssh_credential>
            <smb_credential id="">
              <name></name>
            </smb_credential>
            <esxi_credential id="">
              <name></name>
            </esxi_credential>
          </asset>
          <truncated>...</truncated>
        </get_assets_response>
      </response>
    </example>
    <example>
      <summary>Get a single asset, including tasks using the asset</summary>
      <request>
        <get_assets asset_id="1f28d970-17ef-4c69-ba8a-13827059f2b9" tasks="1">
        </get_assets>
      </request>
      <response>
        <get_assets_response status="200" status_text="OK">
          <asset id="1f28d970-17ef-4c69-ba8a-13827059f2b9">
            <name>dik</name>
            <comment>dik mm</comment>
            <creation_time>2018-08-29T20:21:33Z</creation_time>
            <modification_time>2018-08-29T20:21:33Z</modification_time>
            <writable>0</writable>
            <in_use>4</in_use>
            <hosts>dik.example.org</hosts>
            <max_hosts>1</max_hosts>
            <ssh_credential id="58ff2793-2dc7-43fe-85f9-20bfac5a87e4">
              <name>mm</name>
            </ssh_credential>
            <smb_credential id="">
              <name></name>
            </smb_credential>
            <esxi_credential id="">
              <name></name>
            </esxi_credential>
            <tasks>
              <task id="13bb418a-4220-4575-b35b-ec398bff7417">
                <name>dik mm</name>
              </task>
              <truncated>...</truncated>
            </tasks>
          </asset>
        </get_assets_response>
      </response>
    </example>
  </command>
  <command>
    <name>get_configs</name>
    <summary>Get one or many configs</summary>
    <description>
      The client uses the get_configs command to get config information.
      If the command sent by the client was valid, the manager will
      reply with a list of configs to the client.
    </description>
    <pattern>
      <attrib>
        <name>config_id</name>
        <summary>ID of single config to get</summary>
        <type>uuid</type>
      </attrib>
      <attrib>
        <name>filter</name>
        <summary>Filter term to use to filter query</summary>
        <type>text</type>
        <filter_keywords>
          <option>
            <name>first</name>
            <type>integer</type>
            <summary>
              Index of the first item returned, starting at 1 (e.g. first=5
              starts at the 5th item)
            </summary>
          </option>
          <option>
            <name>rows</name>
            <type>integer</type>
            <summary>Number of items to return</summary>
          </option>
          <option>
            <name>sort</name>
            <type>text</type>
            <summary>Column to sort by in ascending order</summary>
          </option>
          <option>
            <name>sort-reverse</name>
            <type>text</type>
            <summary>Column to sort by in descending order</summary>
          </option>
          <column>
            <name>tag</name>
            <type>text</type>
            <summary>
              Name and optional "=" separted value of an attached tag
              (e.g. "mytag" or "mytag=myvalue")
            </summary>
          </column>
          <column>
            <name>tag_id</name>
            <type>UUID</type>
            <summary>
              UUID of an attached tag
            </summary>
          </column>
          <column>
            <name>uuid</name>
            <type>uuid</type>
            <summary>Unique ID</summary>
          </column>
          <column>
            <name>name</name>
            <type>name</type>
            <summary>Name</summary>
          </column>
          <column>
            <name>comment</name>
            <type>text</type>
            <summary>Comment text</summary>
          </column>
          <column>
            <name>created</name>
            <type>iso_time</type>
            <summary>Creation time</summary>
          </column>
          <column>
            <name>modified</name>
            <type>iso_time</type>
            <summary>Modification time</summary>
          </column>
          <column>
            <name>owner</name>
            <type>name</type>
            <summary>Name of the owner</summary>
          </column>
          <column>
            <name>nvt_selector</name>
            <type>uuid</type>
            <summary>NVT selector UUID</summary>
          </column>
          <column>
            <name>families_total</name>
            <type>integer</type>
            <summary>Total number of selected NVT families</summary>
          </column>
          <column>
            <name>nvts_total</name>
            <type>integer</type>
            <summary>Total number of selected NVTs</summary>
          </column>
          <column>
            <name>families_trend</name>
            <type>boolean</type>
            <summary>Whether new NVT families will be added</summary>
          </column>
          <column>
            <name>nvts_trend</name>
            <type>boolean</type>
            <summary>Whether new NVTs will be added</summary>
          </column>
          <column>
            <name>usage_type</name>
            <type>
              <alts>
                <alt>scan</alt>
              </alts>
            </type>
            <summary>Usage type</summary>
          </column>
          <column>
            <name>predefined</name>
            <type>boolean</type>
            <summary>Whether the config was created from the feed</summary>
          </column>
        </filter_keywords>
      </attrib>
      <attrib>
        <name>filt_id</name>
        <summary>ID of filter to use to filter query</summary>
        <type>uuid</type>
      </attrib>
      <attrib>
        <name>trash</name>
        <summary>Whether to get the trashcan configs instead</summary>
        <type>boolean</type>
      </attrib>
      <attrib>
        <name>details</name>
        <summary>Whether to get config families, preferences and nvt selectors</summary>
        <type>boolean</type>
      </attrib>
      <attrib>
        <name>families</name>
        <summary>Whether to include the families if no details are requested</summary>
        <type>boolean</type>
      </attrib>
      <attrib>
        <name>preferences</name>
        <summary>Whether to include the preferences if no details are requested</summary>
        <type>boolean</type>
      </attrib>
      <attrib>
        <name>tasks</name>
        <summary>Whether to get tasks using this config</summary>
        <type>boolean</type>
      </attrib>
      <attrib>
        <name>usage_type</name>
        <summary>Optional usage type to limit the configs to. Affects total count unlike filter</summary>
        <type>
          <alts>
            <alt>scan</alt>
            <alt></alt>
          </alts>
        </type>
      </attrib>
    </pattern>
    <response>
      <pattern>
        <attrib>
          <name>status</name>
          <type>status</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>status_text</name>
          <type>text</type>
          <required>1</required>
        </attrib>
        <any><e>config</e></any>
        <e>filters</e>
        <e>sort</e>
        <e>configs</e>
        <e>config_count</e>
      </pattern>
      <ele>
        <name>config</name>
        <pattern>
          <attrib>
            <name>id</name>
            <type>uuid</type>
            <required>1</required>
          </attrib>
          <e>owner</e>
          <e>name</e>
          <e>comment</e>
          <e>creation_time</e>
          <e>modification_time</e>
          <e>family_count</e>
          <e>nvt_count</e>
          <e>type</e>
          <e>usage_type</e>
          <e>max_nvt_count</e>
          <e>known_nvt_count</e>
          <o><e>scanner</e></o>
          <e>in_use</e>
          <e>writable</e>
          <e>permissions</e>
          <o><e>user_tags</e></o>
          <e>tasks</e>
          <o><e>families</e></o>
          <o><e>preferences</e></o>
          <o><e>nvt_selectors</e></o>
          <e>predefined</e>
          <o><e>deprecated</e></o>
        </pattern>
        <ele>
          <name>owner</name>
          <summary>Owner of the config</summary>
          <pattern>
            <e>name</e>
          </pattern>
          <ele>
            <name>name</name>
            <summary>The name of the owner</summary>
            <pattern><t>name</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>name</name>
          <summary>The name of the config</summary>
          <pattern><t>name</t></pattern>
        </ele>
        <ele>
          <name>comment</name>
          <summary>The comment on the config</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>creation_time</name>
          <summary>Creation time of the config</summary>
          <pattern><t>iso_time</t></pattern>
        </ele>
        <ele>
          <name>modification_time</name>
          <summary>Last time the config was modified</summary>
          <pattern><t>iso_time</t></pattern>
        </ele>
        <ele>
          <name>family_count</name>
          <summary>The number of families selected by the config</summary>
          <pattern>
            <t>integer</t>
            <e>growing</e>
          </pattern>
          <ele>
            <name>growing</name>
            <summary>
              Whether new families are automatically added to the
              config
            </summary>
            <pattern><t>boolean</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>nvt_count</name>
          <summary>The number of NVTs selected by the config</summary>
          <pattern>
            <t>integer</t>
            <e>growing</e>
          </pattern>
          <ele>
            <name>growing</name>
            <summary>
              Whether new NVTs are automatically added to the config
            </summary>
            <pattern><t>boolean</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>type</name>
          <summary>The type of the config (0 = OpenVAS, 1 OSP)</summary>
          <pattern>
            <alts>
              <alt>0</alt>
              <alt>1</alt>
            </alts>
          </pattern>
        </ele>
        <ele>
          <name>usage_type</name>
          <summary>The usage type of the config. Only scan configs are supported.</summary>
          <pattern>
            <alts>
              <alt>scan</alt>
            </alts>
          </pattern>
        </ele>
        <ele>
          <name>max_nvt_count</name>
          <summary>Total number of NVTs in the families selected by the config</summary>
          <pattern>
            <t>integer</t>
          </pattern>
        </ele>
        <ele>
          <name>known_nvt_count</name>
          <summary>Total number of known NVTs selected by the config</summary>
          <pattern>
            <t>integer</t>
          </pattern>
        </ele>
        <ele>
          <name>scanner</name>
          <summary>The scanner used by the config if it is an OSP one</summary>
          <pattern>
            <t>text</t>
            <attrib>
              <name>id</name>
              <type>uuid</type>
              <summary>UUID of the scanner</summary>
              <required>1</required>
            </attrib>
            <e>trash</e>
          </pattern>
          <ele>
            <name>trash</name>
            <summary>Whether the scanner is in the trashcan</summary>
            <pattern>
              <t>boolean</t>
            </pattern>
          </ele>
        </ele>
        <ele>
          <name>in_use</name>
          <summary>Whether any tasks are using the config</summary>
          <pattern><t>boolean</t></pattern>
        </ele>
        <ele>
          <name>writable</name>
          <summary>
            Whether the config may be modified
          </summary>
          <pattern><t>boolean</t></pattern>
        </ele>
        <ele>
          <name>permissions</name>
          <summary>Permissions that the current user has on the target</summary>
          <pattern>
            <any><e>permission</e></any>
          </pattern>
          <ele>
            <name>permission</name>
            <pattern>
              <e>name</e>
            </pattern>
            <ele>
              <name>name</name>
              <summary>The name of the permission</summary>
              <pattern><t>name</t></pattern>
            </ele>
          </ele>
        </ele>
        <ele>
          <name>user_tags</name>
          <summary>Info on tags attached to the config</summary>
          <pattern>
            <e>count</e>
            <any><e>tag</e></any>
          </pattern>
          <ele>
            <name>count</name>
            <summary>Number of attached tags</summary>
            <pattern><t>integer</t></pattern>
          </ele>
          <ele>
            <name>tag</name>
            <summary>
              Short info on an individual tag
              (only if details were requested)
            </summary>
            <pattern>
              <attrib>
                <name>id</name>
                <type>uuid</type>
                <summary>UUID of the tag</summary>
                <required>1</required>
              </attrib>
              <e>name</e>
              <e>value</e>
              <e>comment</e>
            </pattern>
            <ele>
              <name>name</name>
              <summary>Name of the tag (usually namespace:predicate)</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>value</name>
              <summary>Value of the tag</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>comment</name>
              <summary>Comment for the tag</summary>
              <pattern>text</pattern>
            </ele>
          </ele>
        </ele>
        <ele>
          <name>tasks</name>
          <summary>All tasks using the config</summary>
          <pattern>
            <any><e>task</e></any>
          </pattern>
          <ele>
            <name>task</name>
            <pattern>
              <attrib>
                <name>id</name>
                <type>uuid</type>
                <required>1</required>
              </attrib>
              <e>name</e>
              <o><e>permissions</e></o>
            </pattern>
            <ele>
              <name>name</name>
              <summary>The name of the task</summary>
              <pattern><t>name</t></pattern>
            </ele>
            <ele>
              <name>permissions</name>
              <summary>Permissions the user has on the task</summary>
              <pattern></pattern>
            </ele>
          </ele>
        </ele>
        <ele>
          <name>families</name>
          <summary>All families selected by the config</summary>
          <pattern>
            <any><e>family</e></any>
          </pattern>
          <ele>
            <name>family</name>
            <pattern>
              <e>name</e>
              <e>nvt_count</e>
              <e>max_nvt_count</e>
              <e>growing</e>
            </pattern>
            <ele>
              <name>name</name>
              <summary>The name of the family</summary>
              <pattern><t>name</t></pattern>
            </ele>
            <ele>
              <name>type</name>
              <summary>The type of the config. 0 = OpenVAS scanner, 1 = OSP Scanner</summary>
              <pattern><t>integer</t></pattern>
            </ele>
            <ele>
              <name>nvt_count</name>
              <summary>The number of NVTs selected in the family</summary>
              <pattern><t>integer</t></pattern>
            </ele>
            <ele>
              <name>max_nvt_count</name>
              <summary>The total number of NVTs in the family</summary>
              <pattern><t>integer</t></pattern>
            </ele>
            <ele>
              <name>growing</name>
              <summary>
                Whether new NVTs in the family are automatically added to the selection
              </summary>
              <pattern><t>boolean</t></pattern>
            </ele>
          </ele>
        </ele>
        <ele>
          <name>preferences</name>
          <summary>Preferences for all NVTs selected by the config</summary>
          <pattern>
            <any><e>preference</e></any>
          </pattern>
          <ele>
            <name>preference</name>
            <pattern>
              <e>nvt</e>
              <e>name</e>
              <o><e>hr_name</e></o>
              <e>id</e>
              <e>type</e>
              <e>value</e>
              <o><e>default</e></o>
              <any><e>alt</e></any>
            </pattern>
            <ele>
              <name>nvt</name>
              <summary>NVT to which preference applies</summary>
              <pattern>
                <attrib>
                  <name>oid</name>
                  <type>oid</type>
                  <required>1</required>
                </attrib>
                <e>name</e>
              </pattern>
              <ele>
                <name>name</name>
                <summary>The name of the NVT</summary>
                <pattern><t>name</t></pattern>
              </ele>
            </ele>
            <ele>
              <name>name</name>
              <summary>The compact name of the preference as used by the scanner</summary>
              <pattern><t>name</t></pattern>
            </ele>
            <ele>
              <name>hr_name</name>
              <summary>The human readable name of the preference</summary>
              <pattern><t>name</t></pattern>
            </ele>
            <ele>
              <name>id</name>
              <summary>The ID of the preference</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>type</name>
              <summary>The type of the preference</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>value</name>
              <summary>The value of the preference</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>default</name>
              <summary>The default value of the preference</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>alt</name>
              <summary>An alternate value for the preference</summary>
              <pattern>text</pattern>
            </ele>
          </ele>
        </ele>
        <ele>
          <name>nvt_selectors</name>
          <summary>All NVT selectors of the config</summary>
          <pattern>
            <any><e>nvt_selector</e></any>
          </pattern>
          <ele>
            <name>nvt_selector</name>
            <summary>An NVT selector</summary>
            <pattern>
              <e>name</e>
              <e>include</e>
              <e>type</e>
              <e>family_or_nvt</e>
            </pattern>
            <ele>
              <name>name</name>
              <summary>Name of the selector</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>include</name>
              <summary>Whether the selector is an include selector</summary>
              <pattern>
                <t>boolean</t>
              </pattern>
            </ele>
            <ele>
              <name>type</name>
              <summary>Selector type: 0 = all, 1 = family, 2 = NVT</summary>
              <pattern>
                <t>integer</t>
              </pattern>
            </ele>
            <ele>
              <name>family_or_nvt</name>
              <summary>Name of the family or OID of the NVT</summary>
              <pattern>text</pattern>
            </ele>
          </ele>
        </ele>
        <ele>
          <name>predefined</name>
          <summary>Whether the config was predefined by the feed</summary>
          <pattern><t>boolean</t></pattern>
        </ele>
        <ele>
          <name>deprecated</name>
          <summary>Whether the config is deprecated</summary>
          <pattern><t>boolean</t></pattern>
        </ele>
      </ele>
      <ele>
        <name>filters</name>
        <pattern>
          <attrib>
            <name>id</name>
            <summary>UUID of filter if any, else 0</summary>
            <type>uuid</type>
            <required>1</required>
          </attrib>
          <e>term</e>
          <o><e>name</e></o>
          <e>keywords</e>
        </pattern>
        <ele>
          <name>term</name>
          <summary>Filter term</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>name</name>
          <summary>Filter name, if applicable</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>keywords</name>
          <summary>Filter broken down into keywords</summary>
          <pattern><any><e>keyword</e></any></pattern>
          <ele>
            <name>keyword</name>
            <pattern>
              <e>column</e>
              <e>relation</e>
              <e>value</e>
            </pattern>
            <ele>
              <name>column</name>
              <summary>Column prefix</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>relation</name>
              <summary>Relation operator</summary>
              <pattern>
                <alts>
                  <alt>=</alt>
                  <alt>:</alt>
                  <alt>~</alt>
                  <alt>&gt;</alt>
                  <alt>&lt;</alt>
                </alts>
              </pattern>
            </ele>
            <ele>
              <name>value</name>
              <summary>The filter text</summary>
              <pattern>text</pattern>
            </ele>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>sort</name>
        <pattern>
          text
          <e>field</e>
        </pattern>
        <ele>
          <name>field</name>
          <pattern>
            <e>order</e>
          </pattern>
          <ele>
            <name>order</name>
            <pattern>
              <alts>
                <alt>ascending</alt>
                <alt>descending</alt>
              </alts>
            </pattern>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>configs</name>
        <pattern>
          <attrib>
            <name>start</name>
            <summary>First config</summary>
            <type>integer</type>
            <required>1</required>
          </attrib>
          <attrib>
            <name>max</name>
            <summary>Maximum number of configs</summary>
            <type>integer</type>
            <required>1</required>
          </attrib>
        </pattern>
      </ele>
      <ele>
        <name>config_count</name>
        <pattern>
          <e>filtered</e>
          <e>page</e>
        </pattern>
        <ele>
          <name>filtered</name>
          <summary>Number of configs after filtering</summary>
          <pattern><t>integer</t></pattern>
        </ele>
        <ele>
          <name>page</name>
          <summary>Number of configs on current page</summary>
          <pattern><t>integer</t></pattern>
        </ele>
      </ele>
    </response>
    <example>
      <summary>Get one or many configs</summary>
      <request>
        <get_configs></get_configs>
      </request>
      <response>
        <get_configs_response status="200" status_text="OK">
          <config id="daba56c8-73ec-11df-a475-002264764cea">
            <owner>
              <name>mabel</name>
            </owner>
            <name>Full and fast</name>
            <comment>Most NVT's; optimized by using previously collected information. Version 20201215.</comment>
            <creation_time>2023-03-06T11:26:30-05:00</creation_time>
            <modification_time>2024-01-23T10:02:26-05:00</modification_time>
            <writable>0</writable>
            <in_use>1</in_use>
            <permissions>
              <permission>
                <name>Everything</name>
              </permission>
            </permissions>
            <family_count>
              56
              <growing>1</growing>
            </family_count>
            <nvt_count>
              88005
              <growing>1</growing>
            </nvt_count>
            <type>0</type>
            <usage_type>scan</usage_type>
            <predefined>0</predefined>
          </config>
          <truncated>...</truncated>
        </get_configs_response>
      </response>
    </example>
    <example>
      <summary>Get a single config, including preference, family lists and tasks using this config</summary>
      <request>
        <get_configs config_id="daba56c8-73ec-11df-a475-002264764cea" preferences="1" families="1" tasks="1">
        </get_configs>
      </request>
      <response>
        <get_configs_response status="200" status_text="OK">
          <config id="daba56c8-73ec-11df-a475-002264764cea">
            <owner>
              <name>mabel</name>
            </owner>
            <name>Full and fast</name>
            <comment>
              Most NVT's; optimized by using previously collected information. Version 20201215.
            </comment>
            <creation_time>2023-03-06T11:26:30-05:00</creation_time>
            <modification_time>2024-01-23T10:02:26-05:00</modification_time>
            <writable>0</writable>
            <in_use>1</in_use>
            <permissions>
              <permission>
                <name>Everything</name>
              </permission>
            </permissions>
            <family_count>
              56
              <growing>1</growing>
            </family_count>
            <nvt_count>
              88005
              <growing>1</growing>
            </nvt_count>
            <type>0</type>
            <usage_type>scan</usage_type>
            <predefined>0</predefined>
            <families>
              <family>
                <name>AIX Local Security Checks</name>
                <nvt_count>1</nvt_count>
                <max_nvt_count>1</max_nvt_count>
                <growing>1</growing>
              </family>
              <truncated>...</truncated>
            </families>
            <max_nvt_count>88014</max_nvt_count>
            <known_nvt_count>88005</known_nvt_count>
            <preferences>
              <preference>
                <nvt oid="1.3.6.1.4.1.25623.1.0.100151">
                  <name>PostgreSQL Detection (TCP)</name>
                </nvt>
                <id>1</id>
                <hr_name>Postgres Username:</hr_name>
                <name>Postgres Username:</name>
                <type>entry</type>
                <value>postgres</value>
                <default>postgres</default>
              </preference>
              <truncated>...</truncated>
            </preferences>
            <tasks>
              <task id="1d5c5fc8-937e-41f1-b52f-49887c386b12">
                <name>Web Servers</name>
              </task>
              <truncated>...</truncated>
            </tasks>
          </config>
          <truncated>...</truncated>
        </get_configs_response>
      </response>
    </example>
  </command>
  <command>
    <name>get_credentials</name>
    <summary>Get one or many credentials</summary>
    <description>
      The client uses the get_credentials command to get credentials information.
      If the command sent by the client was valid, the manager will
      reply with a list of credentials to the client.
    </description>
    <pattern>
      <attrib>
        <name>credential_id</name>
        <summary>ID of single credential to get</summary>
        <type>uuid</type>
      </attrib>
      <attrib>
        <name>filter</name>
        <summary>Filter term to use to filter query</summary>
        <type>text</type>
        <filter_keywords>
          <option>
            <name>first</name>
            <type>integer</type>
            <summary>
              Index of the first item returned, starting at 1 (e.g. first=5
              starts at the 5th item)
            </summary>
          </option>
          <option>
            <name>rows</name>
            <type>integer</type>
            <summary>Number of items to return</summary>
          </option>
          <option>
            <name>sort</name>
            <type>text</type>
            <summary>Column to sort by in ascending order</summary>
          </option>
          <option>
            <name>sort-reverse</name>
            <type>text</type>
            <summary>Column to sort by in descending order</summary>
          </option>
          <column>
            <name>tag</name>
            <type>text</type>
            <summary>
              Name and optional "=" separted value of an attached tag
              (e.g. "mytag" or "mytag=myvalue")
            </summary>
          </column>
          <column>
            <name>tag_id</name>
            <type>UUID</type>
            <summary>
              UUID of an attached tag
            </summary>
          </column>
          <column>
            <name>uuid</name>
            <type>uuid</type>
            <summary>Unique ID</summary>
          </column>
          <column>
            <name>name</name>
            <type>name</type>
            <summary>Name</summary>
          </column>
          <column>
            <name>comment</name>
            <type>text</type>
            <summary>Comment text</summary>
          </column>
          <column>
            <name>created</name>
            <type>iso_time</type>
            <summary>Creation time</summary>
          </column>
          <column>
            <name>modified</name>
            <type>iso_time</type>
            <summary>Modification time</summary>
          </column>
          <column>
            <name>owner</name>
            <type>name</type>
            <summary>Name of the owner</summary>
          </column>
          <column>
            <name>login</name>
            <type>text</type>
            <summary>The login username</summary>
          </column>
          <column>
            <name>type</name>
            <type>text</type>
            <summary>The type abbreviation</summary>
          </column>
          <column>
            <name>allow_insecure</name>
            <type>boolean</type>
            <summary>Whether insecure use is allowed</summary>
          </column>
        </filter_keywords>
      </attrib>
      <attrib>
        <name>filt_id</name>
        <summary>ID of filter to use to filter query</summary>
        <type>uuid</type>
      </attrib>
      <attrib>
        <name>details</name>
        <summary>Whether to include certificate info</summary>
        <type>boolean</type>
      </attrib>
      <attrib>
        <name>scanners</name>
        <summary>Whether to include a list of scanners using the credentials</summary>
        <type>boolean</type>
      </attrib>
      <attrib>
        <name>trash</name>
        <summary>Whether to get the trashcan credentials instead</summary>
        <type>boolean</type>
      </attrib>
      <attrib>
        <name>targets</name>
        <summary>Whether to include a list of targets using the credentials</summary>
        <type>boolean</type>
      </attrib>
    </pattern>
    <response>
      <pattern>
        <attrib>
          <name>status</name>
          <type>status</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>status_text</name>
          <type>text</type>
          <required>1</required>
        </attrib>
        <any><e>credential</e></any>
        <e>filters</e>
        <e>sort</e>
        <e>credentials</e>
        <e>credential_count</e>
      </pattern>
      <ele>
        <name>credential</name>
        <pattern>
          <attrib>
            <name>id</name>
            <type>uuid</type>
            <required>1</required>
          </attrib>
          <e>owner</e>
          <e>name</e>
          <e>allow_insecure</e>
          <e>login</e>
          <e>comment</e>
          <e>creation_time</e>
          <e>modification_time</e>
          <e>writable</e>
          <e>in_use</e>
          <e>permissions</e>
          <o><e>user_tags</e></o>
          <e>type</e>
          <e>full_type</e>
          <o><e>auth_algorithm</e></o>
          <o><e>privacy</e></o>
          <o><e>certificate_info</e></o>
          <o><e>private_key_info</e></o>
          <o><e>public_key_info</e></o>
          <o><e>scanners</e></o>
          <o><e>targets</e></o>
          <o><e>kdc</e></o>
          <o><e>kdcs</e></o>
          <o><e>realm</e></o>
        </pattern>
        <ele>
          <name>owner</name>
          <summary>Owner of the credential</summary>
          <pattern>
            <e>name</e>
          </pattern>
          <ele>
            <name>name</name>
            <summary>The name of the owner</summary>
            <pattern><t>name</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>name</name>
          <summary>The name of the credential</summary>
          <pattern><t>name</t></pattern>
        </ele>
        <ele>
          <name>allow_insecure</name>
          <summary>Whether insecure use of the credential is allowed</summary>
          <pattern>
            <t>boolean</t>
          </pattern>
        </ele>
        <ele>
          <name>login</name>
          <summary>The username of the credential</summary>
          <pattern><t>name</t></pattern>
        </ele>
        <ele>
          <name>comment</name>
          <summary>The comment on the credential</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>creation_time</name>
          <summary>Date and time the credential was created</summary>
          <pattern><t>iso_time</t></pattern>
        </ele>
        <ele>
          <name>modification_time</name>
          <summary>Date and time the credential was last modified</summary>
          <pattern><t>iso_time</t></pattern>
        </ele>
        <ele>
          <name>writable</name>
          <summary>Whether this credential is writable</summary>
          <pattern><t>boolean</t></pattern>
        </ele>
        <ele>
          <name>in_use</name>
          <summary>Whether any targets are using the credential</summary>
          <pattern><t>boolean</t></pattern>
        </ele>
        <ele>
          <name>permissions</name>
          <summary>
            Permissions that the current user has on the credential
          </summary>
          <pattern>
            <any><e>permission</e></any>
          </pattern>
          <ele>
            <name>permission</name>
            <pattern>
              <e>name</e>
            </pattern>
            <ele>
              <name>name</name>
              <summary>The name of the permission</summary>
              <pattern><t>name</t></pattern>
            </ele>
          </ele>
        </ele>
        <ele>
          <name>user_tags</name>
          <summary>Info on tags attached to the credential</summary>
          <pattern>
            <e>count</e>
            <any><e>tag</e></any>
          </pattern>
          <ele>
            <name>count</name>
            <summary>Number of attached tags</summary>
            <pattern><t>integer</t></pattern>
          </ele>
          <ele>
            <name>tag</name>
            <summary>
              Short info on an individual tag
              (only if details were requested)
            </summary>
            <pattern>
              <attrib>
                <name>id</name>
                <type>uuid</type>
                <summary>UUID of the tag</summary>
                <required>1</required>
              </attrib>
              <e>name</e>
              <e>value</e>
              <e>comment</e>
            </pattern>
            <ele>
              <name>name</name>
              <summary>Name of the tag (usually namespace:predicate)</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>value</name>
              <summary>Value of the tag</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>comment</name>
              <summary>Comment for the tag</summary>
              <pattern>text</pattern>
            </ele>
          </ele>
        </ele>
        <ele>
          <name>type</name>
          <summary>The type of the credential</summary>
          <description>
            <p>cc: Client certificate</p>
            <p>krb5: Kerberos 5</p>
            <p>pgp: PGP encryption key</p>
            <p>pw: Password only</p>
            <p>smime: S/MIME certificate</p>
            <p>snmp: SNMP</p>
            <p>up: User name + password</p>
            <p>usk: User name + SSH key</p>
          </description>
          <pattern>
            <alts>
              <alt>cc</alt>
              <alt>krb5</alt>
              <alt>pgp</alt>
              <alt>pw</alt>
              <alt>smime</alt>
              <alt>snmp</alt>
              <alt>up</alt>
              <alt>usk</alt>
            </alts>
          </pattern>
        </ele>
        <ele>
          <name>full_type</name>
          <summary>The type of the credential written out</summary>
          <pattern>
            text
          </pattern>
        </ele>
        <ele>
          <name>auth_algorithm</name>
          <summary>The SNMP authentication algorithm</summary>
          <pattern>
            <alts>
              <alt>md5</alt>
              <alt>sha1</alt>
            </alts>
          </pattern>
        </ele>
        <ele>
          <name>privacy</name>
          <pattern>
            <e>algorithm</e>
          </pattern>
          <ele>
            <name>algorithm</name>
            <summary>The SNMP privacy algorithm</summary>
            <pattern>
              <alts>
                <alt>aes</alt>
                <alt>des</alt>
              </alts>
            </pattern>
          </ele>
        </ele>
        <ele>
          <name>certificate_info</name>
          <summary>
            Info about the certificate
          </summary>
          <type>certificate_info</type>
        </ele>
        <ele>
          <name>private_key_info</name>
          <summary>
            Info about the private key if one is set.
          </summary>
          <pattern>
            <o><e>type</e></o>
            <o><e>sha256_hash</e></o>
          </pattern>
          <ele>
            <name>type</name>
            <summary>The key type / algorithm if the key is valid</summary>
            <pattern>text</pattern>
          </ele>
          <ele>
            <name>sha256_hash</name>
            <summary>SHA-256 hash of the key if it is valid</summary>
            <pattern>text</pattern>
          </ele>
        </ele>
        <ele>
          <name>public_key_info</name>
          <summary>
            Info about the public key if one is set.
          </summary>
          <pattern>
            <o><e>fingerprint</e></o>
          </pattern>
          <ele>
            <name>fingerprint</name>
            <summary>The key fingerprint if the key is valid</summary>
            <pattern>text</pattern>
          </ele>
        </ele>
        <ele>
          <name>scanners</name>
          <summary>All scanners using this credential</summary>
          <pattern>
            <any><e>scanner</e></any>
          </pattern>
          <ele>
            <name>scanner</name>
            <pattern>
              <attrib>
                <name>id</name>
                <type>uuid</type>
                <required>1</required>
              </attrib>
              <e>name</e>
              <o><e>permissions</e></o>
            </pattern>
            <ele>
              <name>name</name>
              <summary>The name of the scanner</summary>
              <pattern><t>name</t></pattern>
            </ele>
            <ele>
              <name>permissions</name>
              <summary>Permissions the user has on the scanner</summary>
              <pattern></pattern>
            </ele>
          </ele>
        </ele>
        <ele>
          <name>targets</name>
          <summary>All targets using this credential</summary>
          <pattern>
            <any><e>target</e></any>
          </pattern>
          <ele>
            <name>target</name>
            <pattern>
              <attrib>
                <name>id</name>
                <type>uuid</type>
                <required>1</required>
              </attrib>
              <e>name</e>
              <o><e>permissions</e></o>
            </pattern>
            <ele>
              <name>name</name>
              <summary>The name of the target</summary>
              <pattern><t>name</t></pattern>
            </ele>
            <ele>
              <name>permissions</name>
              <summary>Permissions the user has on the target</summary>
              <pattern></pattern>
            </ele>
          </ele>
        </ele>
        <ele>
          <name>kdc</name>
          <pattern>text</pattern>
          <summary>Deprecated: This element is deprecated. Use kdcs instead. The Kerberos KDC (key distribution center(s))</summary>
        </ele>
        <ele>
          <name>kdcs</name>
          <summary>Multiple Kerberos KDCs</summary>
          <description>
            <p>List of one or more Kerberos Key Distribution Centers (KDCs).</p>
          </description>
          <pattern>
            <any><e>kdc</e></any>
          </pattern>
          <ele>
            <name>kdc</name>
            <summary>A single Kerberos Key Distribution Center</summary>
            <pattern>text</pattern>
          </ele>
        </ele>
        <ele>
          <name>realm</name>
          <pattern>text</pattern>
          <summary>The Kerberos realm</summary>
        </ele>
      </ele>
      <ele>
        <name>filters</name>
        <pattern>
          <attrib>
            <name>id</name>
            <summary>UUID of filter if any, else 0</summary>
            <type>uuid</type>
            <required>1</required>
          </attrib>
          <e>term</e>
          <o><e>name</e></o>
          <e>keywords</e>
        </pattern>
        <ele>
          <name>term</name>
          <summary>Filter term</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>name</name>
          <summary>Filter name, if applicable</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>keywords</name>
          <summary>Filter broken down into keywords</summary>
          <pattern><any><e>keyword</e></any></pattern>
          <ele>
            <name>keyword</name>
            <pattern>
              <e>column</e>
              <e>relation</e>
              <e>value</e>
            </pattern>
            <ele>
              <name>column</name>
              <summary>Column prefix</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>relation</name>
              <summary>Relation operator</summary>
              <pattern>
                <alts>
                  <alt>=</alt>
                  <alt>:</alt>
                  <alt>~</alt>
                  <alt>&gt;</alt>
                  <alt>&lt;</alt>
                </alts>
              </pattern>
            </ele>
            <ele>
              <name>value</name>
              <summary>The filter text</summary>
              <pattern>text</pattern>
            </ele>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>sort</name>
        <pattern>
          text
          <e>field</e>
        </pattern>
        <ele>
          <name>field</name>
          <pattern>
            <e>order</e>
          </pattern>
          <ele>
            <name>order</name>
            <pattern>
              <alts>
                <alt>ascending</alt>
                <alt>descending</alt>
              </alts>
            </pattern>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>credentials</name>
        <pattern>
          <attrib>
            <name>start</name>
            <summary>First credential</summary>
            <type>integer</type>
            <required>1</required>
          </attrib>
          <attrib>
            <name>max</name>
            <summary>Maximum number of credentials</summary>
            <type>integer</type>
            <required>1</required>
          </attrib>
        </pattern>
      </ele>
      <ele>
        <name>credential_count</name>
        <pattern>
          <e>filtered</e>
          <e>page</e>
        </pattern>
        <ele>
          <name>filtered</name>
          <summary>Number of credentials after filtering</summary>
          <pattern><t>integer</t></pattern>
        </ele>
        <ele>
          <name>page</name>
          <summary>Number of credentials on current page</summary>
          <pattern><t>integer</t></pattern>
        </ele>
      </ele>
    </response>
    <example>
      <summary>Get one or many the credentials</summary>
      <request>
        <get_credentials></get_credentials>
      </request>
      <response>
        <get_credentials_response status="200" status_text="OK">
          <credential id="c33864a9-d3fd-44b3-8717-972bfb01dfcf">
            <name>sally</name>
            <login>sally</login>
            <comment></comment>
            <creation_time>2012-12-14T17:11:25+01:00</creation_time>
            <modification_time>2012-05-28T11:19:20+01:00</modification_time>
            <writable>1</writable>
            <in_use>0</in_use>
            <type>usk</type>
            <full_type>username + SSH key</full_type>
          </credential>
          <credential id="8e305b0b-260d-450d-91a8-dadf0b144e15">
            <name>bob</name>
            <comment>Bob on the web server.</comment>
            <creation_time>2013-01-03T15:49:35+01:00</creation_time>
            <modification_time>2013-01-18T12:07:00+01:00</modification_time>
            <writable>1</writable>
            <in_use>1</in_use>
            <login>bob</login>
            <type>up</type>
            <full_type>username + password</full_type>
          </credential>
          <truncated>...</truncated>
        </get_credentials_response>
      </response>
    </example>
  </command>
  <command>
    <name>get_info</name>
    <summary>Get information for items of given type</summary>
    <description>
      The client uses the get_info command to get information about
      static data from an external source, like CVE or CPE.
      If the command sent by the client was valid, the manager will
      reply with a list of info elements of a given type to the client.
    </description>
    <pattern>
      <attrib>
        <name>type</name>
        <summary>Type must be either CERT_BUND_ADV, CPE, CVE, DFN_CERT_ADV or NVT</summary>
        <type>text</type>
        <required>1</required>
      </attrib>
      <attrib>
        <name>name</name>
        <summary>Name or identifier of the requested information</summary>
        <type>text</type>
      </attrib>
      <attrib>
        <name>info_id</name>
        <summary>ID of single info to get. Conflicts with name</summary>
        <type>text</type>
      </attrib>
      <attrib>
        <name>filter</name>
        <summary>Filter term to use to filter query</summary>
        <type>text</type>
        <filter_keywords>
          <option>
            <name>first</name>
            <type>integer</type>
            <summary>
              Index of the first item returned, starting at 1 (e.g. first=5
              starts at the 5th item)
            </summary>
          </option>
          <option>
            <name>rows</name>
            <type>integer</type>
            <summary>Number of items to return</summary>
          </option>
          <option>
            <name>sort</name>
            <type>text</type>
            <summary>Column to sort by in ascending order</summary>
          </option>
          <option>
            <name>sort-reverse</name>
            <type>text</type>
            <summary>Column to sort by in descending order</summary>
          </option>
          <column>
            <name>tag</name>
            <type>text</type>
            <summary>
              Name and optional "=" separted value of an attached tag
              (e.g. "mytag" or "mytag=myvalue")
            </summary>
          </column>
          <column>
            <name>tag_id</name>
            <type>UUID</type>
            <summary>
              UUID of an attached tag
            </summary>
          </column>
          <column>
            <name>uuid</name>
            <type>uuid</type>
            <summary>Unique ID</summary>
          </column>
          <column>
            <name>name</name>
            <type>name</type>
            <summary>Name</summary>
          </column>
          <column>
            <name>comment</name>
            <type>text</type>
            <summary>Comment text</summary>
          </column>
          <column>
            <name>created</name>
            <type>iso_time</type>
            <summary>Creation time</summary>
          </column>
          <column>
            <name>modified</name>
            <type>iso_time</type>
            <summary>Modification time</summary>
          </column>
          <column>
            <name>owner</name>
            <type>name</type>
            <summary>Name of the owner</summary>
          </column>
          <column>
            <name>severity</name>
            <type>severity</type>
            <summary>CVSS severity score of the SecInfo</summary>
          </column>
        </filter_keywords>
        <filter_keywords>
          <condition>type is "nvt"</condition>
          <column>
            <name>summary</name>
            <type>text</type>
            <summary>Summary text of the NVT</summary>
          </column>
          <column>
            <name>cve</name>
            <type>text</type>
            <summary>List of CVEs of the NVT</summary>
          </column>
          <column>
            <name>family</name>
            <type>text</type>
            <summary>Family of the NVT</summary>
          </column>
          <column>
            <name>cvss</name>
            <type>severity</type>
            <summary>Alias for severity</summary>
          </column>
          <column>
            <name>cvss_base</name>
            <type>severity</type>
            <summary>Alias for severity</summary>
          </column>
          <column>
            <name>script_tags</name>
            <type>text</type>
            <summary>List of script tags</summary>
          </column>
          <column>
            <name>qod</name>
            <type>integer</type>
            <summary>Numerical QoD</summary>
          </column>
          <column>
            <name>qod_type</name>
            <type>text</type>
            <summary>QoD type</summary>
          </column>
          <column>
            <name>solution_type</name>
            <type>text</type>
            <summary>Solution type</summary>
          </column>
          <column>
            <name>solution</name>
            <type>text</type>
            <summary>Solution description text</summary>
          </column>
          <column>
            <name>insight</name>
            <type>text</type>
            <summary>Insight section text</summary>
          </column>
          <column>
            <name>affected</name>
            <type>text</type>
            <summary>Text listing affected software</summary>
          </column>
          <column>
            <name>impact</name>
            <type>text</type>
            <summary>Impact description text</summary>
          </column>
          <column>
            <name>detection</name>
            <type>text</type>
            <summary>Detection description text</summary>
          </column>
          <column>
            <name>solution_method</name>
            <type>text</type>
            <summary>Solution method</summary>
          </column>
          <column>
            <name>version</name>
            <type>integer</type>
            <summary>Version of the NVT (deprected)</summary>
          </column>
          <column>
            <name>epss_score</name>
            <type>decimal</type>
            <summary>
              EPSS score of highest severity CVE (see epss/max_severity)
            </summary>
          </column>
          <column>
            <name>epss_percentile</name>
            <type>decimal</type>
            <summary>
              EPSS percentile of highest severity CVE (see epss/max_severity)
            </summary>
          </column>
          <column>
            <name>max_epss_score</name>
            <type>decimal</type>
            <summary>
              Highest EPSS score of referenced CVEs (see epss/max_epss)
            </summary>
          </column>
          <column>
            <name>max_epss_percentile</name>
            <type>decimal</type>
            <summary>
              Highest EPSS percentile of referenced CVEs (see epss/max_epss)
            </summary>
          </column>
        </filter_keywords>
        <filter_keywords>
          <condition>type is "cve"</condition>
          <column>
            <name>cvss_vector</name>
            <type>text</type>
            <summary>The CVSS base vector</summary>
          </column>
          <column>
            <name>products</name>
            <type>text</type>
            <summary>Space separated list CPEs the CVE applies to</summary>
          </column>
          <column>
            <name>description</name>
            <type>text</type>
            <summary>Description text of the CVE</summary>
          </column>
          <column>
            <name>published</name>
            <type><t>iso_time</t></type>
            <summary>Time the CVE was published, alias for created</summary>
          </column>
          <column>
            <name>epss_score</name>
            <type>decimal</type>
            <summary>EPSS score the CVE</summary>
          </column>
          <column>
            <name>epss_percentile</name>
            <type>decimal</type>
            <summary>EPSS percentile of the CVE</summary>
          </column>
        </filter_keywords>
        <filter_keywords>
          <condition>type is "cpe"</condition>
          <column>
            <name>title</name>
            <type>text</type>
            <summary>Title text of the CPE</summary>
          </column>
          <column>
            <name>status</name>
            <type>text</type>
            <summary>Status of the CPE</summary>
          </column>
          <column>
            <name>deprecated_by_id</name>
            <type>text</type>
            <summary>NVD ID that has deprecated this CPE</summary>
          </column>
          <column>
            <name>cves</name>
            <type>integer</type>
            <summary>Number of CVEs referencing this CPE</summary>
          </column>
          <column>
            <name>cpe_name_id</name>
            <type>uuid</type>
            <summary>NVD assigned cpeNameId of the CPE</summary>
          </column>
        </filter_keywords>
        <filter_keywords>
          <condition>type is either "cert_bund_adv" or "dfn_cert_adv"</condition>
          <column>
            <name>title</name>
            <type>text</type>
            <summary>Title text of the CERT advisory</summary>
          </column>
          <column>
            <name>summary</name>
            <type>text</type>
            <summary>Summary text of the CERT advisory</summary>
          </column>
          <column>
            <name>cves</name>
            <type>integer</type>
            <summary>Number of CVEs referenced by the CERT advisory</summary>
          </column>
        </filter_keywords>
      </attrib>
      <attrib>
        <name>filt_id</name>
        <summary>ID of filter to use to filter query</summary>
        <type>uuid</type>
      </attrib>
      <attrib>
        <name>details</name>
        <summary>Whether to include information about references to this information</summary>
        <type>boolean</type>
      </attrib>
    </pattern>
    <response>
      <pattern>
        <attrib>
          <name>status</name>
          <type>status</type>
          <required>1</required>
        </attrib>
        <attrib>
          <name>status_text</name>
          <type>text</type>
          <required>1</required>
        </attrib>
        <any><e>info</e></any>
        <e>filters</e>
        <e>sort</e>
        <e>details</e>
        <e>info_count</e>
      </pattern>
      <ele>
        <name>info</name>
        <pattern>
          <attrib>
            <name>id</name>
            <type>integer</type>
            <summary>A unique number identifying this info, if available</summary>
          </attrib>
          <e>owner</e>
          <e>name</e>
          <e>comment</e>
          <e>creation_time</e>
          <e>modification_time</e>
          <e>permissions</e>
          <o><e>user_tags</e></o>
          <e>update_time</e>
          <or>
            <e>cert_bund_adv</e>
            <e>cpe</e>
            <e>cve</e>
            <e>dfn_cert_adv</e>
            <e>nvt</e>
          </or>
        </pattern>
        <ele>
          <name>owner</name>
          <summary>Owner of the info</summary>
          <pattern>
            <e>name</e>
          </pattern>
          <ele>
            <name>name</name>
            <summary>The name of the owner</summary>
            <pattern><t>name</t></pattern>
          </ele>
        </ele>
        <ele>
          <name>name</name>
          <summary>The name of the info</summary>
          <pattern><t>name</t></pattern>
        </ele>
        <ele>
          <name>comment</name>
          <summary>The comment on the info</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>creation_time</name>
          <summary>Date and time the info was created</summary>
          <pattern><t>iso_time</t></pattern>
        </ele>
        <ele>
          <name>modification_time</name>
          <summary>Date and time the info was last modified</summary>
          <pattern><t>iso_time</t></pattern>
        </ele>
        <ele>
          <name>update_time</name>
          <summary>Date and time the source of the info was read</summary>
          <pattern><t>iso_time</t></pattern>
        </ele>
        <ele>
          <name>permissions</name>
          <summary>Permissions that the current user has on the info</summary>
          <pattern>
            <any><e>permission</e></any>
          </pattern>
          <ele>
            <name>permission</name>
            <pattern>
              <e>name</e>
            </pattern>
            <ele>
              <name>name</name>
              <summary>The name of the permission</summary>
              <pattern><t>name</t></pattern>
            </ele>
          </ele>
        </ele>
        <ele>
          <name>user_tags</name>
          <summary>Info on tags attached to the info</summary>
          <pattern>
            <e>count</e>
            <any><e>tag</e></any>
          </pattern>
          <ele>
            <name>count</name>
            <summary>Number of attached tags</summary>
            <pattern><t>integer</t></pattern>
          </ele>
          <ele>
            <name>tag</name>
            <summary>
              Short info on an individual tag
              (only if details were requested)
            </summary>
            <pattern>
              <attrib>
                <name>id</name>
                <type>uuid</type>
                <summary>UUID of the tag</summary>
                <required>1</required>
              </attrib>
              <e>name</e>
              <e>value</e>
              <e>comment</e>
            </pattern>
            <ele>
              <name>name</name>
              <summary>Name of the tag (usually namespace:predicate)</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>value</name>
              <summary>Value of the tag</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>comment</name>
              <summary>Comment for the tag</summary>
              <pattern>text</pattern>
            </ele>
          </ele>
        </ele>
        <ele>
          <name>cert_bund_adv</name>
          <pattern>
            <e>title</e>
            <e>summary</e>
            <e>severity</e>
            <e>cve_refs</e>
            <o><e>raw_data</e></o>
          </pattern>
          <summary>An CERT-Bund advisory info element</summary>
          <ele>
            <name>title</name>
            <summary>Title of the advisory</summary>
            <pattern>
              text
            </pattern>
          </ele>
          <ele>
            <name>summary</name>
            <summary>Summary text of the advisory</summary>
            <pattern>
              text
            </pattern>
          </ele>
          <ele>
            <name>severity</name>
            <summary>Highest CVSS severity score of CVEs referenced by the advisory</summary>
            <pattern>
              <t>severity</t>
            </pattern>
          </ele>
          <ele>
            <name>cve_refs</name>
            <summary>Number of CVEs referenced by this advisory</summary>
            <pattern>
              <t>integer</t>
            </pattern>
          </ele>
          <ele>
            <name>raw_data</name>
            <summary>Source representation of the information. Only when details were requested</summary>
            <pattern>
              text
            </pattern>
          </ele>
        </ele>
        <ele>
          <name>cpe</name>
          <pattern>
            <e>cpe_name_id</e>
            <o><e>title</e></o>
            <e>severity</e>
            <e>cve_refs</e>
            <e>deprecated</e>
            <any><e>deprecated_by</e></any>
            <o><e>cves</e></o>
            <o><e>references</e></o>
            <o><e>raw_data</e></o>
          </pattern>
          <summary>A CPE info element</summary>
          <ele>
            <name>cpe_name_id</name>
            <summary>NVD assigned cpeNameId of the CPE</summary>
            <pattern>
              text
            </pattern>
          </ele>
          <ele>
            <name>title</name>
            <summary>The title of the CPE</summary>
            <pattern>
              text
            </pattern>
          </ele>
          <ele>
            <name>severity</name>
            <summary>The highest CVSS severity score recorded for this CPE</summary>
            <pattern>
              <t>severity</t>
            </pattern>
          </ele>
          <ele>
            <name>cve_refs</name>
            <summary>The number CVE of references to this CPE</summary>
            <pattern>
              <t>integer</t>
            </pattern>
          </ele>
          <ele>
            <name>deprecated</name>
            <summary>Whether the CPE is deprecated</summary>
            <pattern>
              <t>boolean</t>
            </pattern>
          </ele>
          <ele>
            <name>deprecated_by</name>
            <summary>Another CPE the current one is deprecated by</summary>
            <pattern>
              <attrib>
                <name>cpe_id</name>
                <type>uuid</type>
                <summary>CPE id the current CPE is deprecated by</summary>
                <required>1</required>
              </attrib>
            </pattern>
          </ele>
          <ele>
            <name>cves</name>
            <summary>CVEs referring to this CPE. Only when details were requested</summary>
            <pattern>
              <any><e>cve</e></any>
            </pattern>
            <ele>
              <name>cve</name>
              <summary>CVE referring to this CPE</summary>
              <pattern>
                text
              </pattern>
            </ele>
          </ele>
          <ele>
            <name>references</name>
            <summary>References of this CPE. Only when details were requested</summary>
            <pattern>
              <any><e>reference</e></any>
            </pattern>
            <ele>
              <name>reference</name>
              <summary>Reference of the CPE. Text contains type</summary>
              <pattern>
                <attrib>
                  <name>href</name>
                  <type>text</type>
                  <summary>Reference URL</summary>
                  <required>1</required>
                </attrib>
                text
              </pattern>
            </ele>
          </ele>
          <ele>
            <name>raw_data</name>
            <summary>Source representation of the information. Only when details were requested</summary>
            <pattern>
              text
            </pattern>
          </ele>
        </ele>
        <ele>
          <name>nvt</name>
          <pattern>
            text
          </pattern>
          <summary>A NVT info element</summary>
        </ele>
        <ele>
          <name>cve</name>
          <pattern>
            <e>severity</e>
            <e>cvss_vector</e>
            <e>description</e>
            <e>products</e>
            <o><e>epss</e></o>
            <o><e>nvts</e></o>
            <o><e>cert</e></o>
            <o><e>configuration_nodes</e></o>
            <o><e>references</e></o>
            <o><e>raw_data</e></o>
          </pattern>
          <summary>A CVE info element</summary>
          <ele>
            <name>severity</name>
            <summary>CVSS severity score of the CVE</summary>
            <pattern>
              <t>severity</t>
            </pattern>
          </ele>
          <ele>
            <name>cvss_vector</name>
            <summary>CVSS base vector string</summary>
            <pattern>
              text
            </pattern>
          </ele>
          <ele>
            <name>description</name>
            <summary>The CVE's description</summary>
            <pattern>
              text
            </pattern>
          </ele>
          <ele>
            <name>products</name>
            <summary>Space separated list of CPEs affected by this</summary>
            <pattern>
              text
            </pattern>
          </ele>
          <ele>
            <name>epss</name>
            <summary>Exploit Prediction Scoring System (EPSS) info if available</summary>
            <pattern>
              <e>score</e>
              <e>percentile</e>
            </pattern>
            <ele>
              <name>score</name>
              <summary>EPSS score of the CVE</summary>
              <pattern>
                <t>decimal</t>
              </pattern>
            </ele>
            <ele>
              <name>percentile</name>
              <summary>EPSS percentile of the CVE</summary>
              <pattern>
                <t>decimal</t>
              </pattern>
            </ele>
          </ele>
          <ele>
            <name>nvts</name>
            <summary>NVTs addressing this CVE. Only when details were requested</summary>
            <pattern>
              <any><e>nvt</e></any>
            </pattern>
            <ele>
              <name>nvt</name>
              <summary>NVT referring to this CPE</summary>
              <pattern>
                <attrib>
                  <name>oid</name>
                  <type>oid</type>
                </attrib>
                <e>name</e>
              </pattern>
              <ele>
                <name>name</name>
                <summary>Name of the NVT</summary>
                <pattern>
                  text
                </pattern>
              </ele>
            </ele>
          </ele>
          <ele>
            <name>cert</name>
            <summary>List of CERT advisories referencing this CVE</summary>
            <pattern>
              <any><e>cert_ref</e></any>
              <o><e>warning</e></o>
            </pattern>
            <ele>
              <name>cert_ref</name>
              <summary>A CERT advisory reference</summary>
              <pattern>
                <attrib>
                  <name>type</name>
                  <summary>Type of the advisory (e.g. "DFN-CERT", "CERT-BUND")</summary>
                  <type>text</type>
                </attrib>
                <e>name</e>
                <e>title</e>
              </pattern>
              <ele>
                <name>name</name>
                <summary>The name / ID of the advisory</summary>
                <pattern>
                  text
                </pattern>
              </ele>
              <ele>
                <name>title</name>
                <summary>The title of the advisory</summary>
                <pattern>
                  text
                </pattern>
              </ele>
            </ele>
            <ele>
              <name>warning</name>
              <summary>A warning message, e.g. when the database is unavailable</summary>
              <pattern>
                text
              </pattern>
            </ele>
          </ele>
          <ele>
            <name>configuration_nodes</name>
            <summary>List of configuration nodes. Only when details were requested</summary>
            <pattern>
              <any><e>node</e></any>
            </pattern>
            <ele>
              <name>node</name>
              <summary>A configuration node for the CVE</summary>
              <pattern>
                <e>operator</e>
                <e>negate</e>
                <o><e>match_string</e></o>
                <o><any><e>node</e></any></o>
              </pattern>
              <ele>
                <name>operator</name>
                <summary>The operator for the match criteria</summary>
                <pattern>
                  text
                </pattern>
              </ele>
              <ele>
                <name>negate</name>
                <summary>A true or false value, whether the operator is negated</summary>
                <pattern>
                  text
                </pattern>
              </ele>
              <ele>
                <name>match_string</name>
                <summary>The match string for the node</summary>
                <pattern>
                  <e>criteria</e>
                  <e>vulnerable</e>
                  <e>version_start_including</e>
                  <e>version_start_excluding</e>
                  <e>version_end_including</e>
                  <e>version_end_excluding</e>
                  <e>matched_cpes</e>
                </pattern>
                <ele>
                  <name>criteria</name>
                  <summary>A CPE match criteria</summary>
                  <pattern>
                    text
                  </pattern>
                </ele>
                <ele>
                  <name>vulnerable</name>
                  <summary>A true or false value, whether matching CPEs are considered vulnerable</summary>
                  <pattern>
                    text
                  </pattern>
                </ele>
                <ele>
                  <name>version_start_including</name>
                  <summary>From version (including)</summary>
                  <pattern>
                    text
                  </pattern>
                </ele>
                <ele>
                  <name>version_start_excluding</name>
                  <summary>From version (excluding)</summary>
                  <pattern>
                    text
                  </pattern>
                </ele>
                <ele>
                  <name>version_end_including</name>
                  <summary>Up to version (including)</summary>
                  <pattern>
                    text
                  </pattern>
                </ele>
                <ele>
                  <name>version_end_excluding</name>
                  <summary>Up to version (exluding)</summary>
                  <pattern>
                    text
                  </pattern>
                </ele>
                <ele>
                  <name>matched_cpes</name>
                  <summary>List of matching CPEs</summary>
                  <pattern>
                    <e>name</e>
                    <e>deprecated</e>
                    <o><e>deprecated_by</e></o>
                  </pattern>
                  <ele>
                    <name>name</name>
                    <summary>Name of the matching CPE</summary>
                    <pattern>
                      text
                    </pattern>
                  </ele>
                  <ele>
                    <name>deprecated</name>
                    <summary>A true or false value, whether the CPE is deprecated</summary>
                    <pattern>
                      text
                    </pattern>
                  </ele>
                  <ele>
                    <name>deprecated_by</name>
                    <summary>CPE ID the current CPE is deprecated by. Only when the CPE is deprecated</summary>
                    <pattern>
                      <attrib>
                        <name>cpe_id</name>
                        <type>uuid</type>
                        <summary>CPE ID the current CPE is deprecated by</summary>
                      </attrib>
                    </pattern>
                  </ele>
                </ele>
              </ele>
              <ele>
                <name>node</name>
                <summary>Nodes can contain other nested nodes</summary>
                <pattern>
                  node
                </pattern>
              </ele>
            </ele>
          </ele>
          <ele>
            <name>references</name>
            <summary>References of this CVE. Only when details were requested</summary>
            <pattern>
              <any><e>reference</e></any>
            </pattern>
            <ele>
              <name>reference</name>
              <summary>Reference of the CVE</summary>
              <pattern>
                <e>url</e>
                <e>tags</e>
              </pattern>
              <ele>
                <name>url</name>
                <summary>The URL of the reference</summary>
                <pattern>
                  text
                </pattern>
              </ele>
              <ele>
                <name>tags</name>
                <summary>List of tags for the reference</summary>
                <pattern>
                  <o><any><e>tag</e></any></o>
                </pattern>
                <ele>
                  <name>tag</name>
                  <summary>Tag for a reference</summary>
                  <pattern>
                    text
                  </pattern>
                </ele>
              </ele>
            </ele>
          </ele>
          <ele>
            <name>raw_data</name>
            <summary>Source representation of the information. Only when details were requested</summary>
            <pattern>
              text
            </pattern>
          </ele>
        </ele>
        <ele>
          <name>dfn_cert_adv</name>
          <pattern>
            <e>title</e>
            <e>summary</e>
            <e>severity</e>
            <e>cve_refs</e>
            <o><e>raw_data</e></o>
          </pattern>
          <summary>An DFN-CERT advisory info element</summary>
          <ele>
            <name>title</name>
            <summary>Title of the advisory</summary>
            <pattern>
              text
            </pattern>
          </ele>
          <ele>
            <name>summary</name>
            <summary>Summary text of the advisory</summary>
            <pattern>
              text
            </pattern>
          </ele>
          <ele>
            <name>severity</name>
            <summary>Highest CVSS severity score of CVEs referenced by the advisory</summary>
            <pattern>
              <t>severity</t>
            </pattern>
          </ele>
          <ele>
            <name>cve_refs</name>
            <summary>Number of CVEs referenced by this advisory</summary>
            <pattern>
              <t>integer</t>
            </pattern>
          </ele>
          <ele>
            <name>raw_data</name>
            <summary>Source representation of the information. Only when details were requested</summary>
            <pattern>
              text
            </pattern>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>filters</name>
        <pattern>
          <attrib>
            <name>id</name>
            <summary>UUID of filter if any, else 0</summary>
            <type>uuid</type>
            <required>1</required>
          </attrib>
          <e>term</e>
          <o><e>name</e></o>
          <e>keywords</e>
        </pattern>
        <ele>
          <name>term</name>
          <summary>Filter term</summary>
          <type>text</type>
        </ele>
        <ele>
          <name>name</name>
          <summary>Filter name, if applicable</summary>
          <pattern>text</pattern>
        </ele>
        <ele>
          <name>keywords</name>
          <summary>Filter broken down into keywords</summary>
          <pattern><any><e>keyword</e></any></pattern>
          <ele>
            <name>keyword</name>
            <pattern>
              <e>column</e>
              <e>relation</e>
              <e>value</e>
            </pattern>
            <ele>
              <name>column</name>
              <summary>Column prefix</summary>
              <pattern>text</pattern>
            </ele>
            <ele>
              <name>relation</name>
              <summary>Relation operator</summary>
              <pattern>
                <alts>
                  <alt>=</alt>
                  <alt>:</alt>
                  <alt>~</alt>
                  <alt>&gt;</alt>
                  <alt>&lt;</alt>
                </alts>
              </pattern>
            </ele>
            <ele>
              <name>value</name>
              <summary>The filter text</summary>
              <pattern>text</pattern>
            </ele>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>sort</name>
        <pattern>
          text
          <e>field</e>
        </pattern>
        <ele>
          <name>field</name>
          <pattern>
            <e>order</e>
          </pattern>
          <ele>
            <name>order</name>
            <pattern>
              <alts>
                <alt>ascending</alt>
                <alt>descending</alt>
              </alts>
            </pattern>
          </ele>
        </ele>
      </ele>
      <ele>
        <name>info_count</name>
        <pattern>
          <e>filtered</e>
          <e>page</e>
        </pattern>
        <ele>
          <name>filtered</name>
          <summary>Number of info elements after filtering</summary>
          <pattern><t>integer</t></pattern>
        </ele>
        <ele>
          <name>page</name>
          <summary>Number of info elements on current page</summary>
          <pattern><t>integer</t></pattern>
        </ele>
      </ele>
      <ele>
        <name>details</name>
        <summary>Are details included in this response</summary>
        <type>boolean</type>
      </ele>
    </response>
    <example>
