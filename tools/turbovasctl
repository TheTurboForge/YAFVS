            "native-api-direct.internal-only-retention-plan",
            "native-api.internal-smoke",
        )
        if check in checks
    }
    compact["details"] = {
        "base_url": details.get("base_url"),
        "container_bind": details.get("container_bind"),
        "token_source": details.get("token_source"),
        "finding_count": len(findings),
