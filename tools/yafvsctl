def rust_feed_generation_runtime_guard_finding(
    repo_root: Path, *, selector_only: bool
) -> dict[str, Any]:
    expected_check = (
        "feed-generation.selector-journal"
        if selector_only
        else "feed-generation.current"
    )
    arguments = ["feed-generation-runtime-guard"]
    if selector_only:
        arguments.append("--selector-only")
    arguments.append("--json")
    command = [
        "cargo",
        "run",
        "--quiet",
        "--locked",
        "--target-dir",
        str(repo_root / "build" / "yafvsctl-rs"),
        "--manifest-path",
        str(repo_root / YAFVSCTL_RUST_CRATE / "Cargo.toml"),
        "--",
        *arguments,
    ]
    try:
        completed = run_command(
            command, repo_root, timeout=300 if selector_only else 1800
        )
        payload = json.loads(completed.stdout)
    except (OSError, json.JSONDecodeError):
        completed = None
        payload = None

    findings = payload.get("findings") if isinstance(payload, dict) else None
    metadata_block = payload.get("metadata") if isinstance(payload, dict) else None
    item = findings[0] if isinstance(findings, list) and len(findings) == 1 else None
    status = item.get("status") if isinstance(item, dict) else None
    valid = (
        completed is not None
        and completed.returncode == (1 if status == "fail" else 0)
        and status in {"pass", "fail"}
        and isinstance(item.get("message"), str)
        and item.get("check") == expected_check
        and payload.get("status") == status
        and isinstance(metadata_block, dict)
        and metadata_block.get("command") == "feed-generation-runtime-guard"
    )
    if valid:
        return dict(item)
    return finding(
        "fail",
        expected_check,
        "Rust feed generation runtime guard failed closed because its result was unavailable or invalid.",
        str(feed_activation_state_path(repo_root)),
    )


