        if "Updating VTs failed" in line or "failed to load VTs" in line or "OpenVAS Scanner failed to load VTs" in line:
            relevant.append(line)
            return "fail", relevant
        if "Loading VTs" in line:
            relevant.append(line)
    return "wait", relevant


