def direct_smoke_status_only_result(result: dict[str, Any]) -> dict[str, Any]:
    compact = dict(result)
    findings = result.get("findings", [])
    non_pass = [compact_doctor_finding(item) for item in findings if item.get("status") != "pass"]
    details = result.get("details", {}) if isinstance(result.get("details"), dict) else {}
    checks = {
        item.get("check"): item.get("status")
        for item in findings
        if isinstance(item, dict) and item.get("check")
    }
    important_checks = {
        check: checks[check]
        for check in (
            "native-api-direct.healthz",
            "native-api-direct.missing-token",
            "native-api-direct.wrong-token",
            "native-api-direct.valid-token",
            "native-api-direct.read-only-method-guard",
            "native-api-direct.scope-write-disabled",
            "native-api-direct.tag-write-disabled",
            "native-api-direct.tag-delete-disabled",
            "native-api-direct.write-control-operator",
