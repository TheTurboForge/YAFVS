def parse_safe_schema_table(value: str) -> tuple[str, str]:
    parts = value.split(".")
    if len(parts) != 2:
        raise ValueError("expected schema.table")
    schema, table = (part.strip() for part in parts)
    identifier_pattern = re.compile(r"^[A-Za-z_][A-Za-z0-9_]*$")
    if schema not in DB_INTROSPECT_ALLOWED_SCHEMAS:
        raise ValueError(f"schema {schema!r} is not allowed")
    if not identifier_pattern.fullmatch(table):
        raise ValueError("table must be a simple SQL identifier")
    return schema, table


