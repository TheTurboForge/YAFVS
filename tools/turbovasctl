def run_git(repo_root: Path, args: list[str]) -> str | None:
    try:
        result = subprocess.run(["git", *args], cwd=repo_root, text=True, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL, check=True)
    except (OSError, subprocess.CalledProcessError):
        return None
    return result.stdout.strip()


def git_name_status(repo_root: Path, base: str, pathspecs: tuple[str, ...] = ()) -> list[tuple[str, str]] | None:
    args = ["diff", "--name-status", f"{base}..HEAD"]
    if pathspecs:
        args.append("--")
        args.extend(pathspecs)
    output = run_git(repo_root, args)
    if output is None:
        return None
    rows: list[tuple[str, str]] = []
    for line in output.splitlines():
        parts = line.split("	")
        if len(parts) < 2:
            continue
        rows.append((parts[0], parts[-1]))
    return rows


def git_name_status_for_diff_scope(repo_root: Path, diff_scope: str, pathspecs: tuple[str, ...] = ()) -> list[tuple[str, str]] | None:
    if diff_scope == "baseline":
        return git_name_status(repo_root, IMPORT_BASELINE_COMMIT, pathspecs)
    if diff_scope == "staged":
        args = ["diff", "--cached", "--name-status"]
    elif diff_scope == "worktree":
        args = ["diff", "--name-status"]
    else:
        return None
    if pathspecs:
        args.append("--")
        args.extend(pathspecs)
    output = run_git(repo_root, args)
    if output is None:
        return None
    rows: list[tuple[str, str]] = []
    for line in output.splitlines():
        parts = line.split("\t")
        if len(parts) < 2:
            continue
        rows.append((parts[0], parts[-1]))
    return rows


def git_staged_file_head(repo_root: Path, relative_path: str, limit: int = 5000) -> str | None:
    try:
        result = subprocess.run(
            ["git", "show", f":{relative_path}"],
            cwd=repo_root,
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.DEVNULL,
            check=True,
        )
    except (OSError, subprocess.CalledProcessError):
        return None
    return result.stdout[:limit]


def git_tracked_files(repo_root: Path) -> list[str] | None:
    output = run_git(repo_root, ["ls-files"])
    if output is None:
        return None
    return [line for line in output.splitlines() if line]


def run_command(
    command: list[str],
    cwd: Path,
    env: dict[str, str] | None = None,
    timeout: int | None = None,
    input_text: str | None = None,
) -> subprocess.CompletedProcess[str]:
    try:
        return subprocess.run(command, cwd=cwd, env=env, text=True, input=input_text, stdout=subprocess.PIPE, stderr=subprocess.STDOUT, timeout=timeout)
    except subprocess.TimeoutExpired as error:
        stdout = error.stdout or ""
        if isinstance(stdout, bytes):
            stdout = stdout.decode(errors="replace")
        stdout += f"\nTimed out after {timeout} seconds."
        return subprocess.CompletedProcess(command, 124, stdout)


def find_repo_root(start: Path) -> Path:
