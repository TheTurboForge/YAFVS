def running_service_env_has_key(repo_root: Path, service: str, key: str) -> bool:
    cid = container_id(repo_root, service)
    if not cid:
        return False
    result = run_command(["docker", "inspect", "-f", "{{json .Config.Env}}", cid], repo_root, env=runtime_env(repo_root))
    if result.returncode != 0 or not result.stdout.strip():
        return False
    try:
        values = json.loads(result.stdout)
    except json.JSONDecodeError:
        return False
    if not isinstance(values, list):
        return False
    return env_values_have_nonempty_key(values, key)


def env_values_have_nonempty_key(values: Iterable[Any], key: str) -> bool:
    prefix = f"{key}="
    return any(isinstance(value, str) and value.startswith(prefix) and bool(value[len(prefix) :].strip()) for value in values)


def running_service_env_value(repo_root: Path, service: str, key: str) -> str | None:
    cid = container_id(repo_root, service)
    if not cid:
        return None
    result = run_command(["docker", "inspect", "-f", "{{json .Config.Env}}", cid], repo_root, env=runtime_env(repo_root))
    if result.returncode != 0 or not result.stdout.strip():
        return None
    try:
        values = json.loads(result.stdout)
    except json.JSONDecodeError:
        return None
    if not isinstance(values, list):
        return None
    prefix = f"{key}="
    for value in values:
        if isinstance(value, str) and value.startswith(prefix) and value[len(prefix) :].strip():
            return value[len(prefix) :]
    return None












def native_tooling_residue(relative_path: str, category: str) -> tuple[str, str] | None:
    if category != "product_workflow":
        return None
    name = Path(relative_path).name
    if "/__tests__/" in relative_path or relative_path.startswith("components/gsa/src/gmp/__tests__/"):
