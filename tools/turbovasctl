def command_runtime_manager_init_unlocked(repo_root: Path) -> dict[str, Any]:
    findings = ensure_runtime_dirs(repo_root)
    findings.extend(ensure_build_runtime_dirs(repo_root))
    db_init = command_runtime_init(repo_root)
    findings.append(finding(db_init["status"], "runtime.database-init", db_init["summary"], details={"status": db_init["status"]}))
    if db_init["status"] == "fail":
        return make_result("runtime-manager-init", repo_root, "Manager initialization stopped at database prerequisites.", findings, db_init["artifacts"])

    password, created = read_or_create_runtime_secret(repo_root, DEV_ADMIN_SECRET, DEV_ADMIN_PASSWORD)
    secret_path = runtime_secret_path(repo_root, DEV_ADMIN_SECRET)
    if password != DEV_ADMIN_PASSWORD:
        password = DEV_ADMIN_PASSWORD

        write_private_text(secret_path, password + "\n")
        created = False
        findings.append(finding("pass", "runtime.admin-secret", "Development admin password was aligned to the local default in persistent runtime secrets.", str(secret_path)))
    else:
        findings.append(finding("pass", "runtime.admin-secret", f"Development admin password {'created' if created else 'reused'} in persistent runtime secrets.", str(secret_path)))
    findings.extend(cert_file_findings(repo_root))

    app_build = run_command(compose_command(repo_root, "--profile", "app", "build", "gvmd"), repo_root, env=runtime_env(repo_root), timeout=900)
    findings.append(finding("pass" if app_build.returncode == 0 else "fail", "compose.app-build", f"docker compose build gvmd exit code {app_build.returncode}.", details={"output_tail": output_tail(app_build.stdout, 120, [password])}))
    if app_build.returncode != 0:
        return make_result("runtime-manager-init", repo_root, "Manager initialization stopped while building the app image.", findings, [str(runtime_dir(repo_root))])

    migrate = run_gvmd_oneoff(repo_root, ["--migrate"], no_deps=False)
    migrate_details: dict[str, Any] = {"output_tail": output_tail(migrate.stdout, 100, [password])}
    if migrate.returncode != 0:
        migrate_details["runtime_manager_diagnostics"] = runtime_manager_diagnostics(repo_root)
    findings.append(finding("pass" if migrate.returncode == 0 else "fail", "gvmd.migrate", f"gvmd --migrate exit code {migrate.returncode}.", details=migrate_details))
    if migrate.returncode != 0:
        return make_result("runtime-manager-init", repo_root, "Manager initialization stopped at database migration.", findings, [str(runtime_dir(repo_root))])

    users = run_gvmd_oneoff(repo_root, ["--get-users", "--verbose"], no_deps=False)
    admin_uuid = parse_user_uuid(users.stdout, DEV_ADMIN_USER) if users.returncode == 0 else None
    findings.append(finding("pass" if users.returncode == 0 else "warn", "gvmd.get-users", f"gvmd --get-users --verbose exit code {users.returncode}.", details={"admin_uuid_found": bool(admin_uuid), "output_tail": output_tail(users.stdout, 80, [password])}))

    if not admin_uuid:
        create = run_gvmd_oneoff(repo_root, [f"--create-user={DEV_ADMIN_USER}", f"--password={password}", "--disable-password-policy"], no_deps=False)
        findings.append(finding("pass" if create.returncode == 0 else "fail", "gvmd.create-admin", f"Create/verify development admin user exit code {create.returncode}.", details={"output_tail": output_tail(create.stdout, 80, [password])}))
        if create.returncode != 0:
            return make_result("runtime-manager-init", repo_root, "Manager initialization stopped at admin user creation.", findings, [str(runtime_dir(repo_root))])
        users = run_gvmd_oneoff(repo_root, ["--get-users", "--verbose"], no_deps=False)
        admin_uuid = parse_user_uuid(users.stdout, DEV_ADMIN_USER) if users.returncode == 0 else None
        findings.append(finding("pass" if admin_uuid else "warn", "gvmd.admin-uuid", f"Development admin UUID {'found' if admin_uuid else 'not found after creation'}.", details={"admin_uuid": admin_uuid, "output_tail": output_tail(users.stdout, 80, [password])}))

    if admin_uuid:
        update_password = run_gvmd_oneoff(repo_root, [f"--user={DEV_ADMIN_USER}", f"--new-password={password}", "--disable-password-policy"], no_deps=False)
        findings.append(finding("pass" if update_password.returncode == 0 else "fail", "gvmd.admin-password", f"Set development admin password exit code {update_password.returncode}.", details={"output_tail": output_tail(update_password.stdout, 80, [password])}))
        if update_password.returncode != 0:
            return make_result("runtime-manager-init", repo_root, "Manager initialization stopped at admin password update.", findings, [str(runtime_dir(repo_root))])

    if admin_uuid:
        owner = run_gvmd_oneoff(repo_root, [f"--modify-setting={FEED_IMPORT_OWNER_SETTING}", f"--value={admin_uuid}"], no_deps=False)
        findings.append(finding("pass" if owner.returncode == 0 else "warn", "gvmd.feed-owner", f"Set feed import owner exit code {owner.returncode}.", details={"admin_uuid": admin_uuid, "output_tail": output_tail(owner.stdout, 80, [password])}))
    else:
        findings.append(finding("warn", "gvmd.feed-owner", "Feed import owner was not set because the admin UUID could not be determined."))

    return make_result("runtime-manager-init", repo_root, "Runtime manager initialization completed.", findings, [str(runtime_dir(repo_root)), str(secret_path)])


def command_runtime_gmp_smoke(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    secret_path = runtime_secret_path(repo_root, DEV_ADMIN_SECRET)
    socket_path = gvmd_socket_path(repo_root)
    python = venv_python(repo_root, "python-gvm")
    probe = repo_root / "tools" / "runtime_gmp_smoke.py"
    findings.append(socket_readiness_finding("gvmd.socket", "gvmd", socket_path, missing_status="fail"))
    findings.append(finding("pass" if secret_path.is_file() else "fail", "runtime.admin-secret", "Development admin secret exists." if secret_path.is_file() else "Development admin secret is missing; run just runtime-manager-init.", str(secret_path)))
    findings.append(finding("pass" if python.is_file() else "fail", "python-gvm.venv", "python-gvm runtime venv exists." if python.is_file() else "python-gvm venv is missing; run just build-python.", str(python.relative_to(repo_root)) if python.exists() else str(python)))
    findings.append(finding("pass" if probe.is_file() else "fail", "gmp.probe", "GMP smoke probe exists." if probe.is_file() else "GMP smoke probe is missing.", str(probe.relative_to(repo_root))))
    if aggregate_status(findings) == "fail":
        return make_result("runtime-gmp-smoke", repo_root, "GMP smoke stopped at prerequisites.", findings, [str(runtime_dir(repo_root))])

    result = run_command([str(python), str(probe), "--socket", str(socket_path), "--username", DEV_ADMIN_USER, "--password-file", str(secret_path)], repo_root, env=build_env(repo_root), timeout=60)
    try:
        parsed = json.loads(result.stdout)
    except json.JSONDecodeError:
        parsed = None
    probe_status = parsed.get("status") if parsed else None
    findings.append(finding("pass" if result.returncode == 0 and probe_status == "pass" else "fail", "gvmd.gmp", f"python-gvm authenticated get_version exit code {result.returncode}.", details={"probe": parsed, "output_tail": output_tail(result.stdout, 60)}))
    return make_result("runtime-gmp-smoke", repo_root, "Runtime GMP smoke completed.", findings, [str(runtime_dir(repo_root))])


def wait_for_runtime_gmp_smoke(repo_root: Path, *, attempts: int = 3, interval_seconds: int = 5) -> tuple[dict[str, Any], int]:
    last_result: dict[str, Any] | None = None
    for attempt in range(1, attempts + 1):
        last_result = command_runtime_gmp_smoke(repo_root)
        if last_result.get("status") == "pass":
            return last_result, attempt
        if attempt < attempts:
            time.sleep(interval_seconds)
    return last_result or make_result("runtime-gmp-smoke", repo_root, "Runtime GMP smoke did not run.", []), attempts


def browser_gmp_readiness_finding(repo_root: Path, *, check: str) -> dict[str, Any]:
    gmp_result, attempts = wait_for_runtime_gmp_smoke(repo_root)
    status = "pass" if gmp_result.get("status") == "pass" else "fail"
    return finding(
        status,
        check,
        "Authenticated GMP readiness was verified before browser validation." if status == "pass" else "Authenticated GMP readiness did not become available before browser validation.",
        details={
            "attempts": attempts,
            "status": gmp_result.get("status"),
            "summary": gmp_result.get("summary"),
            "failed_checks": [item for item in gmp_result.get("findings", []) if item.get("status") == "fail"],
        },
    )


