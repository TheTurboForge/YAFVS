def run_app_oneoff(
    repo_root: Path,
    service: str,
    command: list[str],
    no_deps: bool = True,
    timeout: int = 300,
    *,
    app_image_ids: dict[str, str] | None = None,
) -> subprocess.CompletedProcess[str]:
    app_env = deployed_app_env(repo_root)
    if app_image_ids is None:
        receipt, receipt_error = require_app_deployment_receipt(
            repo_root, app_env=app_env
        )
        if receipt_error is not None or receipt is None:
            return subprocess.CompletedProcess(
                ["docker", "compose", "run", service],
                2,
                "",
                receipt_error
                or "Prepared application deployment receipt is unavailable",
            )
        app_image_ids = receipt["image_ids"]
    args = ["--profile", "app", "run", "--rm", "-T"]
    args.extend(["--pull", "never"])
    if no_deps:
        args.append("--no-deps")
    args.extend([service, *command])
    compose = compose_command_with_app_images(repo_root, app_image_ids, *args)
    return run_command(compose, repo_root, env=app_env, timeout=timeout)


