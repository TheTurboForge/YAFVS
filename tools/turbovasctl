        contract["rows_missing_migration_metadata"]
        or contract["direct_exposure_mismatches"]
        or contract["direct_marker_mismatches"]
    )
    findings = [
        finding(
            "pass" if rows else "warn",
            "native-api-migration-matrix.rows",
