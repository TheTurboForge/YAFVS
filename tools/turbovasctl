    if container_running(repo_root, "redis"):
        result = exec_in_service(repo_root, "redis", ["redis-cli", "ping"])
        findings.append(finding("pass" if result.returncode == 0 and "PONG" in result.stdout else "fail", "redis.ready", f"redis-cli ping exit code {result.returncode}.", details={"output_tail": result.stdout.splitlines()[-20:]}))
    if container_running(repo_root, "redis-openvas"):
        result = scanner_redis_ping(repo_root)
        findings.append(finding("pass" if result.returncode == 0 and "PONG" in result.stdout else "fail", "redis-openvas.ready", f"scanner Redis Unix socket ping exit code {result.returncode}.", str(scanner_redis_socket_path(repo_root)), {"output_tail": result.stdout.splitlines()[-20:]}))
        findings.append(finding("pass" if scanner_redis_socket_path(repo_root).is_socket() else "fail", "redis-openvas.socket", "scanner Redis Unix socket exists." if scanner_redis_socket_path(repo_root).is_socket() else "scanner Redis Unix socket is missing.", str(scanner_redis_socket_path(repo_root))))
    if container_running(repo_root, "mosquitto"):
        result = exec_in_service(repo_root, "mosquitto", ["mosquitto_pub", "-h", "127.0.0.1", "-p", "1883", "-t", "turbovas/smoke", "-m", "ok"])
        findings.append(finding("pass" if result.returncode == 0 else "fail", "mosquitto.ready", f"mosquitto_pub broker check exit code {result.returncode}.", details={"output_tail": result.stdout.splitlines()[-20:]}))
    return make_result("runtime-smoke", repo_root, "Runtime smoke checks completed.", findings, [str(runtime_dir(repo_root))])


def command_gvmd_smoke(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    if pg_gvm_extension_status(repo_root)["status"] != "pass":
        findings.append(finding("fail", "gvmd.pg-gvm", "pg-gvm extension is not initialized; run just runtime-init before gvmd smoke."))
        return make_result("gvmd-smoke", repo_root, "gvmd smoke stopped before service startup.", findings)
    result = run_command(compose_command(repo_root, "--profile", "app", "up", "-d", "gvmd"), repo_root, env=runtime_env(repo_root))
    findings.append(finding("pass" if result.returncode == 0 else "fail", "gvmd.up", f"docker compose up gvmd exit code {result.returncode}.", details={"output_tail": result.stdout.splitlines()[-80:]}))
    if result.returncode != 0:
        return make_result("gvmd-smoke", repo_root, "gvmd smoke stopped at container startup.", findings)
    probe = exec_in_service(repo_root, "gvmd", ["sh", "-lc", "command -v gvmd && gvmd --version"])
    findings.append(finding("pass" if probe.returncode == 0 else "warn", "gvmd.binary", f"gvmd binary probe exit code {probe.returncode}.", details={"output_tail": probe.stdout.splitlines()[-40:]}))
    db_probe = exec_in_service(
        repo_root,
        "gvmd",
        [
            "sh",
            "-lc",
            "env PGPASSWORD=${POSTGRES_PASSWORD:-turbovas-dev} psql -h postgres -U ${POSTGRES_USER:-turbovas} -d ${POSTGRES_DB:-turbovas} -At -c \"SELECT extversion FROM pg_extension WHERE extname = 'pg-gvm';\"",
        ],
    )
    findings.append(finding("pass" if db_probe.returncode == 0 and db_probe.stdout.strip() else "warn", "gvmd.database", f"gvmd profile DB probe exit code {db_probe.returncode}.", details={"output_tail": db_probe.stdout.splitlines()[-40:]}))
    findings.append(finding("warn", "gvmd.deferred", "This smoke does not start the full manager daemon yet; certificates, scanner registration, feeds, and runtime paths remain follow-up work."))
    return make_result("gvmd-smoke", repo_root, "gvmd profile smoke completed.", findings, [str(runtime_dir(repo_root))])


def command_doctor(repo_root: Path) -> dict[str, Any]:
    findings: list[dict[str, Any]] = []
    findings.append(finding("pass" if (repo_root / ".git").exists() else "fail", "repo.git", "Repository metadata is present." if (repo_root / ".git").exists() else "Repository metadata is missing.", ".git"))
    porcelain = run_git(repo_root, ["status", "--short"]) or ""
    findings.append(finding("warn" if porcelain else "pass", "git.worktree", "Worktree has uncommitted changes." if porcelain else "Worktree is clean."))
    for doc in EXPECTED_ROOT_DOCS:
        findings.append(finding("pass" if (repo_root / doc).is_file() else "fail", "root.doc", f"Expected root document {doc}", doc))
    for row in component_inventory(repo_root):
        findings.append(finding("pass" if row["exists"] else "fail", "component.exists", f"Expected component {row['name']}", row["path"]))
        for license_file in row["license_files"]:
            findings.append(finding("pass" if license_file["exists"] else "fail", "component.license", f"Expected license/provenance file for {row['name']}", license_file["path"]))
    nested = nested_git_dirs(repo_root)
    findings.append(finding("fail" if nested else "pass", "component.nested_git", "Nested .git directories were found." if nested else "No nested .git directories found under components/.", details={"paths": nested} if nested else None))
    for tool in BASELINE_TOOLS:
        findings.append(finding("pass" if shutil.which(tool) else "warn", "tool.available", f"{tool} is available." if shutil.which(tool) else f"{tool} is not available on PATH."))
    findings.append(finding("pass", "surface.available", "Build readiness surface is available.", details={"commands": ["just deps", "just configure", "just build", "just build-core-c", "just build-c-services", "just build-ui", "just build-python", "just build-baseline"]}))
    findings.append(finding("pass" if compose_file(repo_root).is_file() else "warn", "surface.available", "Runtime infrastructure command surface is available." if compose_file(repo_root).is_file() else "Runtime infrastructure command surface is not available.", details={"commands": ["just runtime-plan", "just up", "just down", "just logs", "just runtime-init", "just runtime-certs-init", "just runtime-manager-init", "just runtime-scanner-redis-init", "just runtime-gmp-smoke", "just runtime-scanner-register", "just feed-state", "just feed-cache-sync", "just feed-copy-to-runtime", "just runtime-status", "just runtime-smoke", "just runtime-app-up", "just runtime-app-smoke", "just runtime-app-down", "just gvmd-smoke"]}))
    findings.append(finding("warn", "surface.deferred", "Test command surface is deferred until component checks are mapped.", details={"command": "just test"}))
    findings.append(finding("warn", "surface.deferred", "Full inherited service orchestration remains experimental until feed, scanner registration, and first UI/API connectivity are stabilized.", details={"commands": ["gvmd", "gsad", "ospd-openvas", "notus-scanner"]}))
    return make_result("doctor", repo_root, "Monorepo health checks completed.", findings)


def print_human(result: dict[str, Any]) -> None:
    print(f"{result['status'].upper()}: {result['summary']}")
    for item in result["findings"]:
        line = f"[{item['status']}] {item['check']}: {item['message']}"
        if "path" in item:
            line += f" ({item['path']})"
        print(line)


def emit(result: dict[str, Any], as_json: bool) -> int:
    if as_json:
        print(json.dumps(result, indent=2, sort_keys=True))
    else:
        print_human(result)
    return 1 if result["status"] == "fail" else 0


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="TurboVAS monorepo health checks")
    parser.add_argument("--json", action="store_true", help="emit machine-readable JSON")
    subparsers = parser.add_subparsers(dest="command", required=True)
    common = argparse.ArgumentParser(add_help=False)
    common.add_argument("--json", action="store_true", default=argparse.SUPPRESS, help=argparse.SUPPRESS)
    subparsers.add_parser("status", parents=[common], help="show repository status")
    inventory = subparsers.add_parser("inventory", parents=[common], help="show expected component inventory")
    inventory.add_argument("--scope", help="limit inventory to a path under the repository")
    subparsers.add_parser("doctor", parents=[common], help="run structural and environment health checks")
    subparsers.add_parser("license-report", parents=[common], help="check preserved license/provenance files")
    deps = subparsers.add_parser("deps", parents=[common], help="check dependency readiness")
    deps.add_argument("component", nargs="?", help="component name")
    configure = subparsers.add_parser("configure", parents=[common], help="configure a CMake component")
    configure.add_argument("component", help="component name")
    build = subparsers.add_parser("build", parents=[common], help="build a CMake component")
    build.add_argument("component", help="component name")
    build.add_argument("--install", action="store_true", help="install into build/prefix after successful build")
    subparsers.add_parser("build-core-c", parents=[common], help="build gvm-libs, openvas-smb, and openvas-scanner")
    subparsers.add_parser("build-c-services", parents=[common], help="build current C service baseline")
    subparsers.add_parser("build-ui", parents=[common], help="build the web UI")
    subparsers.add_parser("build-python", parents=[common], help="build/import-check Python components")
    subparsers.add_parser("build-baseline", parents=[common], help="build the inherited stack baseline")
    subparsers.add_parser("runtime-plan", parents=[common], help="show Docker runtime layout and deferred surfaces")
    subparsers.add_parser("up", parents=[common], help="start runtime infrastructure services")
    subparsers.add_parser("down", parents=[common], help="stop runtime infrastructure services")
    logs = subparsers.add_parser("logs", parents=[common], help="show runtime logs")
    logs.add_argument("service", nargs="?", help="optional Compose service name")
    subparsers.add_parser("runtime-init", parents=[common], help="initialize persistent runtime database prerequisites")
    subparsers.add_parser("runtime-certs-init", parents=[common], help="initialize persistent runtime certificates")
    subparsers.add_parser("runtime-manager-init", parents=[common], help="initialize persistent gvmd database/user prerequisites")
    subparsers.add_parser("runtime-scanner-redis-init", parents=[common], help="initialize dedicated OpenVAS scanner Redis runtime")
    subparsers.add_parser("runtime-gmp-smoke", parents=[common], help="run authenticated GMP smoke over the runtime gvmd socket")
    subparsers.add_parser("runtime-scanner-register", parents=[common], help="create or verify the OpenVAS scanner registration")
    subparsers.add_parser("feed-state", parents=[common], help="show Greenbone Community Feed cache and runtime-copy state")
    subparsers.add_parser("feed-cache-sync", parents=[common], help="start full Greenbone Community Feed cache sync in tmux")
    subparsers.add_parser("feed-copy-to-runtime", parents=[common], help="copy cached feed data into the runtime feed tree")
    subparsers.add_parser("runtime-status", parents=[common], help="show runtime infrastructure status")
    subparsers.add_parser("runtime-smoke", parents=[common], help="run runtime infrastructure smoke checks")
    subparsers.add_parser("runtime-app-up", parents=[common], help="start experimental application services")
    subparsers.add_parser("runtime-app-down", parents=[common], help="stop experimental application services")
    subparsers.add_parser("runtime-app-smoke", parents=[common], help="run experimental application service smoke checks")
    subparsers.add_parser("gvmd-smoke", parents=[common], help="run a narrow gvmd runtime profile smoke")
    return parser


def main(argv: list[str] | None = None) -> int:
    parser = build_parser()
    args = parser.parse_args(argv)
    repo_root = find_repo_root(Path.cwd())
    if args.command == "status":
        result = command_status(repo_root)
    elif args.command == "inventory":
        result = command_inventory(repo_root, args.scope)
    elif args.command == "doctor":
        result = command_doctor(repo_root)
